Dialogue: 0,0:00:04.79,0:00:06.00,Default,,0,0,0,,Này! Tonbo!
Dialogue: 0,0:00:06.71,0:00:07.54,Default,,0,0,0,,Hả?
Dialogue: 0,0:00:07.63,0:00:08.80,Default,,0,0,0,,Tới lượt Hinoki đánh đấy.
Dialogue: 0,0:00:09.00,0:00:12.42,Default,,0,0,0,,Đừng bao giờ đứng trước người sắp đánh.\NĐó là quy tắc cơ bản của golf đấy.
Dialogue: 0,0:00:13.09,0:00:13.97,Default,,0,0,0,,Vâng ạ!
Dialogue: 0,0:00:17.89,0:00:18.81,Default,,0,0,0,,Đánh từ mặt cỏ sao?
Dialogue: 0,0:00:19.72,0:00:21.18,Default,,0,0,0,,Gió ngược mạnh quá.
Dialogue: 0,0:00:21.27,0:00:23.98,Default,,0,0,0,,Bên trái là ranh giới OB.\NMột lựa chọn thông minh.
Dialogue: 0,0:00:26.81,0:00:27.73,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:00:27.81,0:00:28.98,Default,,0,0,0,,Hinoki giỏi thật đấy.
Dialogue: 0,0:00:32.90,0:00:33.82,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:02:12.00,0:02:13.55,Default,,0,0,0,,Xin lỗi chuyện lúc nãy nhé.
Dialogue: 0,0:02:15.01,0:02:17.72,Default,,0,0,0,,Không sao đâu. Quan trọng là\Ntừ đây sẽ đánh thế nào kìa?
Dialogue: 0,0:02:18.26,0:02:20.26,Default,,0,0,0,,Còn lại khoảng 140 yard.
Dialogue: 0,0:02:20.51,0:02:22.43,Default,,0,0,0,,Cờ nằm ngay sau hố cát.
Dialogue: 0,0:02:22.72,0:02:24.72,Default,,0,0,0,,Thế mà lại chỉ có bốn gậy!
Dialogue: 0,0:02:26.27,0:02:27.60,Default,,0,0,0,,Xin cảm ơn rất nhiều ạ.
Dialogue: 0,0:02:29.48,0:02:31.40,Default,,0,0,0,,Nhìn cho kỹ đây, Tonbo!
Dialogue: 0,0:02:34.69,0:02:36.03,Default,,0,0,0,,Gậy sắt số 3 sao?
Dialogue: 0,0:02:36.74,0:02:41.03,Default,,0,0,0,,Chắc là sẽ đánh thấp\Nvà lăn bóng lên green từ hanamichi.
Dialogue: 0,0:02:41.20,0:02:42.74,Default,,0,0,0,,Cũng sẽ làm vậy thôi.
Dialogue: 0,0:02:43.33,0:02:45.49,Default,,0,0,0,,Đó là cách duy nhất\Nđể đưa bóng lên green.
Dialogue: 0,0:02:48.75,0:02:49.62,Default,,0,0,0,,Hả?
Dialogue: 0,0:02:49.71,0:02:51.00,Default,,0,0,0,,Đang nhắm đi đâu vậy?
Dialogue: 0,0:02:53.46,0:02:54.50,Default,,0,0,0,,Làm gì vậy?
Dialogue: 0,0:02:54.59,0:02:56.63,Default,,0,0,0,,Đó là tư thế đánh hố cát mà.
Dialogue: 0,0:02:56.84,0:02:57.88,Default,,0,0,0,,Chẳng hiểu nổi.
Dialogue: 0,0:02:58.34,0:03:01.01,Default,,0,0,0,,Hôm nay toàn làm những tư thế kỳ lạ không thôi.
Dialogue: 0,0:03:05.35,0:03:06.31,Default,,0,0,0,,Đi nào!
Dialogue: 0,0:03:06.52,0:03:07.43,Default,,0,0,0,,Lát cắt mỏng!?
Dialogue: 0,0:03:07.56,0:03:09.31,Default,,0,0,0,,Bay về hướng OB rồi!
Dialogue: 0,0:03:11.31,0:03:13.15,Default,,0,0,0,,Oa! Bóng đang hướng về phía cờ kìa!
Dialogue: 0,0:03:13.31,0:03:14.69,Default,,0,0,0,,Nhưng dùng gậy sắt số 3 mà!
Dialogue: 0,0:03:14.90,0:03:16.15,Default,,0,0,0,,Không dừng lại được đâu!
Dialogue: 0,0:03:20.99,0:03:22.16,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:03:23.57,0:03:25.70,Default,,0,0,0,,Góc nghiêng của gậy sắt số 3 đã được ngả ra.
Dialogue: 0,0:03:25.83,0:03:27.83,Default,,0,0,0,,Bằng cách hướng mặt gậy về phía fairway,
Dialogue: 0,0:03:27.91,0:03:30.75,Default,,0,0,0,,đã tránh được cỏ kẹp\Ngiữa gậy và bóng.
Dialogue: 0,0:03:30.83,0:03:33.00,Default,,0,0,0,,Nhờ tiếp xúc bóng gọn gàng,
Dialogue: 0,0:03:33.25,0:03:37.50,Default,,0,0,0,,lượng xoáy ngược càng tăng thêm\Nnhờ gió ngược.
Dialogue: 0,0:03:38.17,0:03:39.63,Default,,0,0,0,,Nên bóng mới dừng lại.
Dialogue: 0,0:03:40.38,0:03:41.38,Default,,0,0,0,,{\i1}Không thể thua được.{\i0}
Dialogue: 0,0:03:44.47,0:03:46.39,Default,,0,0,0,,{\i1}Hinoki có vẻ đang căng thẳng.{\i0}
Dialogue: 0,0:03:51.35,0:03:52.44,Default,,0,0,0,,Nhớ kỹ chưa?
Dialogue: 0,0:03:52.52,0:03:55.69,Default,,0,0,0,,Tuyệt đối không được thua\Nđối thủ gặp lần đầu.
Dialogue: 0,0:03:56.36,0:03:59.36,Default,,0,0,0,,Chiến thắng sẽ khiến đối thủ\Nphải e sợ.
Dialogue: 0,0:03:59.65,0:04:03.24,Default,,0,0,0,,Chỉ những kẻ khiến người khác e sợ mới thành công trong đời.
Dialogue: 0,0:04:04.57,0:04:06.70,Default,,0,0,0,,{\i1}Không thể thua được. Nếu thua...{\i0}
Dialogue: 0,0:04:16.38,0:04:17.29,Default,,0,0,0,,Suýt nữa thì.
Dialogue: 0,0:04:17.38,0:04:19.46,Default,,0,0,0,,Tiếc quá. Giá mà bay xa thêm chút nữa...
Dialogue: 0,0:04:19.63,0:04:22.55,Default,,0,0,0,,Bóng bị vùi rồi.\NÍt nhất cũng phải bogey.
Dialogue: 0,0:04:29.81,0:04:34.23,Default,,0,0,0,,Ước gì gió ngừng thổi.\NThế này thì khó đánh quá.
Dialogue: 0,0:04:41.24,0:04:42.28,Default,,0,0,0,,Birdie đẹp lắm!
Dialogue: 0,0:04:42.90,0:04:46.82,Default,,0,0,0,,{\i1}Với bogey ở lỗ số một và số ba,{\i0}\N{\i1}kết quả hiện tại là một gậy trên chuẩn.{\i0}
Dialogue: 0,0:04:47.87,0:04:49.49,Default,,0,0,0,,{\i1}Phải giữ vững điểm số này thôi.{\i0}
Dialogue: 0,0:04:53.33,0:04:57.58,Default,,0,0,0,,{\i1}Gió trên đảo vốn thổi rất đều.{\i0}
Dialogue: 0,0:04:57.71,0:05:01.67,Default,,0,0,0,,{\i1}Nhưng ở đây lại lúc mạnh lúc yếu,{\i0}\N{\i1}thay đổi liên tục.{\i0}
Dialogue: 0,0:05:04.72,0:05:05.97,Default,,0,0,0,,{\i1}Tới đây.{\i0}
Dialogue: 0,0:05:07.34,0:05:10.76,Default,,0,0,0,,Cứ như gió dịu lại\Nmỗi khi Tonbo đánh vậy!
Dialogue: 0,0:05:11.27,0:05:12.18,Default,,0,0,0,,Ừ.
Dialogue: 0,0:05:16.10,0:05:17.27,Default,,0,0,0,,Suýt thì vào.
Dialogue: 0,0:05:17.81,0:05:19.44,Default,,0,0,0,,Thế là hai gậy trên chuẩn rồi.
Dialogue: 0,0:05:19.65,0:05:23.82,Default,,0,0,0,,{\i1}Dù chỉ có bốn gậy,{\i0}\N{\i1}vẫn đánh hay không kém gì Hinoki.{\i0}
Dialogue: 0,0:05:24.90,0:05:27.87,Default,,0,0,0,,-Sắp bị thổi bay rồi!\N-Á!
Dialogue: 0,0:05:29.99,0:05:32.29,Default,,0,0,0,,Đây có lẽ là lỗ khó nhất.
Dialogue: 0,0:05:32.45,0:05:34.79,Default,,0,0,0,,Khoảng cách thực tế hơn 400 yard.
Dialogue: 0,0:05:35.00,0:05:38.46,Default,,0,0,0,,{\i1}Gió mạnh thế này lại càng khó hơn.{\i0}
Dialogue: 0,0:05:48.97,0:05:49.85,Default,,0,0,0,,Ồ?
Dialogue: 0,0:05:49.93,0:05:50.93,Default,,0,0,0,,-Igaiga?\N-Igarashi-san?
Dialogue: 0,0:05:51.01,0:05:51.89,Default,,0,0,0,,Giỏi thật.
Dialogue: 0,0:05:51.97,0:05:54.64,Default,,0,0,0,,Cú swing nhẹ nhàng\Nđể kiểm soát độ xoáy ngược.
Dialogue: 0,0:05:54.73,0:05:55.68,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:05:56.14,0:05:58.23,Default,,0,0,0,,Nhưng cũng chỉ tới ngang hố cát bên phải.
Dialogue: 0,0:05:58.35,0:06:00.65,Default,,0,0,0,,Gió mạnh hơn dự tính.
Dialogue: 0,0:06:01.57,0:06:04.57,Default,,0,0,0,,Ngay sau rặng cây kia là vách đá dốc.
Dialogue: 0,0:06:04.78,0:06:07.20,Default,,0,0,0,,Nếu rơi xuống đó\Nthì có thể bị double bogey trở lên.
Dialogue: 0,0:06:07.36,0:06:09.20,Default,,0,0,0,,Còn đáng sợ hơn cả OB.
Dialogue: 0,0:06:09.70,0:06:10.82,Default,,0,0,0,,{\i1}Cứ nhắm vào đó vậy.{\i0}
Dialogue: 0,0:06:10.91,0:06:12.49,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:06:13.08,0:06:14.37,Default,,0,0,0,,Gậy driver sao?
Dialogue: 0,0:06:14.49,0:06:15.87,Default,,0,0,0,,Quà chia tay đấy.
Dialogue: 0,0:06:16.33,0:06:17.87,Default,,0,0,0,,Quà chia tay?
Dialogue: 0,0:06:21.59,0:06:22.84,Default,,0,0,0,,Gì chứ? Có vấn đề gì à?
Dialogue: 0,0:06:23.59,0:06:25.80,Default,,0,0,0,,Tới 15.309 yên lận!
Dialogue: 0,0:06:26.55,0:06:28.51,Default,,0,0,0,,Gậy golf đắt thật đấy.
Dialogue: 0,0:06:29.18,0:06:31.26,Default,,0,0,0,,Igaiga, cho thật luôn hả?
Dialogue: 0,0:06:31.43,0:06:32.35,Default,,0,0,0,,Cảm ơn nhé!
Dialogue: 0,0:06:34.35,0:06:36.02,Default,,0,0,0,,Ừm. Thế là khá rẻ rồi.
Dialogue: 0,0:06:36.18,0:06:37.35,Default,,0,0,0,,Lại còn là gậy cũ nữa.
Dialogue: 0,0:06:43.19,0:06:44.40,Default,,0,0,0,,Dùng được không?
Dialogue: 0,0:06:45.03,0:06:46.36,Default,,0,0,0,,Thử xem sao!
Dialogue: 0,0:06:48.53,0:06:51.70,Default,,0,0,0,,Gió ngược thế này\Nmà lại cắm tee cao vậy sao?
Dialogue: 0,0:06:51.91,0:06:53.87,Default,,0,0,0,,Đúng là không hiểu nổi.
Dialogue: 0,0:06:54.41,0:06:55.79,Default,,0,0,0,,Cứ như làm xiếc vậy,
Dialogue: 0,0:06:56.29,0:06:57.75,Default,,0,0,0,,cách đánh golf của Tonbo ấy.
Dialogue: 0,0:07:02.21,0:07:05.00,Default,,0,0,0,,Đặt bóng ở\Nngay mép trên mặt gậy.
Dialogue: 0,0:07:05.59,0:07:07.71,Default,,0,0,0,,Định đánh cú xoáy thấp sao?
Dialogue: 0,0:07:08.22,0:07:10.26,Default,,0,0,0,,Bằng cây driver chưa quen tay bao giờ ư?
Dialogue: 0,0:07:10.47,0:07:12.14,Default,,0,0,0,,To gan thật đấy.
Dialogue: 0,0:07:16.81,0:07:20.23,Default,,0,0,0,,{\i1}Chữ 'K' đã sâu hơn.{\i0}\N{\i1}Đang kẹp bóng bằng cơ bụng kìa.{\i0}
Dialogue: 0,0:07:24.73,0:07:26.15,Default,,0,0,0,,Đừng đánh slice ở đó!
Dialogue: 0,0:07:26.28,0:07:27.65,Default,,0,0,0,,Sẽ rớt xuống vách đá mất!
Dialogue: 0,0:07:27.90,0:07:30.45,Default,,0,0,0,,{\i1}Lên nào! Hy vọng là chọn đúng gậy!{\i0}
Dialogue: 0,0:07:30.95,0:07:32.11,Default,,0,0,0,,Én lượn vòng!
Dialogue: 0,0:07:36.74,0:07:37.66,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:07:37.95,0:07:39.16,Default,,0,0,0,,Làm được rồi!
Dialogue: 0,0:07:45.46,0:07:48.01,Default,,0,0,0,,Đánh bóng còn xa hơn cả mình.
Dialogue: 0,0:07:48.21,0:07:49.17,Default,,0,0,0,,Sao có thể?
Dialogue: 0,0:07:49.34,0:07:51.76,Default,,0,0,0,,Lúc dùng gậy driver ở sân tập,
Dialogue: 0,0:07:51.84,0:07:53.76,Default,,0,0,0,,toàn đánh ra cú slice mà.
Dialogue: 0,0:07:54.85,0:07:57.39,Default,,0,0,0,,Quả nhiên là\Nchọn đúng gậy driver rồi.
Dialogue: 0,0:07:57.85,0:07:58.85,Default,,0,0,0,,Ra là vậy.
Dialogue: 0,0:07:58.97,0:08:01.23,Default,,0,0,0,,Nếu chỉ muốn đánh cú xoáy thấp,
Dialogue: 0,0:08:01.85,0:08:04.02,Default,,0,0,0,,thì không cần phải cắm tee cao đến thế.
Dialogue: 0,0:08:05.27,0:08:08.23,Default,,0,0,0,,Để kiểm soát bóng\Nbằng góc vung gậy dốc,
Dialogue: 0,0:08:08.32,0:08:11.82,Default,,0,0,0,,đã tạo khoảng trống cho đầu gậy\Nlướt qua sau khi chạm bóng.
Dialogue: 0,0:08:17.37,0:08:19.41,Default,,0,0,0,,Không thấy phiền vì gió sao?
Dialogue: 0,0:08:19.49,0:08:22.29,Default,,0,0,0,,Trên đảo lúc nào cũng gió thế này mà!
Dialogue: 0,0:08:22.37,0:08:27.50,Default,,0,0,0,,{\i1}Mưa rơi thì cứ để ướt,{\i0}\N{\i1}nắng chiếu thì cứ để sạm da.{\i0}
Dialogue: 0,0:08:28.34,0:08:31.67,Default,,0,0,0,,{\i1}Không cần phải bận tâm{\i0}\N{\i1}đến mấy chuyện vặt vãnh đó.{\i0}
Dialogue: 0,0:08:32.26,0:08:35.51,Default,,0,0,0,,{\i1}Như thế thì tâm trí{\i0}\N{\i1}mới luôn thanh thản.{\i0}
Dialogue: 0,0:08:35.72,0:08:39.35,Default,,0,0,0,,{\i1}Đó là điều mà dân chài bọn này{\i0}\N{\i1}luôn ghi nhớ khi ra khơi.{\i0}
Dialogue: 0,0:08:42.14,0:08:44.31,Default,,0,0,0,,Chắc còn khoảng 220 yard.
Dialogue: 0,0:08:44.65,0:08:46.06,Default,,0,0,0,,Vâng.
Dialogue: 0,0:08:46.48,0:08:50.48,Default,,0,0,0,,Nếu khéo léo thì có thể vượt qua\Nbậc đầu tiên của green.
Dialogue: 0,0:08:52.11,0:08:54.11,Default,,0,0,0,,Có hai lựa chọn.
Dialogue: 0,0:08:54.24,0:08:58.74,Default,,0,0,0,,Đánh lay-up để giành ba gậy,\Nhoặc thử dùng gậy gỗ.
Dialogue: 0,0:08:59.12,0:09:02.04,Default,,0,0,0,,{\i1}Còn 180 yard nữa là tới mép trước.{\i0}
Dialogue: 0,0:09:02.29,0:09:06.83,Default,,0,0,0,,{\i1}Có thể đưa bóng tới đó,{\i0}\N{\i1}nhưng phải cẩn thận hố cát.{\i0}
Dialogue: 0,0:09:07.46,0:09:10.92,Default,,0,0,0,,{\i1}Đang dẫn trước một gậy ở hai lỗ cuối.{\i0}
Dialogue: 0,0:09:11.13,0:09:15.38,Default,,0,0,0,,Nếu giờ bị bogey thì có thể bị Tonbo đuổi kịp.
Dialogue: 0,0:09:15.68,0:09:18.22,Default,,0,0,0,,Bằng mọi giá phải giành được par.
Dialogue: 0,0:09:20.93,0:09:22.35,Default,,0,0,0,,Gậy gỗ số 3.
Dialogue: 0,0:09:22.85,0:09:24.77,Default,,0,0,0,,Mang gậy spoon ra quyết đấu luôn sao.
Dialogue: 0,0:09:28.86,0:09:30.44,Default,,0,0,0,,Bay đúng hướng rồi!
Dialogue: 0,0:09:32.48,0:09:33.86,Default,,0,0,0,,Rơi xuống chưa?
Dialogue: 0,0:09:35.70,0:09:39.70,Default,,0,0,0,,Lượng xoáy ngược ít hơn\Nsẽ cản gió ngược tốt hơn.
Dialogue: 0,0:09:39.78,0:09:44.45,Default,,0,0,0,,Nhưng nếu không đủ độ xoáy\Nđể tạo lực nâng,
Dialogue: 0,0:09:44.71,0:09:46.25,Default,,0,0,0,,thì bóng sẽ không bay xa được.
Dialogue: 0,0:09:50.21,0:09:51.30,Default,,0,0,0,,Hinoki!
Dialogue: 0,0:09:51.42,0:09:52.71,Default,,0,0,0,,Đừng trút giận lên sân chứ!
Dialogue: 0,0:09:52.80,0:09:54.88,Default,,0,0,0,,Có hai điều mà golfer nào cũng phải làm.
Dialogue: 0,0:09:55.30,0:09:58.47,Default,,0,0,0,,Giữ gìn phép tắc và tôn trọng sân cỏ!
Dialogue: 0,0:10:00.30,0:10:01.81,Default,,0,0,0,,Cháu xin lỗi.
Dialogue: 0,0:10:04.89,0:10:06.98,Default,,0,0,0,,Lại có một cái cây to tướng đằng kia kìa!
Dialogue: 0,0:10:08.44,0:10:10.11,Default,,0,0,0,,Cú tee shot vừa rồi rõ đẹp...
Dialogue: 0,0:10:10.56,0:10:13.90,Default,,0,0,0,,Nhưng cái cây đó có thể sẽ cản trở\Ncú đánh tiếp theo.
Dialogue: 0,0:10:14.82,0:10:16.15,Default,,0,0,0,,Sân golf này...
Dialogue: 0,0:10:17.24,0:10:19.91,Default,,0,0,0,,Đúng là thú vị thật!
Dialogue: 0,0:10:20.12,0:10:24.49,Default,,0,0,0,,{\i1}Cây long não đó đang chắn ngang đường{\i0}\N{\i1}từ bóng đến cờ.{\i0}
Dialogue: 0,0:10:24.70,0:10:29.79,Default,,0,0,0,,{\i1}Phải nhắm thẳng qua ngọn cây{\i0}\N{\i1}để tránh gió ngược từ bên phải.{\i0}
Dialogue: 0,0:10:30.71,0:10:35.01,Default,,0,0,0,,{\i1}Nhưng nếu đánh cao hơn ngọn cây,{\i0}\N{\i1}thì sẽ bị gió tạt mạnh hơn.{\i0}
Dialogue: 0,0:10:36.42,0:10:39.09,Default,,0,0,0,,{\i1}Đừng lo. Tonbo cũng sẽ không giành được par đâu.{\i0}
Dialogue: 0,0:10:39.93,0:10:41.55,Default,,0,0,0,,Bắt chước Hinoki-san vậy!
Dialogue: 0,0:10:43.51,0:10:44.64,Default,,0,0,0,,Đánh từ mặt cỏ sao?
Dialogue: 0,0:10:45.35,0:10:48.02,Default,,0,0,0,,Lại định làm trò kỳ quái gì nữa đây.
Dialogue: 0,0:10:48.48,0:10:50.94,Default,,0,0,0,,Ước gì cứ đánh bình thường cho xong.
Dialogue: 0,0:10:51.69,0:10:55.61,Default,,0,0,0,,Dùng gậy đánh từ mặt cỏ để đưa bóng qua cái cây đó\Nkhông dễ đâu.
Dialogue: 0,0:10:57.36,0:10:59.99,Default,,0,0,0,,Gì thế kia? Tư thế chuẩn bị uể oải quá vậy.
Dialogue: 0,0:11:00.11,0:11:02.78,Default,,0,0,0,,Cứ như đang định\Nđánh cú chạy bóng tiếp cận vậy.
Dialogue: 0,0:11:02.95,0:11:05.62,Default,,0,0,0,,Đúng là định làm vậy thật.
Dialogue: 0,0:11:07.62,0:11:09.71,Default,,0,0,0,,{\i1}Đã mở vai trái ra sớm hơn.{\i0}
Dialogue: 0,0:11:12.00,0:11:13.13,Default,,0,0,0,,Bay cao quá rồi sao?
Dialogue: 0,0:11:27.89,0:11:29.85,Default,,0,0,0,,Lên nào! Xuyên qua đi!
Dialogue: 0,0:11:32.15,0:11:33.31,Default,,0,0,0,,Xuyên qua rồi!
Dialogue: 0,0:11:33.40,0:11:35.73,Default,,0,0,0,,Lên nào! Quả bóng cá chuồn!
Dialogue: 0,0:11:39.15,0:11:41.61,Default,,0,0,0,,Mỗi lần nảy lên\Nlại lệch sang phải nhiều hơn!
Dialogue: 0,0:11:47.74,0:11:48.91,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:11:49.16,0:11:51.33,Default,,0,0,0,,Đó không phải là cú chạy bóng tiếp cận bình thường.
Dialogue: 0,0:11:51.87,0:11:54.17,Default,,0,0,0,,Đúng vậy. Đã cắt bóng một chút.
Dialogue: 0,0:11:54.63,0:11:57.84,Default,,0,0,0,,Vì vậy,\Nbóng đã nảy cao hơn dự tính.
Dialogue: 0,0:11:58.67,0:12:03.01,Default,,0,0,0,,Có cơ hội giành birdie rồi.\NTrình độ này không đùa được đâu.
Dialogue: 0,0:12:03.89,0:12:04.80,Default,,0,0,0,,Đúng là quái vật.
Dialogue: 0,0:12:06.10,0:12:08.47,Default,,0,0,0,,Sẽ không thể\Nđánh cú bùng nổ được.
Dialogue: 0,0:12:08.68,0:12:11.19,Default,,0,0,0,,Đúng vậy. Sẽ không tới được cờ,
Dialogue: 0,0:12:11.35,0:12:16.11,Default,,0,0,0,,và dù có sượt qua cát khéo đến đâu,\Nđộ xoáy ngược cũng sẽ kéo bóng lùi lại.
Dialogue: 0,0:12:17.27,0:12:18.69,Default,,0,0,0,,Cú này khó thật đấy.
Dialogue: 0,0:12:18.98,0:12:20.32,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:12:20.40,0:12:22.36,Default,,0,0,0,,Mắc bẫy gọn lơn rồi.
Dialogue: 0,0:12:22.78,0:12:23.70,Default,,0,0,0,,Cái bẫy sao?
Dialogue: 0,0:12:23.78,0:12:27.58,Default,,0,0,0,,Tại sao lại chỉ có hố cát\Nở cách green 50 yard?
Dialogue: 0,0:12:27.78,0:12:30.04,Default,,0,0,0,,Lý do gì\Nmà lại làm green ba bậc?
Dialogue: 0,0:12:30.20,0:12:32.75,Default,,0,0,0,,Mọi thứ đều có ý đồ của người thiết kế cả.
Dialogue: 0,0:12:32.83,0:12:38.30,Default,,0,0,0,,Khi cờ cắm ở bậc ngoài cùng,\Nrơi vào hố cát cũng không sao.
Dialogue: 0,0:12:38.46,0:12:42.84,Default,,0,0,0,,Khi cờ ở bậc giữa,\Nthì phải tránh hố cát.
Dialogue: 0,0:12:43.01,0:12:45.64,Default,,0,0,0,,Và khi cờ ở bậc xa nhất,
Dialogue: 0,0:12:46.39,0:12:49.01,Default,,0,0,0,,bằng mọi giá phải tránh xa hố cát ra.
Dialogue: 0,0:12:49.81,0:12:51.27,Default,,0,0,0,,Vậy có nghĩa là...
Dialogue: 0,0:12:51.81,0:12:57.40,Default,,0,0,0,,Hinoki đã sai lầm khi cố đưa bóng\Nlên green ở cú đánh thứ hai.
Dialogue: 0,0:12:58.94,0:13:01.78,Default,,0,0,0,,Không ngờ thiết kế sân golf\Nlại phải tính toán kỹ đến vậy.
Dialogue: 0,0:13:01.90,0:13:03.65,Default,,0,0,0,,Thông minh thật đấy!
Dialogue: 0,0:13:05.82,0:13:06.87,Default,,0,0,0,,Gậy 58 độ.
Dialogue: 0,0:13:07.45,0:13:09.49,Default,,0,0,0,,Định nhắm thẳng vào bậc trong cùng sao.
Dialogue: 0,0:13:09.91,0:13:13.87,Default,,0,0,0,,Gió ngược thế này sẽ làm tăng độ xoáy ngược.
Dialogue: 0,0:13:13.96,0:13:18.04,Default,,0,0,0,,{\i1}Đánh thấp thì bóng sẽ dừng.{\i0}\N{\i1}Chắc chắn sẽ dừng lại.{\i0}
Dialogue: 0,0:13:18.67,0:13:22.59,Default,,0,0,0,,{\i1}Cảm giác này là sao?{\i0}\N{\i1}Mình tuyệt đối không muốn thua cô bé đó.{\i0}
Dialogue: 0,0:13:23.67,0:13:27.51,Default,,0,0,0,,{\i1}Lối chơi đó hoàn toàn khác biệt{\i0}\N{\i1}với thứ golf mà mình đã học.{\i0}
Dialogue: 0,0:13:31.31,0:13:36.02,Default,,0,0,0,,{\i1}Nhìn lối đánh đó khiến mình có cảm giác{\i0}\N{\i1}mọi thứ mình biết về golf đang bị phủ nhận.{\i0}
Dialogue: 0,0:13:39.98,0:13:41.98,Default,,0,0,0,,{\i1}Đang dùng lưng để giữ gậy.{\i0}
Dialogue: 0,0:13:42.99,0:13:45.53,Default,,0,0,0,,{\i1}Không còn góc độ nào giữa{\i0}\N{\i1}cẳng tay và cán gậy nữa.{\i0}
Dialogue: 0,0:13:45.65,0:13:47.99,Default,,0,0,0,,{\i1}Nếu có góc độ,{\i0}\N{\i1}thì sẽ có khoảng trống để duỗi ra.{\i0}
Dialogue: 0,0:13:48.07,0:13:51.29,Default,,0,0,0,,{\i1}Góc độ duỗi ra{\i0}\N{\i1}sẽ tự nhiên làm đầu gậy hạ xuống,{\i0}
Dialogue: 0,0:13:51.37,0:13:53.33,Default,,0,0,0,,{\i1}tăng khả năng đánh trúng đất.{\i0}
Dialogue: 0,0:13:53.45,0:13:55.21,Default,,0,0,0,,{\i1}Đang cố tránh điều đó.{\i0}
Dialogue: 0,0:13:56.08,0:13:58.00,Default,,0,0,0,,{\i1}Được rồi. Tư thế chuẩn bị đã xong.{\i0}
Dialogue: 0,0:14:02.88,0:14:03.88,Default,,0,0,0,,Âm thanh nghe đã thật!
Dialogue: 0,0:14:04.17,0:14:05.17,Default,,0,0,0,,Dừng lại! Xoáy đi!
Dialogue: 0,0:14:07.22,0:14:08.39,Default,,0,0,0,,Lăn khỏi green rồi.
Dialogue: 0,0:14:10.18,0:14:14.10,Default,,0,0,0,,{\i1}Nhớ kỹ chưa?{\i0}\N{\i1}Tuyệt đối không được thua đối thủ gặp lần đầu.{\i0}
Dialogue: 0,0:14:24.40,0:14:25.82,Default,,0,0,0,,Tư thế tốt lắm.
Dialogue: 0,0:14:26.03,0:14:27.07,Default,,0,0,0,,Vâng.
Dialogue: 0,0:14:27.15,0:14:30.70,Default,,0,0,0,,Nhưng bị cuốn theo gió xuôi\Nnên mất độ xoáy ngược rồi.
Dialogue: 0,0:14:31.41,0:14:34.08,Default,,0,0,0,,Hinoki chưa đánh hỏng một cú nào.
Dialogue: 0,0:14:34.16,0:14:35.50,Default,,0,0,0,,Thậm chí,
Dialogue: 0,0:14:35.58,0:14:37.75,Default,,0,0,0,,mọi cú đánh đều vô cùng xuất sắc.
Dialogue: 0,0:14:38.04,0:14:39.50,Default,,0,0,0,,Mặc dù vậy...
Dialogue: 0,0:14:40.08,0:14:42.13,Default,,0,0,0,,{\i1}Golf luôn có luồng diễn biến riêng.{\i0}
Dialogue: 0,0:14:43.71,0:14:48.13,Default,,0,0,0,,{\i1}Tonbo đang lấy cú đánh tiếp cận của Hinoki{\i0}\N{\i1}làm tham chiếu cho độ xoáy và đường đi.{\i0}
Dialogue: 0,0:14:51.97,0:14:53.14,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:14:54.10,0:14:55.39,Default,,0,0,0,,-Birdie đẹp lắm.\N-Birdie đẹp lắm.
Dialogue: 0,0:14:57.73,0:14:59.35,Default,,0,0,0,,{\i1}Vậy là Tonbo được một gậy trên chuẩn.{\i0}
Dialogue: 0,0:15:00.06,0:15:02.40,Default,,0,0,0,,{\i1}Cú gạt bogey này sẽ đưa mình thành hai gậy trên chuẩn.{\i0}
Dialogue: 0,0:15:03.44,0:15:07.07,Default,,0,0,0,,{\i1}Trái ngược với Tonbo,{\i0}\N{\i1}gió đang thổi từ sau lưng tới.{\i0}
Dialogue: 0,0:15:07.19,0:15:10.07,Default,,0,0,0,,{\i1}Một vị trí vô cùng khó chịu{\i0}\N{\i1}đối với bất kỳ golfer nào.{\i0}
Dialogue: 0,0:15:18.21,0:15:19.37,Default,,0,0,0,,Tonbo đã vươn lên dẫn trước.
Dialogue: 0,0:15:20.08,0:15:23.00,Default,,0,0,0,,Dẫn trước Hinoki hai gậy\Nở lỗ cuối cùng.
Dialogue: 0,0:15:32.93,0:15:34.47,Default,,0,0,0,,Gió đang mạnh lên.
Dialogue: 0,0:15:34.56,0:15:37.14,Default,,0,0,0,,Tình hình này bóng sẽ không rẽ hướng đâu.
Dialogue: 0,0:15:37.98,0:15:41.81,Default,,0,0,0,,Chắc phải nhắm đánh bóng hơi lệch sang phải\Nso với hố cát bên trái kia.
Dialogue: 0,0:15:42.56,0:15:45.27,Default,,0,0,0,,Sao cứ phải bận tâm\Nchuyện bóng rẽ hướng vậy?
Dialogue: 0,0:15:46.44,0:15:47.36,Default,,0,0,0,,Không thấy sợ sao?
Dialogue: 0,0:15:48.07,0:15:48.90,Default,,0,0,0,,Sợ ư?
Dialogue: 0,0:15:49.19,0:15:50.20,Default,,0,0,0,,Không hề à?
Dialogue: 0,0:15:50.32,0:15:51.86,Default,,0,0,0,,OB hay hố cát...
Dialogue: 0,0:15:51.95,0:15:53.49,Default,,0,0,0,,Cứ nhắm thẳng vào đó mà đánh!
Dialogue: 0,0:15:54.07,0:15:55.74,Default,,0,0,0,,Lỡ bóng không rẽ hướng...
Dialogue: 0,0:15:55.83,0:15:56.99,Default,,0,0,0,,Không lo lắng sao?
Dialogue: 0,0:15:57.37,0:15:59.20,Default,,0,0,0,,Xin lỗi, nhưng không hiểu lắm.
Dialogue: 0,0:16:00.75,0:16:03.92,Default,,0,0,0,,Ban đêm trên biển\Nthì thấy khá đáng sợ,
Dialogue: 0,0:16:04.08,0:16:06.75,Default,,0,0,0,,chứ đánh golf thì\Nchưa bao giờ thấy sợ cả.
Dialogue: 0,0:16:18.93,0:16:20.35,Default,,0,0,0,,Á, tempura rồi.
Dialogue: 0,0:16:22.98,0:16:24.40,Default,,0,0,0,,Lỗi rồi!
Dialogue: 0,0:16:25.02,0:16:28.11,Default,,0,0,0,,{\i1}Đánh hỏng thế kia mà sao vẫn cười được?{\i0}
Dialogue: 0,0:16:28.82,0:16:31.82,Default,,0,0,0,,{\i1}Sao có thể chơi golf vui vẻ đến vậy chứ?{\i0}
Dialogue: 0,0:16:33.70,0:16:36.95,Default,,0,0,0,,{\i1}Không thể... Nhất định... Nhất định không thể thua!{\i0}
Dialogue: 0,0:16:43.04,0:16:44.71,Default,,0,0,0,,Nằm ngay cạnh hố cát bên trái kìa!
Dialogue: 0,0:16:44.96,0:16:46.13,Default,,0,0,0,,Cú drive xa thật!
Dialogue: 0,0:16:46.42,0:16:48.38,Default,,0,0,0,,Bắt buộc phải giành birdie.
Dialogue: 0,0:16:48.55,0:16:51.01,Default,,0,0,0,,{\i1}Nếu Tonbo bị bogey,{\i0}\N{\i1}thì sẽ gỡ hòa được.{\i0}
Dialogue: 0,0:16:53.80,0:16:55.72,Default,,0,0,0,,Cú đánh đổ dốc khó nhằn đây.
Dialogue: 0,0:16:56.39,0:16:59.52,Default,,0,0,0,,Bóng dừng ngay sau đoạn dốc\Ncủa khu vực phát bóng.
Dialogue: 0,0:16:59.68,0:17:02.85,Default,,0,0,0,,Để có thể nhắm tới green\Nở cú đánh thứ ba,
Dialogue: 0,0:17:03.06,0:17:04.73,Default,,0,0,0,,thì phải cố gắng rút ngắn khoảng cách.
Dialogue: 0,0:17:06.27,0:17:07.65,Default,,0,0,0,,Gậy gỗ số 5 sao?
Dialogue: 0,0:17:08.15,0:17:10.82,Default,,0,0,0,,Dùng gậy gỗ số 5 ở độ dốc thế này ư...
Dialogue: 0,0:17:11.40,0:17:12.53,Default,,0,0,0,,Đổi lại là mình thì chịu.
Dialogue: 0,0:17:13.03,0:17:14.70,Default,,0,0,0,,Chắc chắn là hỏng bét.
Dialogue: 0,0:17:15.03,0:17:16.66,Default,,0,0,0,,Nhưng nếu là Tonbo thì sao?
Dialogue: 0,0:17:29.55,0:17:31.21,Default,,0,0,0,,Không đứng vững nổi luôn!
Dialogue: 0,0:17:31.92,0:17:33.59,Default,,0,0,0,,Thế này thì kẹt thật rồi.
Dialogue: 0,0:17:34.17,0:17:36.34,Default,,0,0,0,,Ai biết được Tonbo sẽ làm gì tiếp theo.
Dialogue: 0,0:17:38.01,0:17:39.81,Default,,0,0,0,,Hả? Quỳ gối đánh sao?
Dialogue: 0,0:17:43.85,0:17:45.85,Default,,0,0,0,,Biết ngay là không được mà.
Dialogue: 0,0:17:46.73,0:17:49.57,Default,,0,0,0,,Tại chưa thử cách đánh này bao giờ mà.
Dialogue: 0,0:17:49.73,0:17:51.40,Default,,0,0,0,,Cú tiếp theo là gậy thứ tư rồi đấy.
Dialogue: 0,0:17:52.61,0:17:55.61,Default,,0,0,0,,{\i1}Tự nhiên thử kỹ thuật mới{\i0}\N{\i1}ngay trên sân luôn sao?{\i0}
Dialogue: 0,0:17:55.86,0:17:58.57,Default,,0,0,0,,{\i1}Rốt cuộc là đang nghĩ gì vậy?{\i0}
Dialogue: 0,0:17:58.74,0:18:01.08,Default,,0,0,0,,Lần này nắm được cảm giác rồi.
Dialogue: 0,0:18:03.87,0:18:05.08,Default,,0,0,0,,Lên nào!
Dialogue: 0,0:18:07.37,0:18:08.42,Default,,0,0,0,,Ái chà.
Dialogue: 0,0:18:09.25,0:18:10.59,Default,,0,0,0,,Vào hố cát rồi.
Dialogue: 0,0:18:11.59,0:18:13.63,Default,,0,0,0,,Lại còn lọt thỏm trong dấu chân nữa.
Dialogue: 0,0:18:14.30,0:18:15.26,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:18:15.72,0:18:17.93,Default,,0,0,0,,Tình cảnh thế mà vẫn thấy vui được nhỉ.
Dialogue: 0,0:18:18.97,0:18:21.97,Default,,0,0,0,,Bình thường thì chắc chắn sẽ nhăn nhó rồi.
Dialogue: 0,0:18:22.72,0:18:25.89,Default,,0,0,0,,Ở Hinoshima gió lúc nào cũng thổi.
Dialogue: 0,0:18:26.06,0:18:28.73,Default,,0,0,0,,Trời đang nắng cũng có thể đổ mưa bất chợt.
Dialogue: 0,0:18:28.90,0:18:32.07,Default,,0,0,0,,Mặt đất cứng\Nnên bóng rất dễ lăn.
Dialogue: 0,0:18:32.15,0:18:34.90,Default,,0,0,0,,Lăn càng nhiều thì càng dễ xuống chỗ thấp.
Dialogue: 0,0:18:35.07,0:18:38.45,Default,,0,0,0,,Nên bóng hay dừng ở vị trí xấu.
Dialogue: 0,0:18:38.82,0:18:42.16,Default,,0,0,0,,Với Tonbo, đó là chuyện đương nhiên.
Dialogue: 0,0:18:45.00,0:18:47.79,Default,,0,0,0,,{\i1}Mình chưa từng nghĩ như vậy bao giờ.{\i0}
Dialogue: 0,0:18:59.55,0:19:02.01,Default,,0,0,0,,Mở mặt gậy hơi nhiều rồi.
Dialogue: 0,0:19:02.30,0:19:03.47,Default,,0,0,0,,Lối chơi của Tonbo
Dialogue: 0,0:19:03.68,0:19:06.85,Default,,0,0,0,,luôn song hành với rủi ro\Nphá hỏng điểm số.
Dialogue: 0,0:19:07.81,0:19:09.98,Default,,0,0,0,,Đó không chỉ là điểm mạnh lớn nhất,
Dialogue: 0,0:19:10.19,0:19:12.86,Default,,0,0,0,,mà còn là điểm yếu chí mạng\Ntrong thi đấu.
Dialogue: 0,0:19:13.65,0:19:17.69,Default,,0,0,0,,Không màng đến điểm số,\Ncũng chẳng sợ làm hỏng nó.
Dialogue: 0,0:19:19.11,0:19:22.87,Default,,0,0,0,,Chỉ tập trung vào\Nviệc tạo ra đường bóng thôi.
Dialogue: 0,0:19:29.58,0:19:31.42,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:19:31.88,0:19:34.75,Default,,0,0,0,,Cẩn thận đừng làm ồn\Nảnh hưởng người khác!
Dialogue: 0,0:19:40.43,0:19:42.76,Default,,0,0,0,,Chỗ này thú vị đây.
Dialogue: 0,0:19:42.97,0:19:45.39,Default,,0,0,0,,{\i1}Lại thế nữa rồi.{\i0}\N{\i1}Chẳng có vẻ gì là lo lắng cả.{\i0}
Dialogue: 0,0:19:46.06,0:19:47.47,Default,,0,0,0,,Nhìn độ dốc đó kìa!
Dialogue: 0,0:19:47.98,0:19:50.23,Default,,0,0,0,,Lại còn ở ngay sát mép hố cát nữa!
Dialogue: 0,0:19:50.31,0:19:52.48,Default,,0,0,0,,Gần như không có khoảng trống để vung gậy!
Dialogue: 0,0:19:53.69,0:19:55.48,Default,,0,0,0,,Dốc này khá cao đấy.
Dialogue: 0,0:19:57.19,0:19:59.74,Default,,0,0,0,,Cũng có thể chọn cách\Nđánh bóng lùi lại phía sau.
Dialogue: 0,0:19:59.82,0:20:02.99,Default,,0,0,0,,Đó là nếu muốn\Nbảo toàn điểm số.
Dialogue: 0,0:20:04.37,0:20:09.54,Default,,0,0,0,,{\i1}Tonbo không quan tâm đến điểm số.{\i0}\N{\i1}Chỉ tận hưởng cảm giác đánh bóng thôi.{\i0}
Dialogue: 0,0:20:11.08,0:20:15.50,Default,,0,0,0,,{\i1}Với tư thế đó, đầu gối phải{\i0}\N{\i1}sẽ cản trở cú vung gậy ra sau!{\i0}
Dialogue: 0,0:20:16.21,0:20:17.34,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:20:17.80,0:20:20.34,Default,,0,0,0,,{\i1}Không thể nào. Tuyệt đối không thể được!{\i0}
Dialogue: 0,0:20:23.18,0:20:25.68,Default,,0,0,0,,Đánh kiểu đó thì có thể được đấy.
Dialogue: 0,0:20:28.47,0:20:29.39,Default,,0,0,0,,Không thể nào!
Dialogue: 0,0:20:29.52,0:20:30.60,Default,,0,0,0,,Làm được rồi!
Dialogue: 0,0:20:32.64,0:20:33.48,Default,,0,0,0,,Lên nào!
Dialogue: 0,0:20:33.56,0:20:34.77,Default,,0,0,0,,Vượt qua đi!
Dialogue: 0,0:20:39.40,0:20:40.49,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:20:41.20,0:20:42.36,Default,,0,0,0,,Xin cảm ơn rất nhiều ạ!
Dialogue: 0,0:20:45.24,0:20:46.49,Default,,0,0,0,,Ba mươi tám gậy sao?
Dialogue: 0,0:20:47.20,0:20:49.79,Default,,0,0,0,,Đã bảo hôm nay tối đa là một gậy trên chuẩn cơ mà!
Dialogue: 0,0:20:50.54,0:20:56.00,Default,,0,0,0,,Tưởng gió hơi to\Nnên không cần giữ lời hứa cũng được sao?
Dialogue: 0,0:20:56.21,0:20:57.67,Default,,0,0,0,,Đừng có hòng!
Dialogue: 0,0:20:57.96,0:20:59.30,Default,,0,0,0,,Bố...
Dialogue: 0,0:21:00.13,0:21:02.84,Default,,0,0,0,,Sao bố biết\Nchỉ là gió hơi to?
Dialogue: 0,0:21:04.47,0:21:06.14,Default,,0,0,0,,Igaiga.
Dialogue: 0,0:21:06.22,0:21:09.01,Default,,0,0,0,,Bố ở trong nhà mà?\NSao lại biết được chứ?
Dialogue: 0,0:21:10.97,0:21:12.27,Default,,0,0,0,,Đi thôi.
Dialogue: 0,0:21:17.98,0:21:20.57,Default,,0,0,0,,Hôm nay có gương mặt mới nhỉ.
Dialogue: 0,0:21:20.69,0:21:22.78,Default,,0,0,0,,Đừng nói là thua cô bé đó đấy nhé?
Dialogue: 0,0:21:23.65,0:21:24.66,Default,,0,0,0,,Thua rồi.
Dialogue: 0,0:21:24.74,0:21:25.57,Default,,0,0,0,,Cái gì?
Dialogue: 0,0:21:26.62,0:21:28.66,Default,,0,0,0,,Thua toàn tập luôn, thưa bố.
Dialogue: 0,0:21:29.49,0:21:30.58,Default,,0,0,0,,Điểm số bao nhiêu?
Dialogue: 0,0:21:31.12,0:21:32.29,Default,,0,0,0,,Không lẽ dưới chuẩn sao?
Dialogue: 0,0:21:33.41,0:21:34.46,Default,,0,0,0,,Bốn mươi mốt.
Dialogue: 0,0:21:34.62,0:21:35.67,Default,,0,0,0,,Bốn mươi mốt ư?
Dialogue: 0,0:21:36.00,0:21:38.42,Default,,0,0,0,,Điểm số tệ hại gì thế?
Dialogue: 0,0:21:38.75,0:21:41.09,Default,,0,0,0,,Ba mươi tám gậy rõ ràng là thắng mà.
Dialogue: 0,0:21:44.30,0:21:46.05,Default,,0,0,0,,Không bận tâm đến cú swing sao?
Dialogue: 0,0:21:46.76,0:21:49.81,Default,,0,0,0,,Với Tonbo, việc rèn luyện cú swing\Nkhông hề có trong ý thức.
Dialogue: 0,0:21:50.64,0:21:53.06,Default,,0,0,0,,Chỉ tập trung vào\Nviệc tạo ra đường bóng thôi.
Dialogue: 0,0:21:53.43,0:21:54.89,Default,,0,0,0,,Tạo ra đường bóng?
Dialogue: 0,0:21:55.81,0:21:59.48,Default,,0,0,0,,Không như những người khác\Nchỉ mải lo làm sao vung gậy cho đúng,
Dialogue: 0,0:21:59.73,0:22:02.11,Default,,0,0,0,,Tonbo chỉ muốn đánh ra đường bóng mình cần thôi.
Dialogue: 0,0:22:03.61,0:22:05.03,Default,,0,0,0,,Thế nào? Thấy tiềm năng chứ?
Dialogue: 0,0:22:05.28,0:22:06.70,Default,,0,0,0,,Có bồi dưỡng được không?
Dialogue: 0,0:22:11.62,0:22:16.00,Default,,0,0,0,,Mang đến một nhân tố quá sức tưởng tượng rồi đấy, Igarashi-san.
Dialogue: 0,0:23:47.97,0:23:48.80,Default,,0,0,0,,PREVIEW
Dialogue: 0,0:23:48.88,0:23:49.84,Default,,0,0,0,,Hinoki-san!
Dialogue: 0,0:23:49.93,0:23:50.93,Default,,0,0,0,,Sao vậy, Tonbo?
Dialogue: 0,0:23:51.01,0:23:55.01,Default,,0,0,0,,Lần đầu ra sân xong rồi,\Ntiếp theo phải làm gì đây?
Dialogue: 0,0:23:55.43,0:23:57.22,Default,,0,0,0,,Để xem nào. Tất nhiên là Giải Nữ Kyushu--
Dialogue: 0,0:23:57.31,0:23:58.64,Default,,0,0,0,,Đi tắm hay ăn tối nhỉ?
Dialogue: 0,0:23:58.73,0:23:59.56,Default,,0,0,0,,Hả?
Dialogue: 0,0:23:59.64,0:24:01.27,Default,,0,0,0,,{\i1}Tập tiếp theo của{\i0} Tonbo!
Dialogue: 0,0:24:01.35,0:24:03.65,Default,,0,0,0,,{\i1}Khai mạc!{\i0}\N{\i1}Giải vô địch nữ Kyushu!{\i0}
Dialogue: 0,0:24:03.77,0:24:06.07,Default,,0,0,0,,Phải viết thư cho ông Gon nữa!
Dialogue: 0,0:24:06.15,0:24:07.94,Default,,0,0,0,,Cái nào cũng quan trọng nhỉ.