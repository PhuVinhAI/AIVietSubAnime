Dialogue: 0,0:00:04.08,0:00:05.13,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:00:05.67,0:00:06.71,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:00:06.96,0:00:07.92,Default,,0,0,0,,...
Dialogue: 0,0:00:08.13,0:00:08.96,Default,,0,0,0,,...
Dialogue: 0,0:00:09.63,0:00:12.17,Default,,0,0,0,,Lỡ làm bóng di chuyển mất rồi!
Dialogue: 0,0:00:20.47,0:00:22.73,Default,,0,0,0,,Biết ngay mà!
Dialogue: 0,0:00:23.02,0:00:27.61,Default,,0,0,0,,Chỉ cần nhận một gậy phạt\Nvà đặt bóng lại vị trí cũ là được!
Dialogue: 0,0:00:28.23,0:00:29.44,Default,,0,0,0,,Cố lên nhé!
Dialogue: 0,0:00:32.65,0:00:33.74,Default,,0,0,0,,Không phải vậy đâu.
Dialogue: 0,0:00:34.15,0:00:36.82,Default,,0,0,0,,Không hiểu rồi, Tonbo.
Dialogue: 0,0:00:37.28,0:00:38.45,Default,,0,0,0,,Không phải thế.
Dialogue: 0,0:00:38.83,0:00:40.20,Default,,0,0,0,,Làm bóng di chuyển ư?
Dialogue: 0,0:00:41.87,0:00:43.54,Default,,0,0,0,,Ý là trước cú đánh cuối cùng à?
Dialogue: 0,0:00:45.17,0:00:49.50,Default,,0,0,0,,Làm bóng di chuyển trong lúc vung gậy\Nnhưng vẫn đánh luôn. Có phải vậy không?
Dialogue: 0,0:00:50.42,0:00:51.34,Default,,0,0,0,,Vâng.
Dialogue: 0,0:00:55.51,0:00:58.85,Default,,0,0,0,,Trong trường hợp đó thì không cần\Nđặt bóng lại vị trí cũ đâu.
Dialogue: 0,0:00:59.35,0:01:02.18,Default,,0,0,0,,Cứ nhận một gậy phạt\Nvà tiếp tục đánh từ vị trí đó thôi.
Dialogue: 0,0:01:02.56,0:01:03.77,Default,,0,0,0,,Một gậy phạt sao?
Dialogue: 0,0:01:04.31,0:01:06.40,Default,,0,0,0,,Vậy là thành four-on rồi đấy.
Dialogue: 0,0:01:11.57,0:01:15.36,Default,,0,0,0,,{\i1}Lại... lại nói dối mất rồi.{\i0}
Dialogue: 0,0:01:16.03,0:01:22.45,Default,,0,0,0,,{\i1}Nhưng như vậy nghĩa là sai lầm chưa phải{\i0}\N{\i1}trả giá hôm qua sẽ được trả giá vào hôm nay.{\i0}
Dialogue: 0,0:01:24.04,0:01:28.38,Default,,0,0,0,,{\i1}Lại ích kỷ nữa rồi. Nhưng mà...{\i0}
Dialogue: 0,0:01:29.04,0:01:32.50,Default,,0,0,0,,{\i1}Cũng thấy nhẹ nhõm hơn một chút.{\i0}
Dialogue: 0,0:03:05.22,0:03:08.39,Default,,0,0,0,,Từ giờ trở đi\Nphải nghiêm túc lên đấy!
Dialogue: 0,0:03:08.60,0:03:09.98,Default,,0,0,0,,Nghiêm túc sao?
Dialogue: 0,0:03:10.39,0:03:14.77,Default,,0,0,0,,Đang giữa một cuộc thi gay cấn đấy!\NKhông muốn chiến thắng sao?
Dialogue: 0,0:03:15.98,0:03:18.03,Default,,0,0,0,,Toàn đi tìm bóng cho người khác,
Dialogue: 0,0:03:18.15,0:03:21.32,Default,,0,0,0,,rồi thực hiện những cú đánh siêu mạo hiểm\Ncó thể làm hỏng cả trận đấu!
Dialogue: 0,0:03:21.61,0:03:24.03,Default,,0,0,0,,Trông chẳng có vẻ gì\Nlà đang cố gắng để thắng cả!
Dialogue: 0,0:03:24.99,0:03:27.41,Default,,0,0,0,,Cơ hội đang treo\Nngay trước mắt kìa!
Dialogue: 0,0:03:27.74,0:03:30.04,Default,,0,0,0,,Phải cống hiến 100% sức lực đi chứ!
Dialogue: 0,0:03:30.37,0:03:32.42,Default,,0,0,0,,100% ư?
Dialogue: 0,0:03:33.00,0:03:35.04,Default,,0,0,0,,Đúng thế! Phải thay đổi cách chơi đi!
Dialogue: 0,0:03:36.84,0:03:38.01,Default,,0,0,0,,{\i1}Thay đổi sao?{\i0}
Dialogue: 0,0:03:39.42,0:03:41.59,Default,,0,0,0,,{\i1}Cống hiến 100% \Nnghĩa là sao chứ?{\i0}
Dialogue: 0,0:03:43.72,0:03:47.64,Default,,0,0,0,,{\i1}Cô bé này từng bị dẫn trước 6 gậy{\i0}\N{\i1}nhưng không hiểu sao đã vươn lên vị trí dẫn đầu.{\i0}
Dialogue: 0,0:03:47.72,0:03:51.06,Default,,0,0,0,,{\i1}Ngay cả khi gió và điều kiện thời tiết{\i0}\N{\i1}đang tồi tệ như thế này.{\i0}
Dialogue: 0,0:03:52.06,0:03:53.60,Default,,0,0,0,,Muốn thay đổi cách chơi sao?
Dialogue: 0,0:03:54.69,0:03:55.65,Default,,0,0,0,,Không.
Dialogue: 0,0:03:55.94,0:03:56.82,Default,,0,0,0,,Nhầm rồi.
Dialogue: 0,0:03:57.57,0:03:59.61,Default,,0,0,0,,Không cần phải thay đổi cách chơi đâu.
Dialogue: 0,0:04:00.07,0:04:02.11,Default,,0,0,0,,Cứ chơi như mọi khi là được.
Dialogue: 0,0:04:03.49,0:04:05.62,Default,,0,0,0,,Muốn xem thêm nữa.
Dialogue: 0,0:04:07.45,0:04:10.33,Default,,0,0,0,,Chắc hẳn câu trả lời cho việc\Nliên tục trượt bài kiểm tra chuyên nghiệp
Dialogue: 0,0:04:10.70,0:04:14.00,Default,,0,0,0,,nằm ở cách chơi golf của Tonbo đấy.
Dialogue: 0,0:04:14.46,0:04:15.88,Default,,0,0,0,,Ở cách chơi này ư?
Dialogue: 0,0:04:16.13,0:04:17.04,Default,,0,0,0,,Ừ.
Dialogue: 0,0:04:17.13,0:04:18.67,Default,,0,0,0,,Chiến thắng không phải là tất cả.
Dialogue: 0,0:04:19.21,0:04:20.38,Default,,0,0,0,,Mà là...
Dialogue: 0,0:04:20.55,0:04:23.38,Default,,0,0,0,,Cứ như đang chơi\Nvì một mục đích khác vậy!
Dialogue: 0,0:04:25.72,0:04:27.39,Default,,0,0,0,,Chẳng hiểu đang nói gì cả.
Dialogue: 0,0:04:28.72,0:04:31.39,Default,,0,0,0,,Dù sao thì cũng chỉ còn 5 lỗ nữa thôi!
Dialogue: 0,0:04:31.48,0:04:34.77,Default,,0,0,0,,Ý là sẽ rất phí phạm\Nnếu không ít nhất thử giành chiến thắng đấy!
Dialogue: 0,0:04:34.85,0:04:35.90,Default,,0,0,0,,Rõ rồi!
Dialogue: 0,0:04:40.23,0:04:43.61,Default,,0,0,0,,Đánh bại người khác quan trọng đến thế sao?
Dialogue: 0,0:04:45.24,0:04:47.99,Default,,0,0,0,,Chỉ muốn đánh golf giỏi hơn thôi mà!
Dialogue: 0,0:04:48.70,0:04:52.75,Default,,0,0,0,,{\i1}Đúng vậy! Đó mới là điều quan trọng nhất!{\i0}
Dialogue: 0,0:04:54.41,0:04:57.17,Default,,0,0,0,,{\i1}Đang tự thử thách bản thân{\i0}\N{\i1}để chơi golf giỏi hơn.{\i0}
Dialogue: 0,0:05:00.88,0:05:04.68,Default,,0,0,0,,{\i1}Đó là điều duy nhất{\i0}\N{\i1}cần phải chú ý đến.{\i0}
Dialogue: 0,0:05:10.93,0:05:12.72,Default,,0,0,0,,Lại double bogey rồi.
Dialogue: 0,0:05:18.23,0:05:21.44,Default,,0,0,0,,{\i1}Đây là lần đầu tiên điểm số{\i0}\N{\i1}thay đổi trong hiệp hai.{\i0}
Dialogue: 0,0:05:21.73,0:05:25.03,Default,,0,0,0,,{\i1}Không thể để điểm số bị tụt trước được.{\i0}
Dialogue: 0,0:05:25.45,0:05:27.20,Default,,0,0,0,,{\i1}Đã quyết tâm cao độ rồi.{\i0}
Dialogue: 0,0:05:28.37,0:05:30.28,Default,,0,0,0,,{\i1}Cuối cùng cũng đồng hạng nhất rồi.{\i0}
Dialogue: 0,0:05:35.75,0:05:38.33,Default,,0,0,0,,{\i1}Hướng gió{\i0}\N{\i1}cuối cùng cũng ổn định rồi.{\i0}
Dialogue: 0,0:05:39.04,0:05:41.55,Default,,0,0,0,,{\i1}Là gió xuôi. Chính là lúc này.{\i0}
Dialogue: 0,0:05:41.80,0:05:45.47,Default,,0,0,0,,{\i1}Sẽ có thể chơi{\i0}\N{\i1}hết mình ở lỗ này.{\i0}
Dialogue: 0,0:05:46.55,0:05:48.34,Default,,0,0,0,,{\i1}Lỗ par 5 cuối cùng trong ngày.{\i0}
Dialogue: 0,0:05:48.47,0:05:51.68,Default,,0,0,0,,{\i1}Lỗ này sẽ là chìa khóa dẫn đến chiến thắng.{\i0}
Dialogue: 0,0:05:52.01,0:05:55.77,Default,,0,0,0,,{\i1}Những quả bóng bổng của Ema có{\i0}\N{\i1}độ xoáy ngược vô cùng đáng kinh ngạc.{\i0}
Dialogue: 0,0:05:56.64,0:05:59.90,Default,,0,0,0,,{\i1}Vào một ngày nhiều gió như hôm nay,{\i0}\N{\i1}đó lại trở thành kẻ thù tồi tệ nhất.{\i0}
Dialogue: 0,0:06:01.48,0:06:05.53,Default,,0,0,0,,{\i1}Với sức gió thế này, gió xuôi sẽ{\i0}\N{\i1}loại bỏ những đường cong nhỏ của bóng.{\i0}
Dialogue: 0,0:06:06.15,0:06:09.70,Default,,0,0,0,,{\i1}Nó sẽ đẩy bóng về phía trước.{\i0}
Dialogue: 0,0:06:10.41,0:06:14.70,Default,,0,0,0,,{\i1}Chính là lúc này. Đây là cơ hội.{\i0}\N{\i1}Đây là cơ hội duy nhất!{\i0}
Dialogue: 0,0:06:19.21,0:06:21.08,Default,,0,0,0,,{\i1}Cuối cùng cũng làm được rồi!{\i0}
Dialogue: 0,0:06:23.80,0:06:25.01,Default,,0,0,0,,{\i1}Phải làm thôi!{\i0}
Dialogue: 0,0:06:25.76,0:06:26.80,Default,,0,0,0,,{\i1}Ngay bây giờ!{\i0}
Dialogue: 0,0:06:30.01,0:06:32.93,Default,,0,0,0,,{\i1}Còn 260 yard nữa{\i0}\N{\i1}mới đến giữa hố cát.{\i0}
Dialogue: 0,0:06:33.14,0:06:34.81,Default,,0,0,0,,{\i1}Ngay cả với gió xuôi thế này...{\i0}
Dialogue: 0,0:06:35.27,0:06:36.23,Default,,0,0,0,,{\i1}Tuyệt quá.{\i0}
Dialogue: 0,0:06:38.73,0:06:40.27,Default,,0,0,0,,-Hay quá.\N-Cảm ơn nhé.
Dialogue: 0,0:06:43.44,0:06:44.69,Default,,0,0,0,,{\i1}Gậy creek sao?{\i0}
Dialogue: 0,0:06:47.82,0:06:52.41,Default,,0,0,0,,{\i1}Ema không phải là người duy nhất coi{\i0}\N{\i1}lỗ này là chìa khóa dẫn đến chiến thắng.{\i0}
Dialogue: 0,0:06:52.82,0:06:56.04,Default,,0,0,0,,{\i1}Có cảm giác rằng bất cứ ai{\i0}\N{\i1}ghi được birdie ở lỗ này{\i0}
Dialogue: 0,0:06:56.20,0:06:58.04,Default,,0,0,0,,{\i1}sẽ trở thành người chiến thắng.{\i0}
Dialogue: 0,0:06:59.00,0:07:02.54,Default,,0,0,0,,{\i1}Để ghi birdie với vị trí cắm cờ{\i0}\N{\i1}của ngày hôm nay, quả bóng sẽ{\i0}
Dialogue: 0,0:07:02.79,0:07:05.13,Default,,0,0,0,,{\i1}quả bóng sẽ phải dừng lại{\i0}\N{\i1}ngay khi vừa chạm đất.{\i0}
Dialogue: 0,0:07:05.71,0:07:07.55,Default,,0,0,0,,{\i1}Sẽ không dễ dàng với sức gió xuôi này.{\i0}
Dialogue: 0,0:07:07.71,0:07:10.01,Default,,0,0,0,,{\i1}Thay vì tiếp cận{\i0}\N{\i1}vùng green từ khoảng cách gần,{\i0}
Dialogue: 0,0:07:10.09,0:07:12.64,Default,,0,0,0,,{\i1}một cú đánh dài sẽ dễ tạo độ xoáy hơn.{\i0}
Dialogue: 0,0:07:13.55,0:07:16.35,Default,,0,0,0,,{\i1}Về việc cú đánh dài đó{\i0}\N{\i1}nên được thực hiện từ đâu,{\i0}
Dialogue: 0,0:07:17.06,0:07:20.60,Default,,0,0,0,,{\i1}sẽ phải cẩn thận với hố cát{\i0}\N{\i1}nằm cách lỗ 100 yard.{\i0}
Dialogue: 0,0:07:20.81,0:07:25.61,Default,,0,0,0,,{\i1}Nếu bóng rơi vào hố cát ở cú đánh{\i0}\N{\i1}thứ hai, sẽ không thể ghi birdie được.{\i0}
Dialogue: 0,0:07:26.19,0:07:29.19,Default,,0,0,0,,{\i1}Phải tìm một lộ trình để tránh{\i0}\N{\i1}rơi vào hố cát.{\i0}
Dialogue: 0,0:07:29.40,0:07:33.24,Default,,0,0,0,,{\i1}Nếu định dừng trước hố cát,{\i0}\N{\i1}thì sẽ là 140 yard.{\i0}
Dialogue: 0,0:07:33.41,0:07:36.33,Default,,0,0,0,,{\i1}Sẽ phải đánh bóng 220 yard hai lần.{\i0}
Dialogue: 0,0:07:36.62,0:07:39.25,Default,,0,0,0,,{\i1}Có thể đánh bóng khoảng{\i0}\N{\i1}200 yard bằng gậy creek.{\i0}
Dialogue: 0,0:07:39.37,0:07:41.75,Default,,0,0,0,,{\i1}Ngay cả khi có gió xuôi,{\i0}\N{\i1}cũng sẽ không đến được hố cát.{\i0}
Dialogue: 0,0:07:42.29,0:07:46.38,Default,,0,0,0,,{\i1}Cứ như thể hố cát không hề tồn tại vậy.{\i0}\N{\i1}Có thể thực hiện cú đánh này mà không bị áp lực.{\i0}
Dialogue: 0,0:07:49.80,0:07:52.68,Default,,0,0,0,,{\i1}Đây là kế hoạch tốt nhất để ghi birdie.{\i0}
Dialogue: 0,0:07:53.59,0:07:55.51,Default,,0,0,0,,{\i1}Nếu bóng đi đúng hướng mong muốn,{\i0}
Dialogue: 0,0:07:55.76,0:07:57.93,Default,,0,0,0,,{\i1}cú đánh thứ ba sẽ là{\i0}\N{\i1}từ khoảng 110 yard.{\i0}
Dialogue: 0,0:07:58.10,0:08:01.35,Default,,0,0,0,,{\i1}Sẽ rất dễ dàng để đưa bóng đáp xuống{\i0}\N{\i1}gần cờ. Dễ hơn nhiều so với Ema.{\i0}
Dialogue: 0,0:08:03.35,0:08:04.77,Default,,0,0,0,,{\i1}Sẽ tiếp tục chiến đấu đến cùng.{\i0}
Dialogue: 0,0:08:05.48,0:08:08.40,Default,,0,0,0,,{\i1}Điểm số và vị trí hiện tại{\i0}\N{\i1}chính là thực lực thật sự.{\i0}
Dialogue: 0,0:08:09.03,0:08:11.78,Default,,0,0,0,,{\i1}Phải xem bản thân có thể tiến xa đến đâu{\i0}
Dialogue: 0,0:08:14.82,0:08:19.29,Default,,0,0,0,,{\i1}Nghiêng tee như vậy sẽ tạo ra{\i0}\N{\i1}lực cản, khiến bóng xoáy nhiều hơn.{\i0}
Dialogue: 0,0:08:19.87,0:08:21.50,Default,,0,0,0,,{\i1}Sẽ có thể tận dụng được sức gió.{\i0}
Dialogue: 0,0:08:27.29,0:08:30.01,Default,,0,0,0,,{\i1}Hinoki vẫn chưa bỏ cuộc đâu.{\i0}
Dialogue: 0,0:08:32.67,0:08:34.72,Default,,0,0,0,,Không thể tin được là bóng lại dừng ở đây.
Dialogue: 0,0:08:35.55,0:08:38.31,Default,,0,0,0,,Thà rơi luôn vào hố cát còn hơn.
Dialogue: 0,0:08:38.68,0:08:40.14,Default,,0,0,0,,Đang nói gì vậy?
Dialogue: 0,0:08:40.22,0:08:43.64,Default,,0,0,0,,Nếu làm thế,\Ncái cây có thể sẽ chắn đường mất.
Dialogue: 0,0:08:44.44,0:08:46.36,Default,,0,0,0,,Từ đây sẽ không đụng phải cây,
Dialogue: 0,0:08:46.73,0:08:49.36,Default,,0,0,0,,nhưng sẽ phải đánh bóng\Ntừ bên trong hố cát.
Dialogue: 0,0:08:49.98,0:08:52.03,Default,,0,0,0,,Sẽ phải đứng nhón gót.
Dialogue: 0,0:08:52.32,0:08:55.24,Default,,0,0,0,,Ngay cả khi có gió xuôi,\Ngậy sand wedge cũng sẽ không đủ lực.
Dialogue: 0,0:08:55.45,0:08:57.16,Default,,0,0,0,,Sẽ phải dùng gậy sắt số 9.
Dialogue: 0,0:08:57.37,0:08:58.99,Default,,0,0,0,,Sẽ dùng... cây này!
Dialogue: 0,0:08:59.33,0:09:00.24,Default,,0,0,0,,Gậy sắt số 6 sao?!
Dialogue: 0,0:09:00.33,0:09:01.87,Default,,0,0,0,,Cái-- Gì cơ?!
Dialogue: 0,0:09:02.50,0:09:07.17,Default,,0,0,0,,Sẽ phải dùng gậy số 9 và đánh lướt qua!
Dialogue: 0,0:09:08.17,0:09:12.09,Default,,0,0,0,,{\i1}Ra là vậy. Có thể đánh{\i0}\N{\i1}xa hơn bằng gậy sắt ngắn.{\i0}
Dialogue: 0,0:09:12.71,0:09:17.09,Default,,0,0,0,,{\i1}Nếu đứng nhón gót, sẽ dễ dàng hơn{\i0}\N{\i1}để nghiêng mặt gậy sang trái.{\i0}
Dialogue: 0,0:09:18.18,0:09:21.85,Default,,0,0,0,,{\i1}Bình thường hay mang theo{\i0}\N{\i1}một cây gậy lớn thế này,{\i0}
Dialogue: 0,0:09:22.10,0:09:25.02,Default,,0,0,0,,{\i1}nhưng chưa bao giờ nghĩ đến việc mang hai hay ba cây.{\i0}
Dialogue: 0,0:09:32.48,0:09:37.41,Default,,0,0,0,,Ôi không. Tưởng bóng sẽ xoáy một chút nhưng\Nlại đi hoàn toàn thẳng.
Dialogue: 0,0:09:37.87,0:09:40.53,Default,,0,0,0,,Đang nói gì vậy?\NCú đánh đó đỉnh quá đi chứ!
Dialogue: 0,0:09:40.66,0:09:41.62,Default,,0,0,0,,Đỉnh sao?
Dialogue: 0,0:09:41.70,0:09:43.16,Default,,0,0,0,,Ý là tuyệt vời đấy!
Dialogue: 0,0:09:47.25,0:09:48.88,Default,,0,0,0,,{\i1}Lại dùng gậy creek rồi.{\i0}
Dialogue: 0,0:09:48.96,0:09:52.96,Default,,0,0,0,,{\i1}Đang cố gắng dừng bóng{\i0}\N{\i1}ngay trước hố cát.{\i0}
Dialogue: 0,0:09:53.80,0:09:57.47,Default,,0,0,0,,{\i1}Ra là vậy. Vậy cú đánh thứ ba{\i0}\N{\i1}sẽ là một cú vung gậy hết lực.{\i0}
Dialogue: 0,0:09:58.89,0:10:04.10,Default,,0,0,0,,{\i1}Tsubura là người duy nhất trong trận đấu này{\i0}\N{\i1} thực sự hiểu rõ sân gôn.{\i0}
Dialogue: 0,0:10:10.23,0:10:11.15,Default,,0,0,0,,Chỉ còn 50 yard nữa thôi.
Dialogue: 0,0:10:11.73,0:10:12.69,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:10:12.98,0:10:14.15,Default,,0,0,0,,Tuyệt quá.
Dialogue: 0,0:10:14.32,0:10:16.90,Default,,0,0,0,,240 yard nữa là đến rìa vùng green.
Dialogue: 0,0:10:17.91,0:10:20.66,Default,,0,0,0,,{\i1}Ngay cả khi có gió xuôi,{\i0}\N{\i1}để đến được đó trong hai cú đánh...{\i0}
Dialogue: 0,0:10:21.58,0:10:22.87,Default,,0,0,0,,{\i1}Ngay cả khi đến được đó,{\i0}
Dialogue: 0,0:10:22.99,0:10:26.46,Default,,0,0,0,,{\i1}cũng không thể đưa bóng qua{\i0}\N{\i1}hố cát để đến cờ bằng gậy spoon được.{\i0}
Dialogue: 0,0:10:26.79,0:10:29.58,Default,,0,0,0,,{\i1}Sẽ phải tránh hố cát{\i0}\N{\i1}và nhắm vào vùng fairway.{\i0}
Dialogue: 0,0:10:30.25,0:10:35.01,Default,,0,0,0,,{\i1}Nếu không, bóng sẽ lăn quá xa{\i0}\N{\i1}khi chạm vào vùng green.{\i0}
Dialogue: 0,0:10:35.34,0:10:38.59,Default,,0,0,0,,{\i1}Nếu không bay đủ xa, {\i0}\N{\i1}sẽ phải đánh bóng qua hố cát.{\i0}
Dialogue: 0,0:10:38.80,0:10:41.76,Default,,0,0,0,,{\i1}Dù thế nào đi nữa, cũng sẽ không dễ dàng{\i0}\N{\i1}để ghi birdie.{\i0}
Dialogue: 0,0:10:42.85,0:10:43.76,Default,,0,0,0,,{\i1}Tsubura.{\i0}
Dialogue: 0,0:10:44.26,0:10:47.14,Default,,0,0,0,,{\i1}Khả năng quản lý sân gôn thật đáng kinh ngạc.{\i0}
Dialogue: 0,0:10:48.19,0:10:49.56,Default,,0,0,0,,{\i1}Nhưng cũng phải nói điều này.{\i0}
Dialogue: 0,0:10:50.65,0:10:53.94,Default,,0,0,0,,{\i1}Tất cả những gì đang làm chỉ là tránh né{\i0}\N{\i1}những mối nguy hiểm trên sân.{\i0}
Dialogue: 0,0:11:00.61,0:11:02.12,Default,,0,0,0,,{\i1}Một đường thẳng đến cờ luôn sao?{\i0}
Dialogue: 0,0:11:05.83,0:11:09.67,Default,,0,0,0,,{\i1}Áp lực lớn quá.{\i0}\N{\i1}Mắt cá chân trái không chịu nổi nữa rồi.{\i0}
Dialogue: 0,0:11:12.50,0:11:15.25,Default,,0,0,0,,{\i1}Nếu đánh bóng mà dồn nhiều{\i0}\N{\i1}trọng lượng lên chân phải như vậy,{\i0}
Dialogue: 0,0:11:15.38,0:11:17.01,Default,,0,0,0,,{\i1}gậy sẽ đập xuống đất mất!{\i0}
Dialogue: 0,0:11:17.30,0:11:19.13,Default,,0,0,0,,{\i1}Gậy spoon có mặt đáy rộng.{\i0}
Dialogue: 0,0:11:19.55,0:11:22.43,Default,,0,0,0,,{\i1}Sẽ không chạm đất{\i0}\N{\i1}dù đánh từ trên cao xuống cỡ nào.{\i0}
Dialogue: 0,0:11:22.72,0:11:24.72,Default,,0,0,0,,{\i1}Không quan trọng là bóng bay cao bao nhiêu.{\i0}
Dialogue: 0,0:11:25.35,0:11:27.43,Default,,0,0,0,,{\i1}Chỉ cần đánh tốt nhất có thể là được.{\i0}
Dialogue: 0,0:11:27.77,0:11:30.64,Default,,0,0,0,,{\i1}Đó là tất cả những gì còn lại phải làm.{\i0}
Dialogue: 0,0:11:31.31,0:11:35.15,Default,,0,0,0,,{\i1}Quan trọng là hướng đi. Cần phải{\i0}\N{\i1}đưa bóng rơi trong phạm vi hai yard quanh cờ.{\i0}
Dialogue: 0,0:11:35.57,0:11:38.15,Default,,0,0,0,,{\i1}Cú đánh tham khảo là push draw.{\i0}
Dialogue: 0,0:11:38.65,0:11:41.32,Default,,0,0,0,,{\i1}Push draw là đánh bóng{\i0}\N{\i1}ra ngoài đường nhắm mục tiêu.{\i0}
Dialogue: 0,0:11:41.53,0:11:45.16,Default,,0,0,0,,{\i1}Hơn nữa, sẽ vung gậy{\i0}\N{\i1}rộng hơn bình thường.{\i0}
Dialogue: 0,0:11:45.91,0:11:48.37,Default,,0,0,0,,{\i1}Thân gậy càng hướng về{\i0}\N{\i1}phía muốn bóng bay tới,{\i0}
Dialogue: 0,0:11:48.66,0:11:51.17,Default,,0,0,0,,{\i1}sẽ càng dễ tạo ra{\i0}\N{\i1}đường bay từ trong ra ngoài.{\i0}
Dialogue: 0,0:11:52.00,0:11:53.79,Default,,0,0,0,,{\i1}Đây là tư thế hoàn hảo!{\i0}
Dialogue: 0,0:11:57.17,0:11:58.05,Default,,0,0,0,,{\i1}Làm được rồi!{\i0}
Dialogue: 0,0:11:58.21,0:11:59.88,Default,,0,0,0,,Nhưng bóng bay quá xa về bên trái rồi!
Dialogue: 0,0:12:02.09,0:12:03.89,Default,,0,0,0,,Vòng lại đi!
Dialogue: 0,0:12:04.76,0:12:06.89,Default,,0,0,0,,{\i1}Ôi không. Nếu bóng rơi vào đó...{\i0}
Dialogue: 0,0:12:11.52,0:12:14.65,Default,,0,0,0,,Đánh từ đó luôn sao? Hai gậy lên green rồi kìa?!
Dialogue: 0,0:12:17.36,0:12:18.48,Default,,0,0,0,,Ema!
Dialogue: 0,0:12:19.28,0:12:20.36,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:12:24.24,0:12:26.03,Default,,0,0,0,,Gần đến thế này cơ mà!
Dialogue: 0,0:12:26.91,0:12:28.37,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:12:39.46,0:12:40.46,Default,,0,0,0,,{\i1}Tsubura.{\i0}
Dialogue: 0,0:12:41.26,0:12:43.93,Default,,0,0,0,,{\i1}Golf là một trò chơi may rủi,{\i0}\N{\i1}đúng không?{\i0}
Dialogue: 0,0:12:44.93,0:12:47.01,Default,,0,0,0,,{\i1}Những cú đánh có tỷ lệ thành công thấp{\i0}
Dialogue: 0,0:12:47.39,0:12:49.56,Default,,0,0,0,,{\i1}sẽ có 0% cơ hội{\i0}\N{\i1}nếu không chịu thử.{\i0}
Dialogue: 0,0:12:50.14,0:12:52.18,Default,,0,0,0,,{\i1}Nhưng nếu dám thử, mọi thứ đều có thể.{\i0}
Dialogue: 0,0:12:52.94,0:12:56.23,Default,,0,0,0,,{\i1}Chiến thắng bằng cách tấn công.{\i0}\N{\i1}Chứ không phải bằng logic và lý trí.{\i0}
Dialogue: 0,0:12:56.36,0:12:58.86,Default,,0,0,0,,{\i1}Phải chiến đấu{\i0}\N{\i1}vào thời khắc quyết định mới có thể chiến thắng.{\i0}
Dialogue: 0,0:12:59.07,0:13:02.15,Default,,0,0,0,,{\i1}Đó là điều đã học được{\i0}\N{\i1}khi chơi golf ở Mỹ.{\i0}
Dialogue: 0,0:13:07.87,0:13:11.25,Default,,0,0,0,,Đã đi xem thử rồi.\NCòn 116 yard nữa là đến cờ.
Dialogue: 0,0:13:11.58,0:13:12.58,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:13:13.83,0:13:15.79,Default,,0,0,0,,{\i1}Trông có vẻ như là 120,{\i0}
Dialogue: 0,0:13:16.08,0:13:18.04,Default,,0,0,0,,{\i1}nhưng bóng lại không bay đủ xa.{\i0}
Dialogue: 0,0:13:18.63,0:13:21.17,Default,,0,0,0,,{\i1}Khoảng cách nằm giữa gậy{\i0}\N{\i1}pitching wedge và gậy sắt số 9.{\i0}
Dialogue: 0,0:13:21.46,0:13:24.34,Default,,0,0,0,,{\i1}Có thể tránh hố cát bằng gậy sắt số 9.{\i0}
Dialogue: 0,0:13:25.59,0:13:29.64,Default,,0,0,0,,{\i1}Đánh bóng nhẹ nhàng bằng một cây gậy lớn{\i0}\N{\i1}sẽ làm giảm tốc độ đầu gậy.{\i0}
Dialogue: 0,0:13:30.60,0:13:34.69,Default,,0,0,0,,{\i1}Nếu vậy, năng lượng tác động sẽ bị{\i0}\N{\i1}giảm, cũng như độ xoáy ngược.{\i0}
Dialogue: 0,0:13:36.14,0:13:37.81,Default,,0,0,0,,{\i1}Chỉ khoảng 5 hay 6 yard thôi.{\i0}
Dialogue: 0,0:13:38.15,0:13:40.11,Default,,0,0,0,,{\i1}Vì tính toán bị sai lệch,{\i0}
Dialogue: 0,0:13:40.36,0:13:42.94,Default,,0,0,0,,{\i1}kế hoạch thực hiện một cú đánh hết lực ở gậy{\i0}\N{\i1}thứ ba đã bị phá sản.{\i0}
Dialogue: 0,0:13:44.03,0:13:45.45,Default,,0,0,0,,{\i1}Sẽ phải đánh thật nhẹ nhàng.{\i0}
Dialogue: 0,0:13:45.95,0:13:50.28,Default,,0,0,0,,{\i1}Nếu có thể tạo ra lực tác động mà không có{\i0}\N{\i1}một ngọn cỏ nào cản đường,{\i0}
Dialogue: 0,0:13:51.20,0:13:52.41,Default,,0,0,0,,{\i1}ngay cả với gậy sắt số 9...{\i0}
Dialogue: 0,0:13:58.67,0:14:00.29,Default,,0,0,0,,{\i1}Với gậy sắt số 8 trở xuống,{\i0}
Dialogue: 0,0:14:00.42,0:14:04.63,Default,,0,0,0,,{\i1}đã rèn luyện độ chính xác của gậy sắt ngắn{\i0}\N{\i1}để có thể nhắm thẳng vào cờ.{\i0}
Dialogue: 0,0:14:05.55,0:14:09.55,Default,,0,0,0,,{\i1}Thật đáng kinh ngạc. Ra đây là{\i0}\N{\i1}ý nghĩa của việc carry bóng.{\i0}
Dialogue: 0,0:14:11.35,0:14:14.02,Default,,0,0,0,,{\i1}Đánh bóng xa nhất có thể{\i0}\N{\i1}bằng gậy driver từ khu vực phát bóng,{\i0}
Dialogue: 0,0:14:14.14,0:14:17.48,Default,,0,0,0,,{\i1}rồi đưa bóng đến gần vùng green{\i0}\N{\i1}bằng gậy gỗ ở cú đánh thứ hai.{\i0}
Dialogue: 0,0:14:17.60,0:14:20.52,Default,,0,0,0,,{\i1}Đó là cách mà hầu hết các gôn thủ{\i0}\N{\i1}sẽ chơi ở một lỗ par 5.{\i0}
Dialogue: 0,0:14:24.11,0:14:27.15,Default,,0,0,0,,{\i1}Những cú đánh, cú tiếp cận{\i0}\N{\i1}và gạt bóng của Hinoki chắc chắn không hề tầm thường,{\i0}
Dialogue: 0,0:14:27.53,0:14:30.03,Default,,0,0,0,,{\i1}nhưng thành thật mà nói, cũng không đáng sợ lắm.{\i0}
Dialogue: 0,0:14:31.95,0:14:33.79,Default,,0,0,0,,{\i1}Bóng bay càng cao,{\i0}
Dialogue: 0,0:14:34.12,0:14:36.33,Default,,0,0,0,,{\i1}gió càng ảnh hưởng nhiều đến độ xoáy.{\i0}
Dialogue: 0,0:14:47.34,0:14:49.68,Default,,0,0,0,,{\i1}Đang trên cùng một đường ngắm.{\i0}
Dialogue: 0,0:14:50.05,0:14:52.22,Default,,0,0,0,,{\i1}Ema sẽ nhìn thấy đường ngắm này.{\i0}
Dialogue: 0,0:14:53.01,0:14:55.35,Default,,0,0,0,,{\i1}Điều này sẽ đảm bảo một điểm eagle cho Ema.{\i0}
Dialogue: 0,0:14:58.77,0:15:00.19,Default,,0,0,0,,{\i1}Phải đưa vào lỗ được quả này.{\i0}
Dialogue: 0,0:15:01.15,0:15:03.02,Default,,0,0,0,,{\i1}Nếu trượt, \NEma sẽ dẫn trước hai gậy.{\i0}
Dialogue: 0,0:15:03.27,0:15:05.40,Default,,0,0,0,,{\i1}Sẽ không tốt chút nào cho 4 lỗ cuối cùng.{\i0}
Dialogue: 0,0:15:06.11,0:15:08.53,Default,,0,0,0,,{\i1}Bắt đầu mất cảm giác{\i0}\N{\i1}vì căng thẳng rồi.{\i0}
Dialogue: 0,0:15:08.78,0:15:11.70,Default,,0,0,0,,{\i1}Là dốc xuống. Phải{\i0}\N{\i1}cẩn thận với tốc độ bóng.{\i0}
Dialogue: 0,0:15:14.08,0:15:15.37,Default,,0,0,0,,{\i1}Đúng như dự đoán!{\i0}
Dialogue: 0,0:15:19.96,0:15:21.46,Default,,0,0,0,,{\i1}Đã quên mất sức gió rồi.{\i0}
Dialogue: 0,0:15:25.30,0:15:26.34,Default,,0,0,0,,Xin phép nhé.
Dialogue: 0,0:15:30.97,0:15:31.93,Default,,0,0,0,,{\i1}Đã nhìn thấy đường ngắm rồi.{\i0}
Dialogue: 0,0:15:33.10,0:15:35.56,Default,,0,0,0,,{\i1}Chính là lúc này. Cuối cùng cũng có thể vươn lên dẫn trước.{\i0}
Dialogue: 0,0:15:40.27,0:15:41.19,Default,,0,0,0,,{\i1}Đánh quá mạnh tay rồi.{\i0}
Dialogue: 0,0:15:46.40,0:15:48.78,Default,,0,0,0,,{\i1}Người chiến thắng ở lỗ này sẽ giành được tất cả.{\i0}
Dialogue: 0,0:15:49.15,0:15:52.16,Default,,0,0,0,,{\i1}Cả hai đều biết điều đó.{\i0}
Dialogue: 0,0:15:52.99,0:15:56.08,Default,,0,0,0,,{\i1}Nhưng mục tiêu lúc đó là birdie.{\i0}
Dialogue: 0,0:15:56.91,0:15:59.20,Default,,0,0,0,,{\i1}Còn Ema lại nhắm đến eagle!{\i0}
Dialogue: 0,0:16:00.21,0:16:01.33,Default,,0,0,0,,{\i1}Ema?{\i0}
Dialogue: 0,0:16:12.59,0:16:14.60,Default,,0,0,0,,Họ đang ở 3 hoặc 4 lỗ cuối cùng.
Dialogue: 0,0:16:15.47,0:16:19.39,Default,,0,0,0,,Giờ mới là lúc thú vị thực sự bắt đầu.\NChúng ta có thể sẽ thấy một phản ứng hóa học.
Dialogue: 0,0:16:19.60,0:16:21.27,Default,,0,0,0,,Phản ứng hóa học sao?
Dialogue: 0,0:16:21.48,0:16:24.15,Default,,0,0,0,,Đây là cuộc thi đầu tiên của Tonbo.
Dialogue: 0,0:16:25.15,0:16:28.94,Default,,0,0,0,,Vào ngày cuối cùng, có thể\Nđã chơi đùa vui vẻ ở 14 lỗ đầu tiên,
Dialogue: 0,0:16:29.48,0:16:31.15,Default,,0,0,0,,Nhưng sau đó,
Dialogue: 0,0:16:31.49,0:16:35.37,Default,,0,0,0,,bị cuốn vào một trận chiến gay cấn,\Nđây có thể là trận golf thực sự đầu tiên.
Dialogue: 0,0:16:35.78,0:16:37.49,Default,,0,0,0,,Ôi không.
Dialogue: 0,0:16:38.12,0:16:38.99,Default,,0,0,0,,"Golf thực sự" sao?
Dialogue: 0,0:16:39.62,0:16:42.04,Default,,0,0,0,,Trái tim dao động giữa\Nnhững điều muốn và không muốn.
Dialogue: 0,0:16:42.87,0:16:44.67,Default,,0,0,0,,Trong thi đấu golf là như vậy đấy.
Dialogue: 0,0:16:45.67,0:16:47.96,Default,,0,0,0,,Thật hào hứng muốn xem quyết định tiếp theo sẽ là gì.
Dialogue: 0,0:16:49.00,0:16:51.22,Default,,0,0,0,,{\i1}Bóng đã bay vào khu rừng bên phải{\i0}\N{\i1}ở lỗ số 11,{\i0}
Dialogue: 0,0:16:51.30,0:16:53.26,Default,,0,0,0,,{\i1}và hố cát bên phải ở lỗ số 14.{\i0}
Dialogue: 0,0:16:53.47,0:16:56.43,Default,,0,0,0,,{\i1}Trong số 5 lỗ có{\i0}\N{\i1}sử dụng gậy driver ở nửa sau,{\i0}
Dialogue: 0,0:16:56.51,0:16:58.93,Default,,0,0,0,,{\i1}đã có 3 lỗ bóng không đáp xuống{\i0}\N{\i1}vùng fairway.{\i0}
Dialogue: 0,0:16:59.14,0:17:00.35,Default,,0,0,0,,{\i1}Lẽ nào...?{\i0}
Dialogue: 0,0:17:00.81,0:17:02.56,Default,,0,0,0,,{\i1}Đã bỏ sót điều gì đó sao?{\i0}
Dialogue: 0,0:17:03.27,0:17:04.98,Default,,0,0,0,,Ở sâu hơn trong này à?
Dialogue: 0,0:17:05.44,0:17:09.15,Default,,0,0,0,,Ema đã đưa bóng đến ngay cạnh cờ\Nở cú đánh thứ hai tại lỗ số 14.
Dialogue: 0,0:17:09.32,0:17:11.24,Default,,0,0,0,,Chắc là đã ghi được eagle rồi.
Dialogue: 0,0:17:12.11,0:17:14.28,Default,,0,0,0,,Vậy là thành 3 gậy âm rồi.
Dialogue: 0,0:17:14.66,0:17:15.57,Default,,0,0,0,,Ra vậy.
Dialogue: 0,0:17:15.82,0:17:17.32,Default,,0,0,0,,Vậy là bị dẫn trước 3 gậy rồi.
Dialogue: 0,0:17:18.28,0:17:19.83,Default,,0,0,0,,Đừng có tỏ ra thảnh thơi như thế.
Dialogue: 0,0:17:20.87,0:17:24.00,Default,,0,0,0,,Nếu mắc sai lầm ở lỗ này,\Nsẽ bị dẫn trước 4 gậy đấy.
Dialogue: 0,0:17:24.29,0:17:26.33,Default,,0,0,0,,Bị dẫn trước 4 gậy khi chỉ còn 3 lỗ.
Dialogue: 0,0:17:26.54,0:17:27.88,Default,,0,0,0,,Sẽ không thể thắng được đâu.
Dialogue: 0,0:17:28.54,0:17:31.88,Default,,0,0,0,,Nói cách khác, đừng để dính bogey\Nnếu vẫn muốn giành chiến thắng.
Dialogue: 0,0:17:35.84,0:17:37.76,Default,,0,0,0,,Nếu vẫn muốn giành chiến thắng...
Dialogue: 0,0:17:38.30,0:17:40.18,Default,,0,0,0,,Đừng giả vờ như không biết!
Dialogue: 0,0:17:41.31,0:17:42.47,Default,,0,0,0,,Biết rõ là thật mà.
Dialogue: 0,0:17:42.85,0:17:44.35,Default,,0,0,0,,Đang cảm thấy áp lực đúng không!
Dialogue: 0,0:17:45.06,0:17:47.86,Default,,0,0,0,,Chỉ đang giả vờ như không nhận ra\Nđiều đó thôi!
Dialogue: 0,0:17:49.69,0:17:53.03,Default,,0,0,0,,Muốn thắng đúng không?\NKhông tưởng tượng được cảm giác đó sẽ thế nào sao?
Dialogue: 0,0:17:54.11,0:17:55.07,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:17:55.15,0:17:57.07,Default,,0,0,0,,Đến từ một hòn đảo\Ntên là Tokara, đúng không?
Dialogue: 0,0:17:57.36,0:17:58.41,Default,,0,0,0,,Vâng.
Dialogue: 0,0:17:58.70,0:18:01.87,Default,,0,0,0,,Hãy nghĩ xem mọi người sẽ vui mừng\Nthế nào nếu giành chiến thắng đi.
Dialogue: 0,0:18:02.87,0:18:06.71,Default,,0,0,0,,Muốn làm mọi người vui đúng không.\NKhông muốn làm mọi người thất vọng chứ gì.
Dialogue: 0,0:18:07.71,0:18:09.13,Default,,0,0,0,,Chuyện bình thường thôi.
Dialogue: 0,0:18:09.50,0:18:11.30,Default,,0,0,0,,Đừng giả vờ như không hiểu nữa!
Dialogue: 0,0:18:12.59,0:18:14.38,Default,,0,0,0,,Giả vờ như không hiểu...
Dialogue: 0,0:18:15.47,0:18:20.05,Default,,0,0,0,,Lờ đi áp lực là điều tồi tệ nhất\Ncó thể làm khi đang chịu áp lực đấy.
Dialogue: 0,0:18:20.97,0:18:23.60,Default,,0,0,0,,Biết là rất khó để thừa nhận\Nbản thân đang sợ hãi.
Dialogue: 0,0:18:24.35,0:18:25.60,Default,,0,0,0,,Biết là chẳng ngầu chút nào.
Dialogue: 0,0:18:26.23,0:18:30.65,Default,,0,0,0,,Biết là đang lên mặt dạy đời, nhưng đó là lý do\Ntại sao lại trượt bài kiểm tra chuyên nghiệp đến 4 lần đấy.
Dialogue: 0,0:18:31.52,0:18:36.49,Default,,0,0,0,,Tonbo! Cần phải thừa nhận áp lực đó\Nvà đối mặt trực tiếp với nó!
Dialogue: 0,0:18:36.78,0:18:39.70,Default,,0,0,0,,Chỉ những người làm được điều đó\Nmới có thể vươn lên đỉnh cao.
Dialogue: 0,0:18:39.99,0:18:41.24,Default,,0,0,0,,Đó chính là golf!
Dialogue: 0,0:18:42.16,0:18:43.54,Default,,0,0,0,,Thừa nhận áp lực.
Dialogue: 0,0:18:44.33,0:18:45.66,Default,,0,0,0,,Đối mặt trực tiếp với nó.
Dialogue: 0,0:18:49.92,0:18:51.50,Default,,0,0,0,,Một vết xước cỏ...
Dialogue: 0,0:18:51.63,0:18:54.21,Default,,0,0,0,,Miễn là gậy\Nkhông đập vào mép sau,
Dialogue: 0,0:18:54.34,0:18:56.55,Default,,0,0,0,,vẫn có đủ không gian\Nđể đánh bóng, nhưng...
Dialogue: 0,0:18:58.76,0:19:00.68,Default,,0,0,0,,Vết xước cỏ kiểu gì thế này?
Dialogue: 0,0:19:01.09,0:19:04.77,Default,,0,0,0,,Chắc là của ai đó\Nở lỗ số 18
Dialogue: 0,0:19:04.97,0:19:07.43,Default,,0,0,0,,đang cố gắng đưa bóng\Ntrở lại vùng fairway.
Dialogue: 0,0:19:08.27,0:19:10.44,Default,,0,0,0,,Thật là một cú đánh tệ hại!
Dialogue: 0,0:19:10.73,0:19:12.81,Default,,0,0,0,,Mặt cỏ bị cày nát hết cả rồi!
Dialogue: 0,0:19:13.82,0:19:15.53,Default,,0,0,0,,Có một góc mở để đánh lên vùng green.
Dialogue: 0,0:19:16.03,0:19:17.11,Default,,0,0,0,,Ừ.
Dialogue: 0,0:19:17.19,0:19:18.82,Default,,0,0,0,,Cũng không xa lắm.
Dialogue: 0,0:19:19.40,0:19:20.57,Default,,0,0,0,,Chắc khoảng 90 yard.
Dialogue: 0,0:19:21.16,0:19:22.16,Default,,0,0,0,,Nhưng...
Dialogue: 0,0:19:22.41,0:19:23.58,Default,,0,0,0,,Với vết xước cỏ này
Dialogue: 0,0:19:23.83,0:19:25.49,Default,,0,0,0,,không thể nhắm thẳng lên vùng green được.
Dialogue: 0,0:19:26.16,0:19:28.29,Default,,0,0,0,,Bất kể dùng góc đánh nào,
Dialogue: 0,0:19:28.46,0:19:31.00,Default,,0,0,0,,mặt đất sẽ chen vào giữa\Nquả bóng và gậy.
Dialogue: 0,0:19:31.88,0:19:34.46,Default,,0,0,0,,Đưa bóng qua hố cát cũng sẽ không dễ dàng\Nchút nào.
Dialogue: 0,0:19:35.55,0:19:38.55,Default,,0,0,0,,{\i1}Có thể đánh bóng cùng{\i0}\N{\i1}hướng với vết xước cỏ.{\i0}
Dialogue: 0,0:19:43.22,0:19:44.72,Default,,0,0,0,,{\i1}Nhưng cứ đà này...{\i0}
Dialogue: 0,0:19:45.81,0:19:48.31,Default,,0,0,0,,{\i1}điểm số sẽ bị tụt lại mất.{\i0}
Dialogue: 0,0:19:49.52,0:19:51.14,Default,,0,0,0,,{\i1}Sẽ không thể giành chiến thắng.{\i0}
Dialogue: 0,0:19:54.69,0:19:55.65,Default,,0,0,0,,{\i1}Hả?{\i0}
Dialogue: 0,0:19:56.44,0:19:58.49,Default,,0,0,0,,{\i1}Gì thế này? Muốn giành chiến thắng.{\i0}
Dialogue: 0,0:19:58.90,0:20:01.91,Default,,0,0,0,,{\i1}Mọi người trên đảo{\i0}\N{\i1}sẽ rất vui nếu giành chiến thắng.{\i0}
Dialogue: 0,0:20:02.24,0:20:04.78,Default,,0,0,0,,{\i1}Muốn làm mọi người vui. Muốn giành chiến thắng.{\i0}
Dialogue: 0,0:20:06.33,0:20:09.08,Default,,0,0,0,,{\i1}Golf là một trò chơi của áp lực.{\i0}
Dialogue: 0,0:20:09.58,0:20:10.71,Default,,0,0,0,,{\i1}Lý do là vì,{\i0}
Dialogue: 0,0:20:10.91,0:20:12.08,Default,,0,0,0,,{\i1}Sẽ "muốn" đạt điểm par.{\i0}
Dialogue: 0,0:20:12.17,0:20:13.25,Default,,0,0,0,,{\i1}"Muốn" đưa bóng lên vùng green.{\i0}
Dialogue: 0,0:20:13.33,0:20:15.34,Default,,0,0,0,,{\i1}"Muốn" đánh trúng. Có rất nhiều thứ muốn.{\i0}
Dialogue: 0,0:20:15.63,0:20:17.67,Default,,0,0,0,,{\i1}Nhưng lại "không muốn" đánh bóng ra ngoài biên.{\i0}
Dialogue: 0,0:20:17.75,0:20:19.26,Default,,0,0,0,,{\i1}"Không muốn" phải gạt bóng 3 lần.{\i0}
Dialogue: 0,0:20:19.55,0:20:20.84,Default,,0,0,0,,{\i1}"Không muốn" đánh hỏng.{\i0}
Dialogue: 0,0:20:21.34,0:20:24.60,Default,,0,0,0,,{\i1}Phải tập trung vào những điều "muốn" và{\i0}\N{\i1}"không muốn" để đánh bóng.{\i0}
Dialogue: 0,0:20:25.85,0:20:29.06,Default,,0,0,0,,Nói cách khác, những thứ\Nnhận được từ thành công,
Dialogue: 0,0:20:29.43,0:20:32.64,Default,,0,0,0,,và những thứ đánh mất từ thất bại.
Dialogue: 0,0:20:34.06,0:20:36.61,Default,,0,0,0,,Những thứ đó càng trở nên lớn lao,
Dialogue: 0,0:20:37.07,0:20:39.11,Default,,0,0,0,,con người ta càng trở nên căng thẳng.
Dialogue: 0,0:20:39.82,0:20:41.36,Default,,0,0,0,,Đó chính là thứ được gọi là áp lực.
Dialogue: 0,0:20:42.40,0:20:44.20,Default,,0,0,0,,{\i1}Đã hiểu rồi.{\i0}
Dialogue: 0,0:20:44.74,0:20:47.62,Default,,0,0,0,,{\i1}Đang căng thẳng.{\i0}
Dialogue: 0,0:20:48.20,0:20:49.54,Default,,0,0,0,,{\i1}Đang chịu áp lực.{\i0}
Dialogue: 0,0:20:56.21,0:20:57.75,Default,,0,0,0,,Đó là cách duy nhất.
Dialogue: 0,0:20:58.38,0:20:59.76,Default,,0,0,0,,Đừng đánh quá mạnh.
Dialogue: 0,0:21:00.38,0:21:02.01,Default,,0,0,0,,Dừng lại trước hố cát.
Dialogue: 0,0:21:02.84,0:21:05.39,Default,,0,0,0,,{\i1}Đây không phải là cách duy nhất. Tuy nhiên...{\i0}
Dialogue: 0,0:21:08.14,0:21:11.02,Default,,0,0,0,,{\i1}Tuy nhiên, đây là cơ hội tốt nhất.{\i0}
Dialogue: 0,0:21:16.23,0:21:17.23,Default,,0,0,0,,Sao vậy?
Dialogue: 0,0:21:17.98,0:21:19.73,Default,,0,0,0,,Không quan tâm đến cơ hội đâu.
Dialogue: 0,0:21:21.99,0:21:24.91,Default,,0,0,0,,Bằng cách thừa nhận áp lực đang phải chịu đựng,
Dialogue: 0,0:21:26.49,0:21:28.58,Default,,0,0,0,,đã sẵn sàng đối mặt trực tiếp với nó rồi.
Dialogue: 0,0:21:29.99,0:21:31.66,Default,,0,0,0,,Đừng đánh theo cách đó!
Dialogue: 0,0:21:31.95,0:21:33.58,Default,,0,0,0,,{\i1}Có thể sẽ thất bại.{\i0}
Dialogue: 0,0:21:35.75,0:21:37.25,Default,,0,0,0,,{\i1}Đúng là một cú đánh đáng sợ.{\i0}
Dialogue: 0,0:21:39.63,0:21:41.76,Default,,0,0,0,,{\i1}Đây là lần đầu tiên{\i0}\N{\i1}cảm thấy thế này.{\i0}
Dialogue: 0,0:21:43.30,0:21:44.38,Default,,0,0,0,,{\i1}Đã hiểu rồi.{\i0}
Dialogue: 0,0:21:44.51,0:21:46.01,Default,,0,0,0,,{\i1}Ra đây là golf thực sự.{\i0}
Dialogue: 0,0:21:46.34,0:21:48.26,Default,,0,0,0,,{\i1}Đừng vung gậy mạnh như vậy chứ!{\i0}
Dialogue: 0,0:21:51.85,0:21:53.18,Default,,0,0,0,,{\i1}Cố lên nào. Quả bóng cua!{\i0}
Dialogue: 0,0:21:55.64,0:21:57.65,Default,,0,0,0,,{\i1}Một cú shank có chủ ý sao?!{\i0}
Dialogue: 0,0:21:58.98,0:22:02.48,Default,,0,0,0,,Làm ơn! Tới đó đi!
Dialogue: 0,0:22:07.45,0:22:08.32,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:22:15.37,0:22:18.00,Default,,0,0,0,,Tuyệt vời!
Dialogue: 0,0:23:49.01,0:23:50.55,Default,,0,0,0,,Gần đến lỗ cuối cùng rồi.
Dialogue: 0,0:23:50.72,0:23:53.55,Default,,0,0,0,,Đúng vậy. Cứ là chính mình thôi.
Dialogue: 0,0:23:53.72,0:23:55.76,Default,,0,0,0,,Chắc chắn rồi! Hãy xem đây, Igaiga!
Dialogue: 0,0:23:56.64,0:23:58.14,Default,,0,0,0,,Trong tập tiếp theo của Tonbo.
Dialogue: 0,0:23:58.39,0:23:59.89,Default,,0,0,0,,{\i1}Tonbo, Đưa Bóng Vào Lỗ{\i0}
Dialogue: 0,0:24:00.06,0:24:02.23,Default,,0,0,0,,Đừng rời mắt\Ndù chỉ một giây nhé.
Dialogue: 0,0:24:03.81,0:24:05.98,Default,,0,0,0,,Vẻ mặt đáng sợ quá không tập trung được đâu!
Dialogue: 0,0:24:06.11,0:24:07.11,Default,,0,0,0,,Tonbo!