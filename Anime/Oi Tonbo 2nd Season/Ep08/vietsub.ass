Dialogue: 0,0:00:04.25,0:00:06.50,Default,,0,0,0,,Cú đánh trên thuyền của ông Gon sao?
Dialogue: 0,0:00:06.96,0:00:07.84,Default,,0,0,0,,Làm gì cơ?
Dialogue: 0,0:00:08.30,0:00:09.25,Default,,0,0,0,,Ngay trong một vòng đấu à?
Dialogue: 0,0:00:09.55,0:00:10.88,Default,,0,0,0,,Đúng vậy. Làm rồi.
Dialogue: 0,0:00:11.63,0:00:12.72,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:00:13.55,0:00:14.47,Default,,0,0,0,,Đấy mới là điều đáng nghe chứ!
Dialogue: 0,0:00:14.68,0:00:16.22,Default,,0,0,0,,Đúng là Tonbo mà.
Dialogue: 0,0:00:16.55,0:00:20.39,Default,,0,0,0,,Tưởng tượng được ngay vẻ mặt\Ncủa họ khi thấy cảnh đó luôn!
Dialogue: 0,0:00:24.06,0:00:26.52,Default,,0,0,0,,Đâu có buồn cười đến thế!
Dialogue: 0,0:00:27.73,0:00:31.11,Default,,0,0,0,,{\i1}Tonbo chẳng thay đổi chút nào. Nhưng...{\i0}
Dialogue: 0,0:00:31.90,0:00:32.78,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:00:33.57,0:00:35.20,Default,,0,0,0,,Muốn xem thử một cú đánh quá.
Dialogue: 0,0:00:36.70,0:00:38.20,Default,,0,0,0,,Được thôi. Đi nào.
Dialogue: 0,0:02:10.67,0:02:12.96,Default,,0,0,0,,Đừng vội lơ là nhé.
Dialogue: 0,0:02:13.05,0:02:14.25,Default,,0,0,0,,Mới là ngày thứ hai thôi.
Dialogue: 0,0:02:15.17,0:02:18.30,Default,,0,0,0,,Nếu cuối cùng không đứng nhất\Nthì mọi công sức đều đổ sông đổ biển đấy!
Dialogue: 0,0:02:20.55,0:02:21.51,Default,,0,0,0,,Hinoki.
Dialogue: 0,0:02:21.68,0:02:22.97,Default,,0,0,0,,Vẫn đang tập luyện sao.
Dialogue: 0,0:02:23.93,0:02:26.10,Default,,0,0,0,,Ồ. Giờ mới bắt đầu à?
Dialogue: 0,0:02:27.43,0:02:29.10,Default,,0,0,0,,Chỉ là cố đấm ăn xôi thôi.
Dialogue: 0,0:02:29.69,0:02:31.48,Default,,0,0,0,,Hinoki đang dẫn trước sáu gậy đấy.
Dialogue: 0,0:02:32.02,0:02:33.27,Default,,0,0,0,,E là hết may mắn rồi.
Dialogue: 0,0:02:34.32,0:02:35.36,Default,,0,0,0,,Về nhà thôi.
Dialogue: 0,0:02:36.36,0:02:37.28,Default,,0,0,0,,Ừ.
Dialogue: 0,0:02:38.82,0:02:40.11,Default,,0,0,0,,Ngày mai gặp lại nhé!
Dialogue: 0,0:02:42.37,0:02:47.37,Default,,0,0,0,,{\i1}Tonbo. Xin lỗi nhé. Phải thắng thôi. Nhất định phải thắng.{\i0}
Dialogue: 0,0:02:49.79,0:02:51.08,Default,,0,0,0,,{\i1}Tha lỗi nhé.{\i0}
Dialogue: 0,0:02:52.04,0:02:54.50,Default,,0,0,0,,Vậy là đã thêm gậy sắt số sáu\Nvà số chín vào túi rồi sao?
Dialogue: 0,0:02:55.13,0:02:56.30,Default,,0,0,0,,Ai đã cho vậy?
Dialogue: 0,0:02:57.01,0:02:58.55,Default,,0,0,0,,Bố đã cho gậy sắt số sáu,
Dialogue: 0,0:02:59.13,0:03:02.30,Default,,0,0,0,,còn gậy sắt số chín thì nhận\Ntừ Nakase-san ở câu lạc bộ.
Dialogue: 0,0:03:03.39,0:03:05.06,Default,,0,0,0,,Ba, sáu, chín.
Dialogue: 0,0:03:05.51,0:03:06.60,Default,,0,0,0,,Một gậy wedge.
Dialogue: 0,0:03:06.89,0:03:09.69,Default,,0,0,0,,Nói thế này là đã đủ\Nmột bộ cho Tonbo rồi đấy!
Dialogue: 0,0:03:10.31,0:03:11.98,Default,,0,0,0,,Đây sẽ là một bộ gậy tuyệt vời.
Dialogue: 0,0:03:12.56,0:03:14.98,Default,,0,0,0,,Đi đây. Bắt đầu với một cú bóng én!
Dialogue: 0,0:03:20.32,0:03:21.36,Default,,0,0,0,,Bóng ó cá!
Dialogue: 0,0:03:23.91,0:03:24.87,Default,,0,0,0,,Một cú slice nhẹ!
Dialogue: 0,0:03:26.16,0:03:27.04,Default,,0,0,0,,Hajime.
Dialogue: 0,0:03:27.79,0:03:29.71,Default,,0,0,0,,Chưa huấn luyện chút nào sao.
Dialogue: 0,0:03:30.16,0:03:31.12,Default,,0,0,0,,Tại sao vậy?
Dialogue: 0,0:03:32.17,0:03:33.71,Default,,0,0,0,,Không thể làm thế được.
Dialogue: 0,0:03:35.25,0:03:37.34,Default,,0,0,0,,Lo rằng nếu điều chỉnh dù chỉ một chút,
Dialogue: 0,0:03:37.71,0:03:40.51,Default,,0,0,0,,sẽ phải điều chỉnh lại\Nmọi mặt trong lối chơi.
Dialogue: 0,0:03:40.80,0:03:42.55,Default,,0,0,0,,Sợ rằng điều đó sẽ
Dialogue: 0,0:03:42.97,0:03:45.72,Default,,0,0,0,,làm xáo trộn hoàn toàn lối chơi của Tonbo.
Dialogue: 0,0:03:46.72,0:03:50.02,Default,,0,0,0,,Muốn con bé tiếp tục chơi\Nvới một tinh thần tự do.
Dialogue: 0,0:03:54.35,0:03:55.31,Default,,0,0,0,,Hajime.
Dialogue: 0,0:03:55.44,0:03:57.36,Default,,0,0,0,,Thật mừng vì đã giao phó cho cậu.
Dialogue: 0,0:03:59.65,0:04:00.61,Default,,0,0,0,,Tuy nhiên,
Dialogue: 0,0:04:00.69,0:04:04.28,Default,,0,0,0,,từ khi đến Kumamoto, ngày nào Tonbo\Ncũng đánh bóng từ trên thảm.
Dialogue: 0,0:04:04.95,0:04:07.03,Default,,0,0,0,,Điều đó bắt đầu bộc lộ trong cú swing rồi.
Dialogue: 0,0:04:08.12,0:04:09.37,Default,,0,0,0,,Thảm tập
Dialogue: 0,0:04:09.45,0:04:11.21,Default,,0,0,0,,thường bị mòn ở giữa,
Dialogue: 0,0:04:11.29,0:04:13.87,Default,,0,0,0,,khiến mép bên trái\Nnhô cao hơn một chút.
Dialogue: 0,0:04:14.83,0:04:16.21,Default,,0,0,0,,Đặt bóng ở đó
Dialogue: 0,0:04:16.34,0:04:18.71,Default,,0,0,0,,sẽ tạo ra một độ dốc\Nnhẹ cho chân trái.
Dialogue: 0,0:04:18.80,0:04:23.55,Default,,0,0,0,,Điều đó tạo ra một khoảng trống nhỏ\Ngiữa mặt đất và quả bóng.
Dialogue: 0,0:04:23.63,0:04:26.80,Default,,0,0,0,,Chính điều này khiến cú swing của Tonbo bị nới lỏng.
Dialogue: 0,0:04:27.60,0:04:31.52,Default,,0,0,0,,Do độ nghiêng của thảm, mắt phải\Nthấp hơn khoảng nửa chiều rộng quả bóng
Dialogue: 0,0:04:31.68,0:04:33.64,Default,,0,0,0,,và sống mũi\Nnghiêng sang bên phải.
Dialogue: 0,0:04:34.85,0:04:35.69,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:04:38.61,0:04:39.57,Default,,0,0,0,,Đánh ở đây đi.
Dialogue: 0,0:04:39.86,0:04:40.82,Default,,0,0,0,,Vâng.
Dialogue: 0,0:04:46.24,0:04:49.74,Default,,0,0,0,,{\i1}Đã điều chỉnh tầm mắt{\i0}\N{\i1}theo độ nghiêng của mặt cỏ. {\i0}
Dialogue: 0,0:04:50.04,0:04:53.71,Default,,0,0,0,,{\i1}Bản năng tự điều chỉnh{\i0}\N{\i1}tư thế để phù hợp với địa hình.{\i0}
Dialogue: 0,0:04:54.58,0:04:56.46,Default,,0,0,0,,{\i1}Đây là một trong những kỹ năng của Tonbo.{\i0}
Dialogue: 0,0:05:00.63,0:05:03.88,Default,,0,0,0,,{\i1}Đã thay đổi gì vậy? Thay đổi cái gì cơ?{\i0}
Dialogue: 0,0:05:04.26,0:05:06.26,Default,,0,0,0,,{\i1}Quỹ đạo đã thấp hơn một chút.{\i0}
Dialogue: 0,0:05:06.76,0:05:08.93,Default,,0,0,0,,Lần này cứ đặt bóng\Nở bất cứ đâu tùy thích đi.
Dialogue: 0,0:05:09.51,0:05:10.60,Default,,0,0,0,,Có mũ không?
Dialogue: 0,0:05:11.06,0:05:12.10,Default,,0,0,0,,Có một cái.
Dialogue: 0,0:05:13.64,0:05:15.06,Default,,0,0,0,,Hinoki đã tặng đấy.
Dialogue: 0,0:05:15.64,0:05:18.44,Default,,0,0,0,,Hãy đảm bảo hai đầu\Ncủa vành mũ song song với nhau.
Dialogue: 0,0:05:18.90,0:05:21.19,Default,,0,0,0,,Chỉ cần chắc chắn\Nđầu bên phải không thấp hơn.
Dialogue: 0,0:05:21.78,0:05:24.61,Default,,0,0,0,,Bên trái thấp hơn cũng không sao.
Dialogue: 0,0:05:25.03,0:05:25.86,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:05:33.62,0:05:34.96,Default,,0,0,0,,Được rồi. Đánh đi!
Dialogue: 0,0:05:43.51,0:05:44.67,Default,,0,0,0,,{\i1}Âm thanh đã thay đổi.{\i0}
Dialogue: 0,0:05:44.88,0:05:48.93,Default,,0,0,0,,{\i1}Igarashi đã quan sát con bé rất lâu.{\i0}\N{\i1}Nên biết chính xác cần điều chỉnh gì.{\i0}
Dialogue: 0,0:05:49.39,0:05:50.26,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:05:50.68,0:05:51.76,Default,,0,0,0,,Thử đánh chân trần xem.
Dialogue: 0,0:05:56.19,0:05:57.10,Default,,0,0,0,,Nhột quá.
Dialogue: 0,0:06:00.65,0:06:01.61,Default,,0,0,0,,{\i1}Biết ngay mà.{\i0}
Dialogue: 0,0:06:01.69,0:06:03.65,Default,,0,0,0,,{\i1}Đang nhấc ngón chân cái bên trái lên.{\i0}
Dialogue: 0,0:06:04.40,0:06:08.24,Default,,0,0,0,,{\i1}Ngón chân từng dùng để bám trụ{\i0}\N{\i1}trên sàn ướt của thuyền đánh cá.{\i0}
Dialogue: 0,0:06:09.32,0:06:10.24,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:06:10.32,0:06:13.79,Default,,0,0,0,,Còn nhớ cái dụng cụ từng dùng\Nđể đâm bạch tuộc và cá không?
Dialogue: 0,0:06:14.12,0:06:15.25,Default,,0,0,0,,Nhớ ạ.
Dialogue: 0,0:06:16.25,0:06:20.17,Default,,0,0,0,,Tưởng tượng đang dùng dụng cụ đó để ghim\Nngón chân xuống đất khi đánh bóng đi.
Dialogue: 0,0:06:20.54,0:06:21.92,Default,,0,0,0,,Nghe đau quá!
Dialogue: 0,0:06:22.25,0:06:23.67,Default,,0,0,0,,Chỉ là tưởng tượng thôi!
Dialogue: 0,0:06:24.00,0:06:25.55,Default,,0,0,0,,Đâu có dùng thật đâu.
Dialogue: 0,0:06:26.76,0:06:28.22,Default,,0,0,0,,Ý là phải đứng yên sao?
Dialogue: 0,0:06:28.55,0:06:29.38,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:06:29.55,0:06:30.76,Default,,0,0,0,,Trong một cú swing,
Dialogue: 0,0:06:30.89,0:06:34.64,Default,,0,0,0,,phải di chuyển một số bộ phận cơ thể\Nvà giữ những bộ phận khác hoàn toàn bất động.
Dialogue: 0,0:06:35.27,0:06:37.35,Default,,0,0,0,,Các ngón chân trái không được nhúc nhích.
Dialogue: 0,0:06:37.85,0:06:38.69,Default,,0,0,0,,Vâng.
Dialogue: 0,0:06:38.77,0:06:39.77,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:06:42.77,0:06:44.02,Default,,0,0,0,,{\i1}Đúng như thế này.{\i0}
Dialogue: 0,0:06:48.40,0:06:49.78,Default,,0,0,0,,{\i1}Âm thanh lại thay đổi rồi.{\i0}
Dialogue: 0,0:06:50.36,0:06:51.20,Default,,0,0,0,,Đúng rồi đấy.
Dialogue: 0,0:06:51.37,0:06:54.99,Default,,0,0,0,,Ngay cả khi đánh một cú fade,\Ncũng đừng quên để ý đến ngón chân.
Dialogue: 0,0:06:55.45,0:06:58.12,Default,,0,0,0,,Phải tập trung vào đôi chân,\Nchứ không chỉ ở phần hông.
Dialogue: 0,0:06:58.46,0:06:59.33,Default,,0,0,0,,Vâng!
Dialogue: 0,0:07:01.58,0:07:02.54,Default,,0,0,0,,Gì vậy?
Dialogue: 0,0:07:02.88,0:07:03.88,Default,,0,0,0,,Không có gì.
Dialogue: 0,0:07:04.09,0:07:05.55,Default,,0,0,0,,Chỉ là đang nghĩ,
Dialogue: 0,0:07:05.96,0:07:08.05,Default,,0,0,0,,ông mới nên là người dạy con bé.
Dialogue: 0,0:07:09.34,0:07:11.89,Default,,0,0,0,,Chỉ thực hiện vài điều chỉnh nhỏ thôi.
Dialogue: 0,0:07:12.47,0:07:15.76,Default,,0,0,0,,Nếu tạo quá nhiều áp lực\Nlên cơ thể để kiểm soát cú swing,
Dialogue: 0,0:07:15.89,0:07:18.14,Default,,0,0,0,,ngày mai sẽ thấy hậu quả ngay.
Dialogue: 0,0:07:18.60,0:07:19.60,Default,,0,0,0,,Ngày mai sao?
Dialogue: 0,0:07:19.73,0:07:23.27,Default,,0,0,0,,Tối nay nên hạ lưới xuống đi.
Dialogue: 0,0:07:23.98,0:07:26.40,Default,,0,0,0,,Sáng mai gió\Ncó thể sẽ thổi mạnh đấy.
Dialogue: 0,0:07:27.11,0:07:28.65,Default,,0,0,0,,Chuẩn bị nghỉ ngơi chưa?
Dialogue: 0,0:07:29.15,0:07:30.11,Default,,0,0,0,,Ừ.
Dialogue: 0,0:07:30.36,0:07:32.41,Default,,0,0,0,,Dự báo thời tiết đâu có nhắc đến chuyện đó.
Dialogue: 0,0:07:33.16,0:07:34.20,Default,,0,0,0,,Họ chỉ nhắc đến mưa thôi.
Dialogue: 0,0:07:34.49,0:07:35.33,Default,,0,0,0,,Không hề nói có gió.
Dialogue: 0,0:07:36.74,0:07:38.04,Default,,0,0,0,,Igaiga.
Dialogue: 0,0:07:38.87,0:07:40.71,Default,,0,0,0,,Càng ngày càng giống ông Gon rồi đấy!
Dialogue: 0,0:07:43.67,0:07:45.29,Default,,0,0,0,,Tối nay ở lại đây đi.
Dialogue: 0,0:07:46.75,0:07:48.26,Default,,0,0,0,,Không, không thể nào.
Dialogue: 0,0:07:48.80,0:07:51.22,Default,,0,0,0,,Thế thì ngại quá.
Dialogue: 0,0:07:51.47,0:07:55.93,Default,,0,0,0,,Vì những chuyện ngốc nghếch đã làm\Nkhi còn thi đấu cho câu lạc bộ,
Dialogue: 0,0:07:56.22,0:07:59.14,Default,,0,0,0,,danh tiếng của chồng\Nđã bị kéo xuống bùn.
Dialogue: 0,0:07:59.77,0:08:03.40,Default,,0,0,0,,Chà, không sao cả.\NChuyện qua rồi.
Dialogue: 0,0:08:03.60,0:08:04.48,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:08:05.15,0:08:06.82,Default,,0,0,0,,Ông cũng đang chăm sóc Tonbo,
Dialogue: 0,0:08:06.94,0:08:09.65,Default,,0,0,0,,không thể đòi hỏi gì thêm nữa.
Dialogue: 0,0:08:10.99,0:08:13.70,Default,,0,0,0,,Không thể nhờ\Nchăm sóc thêm cả bên này nữa đâu.
Dialogue: 0,0:08:13.99,0:08:16.78,Default,,0,0,0,,-Không thể đâu.\N-Đang thay đồ ngủ rồi kìa!
Dialogue: 0,0:08:23.46,0:08:27.38,Default,,0,0,0,,Ông Gon dạo này thế nào?\NVẫn chỉ uống ba ly thôi chứ?
Dialogue: 0,0:08:27.79,0:08:31.30,Default,,0,0,0,,Chuyện uống rượu thì không rõ, nhưng\Nông ấy vẫn rất khỏe.
Dialogue: 0,0:08:32.51,0:08:35.30,Default,,0,0,0,,Sắp đến mùa cá chuồn rồi.
Dialogue: 0,0:08:36.01,0:08:38.06,Default,,0,0,0,,Thời điểm bận rộn nhất trong năm.
Dialogue: 0,0:08:39.01,0:08:42.31,Default,,0,0,0,,Năm nay sẽ không thể giúp ông\Nphi lê cá được rồi.
Dialogue: 0,0:08:43.27,0:08:44.27,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:08:44.52,0:08:45.69,Default,,0,0,0,,Về ngày mai,
Dialogue: 0,0:08:46.27,0:08:48.82,Default,,0,0,0,,gió mạnh sẽ làm khô mặt cỏ.
Dialogue: 0,0:08:49.53,0:08:50.98,Default,,0,0,0,,-Đó là lý do--\N-Setsu-ba thế nào rồi?
Dialogue: 0,0:08:52.03,0:08:54.70,Default,,0,0,0,,Ước gì có thể giúp bà ấy ở nhà trọ.
Dialogue: 0,0:08:55.07,0:08:57.20,Default,,0,0,0,,Tự mình làm bữa tối chắc vất vả lắm.
Dialogue: 0,0:08:57.82,0:09:00.33,Default,,0,0,0,,Bà ấy vẫn luôn kiên trì như mọi khi.
Dialogue: 0,0:09:01.12,0:09:03.29,Default,,0,0,0,,Còn mộ của bố mẹ thì sao?
Dialogue: 0,0:09:03.54,0:09:05.58,Default,,0,0,0,,Ngày nào cũng có hoa tươi.
Dialogue: 0,0:09:06.54,0:09:08.38,Default,,0,0,0,,Thi thoảng cũng hay ghé qua.
Dialogue: 0,0:09:08.92,0:09:11.00,Default,,0,0,0,,Ra vậy. Cảm ơn nhé.
Dialogue: 0,0:09:13.01,0:09:15.30,Default,,0,0,0,,Tonbo trông vui quá nhỉ.
Dialogue: 0,0:09:15.93,0:09:18.47,Default,,0,0,0,,Dù sao thì Igarashi-san\Ncũng giống như một người cha vậy.
Dialogue: 0,0:09:20.68,0:09:23.64,Default,,0,0,0,,Thật sao? Wataru vẫn đang chơi golf à?
Dialogue: 0,0:09:23.93,0:09:26.02,Default,,0,0,0,,Bunpei chắc đang lo lắng lắm đây!
Dialogue: 0,0:09:26.69,0:09:29.23,Default,,0,0,0,,Bunpei cũng vẫn ổn.
Dialogue: 0,0:09:29.94,0:09:31.36,Default,,0,0,0,,Bunpei và Yoko,
Dialogue: 0,0:09:31.86,0:09:33.03,Default,,0,0,0,,họ có hòa thuận không?
Dialogue: 0,0:09:33.69,0:09:35.49,Default,,0,0,0,,Không biết cậu ấy có còn nghĩ đến cô ấy
Dialogue: 0,0:09:36.07,0:09:38.74,Default,,0,0,0,,khi ăn kem sau khi\Ntắm suối nước nóng không nhỉ?
Dialogue: 0,0:09:40.08,0:09:42.24,Default,,0,0,0,,Hả? Igaiga?
Dialogue: 0,0:09:47.46,0:09:48.67,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:09:48.88,0:09:51.04,Default,,0,0,0,,Cảm ơn vì đã đến.
Dialogue: 0,0:10:03.89,0:10:05.06,Default,,0,0,0,,Nikome!
Dialogue: 0,0:10:05.60,0:10:07.06,Default,,0,0,0,,Nana! Momoko!
Dialogue: 0,0:10:07.48,0:10:09.15,Default,,0,0,0,,Tuần này chúng ta cùng nhóm đấy!
Dialogue: 0,0:10:09.48,0:10:10.90,Default,,0,0,0,,Mong chờ quá đi.
Dialogue: 0,0:10:11.23,0:10:12.52,Default,,0,0,0,,Cũng vậy nè!
Dialogue: 0,0:10:12.98,0:10:14.15,Default,,0,0,0,,Nhân tiện,
Dialogue: 0,0:10:14.23,0:10:16.07,Default,,0,0,0,,cô bé đó sao rồi?
Dialogue: 0,0:10:16.49,0:10:18.91,Default,,0,0,0,,Ngày đầu tiên đứng ở vị trí số một,
Dialogue: 0,0:10:19.24,0:10:20.62,Default,,0,0,0,,nhưng ngày thứ hai lại tụt hạng.
Dialogue: 0,0:10:20.99,0:10:23.41,Default,,0,0,0,,Hình như đang đứng thứ tư\Nvới điểm even par.
Dialogue: 0,0:10:23.74,0:10:24.91,Default,,0,0,0,,Dù sao thì cũng chỉ có bảy thôi mà.
Dialogue: 0,0:10:25.45,0:10:26.41,Default,,0,0,0,,Bảy á?
Dialogue: 0,0:10:26.75,0:10:27.66,Default,,0,0,0,,Bảy cái gì cơ?
Dialogue: 0,0:10:29.29,0:10:30.25,Default,,0,0,0,,Bảy cây gậy!
Dialogue: 0,0:10:31.17,0:10:33.71,Default,,0,0,0,,Hả? Gì cơ?
Dialogue: 0,0:10:37.17,0:10:39.01,Default,,0,0,0,,Đã là ngày thi đấu cuối cùng.
Dialogue: 0,0:10:39.26,0:10:42.14,Default,,0,0,0,,Hinoki Otoha đang đạt thành tích\Nsáu under.
Dialogue: 0,0:10:42.43,0:10:45.14,Default,,0,0,0,,Tsubura Adaniya và Ema Kurisu\Nđều đạt năm under.
Dialogue: 0,0:10:45.35,0:10:47.43,Default,,0,0,0,,Họ là ba người duy nhất đạt điểm under par.
Dialogue: 0,0:10:47.77,0:10:52.27,Default,,0,0,0,,Tonbo Oi đang ở vị trí thứ tư,\Nkém năm gậy với điểm even par.
Dialogue: 0,0:10:53.02,0:10:56.11,Default,,0,0,0,,Có vẻ như một trong ba người\Nđứng đầu sẽ giành chiến thắng.
Dialogue: 0,0:10:56.53,0:10:58.95,Default,,0,0,0,,Mặc dù Tonbo Oi cùng\Nnửa bộ gậy của mình
Dialogue: 0,0:10:59.07,0:11:01.70,Default,,0,0,0,,giành chiến thắng vào phút chót
Dialogue: 0,0:11:01.95,0:11:03.74,Default,,0,0,0,,sẽ tạo nên một câu chuyện hay hơn.
Dialogue: 0,0:11:07.20,0:11:09.29,Default,,0,0,0,,Hôm nay gió to thật đấy!
Dialogue: 0,0:11:09.54,0:11:10.62,Default,,0,0,0,,Im đi!
Dialogue: 0,0:11:12.96,0:11:15.46,Default,,0,0,0,,Dự báo thời tiết sai bét rồi.
Dialogue: 0,0:11:15.92,0:11:18.76,Default,,0,0,0,,Đúng là giống hệt ông Gon mà!
Dialogue: 0,0:11:21.30,0:11:22.22,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:11:25.39,0:11:29.14,Default,,0,0,0,,Hôm nay Tonbo cư xử lạ quá.\NBiết ngay là có chuyện gì mà.
Dialogue: 0,0:11:32.81,0:11:33.69,Default,,0,0,0,,Chuyện gì vậy?
Dialogue: 0,0:11:34.36,0:11:35.27,Default,,0,0,0,,Không có gì.
Dialogue: 0,0:11:38.74,0:11:41.24,Default,,0,0,0,,Xin lỗi, cho xin tờ vị trí lỗ golf hôm nay được không ạ?
Dialogue: 0,0:11:42.78,0:11:45.41,Default,,0,0,0,,{\i1}Họ đã để dành những lỗ khó nhất{\i0}\N{\i1}cho ngày cuối cùng.{\i0}
Dialogue: 0,0:11:46.37,0:11:49.45,Default,,0,0,0,,{\i1}Có rất nhiều lỗ{\i0}\N{\i1}được đặt gần hố cát.{\i0}
Dialogue: 0,0:11:53.92,0:11:56.67,Default,,0,0,0,,{\i1}Ema đang đánh bóng khá cao.{\i0}
Dialogue: 0,0:11:57.17,0:12:03.34,Default,,0,0,0,,{\i1}Minh chứng cho độ xoáy cực khủng. Có thể{\i0}\N{\i1}làm quả bóng dừng lại tốt hơn bất kỳ ai.{\i0}
Dialogue: 0,0:12:04.26,0:12:07.39,Default,,0,0,0,,{\i1}Sẽ có cơ hội tốt nhất{\i0}\N{\i1}với các vị trí lỗ hôm nay.{\i0}
Dialogue: 0,0:12:09.81,0:12:11.77,Default,,0,0,0,,{\i1}Cuối cùng cũng có cơ hội chiến thắng.{\i0}
Dialogue: 0,0:12:12.31,0:12:14.10,Default,,0,0,0,,{\i1}Phải biến nó thành hiện thực.{\i0}
Dialogue: 0,0:12:14.56,0:12:16.98,Default,,0,0,0,,{\i1}Đã chờ đợi mười năm cho việc này rồi.{\i0}
Dialogue: 0,0:12:17.73,0:12:19.19,Default,,0,0,0,,{\i1}Cảm thấy rất tự tin.{\i0}
Dialogue: 0,0:12:19.82,0:12:21.28,Default,,0,0,0,,{\i1}Chỉ lo lắng...{\i0}
Dialogue: 0,0:12:22.82,0:12:24.62,Default,,0,0,0,,{\i1}...về một điều.{\i0}
Dialogue: 0,0:12:27.74,0:12:31.58,Default,,0,0,0,,Có ngạc nhiên khi nghe tin\Nđứng nhất vào ngày đầu tiên không?
Dialogue: 0,0:12:32.08,0:12:34.37,Default,,0,0,0,,Thật ra cũng không\Nngạc nhiên đến thế.
Dialogue: 0,0:12:34.88,0:12:35.83,Default,,0,0,0,,Sao cũng được.
Dialogue: 0,0:12:36.13,0:12:37.67,Default,,0,0,0,,Chỉ thấy vui hơn bất cứ điều gì.
Dialogue: 0,0:12:38.00,0:12:38.92,Default,,0,0,0,,Rất vui.
Dialogue: 0,0:12:40.55,0:12:41.84,Default,,0,0,0,,Đâu chỉ có vậy.
Dialogue: 0,0:12:42.47,0:12:44.64,Default,,0,0,0,,Mọi người trên đảo đều mỉm cười.
Dialogue: 0,0:12:45.39,0:12:48.85,Default,,0,0,0,,Mọi người trên đảo đều đang cổ vũ đấy.
Dialogue: 0,0:12:49.64,0:12:50.56,Default,,0,0,0,,Cứ như thể
Dialogue: 0,0:12:51.14,0:12:54.44,Default,,0,0,0,,đã trở thành niềm tự hào\Ncủa cả hòn đảo vậy.
Dialogue: 0,0:12:54.90,0:12:56.94,Default,,0,0,0,,Đúng là một cô gái của hòn đảo mà, Tonbo.
Dialogue: 0,0:13:01.24,0:13:04.66,Default,,0,0,0,,Mọi người đều vui vẻ. Đã làm họ mỉm cười.
Dialogue: 0,0:13:05.66,0:13:07.45,Default,,0,0,0,,Đang làm điều này vì họ.
Dialogue: 0,0:13:08.16,0:13:09.24,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:13:12.25,0:13:14.37,Default,,0,0,0,,Hôm nay phải đạt được ba under.
Dialogue: 0,0:13:15.17,0:13:18.34,Default,,0,0,0,,Nếu có thể đưa điểm số\Nlên chín under thì sẽ không thể thua.
Dialogue: 0,0:13:18.67,0:13:20.25,Default,,0,0,0,,Sẽ lọt vào vòng loại trực tiếp.
Dialogue: 0,0:13:20.59,0:13:22.38,Default,,0,0,0,,Hiểu chưa? Ba gậy.
Dialogue: 0,0:13:22.92,0:13:24.51,Default,,0,0,0,,{\i1}Mục tiêu là sáu mươi chín.{\i0}
Dialogue: 0,0:13:25.59,0:13:28.35,Default,,0,0,0,,{\i1}Sẽ cố gắng đạt hai under{\i0}\N{\i1}trong nửa đầu trận.{\i0}
Dialogue: 0,0:13:33.89,0:13:34.94,Default,,0,0,0,,Thật đáng tiếc.
Dialogue: 0,0:13:35.44,0:13:37.35,Default,,0,0,0,,Hôm nay sẽ không thể thi đấu cùng rồi.
Dialogue: 0,0:13:37.65,0:13:39.98,Default,,0,0,0,,Hôm nay chúng ta thi đấu theo nhóm ba người.
Dialogue: 0,0:13:40.27,0:13:43.19,Default,,0,0,0,,Hôm nay ở nhóm cuối\Ncùng Tsubura đúng không, Hata?
Dialogue: 0,0:13:43.65,0:13:45.61,Default,,0,0,0,,Ai là caddie cho nhóm này vậy?
Dialogue: 0,0:13:47.28,0:13:48.28,Default,,0,0,0,,Đây!
Dialogue: 0,0:13:48.91,0:13:50.49,Default,,0,0,0,,Có cần lau bóng không?
Dialogue: 0,0:13:50.78,0:13:52.20,Default,,0,0,0,,Không cần đâu.
Dialogue: 0,0:13:52.66,0:13:54.62,Default,,0,0,0,,Đây là Nishi-san, caddie đang thực tập.
Dialogue: 0,0:13:54.91,0:13:56.83,Default,,0,0,0,,Đã trượt bài kiểm tra chuyên nghiệp bốn lần rồi.
Dialogue: 0,0:13:58.29,0:13:59.71,Default,,0,0,0,,Không cần nhắc đến chuyện đó đâu.
Dialogue: 0,0:14:00.17,0:14:01.34,Default,,0,0,0,,Là Tonbo Oi.
Dialogue: 0,0:14:01.92,0:14:03.21,Default,,0,0,0,,Rất vui được gặp!
Dialogue: 0,0:14:03.46,0:14:04.46,Default,,0,0,0,,Ừ-ừm.
Dialogue: 0,0:14:04.92,0:14:06.43,Default,,0,0,0,,Rất vui được gặp.
Dialogue: 0,0:14:07.55,0:14:12.35,Default,,0,0,0,,{\i1}Đã nghe tin đồn rồi. Thật sự chỉ có{\i0}\N{\i1}bảy cây gậy thôi sao. Chơi thế nào được chứ?{\i0}
Dialogue: 0,0:14:13.39,0:14:16.06,Default,,0,0,0,,{\i1}Tại sao lại phải làm caddie cho nhóc này chứ?{\i0}
Dialogue: 0,0:14:16.60,0:14:19.98,Default,,0,0,0,,{\i1} Sao Nakase-san lại bảo làm việc này?{\i0}
Dialogue: 0,0:14:32.08,0:14:34.04,Default,,0,0,0,,Mặt mũi kiểu gì thế kia?
Dialogue: 0,0:14:34.33,0:14:35.66,Default,,0,0,0,,Xin lỗi nhé, Igaiga.
Dialogue: 0,0:14:36.08,0:14:37.79,Default,,0,0,0,,Đúng là giống hệt ông Gon mà.
Dialogue: 0,0:14:39.96,0:14:41.88,Default,,0,0,0,,Kasahara-san, hãy ghi điểm cho Okawa-san nhé.
Dialogue: 0,0:14:42.50,0:14:44.38,Default,,0,0,0,,Oi-san, hãy ghi điểm cho Kasahara-san nhé.
Dialogue: 0,0:14:45.01,0:14:47.34,Default,,0,0,0,,Okawa, ghi điểm cho Oi-san nhé.
Dialogue: 0,0:14:48.93,0:14:51.18,Default,,0,0,0,,{\i1}Có thể dẫn trước{\i0}\N{\i1}ba gậy trong cơn gió này không?{\i0}
Dialogue: 0,0:14:53.35,0:14:55.52,Default,,0,0,0,,{\i1}Còn một điều nữa{\i0}\N{\i1}đáng để lo lắng.{\i0}
Dialogue: 0,0:14:56.52,0:15:02.77,Default,,0,0,0,,{\i1}Những cú đánh có độ xoáy lớn và rất dễ{\i0}\N{\i1}bị gió tạt. Đó là cách duy nhất có thể đánh.{\i0}
Dialogue: 0,0:15:04.11,0:15:10.36,Default,,0,0,0,,{\i1}Đã quen chơi trong gió rồi. Cũng không{\i0}\N{\i1}bận tâm lắm. Nhưng không phải là người duy nhất.{\i0}
Dialogue: 0,0:15:10.86,0:15:13.08,Default,,0,0,0,,{\i1}Vẫn còn người khác{\i0}\N{\i1}cần phải dè chừng.{\i0}
Dialogue: 0,0:15:13.87,0:15:17.04,Default,,0,0,0,,Khu rừng đã chuyển sang màu trắng xóa rồi.
Dialogue: 0,0:15:17.91,0:15:19.08,Default,,0,0,0,,Màu trắng á?
Dialogue: 0,0:15:19.37,0:15:22.13,Default,,0,0,0,,Màu của những chiếc lá\Nkhi bị gió thổi tung lên.
Dialogue: 0,0:15:22.38,0:15:26.05,Default,,0,0,0,,Khi đọc hướng gió,\Nngười chơi golf phải chú ý đến những cái cây.
Dialogue: 0,0:15:27.01,0:15:28.63,Default,,0,0,0,,Những người chuyên nghiệp sẽ nhìn vào màu của lá.
Dialogue: 0,0:15:30.88,0:15:32.30,Default,,0,0,0,,Khi gió thổi mạnh thế này,
Dialogue: 0,0:15:32.76,0:15:36.47,Default,,0,0,0,,ngay cả Bunpei cũng có thể biết\Nnó đến từ hướng nào.
Dialogue: 0,0:15:37.39,0:15:40.73,Default,,0,0,0,,Đó là vì cậu ấy\Nrất giỏi đọc hướng gió!
Dialogue: 0,0:15:41.14,0:15:42.73,Default,,0,0,0,,Bunpei là ai vậy?
Dialogue: 0,0:15:43.02,0:15:44.19,Default,,0,0,0,,Vua của môn golf {\i1}goro{\i0}.
Dialogue: 0,0:15:44.73,0:15:45.86,Default,,0,0,0,,Golf {\i1}goro{\i0} á?
Dialogue: 0,0:15:46.57,0:15:48.82,Default,,0,0,0,,Có lẽ hôm nay cũng thử chơi golf {\i1}goro{\i0} xem sao.
Dialogue: 0,0:15:54.03,0:15:55.33,Default,,0,0,0,,Ra là họ làm vậy!
Dialogue: 0,0:15:55.66,0:15:57.08,Default,,0,0,0,,Ngầu quá đi!
Dialogue: 0,0:16:13.30,0:16:15.80,Default,,0,0,0,,Gió đã cuốn nó bay tít\Nvào khu rừng bên trái rồi.
Dialogue: 0,0:16:17.60,0:16:19.64,Default,,0,0,0,,Phải buộc chặt hơn một chút mới được.
Dialogue: 0,0:16:20.77,0:16:22.31,Default,,0,0,0,,Này! Đến lượt rồi kìa!
Dialogue: 0,0:16:23.81,0:16:25.40,Default,,0,0,0,,{\i1}Lỗ bắt đầu với một lùm cây ở bên phải.{\i0}
Dialogue: 0,0:16:25.61,0:16:28.78,Default,,0,0,0,,{\i1}Có lẽ sẽ phải nhắm{\i0}\N{\i1}vào lỗ liền kề,{\i0}
Dialogue: 0,0:16:29.61,0:16:31.20,Default,,0,0,0,,{\i1}nhưng nhắm quá xa về bên phải{\i0}
Dialogue: 0,0:16:32.11,0:16:33.20,Default,,0,0,0,,{\i1}thì đáng sợ lắm.{\i0}
Dialogue: 0,0:16:40.08,0:16:43.83,Default,,0,0,0,,{\i1}Ngay cả với một fairway bằng phẳng, đưa bóng{\i0}\N{\i1}đáp đúng chỗ cũng sẽ rất khó khăn.{\i0}
Dialogue: 0,0:16:46.84,0:16:49.13,Default,,0,0,0,,Dây thun sẽ đứt\Nnếu kéo mạnh quá đấy!
Dialogue: 0,0:16:49.71,0:16:51.88,Default,,0,0,0,,Cần cả kẹp tăm nữa.
Dialogue: 0,0:16:55.68,0:16:56.89,Default,,0,0,0,,Xong rồi!
Dialogue: 0,0:16:56.97,0:16:59.14,Default,,0,0,0,,Chưa xong đâu! Phải đánh bóng đi chứ!
Dialogue: 0,0:17:01.14,0:17:02.89,Default,,0,0,0,,Xin lỗi nhé, sẽ dùng cây này.
Dialogue: 0,0:17:04.10,0:17:05.31,Default,,0,0,0,,Gậy gỗ số năm sao?
Dialogue: 0,0:17:06.98,0:17:07.94,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:17:08.02,0:17:11.69,Default,,0,0,0,,Đừng bận tâm đến điểm số!\NRa đó và giành chiến thắng đi!
Dialogue: 0,0:17:12.99,0:17:14.07,Default,,0,0,0,,Cứ chơi theo cách của mình!
Dialogue: 0,0:17:14.40,0:17:17.32,Default,,0,0,0,,Cho mọi người thấy phong cách đặc biệt của Tonbo đi!
Dialogue: 0,0:17:18.24,0:17:19.12,Default,,0,0,0,,Vâng!
Dialogue: 0,0:17:22.54,0:17:25.08,Default,,0,0,0,,Cắm tee cao trong gió thế này sao?
Dialogue: 0,0:17:27.04,0:17:29.04,Default,,0,0,0,,Đang nhắm đi đâu vậy?
Dialogue: 0,0:17:30.92,0:17:32.84,Default,,0,0,0,,Tonbo định đánh một cú bóng én.
Dialogue: 0,0:17:33.42,0:17:35.13,Default,,0,0,0,,Nhưng sao lại dùng gậy gỗ số năm?
Dialogue: 0,0:17:35.84,0:17:39.56,Default,,0,0,0,,Gậy driver được thiết kế\Nđể tạo ra ít độ xoáy nhất có thể.
Dialogue: 0,0:17:40.18,0:17:43.52,Default,,0,0,0,,Không chỉ xoáy ngược, mà\Ntạo xoáy ngang cũng rất khó.
Dialogue: 0,0:17:43.93,0:17:45.64,Default,,0,0,0,,Rất khó để bẻ cong đường bóng.
Dialogue: 0,0:17:46.02,0:17:48.56,Default,,0,0,0,,Vì gậy gỗ số năm thường\Nđược đánh từ mặt đất,
Dialogue: 0,0:17:48.94,0:17:52.48,Default,,0,0,0,,nên nó được thiết kế để tạo xoáy ngược\Ngiúp đưa bóng lên cao.
Dialogue: 0,0:17:53.19,0:17:54.61,Default,,0,0,0,,Rất dễ để bẻ cong đường bóng.
Dialogue: 0,0:17:55.57,0:17:59.70,Default,,0,0,0,,Không phải nhắm tới cú bóng én đâu.\NĐang tìm cách cải thiện điểm số đấy.
Dialogue: 0,0:18:04.58,0:18:07.08,Default,,0,0,0,,Cái gì? Gió không cuốn nó đi kìa!
Dialogue: 0,0:18:07.46,0:18:09.88,Default,,0,0,0,,Lên nào! Bóng cá chuồn!
Dialogue: 0,0:18:11.88,0:18:12.88,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:18:13.80,0:18:18.89,Default,,0,0,0,,Quả bóng có độ xoáy cắt ngang mãnh liệt\Nxuyên thẳng qua gió mà không hề hấn gì.
Dialogue: 0,0:18:19.68,0:18:21.22,Default,,0,0,0,,Ôi không! Mũ lưỡi trai bay mất rồi!
Dialogue: 0,0:18:21.56,0:18:22.47,Default,,0,0,0,,Phải làm sao đây?
Dialogue: 0,0:18:22.68,0:18:25.85,Default,,0,0,0,,Chiếc mũ Hinoki đã tặng! Bay đi đâu rồi?
Dialogue: 0,0:18:25.93,0:18:28.15,Default,,0,0,0,,Độ tập trung thật đáng kinh ngạc.
Dialogue: 0,0:18:28.90,0:18:33.11,Default,,0,0,0,,{\i1}Ngay cả trong cơn gió này, vẫn có thể{\i0}\N{\i1}đưa bóng đi bất cứ hướng nào mình muốn{\i0}.
Dialogue: 0,0:18:33.65,0:18:34.99,Default,,0,0,0,,{\i1}Như cá gặp nước vậy.{\i0}
Dialogue: 0,0:18:35.44,0:18:36.74,Default,,0,0,0,,Này! Chúng ta phải đi tiếp thôi!
Dialogue: 0,0:18:37.07,0:18:38.74,Default,,0,0,0,,Lát nữa sẽ tìm cho!
Dialogue: 0,0:18:39.70,0:18:40.66,Default,,0,0,0,,Vâng.
Dialogue: 0,0:18:45.12,0:18:46.58,Default,,0,0,0,,Thật tuyệt vời.
Dialogue: 0,0:18:47.37,0:18:49.37,Default,,0,0,0,,{\i1}Làm sao có thể bẻ cong đường bóng được chứ?{\i0}
Dialogue: 0,0:18:49.46,0:18:52.75,Default,,0,0,0,,{\i1}Cú swing thay đổi{\i0}\N{\i1}sau mỗi lần đánh!{\i0}
Dialogue: 0,0:19:04.93,0:19:06.85,Default,,0,0,0,,{\i1}Cú này sẽ không dễ dàng đâu. {\i0}
Dialogue: 0,0:19:07.06,0:19:09.39,Default,,0,0,0,,{\i1}Nằm trên cát với lớp cỏ mỏng.{\i0}
Dialogue: 0,0:19:09.65,0:19:13.19,Default,,0,0,0,,{\i1}Thậm chí còn có một hố cát{\i0}\N{\i1}giữa quả bóng và lỗ.{\i0}
Dialogue: 0,0:19:13.52,0:19:15.11,Default,,0,0,0,,Cái gì?
Dialogue: 0,0:19:16.03,0:19:16.94,Default,,0,0,0,,Tư thế đó!
Dialogue: 0,0:19:20.82,0:19:22.62,Default,,0,0,0,,Đã tránh được bãi cát!
Dialogue: 0,0:19:27.00,0:19:27.83,Default,,0,0,0,,Cái gì?
Dialogue: 0,0:19:28.12,0:19:30.67,Default,,0,0,0,,Biết ngay là sẽ hiệu quả mà! Vui quá đi mất!
Dialogue: 0,0:19:31.12,0:19:32.17,Default,,0,0,0,,Biết ngay sao?
Dialogue: 0,0:19:32.38,0:19:33.67,Default,,0,0,0,,Ý là đã tự tin vào cú đánh đó à?
Dialogue: 0,0:19:34.13,0:19:35.59,Default,,0,0,0,,Không biết sợ là gì sao?
Dialogue: 0,0:19:35.80,0:19:36.63,Default,,0,0,0,,Sợ á?
Dialogue: 0,0:19:36.76,0:19:39.68,Default,,0,0,0,,Đó là một cú đánh đáng sợ đấy!\NNhỡ rơi vào hố cát thì sao?
Dialogue: 0,0:19:40.01,0:19:40.88,Default,,0,0,0,,Gì cơ?
Dialogue: 0,0:19:41.01,0:19:43.72,Default,,0,0,0,,Chỉ nghĩ sẽ rất ngầu nếu có thể đưa\Nnó bay qua hố cát thôi!
Dialogue: 0,0:19:44.89,0:19:45.81,Default,,0,0,0,,Ngầu á?
Dialogue: 0,0:19:46.52,0:19:49.06,Default,,0,0,0,,Đã tránh được một cú đánh hỏng\Nbằng tư thế đó đấy!
Dialogue: 0,0:19:49.64,0:19:51.31,Default,,0,0,0,,Cái gì? Nhưng làm thế nào?
Dialogue: 0,0:19:54.02,0:19:54.98,Default,,0,0,0,,Cũng không chắc nữa.
Dialogue: 0,0:20:53.37,0:20:54.71,Default,,0,0,0,,{\i1}Đó là nơi Tonbo vừa đánh.{\i0}
Dialogue: 0,0:20:55.88,0:20:57.46,Default,,0,0,0,,{\i1}Ngay cả trong cơn gió mạnh này,{\i0}
Dialogue: 0,0:20:57.67,0:21:01.01,Default,,0,0,0,,{\i1} vẫn đang nhắm những cú swing{\i0}\N{\i1}về phía lỗ số bảy bên trái.{\i0}
Dialogue: 0,0:21:02.09,0:21:06.72,Default,,0,0,0,,{\i1}Chắc chắn đã đánh cú cắt bóng đó{\i0}\N{\i1}để chống lại gió,{\i0}
Dialogue: 0,0:21:07.72,0:21:09.64,Default,,0,0,0,,{\i1}nhưng mình không định chống lại gió.{\i0}
Dialogue: 0,0:21:09.81,0:21:12.14,Default,,0,0,0,,{\i1} Sẽ tận dụng nó làm lợi thế.{\i0}
Dialogue: 0,0:21:12.35,0:21:14.90,Default,,0,0,0,,{\i1}Đó là cách đối phó với gió.{\i0}
Dialogue: 0,0:21:15.56,0:21:19.69,Default,,0,0,0,,{\i1}Chỉ cần đưa bóng{\i0}\N{\i1}vào khu vực rộng bên trái lỗ là được.{\i0}
Dialogue: 0,0:21:27.91,0:21:29.12,Default,,0,0,0,,Sẽ không tới đâu!
Dialogue: 0,0:21:32.96,0:21:33.79,Default,,0,0,0,,Xin lỗi nhé!
Dialogue: 0,0:21:35.79,0:21:38.34,Default,,0,0,0,,Này Tsubura! Tình hình sao rồi?
Dialogue: 0,0:21:38.79,0:21:41.59,Default,,0,0,0,,Trông thế nào hả? Bóng bay tít\Nsang tận bên này rồi!
Dialogue: 0,0:21:42.30,0:21:43.59,Default,,0,0,0,,Còn Tonbo thì sao?
Dialogue: 0,0:21:45.34,0:21:48.18,Default,,0,0,0,,Điểm số vẫn chưa thay đổi.
Dialogue: 0,0:21:53.93,0:21:55.44,Default,,0,0,0,,{\i1}Adaniya bị double bogey.{\i0}
Dialogue: 0,0:21:56.65,0:22:00.94,Default,,0,0,0,,{\i1}Đang kém ba gậy.{\i0}\N{\i1}Tsubura và Ema đang kém hai gậy.{\i0}
Dialogue: 0,0:22:01.61,0:22:04.28,Default,,0,0,0,,{\i1}Tất cả đều đang hòa ở mức ba under.{\i0}
Dialogue: 0,0:22:05.07,0:22:10.91,Default,,0,0,0,,{\i1}Cứ tưởng chỉ có ba người mới có{\i0}\N{\i1}cơ hội chiến thắng. Nhưng Tonbo đang đánh ngang chuẩn.{\i0}
Dialogue: 0,0:22:11.66,0:22:15.04,Default,,0,0,0,,{\i1}Đã tham gia vào cuộc đua{\i0}\N{\i1}giành chiến thắng rồi!{\i0}
Dialogue: 0,0:23:49.17,0:23:51.47,Default,,0,0,0,,Ngày thi đấu cuối cùng\Nđã bắt đầu!
Dialogue: 0,0:23:52.55,0:23:54.01,Default,,0,0,0,,Hả? Có chuyện gì vậy, Tonbo?
Dialogue: 0,0:23:54.26,0:23:56.22,Default,,0,0,0,,À thì, thấy đấy...
Dialogue: 0,0:23:56.81,0:23:58.18,Default,,0,0,0,,Trong tập tiếp theo của Tonbo!
Dialogue: 0,0:23:58.60,0:23:59.81,Default,,0,0,0,,{\i1}Nỗi phiền muộn của Hinoki{\i0}
Dialogue: 0,0:24:00.14,0:24:04.73,Default,,0,0,0,,Yaya đã bắt chọn giữa đồ Âu\Nhoặc đồ Hoa cho bữa tối đấy!
Dialogue: 0,0:24:04.94,0:24:06.78,Default,,0,0,0,,Vẫn chẳng thay đổi chút nào.