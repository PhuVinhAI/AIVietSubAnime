Dialogue: 0,0:00:08.25,0:00:09.51,Default,,0,0,0,,Ngon!
Dialogue: 0,0:00:09.63,0:00:13.68,Default,,0,0,0,,Chắc chắn biết nếu đánh bogey ở đây\Nlà xong đời.
Dialogue: 0,0:00:13.88,0:00:15.05,Default,,0,0,0,,Nhưng thay vào đó lại được birdie.
Dialogue: 0,0:00:18.14,0:00:21.89,Default,,0,0,0,,Giờ vẫn còn cơ hội đuổi kịp\Nđiểm âm 3 của Ema!
Dialogue: 0,0:00:22.06,0:00:23.19,Default,,0,0,0,,Đúng vậy!
Dialogue: 0,0:00:28.94,0:00:29.82,Default,,0,0,0,,Ema?
Dialogue: 0,0:00:29.90,0:00:32.99,Default,,0,0,0,,Không thể nào. Cú đánh thứ hai\Ntừ khoảng cách gần hố cát thế sao?
Dialogue: 0,0:00:33.40,0:00:36.87,Default,,0,0,0,,Tức là cú tee shot chỉ bay được\Nkhoảng 170 yard.
Dialogue: 0,0:00:38.58,0:00:40.62,Default,,0,0,0,,{\i1}Cú tee shot quá mỏng.{\i0}
Dialogue: 0,0:00:41.08,0:00:43.83,Default,,0,0,0,,{\i1}Chân trái gần như{\i0}\N{\i1}không chạm đất.{\i0}
Dialogue: 0,0:00:55.47,0:00:56.51,Default,,0,0,0,,Đánh trúng đất rồi.
Dialogue: 0,0:02:35.65,0:02:39.82,Default,,0,0,0,,Vẫn đang chơi hố thứ 16.\NCứ đợi ở đây đã.
Dialogue: 0,0:02:45.66,0:02:47.00,Default,,0,0,0,,Gậy này dài quá.
Dialogue: 0,0:02:47.91,0:02:49.62,Default,,0,0,0,,Cho xin gậy putter.
Dialogue: 0,0:02:58.17,0:02:59.59,Default,,0,0,0,,Ema.
Dialogue: 0,0:03:00.01,0:03:01.13,Default,,0,0,0,,Mắt cá chân trái.
Dialogue: 0,0:03:02.01,0:03:05.51,Default,,0,0,0,,{\i1}Đã cố tránh lê mắt cá chân{\i0}\N{\i1}để giấu cơn đau.{\i0}
Dialogue: 0,0:03:05.64,0:03:08.02,Default,,0,0,0,,{\i1}nhưng cuối cùng cũng đến giới hạn.{\i0}
Dialogue: 0,0:03:08.93,0:03:10.14,Default,,0,0,0,,Ema.
Dialogue: 0,0:03:10.52,0:03:11.90,Default,,0,0,0,,{\i1}Cũng thấy tội nghiệp thật.{\i0}
Dialogue: 0,0:03:11.98,0:03:14.48,Default,,0,0,0,,{\i1}Tuy nhiên, nỗi đau là vấn đề của Ema.{\i0}
Dialogue: 0,0:03:14.69,0:03:17.28,Default,,0,0,0,,{\i1}Còn vấn đề của bản thân\Nthì phải tự lo.{\i0}
Dialogue: 0,0:03:19.11,0:03:22.28,Default,,0,0,0,,{\i1}Nếu Ema bị bogey{\i0}\N{\i1}và ghi được birdie,{\i0}
Dialogue: 0,0:03:22.53,0:03:24.12,Default,,0,0,0,,{\i1}sẽ đồng hạng nhất.{\i0}
Dialogue: 0,0:03:24.87,0:03:26.91,Default,,0,0,0,,{\i1}Còn 100 yard đến mép trước.{\i0}
Dialogue: 0,0:03:27.41,0:03:29.04,Default,,0,0,0,,{\i1}126 yard đến cờ.{\i0}
Dialogue: 0,0:03:30.50,0:03:32.79,Default,,0,0,0,,{\i1}Gió thổi từ bên phải.{\i0}
Dialogue: 0,0:03:33.00,0:03:34.84,Default,,0,0,0,,{\i1}Cuối cùng cũng dịu bớt.{\i0}
Dialogue: 0,0:03:35.59,0:03:39.51,Default,,0,0,0,,{\i1}Green dốc xuống{\i0}\N{\i1}từ phía giữa bên phải.{\i0}
Dialogue: 0,0:03:40.01,0:03:43.84,Default,,0,0,0,,{\i1}Lỗ nằm cách gờ chạy dọc sườn dốc{\i0}\N{\i1}hai bước chân.{\i0}
Dialogue: 0,0:03:44.89,0:03:49.27,Default,,0,0,0,,{\i1}Để đến gần cờ, phải đưa bóng đáp{\i0}\N{\i1}ngay trước con dốc.{\i0}
Dialogue: 0,0:03:49.39,0:03:51.98,Default,,0,0,0,,{\i1}Nếu bóng bay không đủ xa,{\i0}
Dialogue: 0,0:03:52.14,0:03:54.65,Default,,0,0,0,,{\i1}sẽ dừng lại trước gờ dốc.{\i0}
Dialogue: 0,0:03:55.40,0:03:58.57,Default,,0,0,0,,{\i1}Nghĩa là sẽ phải{\i0}\N{\i1}thực hiện cú gạt bóng lên dốc.{\i0}
Dialogue: 0,0:04:01.32,0:04:02.65,Default,,0,0,0,,{\i1}Nhắm thẳng vào cờ thôi.{\i0}
Dialogue: 0,0:04:03.57,0:04:06.16,Default,,0,0,0,,{\i1}Sẽ đưa bóng bay thẳng{\i0}\N{\i1}đến chân cờ.{\i0}
Dialogue: 0,0:04:06.28,0:04:08.37,Default,,0,0,0,,{\i1}Cho dù có đánh lố đi nữa.{\i0}
Dialogue: 0,0:04:09.04,0:04:11.71,Default,,0,0,0,,{\i1}So với việc phải đối mặt{\i0}\N{\i1}với cú gạt xuống dốc,{\i0}
Dialogue: 0,0:04:11.83,0:04:15.63,Default,,0,0,0,,{\i1}cú gạt lên dốc sẽ có cơ hội{\i0}\N{\i1}vào lỗ trong một gậy cao hơn.{\i0}
Dialogue: 0,0:04:17.71,0:04:19.46,Default,,0,0,0,,{\i1}Cách cờ ba bước về bên phải!{\i0}
Dialogue: 0,0:04:21.22,0:04:23.63,Default,,0,0,0,,Tuyệt! Là thế đấy!\NKhá lắm, Tsubura!
Dialogue: 0,0:04:24.09,0:04:25.05,Default,,0,0,0,,{\i1}Lên nào!{\i0}
Dialogue: 0,0:04:29.72,0:04:31.93,Default,,0,0,0,,Cách bốn bước ở phía trong đấy!
Dialogue: 0,0:04:32.23,0:04:33.31,Default,,0,0,0,,Bốn bước?
Dialogue: 0,0:04:34.81,0:04:36.73,Default,,0,0,0,,{\i1}Sẽ phải gạt trong hai bước.{\i0}
Dialogue: 0,0:04:37.44,0:04:40.94,Default,,0,0,0,,{\i1}Không. Vẫn còn cơ hội{\i0}\N{\i1}cho cú gạt lên dốc.{\i0}
Dialogue: 0,0:04:41.57,0:04:44.03,Default,,0,0,0,,{\i1}Đang vẽ ra một đường bóng vô cùng tỉ mỉ.{\i0}
Dialogue: 0,0:04:44.11,0:04:47.07,Default,,0,0,0,,{\i1}Chưa từng thấy khả năng{\i0}\N{\i1}kiểm soát bóng nào như thế.{\i0}
Dialogue: 0,0:04:48.99,0:04:52.04,Default,,0,0,0,,{\i1}Sao có thể tạo ra những đường bóng như thế chứ?{\i0}
Dialogue: 0,0:04:54.58,0:04:56.21,Default,,0,0,0,,{\i1}111 yard đến cờ.{\i0}
Dialogue: 0,0:04:56.29,0:04:57.38,Default,,0,0,0,,{\i1}109 yard đến gờ.{\i0}
Dialogue: 0,0:04:58.13,0:05:00.88,Default,,0,0,0,,{\i1}Nếu tính cả độ xoáy,{\i0}
Dialogue: 0,0:05:01.67,0:05:03.63,Default,,0,0,0,,{\i1}sẽ cần đánh 105 yard.{\i0}
Dialogue: 0,0:05:04.55,0:05:05.84,Default,,0,0,0,,{\i1}Cú đánh tuyệt lắm, Hinoki!{\i0}
Dialogue: 0,0:05:06.97,0:05:09.81,Default,,0,0,0,,{\i1}Vượt qua... gờ dốc rồi!{\i0}
Dialogue: 0,0:05:11.85,0:05:13.64,Default,,0,0,0,,Cách cờ một bước ở phía trước!
Dialogue: 0,0:05:16.10,0:05:19.06,Default,,0,0,0,,Phía trước sao? Vậy là bóng không hề lăn.
Dialogue: 0,0:05:21.02,0:05:21.90,Default,,0,0,0,,Đây ạ.
Dialogue: 0,0:05:21.98,0:05:23.15,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:05:34.45,0:05:35.71,Default,,0,0,0,,{\i1}Vẫn còn xa quá.{\i0}
Dialogue: 0,0:05:43.26,0:05:44.26,Default,,0,0,0,,Ema.
Dialogue: 0,0:05:44.51,0:05:45.59,Default,,0,0,0,,Ây da.
Dialogue: 0,0:05:46.26,0:05:48.43,Default,,0,0,0,,{\i1}Áp lực lên mắt cá chân quá lớn.{\i0}
Dialogue: 0,0:05:48.51,0:05:51.01,Default,,0,0,0,,{\i1}Kể cả những cú đánh nhỏ{\i0}\N{\i1}dùng phần thân phải cũng đau.{\i0}
Dialogue: 0,0:05:52.47,0:05:54.14,Default,,0,0,0,,Cho xin gậy 52 độ.
Dialogue: 0,0:05:57.02,0:06:01.19,Default,,0,0,0,,{\i1}Sẽ đưa bóng lên green{\i0}\N{\i1}và để nó tự lăn nốt quãng đường còn lại.{\i0}
Dialogue: 0,0:06:01.77,0:06:04.65,Default,,0,0,0,,{\i1}Chỉ cần vượt qua{\i0}\N{\i1}độ cao của mép hố...{\i0}
Dialogue: 0,0:06:19.71,0:06:21.38,Default,,0,0,0,,Rốt cuộc lại là double-bogey.
Dialogue: 0,0:06:31.22,0:06:32.26,Default,,0,0,0,,Khoan đã.
Dialogue: 0,0:06:32.72,0:06:34.01,Default,,0,0,0,,Thế này nghĩa là...
Dialogue: 0,0:06:34.85,0:06:35.93,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:06:37.31,0:06:40.27,Default,,0,0,0,,Vậy là tất cả đều đang âm 1 sao?
Dialogue: 0,0:06:55.54,0:06:57.08,Default,,0,0,0,,Chỉ còn ba hố nữa!
Dialogue: 0,0:06:57.33,0:06:59.62,Default,,0,0,0,,Cả bốn người đang đồng hạng nhất!
Dialogue: 0,0:07:05.09,0:07:06.05,Default,,0,0,0,,Phải.
Dialogue: 0,0:07:07.42,0:07:08.59,Default,,0,0,0,,Làm được mà.
Dialogue: 0,0:07:09.30,0:07:10.76,Default,,0,0,0,,Có thể chiến thắng giải này!
Dialogue: 0,0:07:19.10,0:07:22.44,Default,,0,0,0,,Có vẻ nhóm của Tonbo\Nđã vào khu vực phát bóng.
Dialogue: 0,0:07:23.19,0:07:25.73,Default,,0,0,0,,{\i1}Đang nghĩ gì vậy, Tonbo?{\i0}
Dialogue: 0,0:07:25.86,0:07:28.44,Default,,0,0,0,,{\i1}Rốt cuộc thì phản ứng hóa học có xảy ra không?{\i0}
Dialogue: 0,0:07:37.24,0:07:39.25,Default,,0,0,0,,Sao không tự đi mà hỏi?
Dialogue: 0,0:07:39.62,0:07:41.17,Default,,0,0,0,,Thôi nào.\NĐi hỏi đi!
Dialogue: 0,0:07:42.50,0:07:43.54,Default,,0,0,0,,Xin lỗi.
Dialogue: 0,0:07:44.13,0:07:46.84,Default,,0,0,0,,Cho mượn ống nhòm\Nmột chút được không ạ?
Dialogue: 0,0:07:47.63,0:07:49.42,Default,,0,0,0,,Ồ, được chứ!
Dialogue: 0,0:07:50.51,0:07:51.93,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:07:56.05,0:07:57.18,Default,,0,0,0,,Thấy gì thế?
Dialogue: 0,0:07:59.52,0:08:00.98,Default,,0,0,0,,Trông tự tin lắm.
Dialogue: 0,0:08:03.52,0:08:07.86,Default,,0,0,0,,Ema bị rớt một gậy ở hố thứ 17\Nvà giờ đang ở điểm par.
Dialogue: 0,0:08:08.03,0:08:12.78,Default,,0,0,0,,Tonbo, Tsubura và Hinoki\Nđang đồng hạng nhất với điểm âm 1.
Dialogue: 0,0:08:12.91,0:08:14.07,Default,,0,0,0,,Ema bị rớt gậy sao?
Dialogue: 0,0:08:14.28,0:08:17.95,Default,,0,0,0,,Dù đã dẫn trước ở vị trí thứ nhất\Nvới cách biệt hai gậy ư?
Dialogue: 0,0:08:18.16,0:08:20.91,Default,,0,0,0,,Có vẻ mắt cá chân trái\Nđang gặp vấn đề.
Dialogue: 0,0:08:21.79,0:08:23.71,Default,,0,0,0,,Tonbo đang ở vị trí có thể chiến thắng.
Dialogue: 0,0:08:24.29,0:08:25.13,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:08:25.92,0:08:31.38,Default,,0,0,0,,{\i1}Nếu Tonbo có thể hoàn thành hố thứ 18{\i0}\N{\i1}với điểm dưới par trong nhóm,{\i0}
Dialogue: 0,0:08:31.76,0:08:36.14,Default,,0,0,0,,{\i1}nhóm phía sau sẽ thua{\i0}\N{\i1}nếu không hoàn thành với điểm par.{\i0}
Dialogue: 0,0:08:36.76,0:08:40.06,Default,,0,0,0,,{\i1}Điều đó tạo ra nghĩa vụ phải đạt điểm par.{\i0}
Dialogue: 0,0:08:40.47,0:08:44.19,Default,,0,0,0,,{\i1}Nghĩa vụ có thể trói buộc và{\i0}\N{\i1}tạo ra áp lực rất lớn.{\i0}
Dialogue: 0,0:08:48.27,0:08:49.69,Default,,0,0,0,,{\i1}Tay đang đổ mồ hôi.{\i0}
Dialogue: 0,0:08:49.90,0:08:51.78,Default,,0,0,0,,{\i1}Chuyện này chưa từng xảy ra.{\i0}
Dialogue: 0,0:08:53.07,0:08:55.11,Default,,0,0,0,,{\i1}Đó là lý do mọi người đều đeo găng tay sao?{\i0}
Dialogue: 0,0:09:01.95,0:09:03.50,Default,,0,0,0,,Nhóm cuối cùng đến rồi.
Dialogue: 0,0:09:12.59,0:09:14.42,Default,,0,0,0,,Ema...
Dialogue: 0,0:09:31.73,0:09:33.03,Default,,0,0,0,,Mắt cá chân trái của Ema.
Dialogue: 0,0:09:33.74,0:09:35.40,Default,,0,0,0,,Trông không ổn chút nào.
Dialogue: 0,0:09:37.16,0:09:39.20,Default,,0,0,0,,{\i1}Sau khi hòa nhau ở hố thứ 15,{\i0}
Dialogue: 0,0:09:39.28,0:09:41.95,Default,,0,0,0,,{\i1}Ema đã tụt lại một gậy.{\i0}
Dialogue: 0,0:09:42.79,0:09:45.75,Default,,0,0,0,,{\i1}Với tình trạng này,{\i0}\N{\i1}ngạc nhiên là chỉ mới một gậy đấy.{\i0}
Dialogue: 0,0:09:46.37,0:09:47.88,Default,,0,0,0,,Fairway đã trống.
Dialogue: 0,0:09:49.13,0:09:50.63,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:09:52.88,0:09:55.05,Default,,0,0,0,,Tonbo đã vào tư thế tee shot.
Dialogue: 0,0:09:55.17,0:09:56.55,Default,,0,0,0,,Đừng lo.
Dialogue: 0,0:09:58.09,0:10:01.05,Default,,0,0,0,,{\i1}Thật thảm hại. Thậm chí không dám nhìn.{\i0}
Dialogue: 0,0:10:02.35,0:10:06.60,Default,,0,0,0,,{\i1}Tonbo. Cú tee shot rất quan trọng.{\i0}\N{\i1}Làm được mà.{\i0}
Dialogue: 0,0:10:06.94,0:10:09.35,Default,,0,0,0,,{\i1}Cho nhóm cuối thấy bản lĩnh đi nào!{\i0}
Dialogue: 0,0:10:11.61,0:10:13.53,Default,,0,0,0,,Bóng đang bay về phía hố cát bên trái
Dialogue: 0,0:10:13.61,0:10:14.82,Default,,0,0,0,,và đang xoáy phải!
Dialogue: 0,0:10:14.90,0:10:15.82,Default,,0,0,0,,Ngon!
Dialogue: 0,0:10:17.91,0:10:19.03,Default,,0,0,0,,Bay vào lùm cây rồi!
Dialogue: 0,0:10:21.58,0:10:23.83,Default,,0,0,0,,{\i1}Không thể tin là lại đánh như vậy.{\i0}
Dialogue: 0,0:10:24.16,0:10:25.79,Default,,0,0,0,,{\i1}Vẫn còn quá sớm để nói.{\i0}
Dialogue: 0,0:10:26.58,0:10:29.00,Default,,0,0,0,,{\i1}Cuối cùng Tonbo cũng cảm thấy áp lực.{\i0}
Dialogue: 0,0:10:30.63,0:10:33.05,Default,,0,0,0,,{\i1}Cơ thể tê cứng khi đánh.{\i0}
Dialogue: 0,0:10:33.21,0:10:36.63,Default,,0,0,0,,{\i1}Thậm chí còn không tập trung vào cú đánh.{\i0}
Dialogue: 0,0:10:36.72,0:10:39.55,Default,,0,0,0,,{\i1}Phải cố gắng đánh theo cách{\i0}\N{\i1}mọi khi.{\i0}
Dialogue: 0,0:10:40.09,0:10:41.76,Default,,0,0,0,,{\i1}Đó là lý do phải luôn luyện tập!{\i0}
Dialogue: 0,0:10:43.39,0:10:47.94,Default,,0,0,0,,Bóng xuyên qua lùm cây và rơi\Ngần fairway của hố thứ 5!
Dialogue: 0,0:10:48.69,0:10:51.40,Default,,0,0,0,,Để đưa bóng về lại\Nfairway của hố 18...
Dialogue: 0,0:10:51.86,0:10:54.61,Default,,0,0,0,,...sẽ phải đi thẳng\Nxuyên qua lùm cây.
Dialogue: 0,0:10:54.78,0:10:58.28,Default,,0,0,0,,Toàn là cây cối.\NĐưa bóng về không dễ đâu.
Dialogue: 0,0:10:58.70,0:10:59.57,Default,,0,0,0,,{\i1}Muốn chiến thắng.{\i0}
Dialogue: 0,0:10:59.70,0:11:01.03,Default,,0,0,0,,Chỗ rộng nhất.
Dialogue: 0,0:11:01.95,0:11:03.95,Default,,0,0,0,,Sẽ phải nhắm vào đó.
Dialogue: 0,0:11:05.20,0:11:06.79,Default,,0,0,0,,Tất cả phụ thuộc vào cú đánh thứ ba.
Dialogue: 0,0:11:06.87,0:11:10.17,Default,,0,0,0,,Nếu đạt điểm par thì vẫn\Ncòn cơ hội chiến thắng.
Dialogue: 0,0:11:10.29,0:11:14.34,Default,,0,0,0,,Vị trí cờ hôm nay không dễ\Nđể bất cứ ai ghi điểm birdie.
Dialogue: 0,0:11:15.21,0:11:20.09,Default,,0,0,0,,{\i1}Muốn chiến thắng. Muốn nói với mọi người trên{\i0}\N{\i1}đảo là đã thắng.{\i0}
Dialogue: 0,0:11:20.76,0:11:22.85,Default,,0,0,0,,{\i1}Muốn nói điều đó với một nụ cười.{\i0}
Dialogue: 0,0:11:29.31,0:11:30.98,Default,,0,0,0,,{\i1}Muốn chiến thắng!{\i0}
Dialogue: 0,0:11:41.15,0:11:45.33,Default,,0,0,0,,Có vẻ cú tee shot của Tonbo\Nđã rơi sang hố bên cạnh.
Dialogue: 0,0:11:45.53,0:11:46.45,Default,,0,0,0,,Hả?
Dialogue: 0,0:11:46.91,0:11:48.70,Default,,0,0,0,,Tonbo đang ở hố thứ 5.
Dialogue: 0,0:11:52.54,0:11:53.54,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:11:54.63,0:11:58.34,Default,,0,0,0,,Nếu đánh xuyên qua và trở lại\Nfairway của hố 18,
Dialogue: 0,0:11:58.55,0:12:01.26,Default,,0,0,0,,sẽ bị lùi lại một chút.
Dialogue: 0,0:12:02.18,0:12:05.97,Default,,0,0,0,,Cú đánh thứ ba sẽ còn khoảng\N150-160 yard.
Dialogue: 0,0:12:07.26,0:12:08.60,Default,,0,0,0,,Igaiga.
Dialogue: 0,0:12:09.06,0:12:10.06,Default,,0,0,0,,Cờ kia đúng không?
Dialogue: 0,0:12:10.14,0:12:10.98,Default,,0,0,0,,Ừ.
Dialogue: 0,0:12:11.35,0:12:13.10,Default,,0,0,0,,Đưa bóng đến đó trong ba gậy.
Dialogue: 0,0:12:13.31,0:12:17.44,Default,,0,0,0,,Sẽ phải trở lại\Nhố 18 trong một gậy.
Dialogue: 0,0:12:17.57,0:12:18.61,Default,,0,0,0,,Đánh hướng này được không?
Dialogue: 0,0:12:19.48,0:12:20.49,Default,,0,0,0,,Rất rộng mở.
Dialogue: 0,0:12:20.74,0:12:23.11,Default,,0,0,0,,Fairway của hố thứ 5 sao?
Dialogue: 0,0:12:23.57,0:12:25.74,Default,,0,0,0,,Ra vậy! Có thể sẽ hiệu quả đấy!
Dialogue: 0,0:12:26.45,0:12:28.83,Default,,0,0,0,,Sẽ dễ dàng nếu đánh từ hố thứ 5.
Dialogue: 0,0:12:28.95,0:12:31.75,Default,,0,0,0,,Chỉ cần lăn bóng được 50 yard.
Dialogue: 0,0:12:36.67,0:12:38.38,Default,,0,0,0,,Chờ đã! Khoan đã.
Dialogue: 0,0:12:39.21,0:12:43.55,Default,,0,0,0,,Bóng của Tonbo bay sang\Nhố bên cạnh và vẫn chưa đánh tiếp.
Dialogue: 0,0:12:44.84,0:12:46.05,Default,,0,0,0,,Hố khác á?
Dialogue: 0,0:12:46.51,0:12:49.68,Default,,0,0,0,,{\i1}Nghĩa là Tonbo có thể sẽ bị{\i0}\N{\i1}bogey hố này.{\i0}
Dialogue: 0,0:12:50.06,0:12:54.60,Default,,0,0,0,,{\i1}Ema đang bị tụt một gậy và{\i0}\N{\i1}không đủ sức để tiếp tục thi đấu.{\i0}
Dialogue: 0,0:12:59.57,0:13:02.44,Default,,0,0,0,,{\i1}Hinoki là người duy nhất cản đường.{\i0}
Dialogue: 0,0:13:03.11,0:13:06.41,Default,,0,0,0,,{\i1}Không nghĩ là Tsubura và Hinoki{\i0}\N{\i1}sẽ bị bogey đâu.{\i0}
Dialogue: 0,0:13:06.87,0:13:10.99,Default,,0,0,0,,{\i1}Chơi cùng mới thấy hai người đó{\i0}\N{\i1}giỏi hơn thế nhiều.{\i0}
Dialogue: 0,0:13:11.91,0:13:15.04,Default,,0,0,0,,{\i1}Nghĩa là phải ghi được birdie.{\i0}
Dialogue: 0,0:13:16.00,0:13:18.00,Default,,0,0,0,,{\i1}Bằng cái chân trái này.{\i0}
Dialogue: 0,0:13:19.13,0:13:21.21,Default,,0,0,0,,Đang có gió ngược.
Dialogue: 0,0:13:23.13,0:13:27.22,Default,,0,0,0,,{\i1}Sao lại bận tâm về gió chứ?{\i0}\N{\i1}Chỉ cần đánh thẳng là được mà.{\i0}
Dialogue: 0,0:13:28.64,0:13:30.72,Default,,0,0,0,,{\i1}Cơ thể đã thả lỏng trở lại.{\i0}
Dialogue: 0,0:13:31.68,0:13:34.64,Default,,0,0,0,,{\i1}Không muốn lặp lại{\i0}\N{\i1}sai lầm đó nữa.{\i0}
Dialogue: 0,0:13:35.56,0:13:38.69,Default,,0,0,0,,{\i1}Phải dùng tay phải{\i0}\N{\i1}giống như đang quăng thòng lọng.{\i0}
Dialogue: 0,0:13:38.86,0:13:42.36,Default,,0,0,0,,{\i1}Nếu di chuyển các ngón tay thật nhanh{\i0}\N{\i1}rồi dừng lại,{\i0}
Dialogue: 0,0:13:43.32,0:13:45.61,Default,,0,0,0,,{\i1}có thể đóng mặt gậy lại.{\i0}
Dialogue: 0,0:13:48.28,0:13:49.20,Default,,0,0,0,,Đang làm gì vậy?
Dialogue: 0,0:13:55.91,0:13:58.25,Default,,0,0,0,,Tonbo đang nhắm sang phải.
Dialogue: 0,0:13:58.92,0:14:01.42,Default,,0,0,0,,Sẽ đưa bóng lên fairway của hố thứ 5.
Dialogue: 0,0:14:08.47,0:14:12.31,Default,,0,0,0,,{\i1}Chỉ cần lăn bóng thôi mà.{\i0}\N{\i1}Sao thế đứng lại rộng vậy?{\i0}
Dialogue: 0,0:14:13.27,0:14:14.18,Default,,0,0,0,,{\i1}Thêm một chút nữa.{\i0}
Dialogue: 0,0:14:20.48,0:14:21.32,Default,,0,0,0,,{\i1}Lên nào.{\i0}
Dialogue: 0,0:14:22.11,0:14:23.94,Default,,0,0,0,,{\i1}Đúng như Igaiga đã dặn.{\i0}
Dialogue: 0,0:14:29.62,0:14:31.74,Default,,0,0,0,,{\i1}Tonbo, biết định làm gì rồi.{\i0}
Dialogue: 0,0:14:32.62,0:14:35.91,Default,,0,0,0,,{\i1}Không hề nhắm vào fairway chút nào!{\i0}
Dialogue: 0,0:14:39.00,0:14:40.38,Default,,0,0,0,,Đúng như đã dặn.
Dialogue: 0,0:14:40.50,0:14:42.46,Default,,0,0,0,,Điểm số không quan trọng!
Dialogue: 0,0:14:50.47,0:14:53.85,Default,,0,0,0,,Dốc hết sức đi! Giành chiến thắng nào!
Dialogue: 0,0:14:55.18,0:14:57.81,Default,,0,0,0,,Nhắm thẳng vào green luôn!
Dialogue: 0,0:14:57.94,0:14:59.10,Default,,0,0,0,,Xoáy nữa đi!
Dialogue: 0,0:14:59.81,0:15:01.15,Default,,0,0,0,,Phải xoáy thêm nữa!
Dialogue: 0,0:15:06.19,0:15:08.03,Default,,0,0,0,,Lên nào! Qua đây!
Dialogue: 0,0:15:08.74,0:15:11.74,Default,,0,0,0,,Qua đây! Qua đây nào!
Dialogue: 0,0:15:18.58,0:15:19.87,Default,,0,0,0,,Lên được chưa?
Dialogue: 0,0:15:20.83,0:15:22.25,Default,,0,0,0,,Có lên được không?
Dialogue: 0,0:15:22.92,0:15:27.63,Default,,0,0,0,,-Lên rồi! Tuyệt vời!\N-Thật không thể tin nổi!
Dialogue: 0,0:15:29.34,0:15:30.97,Default,,0,0,0,,Đánh được cú thòng lọng rồi!
Dialogue: 0,0:15:31.09,0:15:32.26,Default,,0,0,0,,Cú thòng lọng sao?
Dialogue: 0,0:15:36.14,0:15:37.77,Default,,0,0,0,,Tonbo đã lên green.
Dialogue: 0,0:15:38.23,0:15:40.77,Default,,0,0,0,,{\i1}Khán giả đang hò reo.{\i0}\N{\i1}Gần đến mức nào vậy?{\i0}
Dialogue: 0,0:15:41.02,0:15:43.52,Default,,0,0,0,,{\i1}Nếu đã lên green,{\i0}\N{\i1}chắc chắn sẽ được par.{\i0}
Dialogue: 0,0:15:44.02,0:15:47.69,Default,,0,0,0,,{\i1}Điểm chiến thắng giờ sẽ không{\i0}\N{\i1}thấp hơn âm 1 đâu.{\i0}
Dialogue: 0,0:15:48.28,0:15:50.36,Default,,0,0,0,,{\i1}Phải đạt ít nhất là điểm par.{\i0}
Dialogue: 0,0:15:51.28,0:15:53.07,Default,,0,0,0,,{\i1}Phải lấy được điểm par.{\i0}
Dialogue: 0,0:15:53.37,0:15:54.28,Default,,0,0,0,,Igarashi-san!
Dialogue: 0,0:15:54.62,0:15:56.03,Default,,0,0,0,,Cú đánh tuyệt quá!
Dialogue: 0,0:15:56.62,0:15:57.54,Default,,0,0,0,,Giỏi lắm.
Dialogue: 0,0:15:57.74,0:15:59.41,Default,,0,0,0,,Đánh hỏng cú tee shot,
Dialogue: 0,0:15:59.58,0:16:02.42,Default,,0,0,0,,nhưng lại cảm thấy có nghĩa vụ phải thành công.
Dialogue: 0,0:16:03.25,0:16:04.59,Default,,0,0,0,,Không thể tin được.
Dialogue: 0,0:16:05.50,0:16:06.38,Default,,0,0,0,,Con bé đó.
Dialogue: 0,0:16:06.50,0:16:07.67,Default,,0,0,0,,Dùng bộ gậy một nửa sao?
Dialogue: 0,0:16:08.26,0:16:11.18,Default,,0,0,0,,Và vẫn đang trên đà\Nchiến thắng giải này ư?
Dialogue: 0,0:16:11.26,0:16:12.30,Default,,0,0,0,,Chà.
Dialogue: 0,0:16:12.51,0:16:13.51,Default,,0,0,0,,Phải.
Dialogue: 0,0:16:13.59,0:16:14.76,Default,,0,0,0,,Lên green rồi!
Dialogue: 0,0:16:20.02,0:16:23.10,Default,,0,0,0,,{\i1}Ở trên đảo đâu có được{\i0}\N{\i1}ai vỗ tay tán thưởng.{\i0}
Dialogue: 0,0:16:23.31,0:16:25.48,Default,,0,0,0,,{\i1}Đặc biệt là không như thế này.{\i0}
Dialogue: 0,0:16:25.61,0:16:30.24,Default,,0,0,0,,{\i1}Chưa từng có đám đông nào{\i0}\N{\i1}vỗ tay tán thưởng như vậy cả.{\i0}
Dialogue: 0,0:16:34.99,0:16:35.99,Default,,0,0,0,,{\i1}Được rồi.{\i0}
Dialogue: 0,0:16:36.41,0:16:37.95,Default,,0,0,0,,{\i1}Đã lên fairway.{\i0}
Dialogue: 0,0:16:38.37,0:16:41.00,Default,,0,0,0,,{\i1}Cứ thế này thì có thể ghi được birdie.{\i0}
Dialogue: 0,0:17:02.14,0:17:03.10,Default,,0,0,0,,Ema!
Dialogue: 0,0:17:03.19,0:17:04.14,Default,,0,0,0,,Không sao chứ?
Dialogue: 0,0:17:06.02,0:17:07.06,Default,,0,0,0,,Xin lỗi!
Dialogue: 0,0:17:07.15,0:17:08.98,Default,,0,0,0,,Làm ơn! Xin hãy tha lỗi!
Dialogue: 0,0:17:13.78,0:17:14.61,Default,,0,0,0,,Thật sự--
Dialogue: 0,0:17:14.70,0:17:15.82,Default,,0,0,0,,Đừng bận tâm.
Dialogue: 0,0:17:16.74,0:17:18.41,Default,,0,0,0,,Không phải lỗi của ai đâu.
Dialogue: 0,0:17:18.66,0:17:20.62,Default,,0,0,0,,Chỉ là trượt chân khi vung gậy thôi.
Dialogue: 0,0:17:22.33,0:17:25.21,Default,,0,0,0,,{\i1}Chỉ là không đủ tập trung.{\i0}
Dialogue: 0,0:17:26.38,0:17:29.13,Default,,0,0,0,,{\i1}Sao có thể trách cứ{\i0}\N{\i1}trong tình trạng đó chứ?{\i0}
Dialogue: 0,0:17:33.17,0:17:36.76,Default,,0,0,0,,{\i1}Đã tập luyện suốt mười năm{\i0}\N{\i1}để trở lại vị trí hiện tại.{\i0}
Dialogue: 0,0:17:37.05,0:17:40.06,Default,,0,0,0,,{\i1}Và giờ lại phải chịu đau đớn lần nữa.{\i0}
Dialogue: 0,0:17:40.35,0:17:42.89,Default,,0,0,0,,{\i1}Đang chiến đấu cùng với nỗi đau.{\i0}
Dialogue: 0,0:17:44.56,0:17:48.27,Default,,0,0,0,,{\i1}Không muốn thua,{\i0}\N{\i1}nhưng cũng không muốn Ema thua.{\i0}
Dialogue: 0,0:17:48.44,0:17:50.11,Default,,0,0,0,,{\i1}Không phải vì một chấn thương.{\i0}
Dialogue: 0,0:17:53.57,0:17:56.78,Default,,0,0,0,,{\i1}Những người này là đối thủ.{\i0}
Dialogue: 0,0:17:59.91,0:18:04.25,Default,,0,0,0,,{\i1}Bản thân chẳng giống hai người đó chút nào.{\i0}\N{\i1}Không giống Tonbo và những người khác.{\i0}
Dialogue: 0,0:18:05.46,0:18:07.62,Default,,0,0,0,,{\i1}Hoàn toàn khác biệt.{\i0}
Dialogue: 0,0:18:09.96,0:18:11.50,Default,,0,0,0,,{\i1}Không phải là golfer.{\i0}
Dialogue: 0,0:18:12.13,0:18:14.72,Default,,0,0,0,,{\i1}Không phải là golfer thực thụ!{\i0}
Dialogue: 0,0:18:20.72,0:18:23.02,Default,,0,0,0,,Cần phải ghi được birdie ở hố này.
Dialogue: 0,0:18:24.98,0:18:26.98,Default,,0,0,0,,Thực sự nên nghỉ ngơi đi.
Dialogue: 0,0:18:27.60,0:18:32.65,Default,,0,0,0,,Cuối cùng cũng được thi đấu trở lại.\NĐang chiến đấu vì giải thưởng một lần nữa.
Dialogue: 0,0:18:33.61,0:18:36.40,Default,,0,0,0,,Đang tận hưởng khoảng thời gian tuyệt vời nhất.
Dialogue: 0,0:18:43.91,0:18:46.96,Default,,0,0,0,,{\i1}Đang ở hố bên cạnh,{\i0}\N{\i1}giống như Tonbo.{\i0}
Dialogue: 0,0:18:49.08,0:18:50.13,Default,,0,0,0,,{\i1}Của Tonbo đây sao?{\i0}
Dialogue: 0,0:18:52.17,0:18:55.05,Default,,0,0,0,,{\i1}Không thể tin là lại nhắm xa về bên phải thế.{\i0}
Dialogue: 0,0:18:58.80,0:19:01.22,Default,,0,0,0,,Đưa bóng lên green từ đây sao?
Dialogue: 0,0:19:03.76,0:19:06.39,Default,,0,0,0,,{\i1}Một vị trí hoàn hảo. Một đường bóng hoàn hảo.{\i0}
Dialogue: 0,0:19:08.94,0:19:10.85,Default,,0,0,0,,{\i1}Gần cờ đến mức đó sao?{\i0}
Dialogue: 0,0:19:12.23,0:19:13.48,Default,,0,0,0,,{\i1}Tonbo tuyệt thật.{\i0}
Dialogue: 0,0:19:14.86,0:19:18.20,Default,,0,0,0,,{\i1}Cả Ema và Tsubura nữa. Tất cả đều rất tuyệt.{\i0}
Dialogue: 0,0:19:22.03,0:19:23.16,Default,,0,0,0,,{\i1}Quyết định rồi.{\i0}
Dialogue: 0,0:19:26.45,0:19:28.00,Default,,0,0,0,,{\i1}Trên mặt đường nhựa luôn sao?{\i0}
Dialogue: 0,0:19:35.09,0:19:37.01,Default,,0,0,0,,{\i1}--Đây là cú gạt birdie{\i0}\N{\i1}--của Tonbo.{\i0}
Dialogue: 0,0:19:42.72,0:19:43.93,Default,,0,0,0,,{\i1}Đường bóng đây rồi.{\i0}
Dialogue: 0,0:19:44.22,0:19:47.18,Default,,0,0,0,,{\i1}Có một gờ lớn{\i0}\N{\i1}ở giữa green.{\i0}
Dialogue: 0,0:19:47.39,0:19:51.31,Default,,0,0,0,,{\i1}Bóng của Tonbo nằm ở rìa.{\i0}\N{\i1}Đó là một đường dốc đứng.{\i0}
Dialogue: 0,0:19:54.98,0:19:56.69,Default,,0,0,0,,{\i1}Có độ dốc hai độ.{\i0}
Dialogue: 0,0:19:57.03,0:20:00.32,Default,,0,0,0,,{\i1}Có thể là ba độ từ vị trí của Tonbo.{\i0}
Dialogue: 0,0:20:01.99,0:20:04.24,Default,,0,0,0,,{\i1}Nếu vào lỗ, sẽ chiến thắng giải này.{\i0}
Dialogue: 0,0:20:12.04,0:20:16.09,Default,,0,0,0,,{\i1}Chắc chỉ cần một con bọ bò ngang{\i0}\N{\i1}cũng đủ làm mất tập trung.{\i0}
Dialogue: 0,0:20:16.17,0:20:19.67,Default,,0,0,0,,Đi ra! Đi ra!
Dialogue: 0,0:20:22.76,0:20:26.18,Default,,0,0,0,,{\i1}Suýt chút nữa thì. {\i0}\N{\i1}Nếu đánh lúc nãy là trượt rồi.{\i0}
Dialogue: 0,0:20:27.81,0:20:30.81,Default,,0,0,0,,{\i1}Không quan trọng{\i0}\N{\i1}mất bao nhiêu gậy.{\i0}
Dialogue: 0,0:20:30.89,0:20:36.02,Default,,0,0,0,,{\i1}Đã học được niềm vui thực sự của golf:{\i0}\N{\i1}tận hưởng cuộc chơi ngay cả khi có áp lực.{\i0}
Dialogue: 0,0:20:42.91,0:20:44.53,Default,,0,0,0,,{\i1}Kuta-san.{\i0}
Dialogue: 0,0:20:44.74,0:20:47.33,Default,,0,0,0,,Tonbo. Kỹ năng gạt bóng ấn tượng lắm.
Dialogue: 0,0:20:49.33,0:20:50.37,Default,,0,0,0,,Nhưng dù vậy...
Dialogue: 0,0:20:51.75,0:20:54.25,Default,,0,0,0,,...có một cây putter muốn cho dùng thử.
Dialogue: 0,0:20:56.29,0:20:58.92,Default,,0,0,0,,{\i1}Khi chơi{\i0}\N{\i1}trên green nhanh của Kuta-san,{\i0}
Dialogue: 0,0:21:00.38,0:21:01.97,Default,,0,0,0,,{\i1}trong cú gạt xuống dốc đó...{\i0}
Dialogue: 0,0:21:02.59,0:21:05.64,Default,,0,0,0,,{\i1}Sẽ cần cầm gậy thật chắc{\i0}\N{\i1}cho cú gạt xuống dốc.{\i0}
Dialogue: 0,0:21:06.30,0:21:08.39,Default,,0,0,0,,{\i1}Tốt lắm, Tonbo.{\i0}
Dialogue: 0,0:21:20.94,0:21:21.82,Default,,0,0,0,,{\i1}Có vào không?{\i0}
Dialogue: 0,0:21:22.03,0:21:23.86,Default,,0,0,0,,{\i1}Nếu vào là xong đời.{\i0}
Dialogue: 0,0:21:24.32,0:21:27.49,Default,,0,0,0,,{\i1}Nếu vào thì sẽ phải{\i0}\N{\i1}hoàn thành trong hai gậy nữa.{\i0}
Dialogue: 0,0:21:28.41,0:21:29.33,Default,,0,0,0,,{\i1}Là thế này đây!{\i0}
Dialogue: 0,0:21:36.42,0:21:37.63,Default,,0,0,0,,{\i1}Nó...{\i0}
Dialogue: 0,0:21:49.85,0:21:53.02,Default,,0,0,0,,Chẳng phải đã bảo\Nđiểm số không quan trọng sao?
Dialogue: 0,0:21:55.48,0:21:58.06,Default,,0,0,0,,{\i1}Trong suốt thời gian chơi golf...{\i0}
Dialogue: 0,0:22:13.66,0:22:15.33,Default,,0,0,0,,{\i1}...đây là lúc vui nhất!{\i0}
Dialogue: 0,0:23:48.97,0:23:50.84,Default,,0,0,0,,Kết thúc rồi!
Dialogue: 0,0:23:51.09,0:23:53.68,Default,,0,0,0,,Giải đấu đầu tiên vui quá đi mất!
Dialogue: 0,0:23:53.76,0:23:55.47,Default,,0,0,0,,Vẫn chưa kết thúc đâu, Tonbo.
Dialogue: 0,0:23:55.68,0:23:58.14,Default,,0,0,0,,Còn phải xem\NTsubura và những người khác nữa.
Dialogue: 0,0:23:58.27,0:23:59.31,Default,,0,0,0,,Đúng rồi!
Dialogue: 0,0:23:59.64,0:24:01.06,Default,,0,0,0,,Trong tập tiếp theo của Tonbo.
Dialogue: 0,0:24:01.56,0:24:02.86,Default,,0,0,0,,"Người chiến thắng và Lòng can đảm"
Dialogue: 0,0:24:03.19,0:24:05.15,Default,,0,0,0,,Igaiga không phải làm việc sao?
Dialogue: 0,0:24:05.32,0:24:07.53,Default,,0,0,0,,Thôi chết! Quên đặt vé phà rồi!