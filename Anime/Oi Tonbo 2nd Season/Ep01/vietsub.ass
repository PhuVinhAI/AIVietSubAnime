Dialogue: 0,0:01:38.14,0:01:41.51,Default,,0,0,0,,{\i1}Igaiga, sắp đến{\i0}\N{\i1}Kagoshima rồi đấy.{\i0}
Dialogue: 0,0:01:41.97,0:01:44.98,Default,,0,0,0,,{\i1}-Hồi hộp quá.{\i0}\N{\i1}-Ừ.{\i0}
Dialogue: 0,0:01:45.56,0:01:46.52,Default,,0,0,0,,{\i1}Sao vậy?{\i0}
Dialogue: 0,0:01:46.73,0:01:48.73,Default,,0,0,0,,{\i1}Chỉ đang nhớ lại chút thôi.{\i0}
Dialogue: 0,0:01:49.15,0:01:53.98,Default,,0,0,0,,{\i1}Lần đầu tiên đi chuyến phà này{\i0}\N{\i1}đến Hinoshima, quê hương của Tonbo.{\i0}
Dialogue: 0,0:01:54.07,0:01:55.53,Default,,0,0,0,,{\i1}Lúc đó có hồi hộp không?{\i0}
Dialogue: 0,0:01:55.82,0:02:00.53,Default,,0,0,0,,{\i1}Hồi hộp á? Phải nói là lo lắng mới đúng.{\i0}
Dialogue: 0,0:02:01.24,0:02:03.49,Default,,0,0,0,,Nơi gì thế này.
Dialogue: 0,0:02:04.12,0:02:08.87,Default,,0,0,0,,Chỉ toàn núi và biển.\NĐã đi xa thật đấy.
Dialogue: 0,0:02:17.17,0:02:20.59,Default,,0,0,0,,{\i1}Lúc mới gặp, giật mình{\i0}\N{\i1}đến mức ngã lăn ra luôn mà!{\i0}
Dialogue: 0,0:02:21.30,0:02:25.89,Default,,0,0,0,,{\i1}Lần đầu nhìn thấy,{\i0}\N{\i1}còn tưởng là con trai cơ!{\i0}
Dialogue: 0,0:02:26.23,0:02:27.39,Default,,0,0,0,,{\i1}Ác quá đi!{\i0}
Dialogue: 0,0:02:27.64,0:02:31.06,Default,,0,0,0,,{\i1}Đã rất mong chờ{\i0}\N{\i1}Igaiga đến luôn đấy!{\i0}
Dialogue: 0,0:02:34.82,0:02:39.57,Default,,0,0,0,,{\i1}Cũng giống như Tonbo, người dân trên{\i0}\N{\i1}hòn đảo này ai cũng đầy cá tính.{\i0}
Dialogue: 0,0:02:40.28,0:02:44.58,Default,,0,0,0,,{\i1}Lúc đầu, Gon-jii nhìn đáng sợ lắm.{\i0}\N{\i1}Đã không thích ông ấy cho lắm.{\i0}
Dialogue: 0,0:02:45.29,0:02:49.16,Default,,0,0,0,,{\i1}Nhưng Gon-jii{\i0}\N{\i1}lúc nào cũng quan tâm đến Tonbo.{\i0}
Dialogue: 0,0:02:50.83,0:02:51.92,Default,,0,0,0,,{\i1}Trà đục quá.{\i0}
Dialogue: 0,0:02:52.96,0:02:56.09,Default,,0,0,0,,{\i1}Ánh mắt đục ngầu.{\i0}
Dialogue: 0,0:02:56.42,0:02:59.68,Default,,0,0,0,,Ichiga Igarashi!
Dialogue: 0,0:02:59.97,0:03:01.80,Default,,0,0,0,,Iga-Iga!
Dialogue: 0,0:03:02.85,0:03:03.80,Default,,0,0,0,,Vâng, ở bên này!
Dialogue: 0,0:03:04.43,0:03:05.26,Default,,0,0,0,,Ở đây này!
Dialogue: 0,0:03:05.39,0:03:08.02,Default,,0,0,0,,Nhân tiện thì, là Kazuyoshi Igarashi!
Dialogue: 0,0:03:08.60,0:03:11.06,Default,,0,0,0,,Ồ, ra là Igaiga.
Dialogue: 0,0:03:12.15,0:03:14.61,Default,,0,0,0,,{\i1}Dì Setsu từ đầu đã rất hiền đúng không?{\i0}
Dialogue: 0,0:03:14.69,0:03:17.28,Default,,0,0,0,,{\i1}Đúng vậy. Giờ nghĩ lại thì,{\i0}
Dialogue: 0,0:03:17.40,0:03:21.45,Default,,0,0,0,,{\i1}Dì Setsu là người đầu tiên{\i0}\N{\i1}gọi cái tên Igaiga.{\i0}
Dialogue: 0,0:03:21.95,0:03:24.74,Default,,0,0,0,,{\i1}Và bữa sáng dì ấy làm cũng rất ngon!{\i0}
Dialogue: 0,0:03:26.41,0:03:27.54,Default,,0,0,0,,{\i1}Đồ ăn đây.{\i0}
Dialogue: 0,0:03:28.75,0:03:30.75,Default,,0,0,0,,Đã đưa giám đốc bảo tàng đến rồi đây.
Dialogue: 0,0:03:31.04,0:03:31.87,Default,,0,0,0,,Ồ.
Dialogue: 0,0:03:32.12,0:03:35.04,Default,,0,0,0,,{\i1}Giám đốc trên danh nghĩa là cấp trên,{\i0}
Dialogue: 0,0:03:35.17,0:03:39.09,Default,,0,0,0,,{\i1}nhưng lại rất dễ gần{\i0}\N{\i1}nên đã nhẹ nhõm hẳn.{\i0}
Dialogue: 0,0:03:39.30,0:03:43.30,Default,,0,0,0,,-Tên ông ấy là gì nhỉ?\N-Tất nhiên là Kento Hidaka rồi!
Dialogue: 0,0:03:43.55,0:03:46.51,Default,,0,0,0,,-À, đúng rồi.\N-Có nhớ tên đầy đủ của Bunpei không?
Dialogue: 0,0:03:47.39,0:03:51.31,Default,,0,0,0,,Bunpei... Bunpei... Tarou!
Dialogue: 0,0:03:51.56,0:03:53.81,Default,,0,0,0,,Osamu Fumihira! Đừng có quên đấy!
Dialogue: 0,0:03:55.94,0:03:58.82,Default,,0,0,0,,{\i1}Đã nghĩ gì{\i0}\N{\i1}khi lần đầu gặp Yoko vậy?{\i0}
Dialogue: 0,0:03:59.32,0:04:03.24,Default,,0,0,0,,Cô ấy hả? Ồ, chà...
Dialogue: 0,0:04:07.70,0:04:11.58,Default,,0,0,0,,-Chào Yoko.\N-Cứ lái xe tiếp đi, Bunpei!
Dialogue: 0,0:04:13.92,0:04:17.34,Default,,0,0,0,,-Cả Takuma nữa.\N-Sẽ cầm máu cho.
Dialogue: 0,0:04:17.63,0:04:19.05,Default,,0,0,0,,Đá bóng thôi!
Dialogue: 0,0:04:19.38,0:04:22.80,Default,,0,0,0,,{\i1}Chú cảnh sát,{\i0}\N{\i1}Sensei, Wataru, và cả Yuma.{\i0}
Dialogue: 0,0:04:23.51,0:04:25.80,Default,,0,0,0,,{\i1}Đã hòa đồng với mọi người ngay lập tức nhỉ.{\i0}
Dialogue: 0,0:04:25.89,0:04:29.85,Default,,0,0,0,,{\i1}-Dù khuôn mặt nhìn đáng sợ!{\i0}\N{\i1}-Lại là người hòa nhập nhanh nhất đấy!{\i0}
Dialogue: 0,0:04:30.85,0:04:32.89,Default,,0,0,0,,{\i1}Đừng quên động vật hoang dã trên đảo nữa!{\i0}
Dialogue: 0,0:04:33.14,0:04:35.27,Default,,0,0,0,,{\i1}Những bộ lông màu đỏ hoàng hôn tuyệt đẹp đó.{\i0}
Dialogue: 0,0:04:35.35,0:04:38.52,Default,,0,0,0,,{\i1}Và cả những chú dê đi dạo khắp nơi!{\i0}
Dialogue: 0,0:04:38.98,0:04:40.94,Default,,0,0,0,,{\i1}Và cả con côn trùng đó nữa!{\i0}
Dialogue: 0,0:04:41.74,0:04:43.24,Default,,0,0,0,,{\i1}Bị đốt ngay vào mông luôn!{\i0}
Dialogue: 0,0:04:43.53,0:04:45.49,Default,,0,0,0,,{\i1}Ngứa kinh khủng khiếp!{\i0}
Dialogue: 0,0:04:45.91,0:04:48.78,Default,,0,0,0,,{\i1}Sinh vật trên đảo tuyệt thật đấy!{\i0}
Dialogue: 0,0:04:49.58,0:04:55.50,Default,,0,0,0,,Lông đỏ, ngựa Tokara, dê,\Nlươn khổng lồ, Bunpei, và cả con côn trùng đó!
Dialogue: 0,0:04:56.00,0:04:58.46,Default,,0,0,0,,Khoan đã. Vừa liệt kê cả Bunpei vào đó hả?
Dialogue: 0,0:04:58.59,0:04:59.42,Default,,0,0,0,,Bunpei á?
Dialogue: 0,0:05:01.42,0:05:03.97,Default,,0,0,0,,{\i1}Nhưng điều đáng ngạc nhiên nhất{\i0}
Dialogue: 0,0:05:04.13,0:05:07.89,Default,,0,0,0,,{\i1}là sân golf khó tin trên đảo!{\i0}
Dialogue: 0,0:05:11.93,0:05:12.77,Default,,0,0,0,,Gì chứ?
Dialogue: 0,0:05:14.14,0:05:15.73,Default,,0,0,0,,Cái quái gì thế này?
Dialogue: 0,0:05:26.24,0:05:27.74,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:05:28.28,0:05:33.58,Default,,0,0,0,,Họ đã tận dụng địa hình ven biển tự nhiên\Nđể tạo ra một sân links hoàn chỉnh!
Dialogue: 0,0:05:34.08,0:05:38.08,Default,,0,0,0,,Người dân trên đảo đã tự xây dựng\Nđể giải trí đấy!
Dialogue: 0,0:05:43.17,0:05:45.09,Default,,0,0,0,,Hôm nay có gió ngược.
Dialogue: 0,0:05:45.84,0:05:47.09,Default,,0,0,0,,Đánh đây!
Dialogue: 0,0:05:49.30,0:05:52.43,Default,,0,0,0,,{\i1}Cầm gậy golf như gậy bóng chày vậy.{\i0}
Dialogue: 0,0:05:53.22,0:05:55.27,Default,,0,0,0,,{\i1}Đúng là chỉ đánh cho vui thôi.{\i0}
Dialogue: 0,0:05:56.69,0:06:01.11,Default,,0,0,0,,{\i1}Tư thế mở cực rộng,{\i0}\N{\i1}hướng thẳng ra biển.{\i0}
Dialogue: 0,0:06:02.15,0:06:07.20,Default,,0,0,0,,{\i1}Với cú đánh như thế này,{\i0}\N{\i1}cần đánh một cú draw thấp và mạnh.{\i0}
Dialogue: 0,0:06:07.70,0:06:09.99,Default,,0,0,0,,{\i1}Nhưng lại dùng gậy sắt số ba mỏng để đánh.{\i0}
Dialogue: 0,0:06:10.66,0:06:14.20,Default,,0,0,0,,{\i1}Với một cô bé, đó là một cây gậy khá dài và cứng.{\i0}
Dialogue: 0,0:06:14.41,0:06:17.62,Default,,0,0,0,,{\i1}Chắc là đang mong đợi một cú slice lớn.{\i0}
Dialogue: 0,0:06:26.51,0:06:27.88,Default,,0,0,0,,Đi nào!
Dialogue: 0,0:06:28.47,0:06:32.89,Default,,0,0,0,,Như cánh én trước cơn mưa,\Nlướt đi dưới ngọn gió!
Dialogue: 0,0:06:33.14,0:06:35.06,Default,,0,0,0,,{\i1}Cú follow-through đó là sao?{\i0}
Dialogue: 0,0:06:35.47,0:06:37.02,Default,,0,0,0,,Bay rồi kìa!
Dialogue: 0,0:06:42.56,0:06:43.98,Default,,0,0,0,,Làm được rồi!
Dialogue: 0,0:06:46.65,0:06:48.95,Default,,0,0,0,,{\i1}Chưa từng thấy đứa trẻ nào chơi như vậy.{\i0}
Dialogue: 0,0:06:49.11,0:06:52.03,Default,,0,0,0,,{\i1}Cứ tưởng là quái vật cơ!{\i0}
Dialogue: 0,0:06:52.16,0:06:54.08,Default,,0,0,0,,{\i1}Quái vật á? Ác quá đi!{\i0}
Dialogue: 0,0:06:54.20,0:06:55.74,Default,,0,0,0,,{\i1}Không, đó là lời khen mà!{\i0}
Dialogue: 0,0:06:55.95,0:07:00.21,Default,,0,0,0,,{\i1}-Ý là đã để lại ấn tượng rất lớn đấy!{\i0}\N{\i1}-Đừng có gọi người ta là quái vật!{\i0}
Dialogue: 0,0:07:00.54,0:07:03.09,Default,,0,0,0,,{\i1}Ấn tượng đầu tiên về Igaiga{\i0}\N{\i1}là gì thế, Tonbo?{\i0}
Dialogue: 0,0:07:03.71,0:07:09.34,Default,,0,0,0,,{\i1}Chà, khuôn mặt đáng sợ.{\i0}
Dialogue: 0,0:07:09.76,0:07:11.34,Default,,0,0,0,,Khuôn mặt cực kỳ đáng sợ.
Dialogue: 0,0:07:14.43,0:07:18.43,Default,,0,0,0,,Mặt Igaiga đáng sợ lắm đấy.
Dialogue: 0,0:07:18.73,0:07:20.69,Default,,0,0,0,,{\i1}Được rồi, chủ đề tiếp theo.{\i0}
Dialogue: 0,0:07:23.11,0:07:26.61,Default,,0,0,0,,{\i1}Lúc đầu, chẳng hiểu gì{\i0}\N{\i1}về Tonbo cả.{\i0}
Dialogue: 0,0:07:27.57,0:07:29.57,Default,,0,0,0,,{\i1}Cứ nhất quyết không chịu rời đảo.{\i0}
Dialogue: 0,0:07:33.12,0:07:35.37,Default,,0,0,0,,Sẽ ở lại đây.
Dialogue: 0,0:07:38.70,0:07:41.37,Default,,0,0,0,,Sẽ ở lại hòn đảo này mãi mãi!
Dialogue: 0,0:07:41.75,0:07:44.88,Default,,0,0,0,,Sẽ không đi đâu hết!
Dialogue: 0,0:07:45.88,0:07:47.96,Default,,0,0,0,,Nhìn kìa!
Dialogue: 0,0:07:56.76,0:07:59.35,Default,,0,0,0,,Đây là niềm tự hào của hòn đảo.
Dialogue: 0,0:08:00.77,0:08:03.56,Default,,0,0,0,,{\i1}Cảm giác như thời gian đã ngừng trôi ở đây.{\i0}
Dialogue: 0,0:08:15.07,0:08:17.95,Default,,0,0,0,,Không biết ngôi sao nào là bố và mẹ nhỉ?
Dialogue: 0,0:08:20.25,0:08:24.96,Default,,0,0,0,,Người ta nói rằng khi chết đi,\Ncon người sẽ hóa thành những vì sao.
Dialogue: 0,0:08:25.17,0:08:29.76,Default,,0,0,0,,{\i1}Đã hiểu lý do tại sao lại học{\i0}\N{\i1}chơi golf bằng gậy sắt số ba rồi.{\i0}
Dialogue: 0,0:08:30.46,0:08:32.34,Default,,0,0,0,,{\i1}Nhớ lúc đó có người đã khóc.{\i0}
Dialogue: 0,0:08:33.38,0:08:35.84,Default,,0,0,0,,{\i1}Chỉ là ánh sao{\i0}\N{\i1}làm cay mắt thôi.{\i0}
Dialogue: 0,0:08:35.93,0:08:37.97,Default,,0,0,0,,{\i1}-Vậy sao?{\i0}\N{\i1}-Tất nhiên rồi!{\i0}
Dialogue: 0,0:08:40.22,0:08:43.10,Default,,0,0,0,,{\i1}Xin lỗi, bị cuốn theo cảm xúc quá.{\i0}
Dialogue: 0,0:08:47.77,0:08:50.61,Default,,0,0,0,,Định tính sao chuyện học cấp ba?
Dialogue: 0,0:08:52.86,0:08:55.32,Default,,0,0,0,,Trên đảo chỉ có\Nmỗi trường cấp hai thôi.
Dialogue: 0,0:08:55.41,0:08:57.12,Default,,0,0,0,,Sẽ không học cấp ba đâu.
Dialogue: 0,0:08:58.99,0:09:00.54,Default,,0,0,0,,Sẽ ở lại đảo.
Dialogue: 0,0:09:00.66,0:09:04.79,Default,,0,0,0,,{\i1}Đã thử đủ mọi cách{\i0}\N{\i1}để cho Tonbo thấy một thế giới mới.{\i0}
Dialogue: 0,0:09:05.08,0:09:06.92,Default,,0,0,0,,{\i1}Vâng!{\i0}\N{\i1}Igaiga đã tặng cho một cây gậy wedge!{\i0}
Dialogue: 0,0:09:07.46,0:09:10.00,Default,,0,0,0,,{\i1}Đó là cây gậy đầu tiên{\i0}\N{\i1}ngoài cây sắt số ba đấy!{\i0}
Dialogue: 0,0:09:14.72,0:09:17.80,Default,,0,0,0,,{\i1}Phần tay cầm chứa đựng kỷ niệm về bố.{\i0}
Dialogue: 0,0:09:20.10,0:09:23.10,Default,,0,0,0,,Chắc hẳn là muốn đánh thử lắm đúng không?
Dialogue: 0,0:09:25.56,0:09:26.40,Default,,0,0,0,,Vâng!
Dialogue: 0,0:09:27.35,0:09:28.86,Default,,0,0,0,,Vì đã có gậy wedge rồi,
Dialogue: 0,0:09:29.36,0:09:33.32,Default,,0,0,0,,sẽ dạy cho một kỹ thuật\Nmà gậy sắt số ba không làm được.
Dialogue: 0,0:09:58.72,0:10:00.89,Default,,0,0,0,,Cũng muốn thử!
Dialogue: 0,0:10:01.76,0:10:03.02,Default,,0,0,0,,Tuyệt quá.
Dialogue: 0,0:10:04.06,0:10:06.02,Default,,0,0,0,,Đẹp quá nhỉ?
Dialogue: 0,0:10:06.81,0:10:09.90,Default,,0,0,0,,Cứ như mặt trời đang tan vào biển vậy.
Dialogue: 0,0:10:10.40,0:10:14.28,Default,,0,0,0,,Đặt một chiếc ghế đá ở đây đúng là ý hay.
Dialogue: 0,0:10:16.70,0:10:22.33,Default,,0,0,0,,{\i1}Được cùng chơi golf và ngắm{\i0}\N{\i1}hoàng hôn từ chiếc ghế đá đó thật tuyệt.{\i0}
Dialogue: 0,0:10:22.45,0:10:23.58,Default,,0,0,0,,{\i1}Đúng không?{\i0}
Dialogue: 0,0:10:23.70,0:10:28.21,Default,,0,0,0,,{\i1}Nó gợi nhớ lại golf vui đến mức nào,{\i0}\N{\i1}dù đó là điều hiển nhiên.{\i0}
Dialogue: 0,0:10:28.75,0:10:32.54,Default,,0,0,0,,{\i1}Nhưng sau đó Igaiga đã nói{\i0}\N{\i1}những lời rất khắc nghiệt.{\i0}
Dialogue: 0,0:10:33.05,0:10:37.72,Default,,0,0,0,,Tonbo, thứ đang chơi không phải là golf.
Dialogue: 0,0:10:38.26,0:10:40.34,Default,,0,0,0,,Không phải là golf sao?
Dialogue: 0,0:10:40.51,0:10:44.18,Default,,0,0,0,,{\i1}Chỉ muốn thách thức{\i0}\N{\i1}Tonbo và lối chơi đó thôi.{\i0}
Dialogue: 0,0:10:44.43,0:10:45.27,Default,,0,0,0,,Thách thức á?
Dialogue: 0,0:10:46.02,0:10:49.06,Default,,0,0,0,,{\i1}Đúng vậy! Và đã thực sự làm được!{\i0}
Dialogue: 0,0:10:52.77,0:10:54.07,Default,,0,0,0,,Tsubura!
Dialogue: 0,0:10:55.07,0:10:58.61,Default,,0,0,0,,-Cháu gái của Yoko.\N-Tsubura Adaniya!
Dialogue: 0,0:11:10.42,0:11:14.75,Default,,0,0,0,,{\i1}Tsubura hoàn toàn khác biệt{\i0}\N{\i1}với bất kỳ ai từng chơi golf cùng trước đây.{\i0}
Dialogue: 0,0:11:15.17,0:11:20.80,Default,,0,0,0,,{\i1}Cậu ấy giỏi đến mức lần đầu tiên,{\i0}\N{\i1}cảm thấy hồi hộp khi chơi.{\i0}
Dialogue: 0,0:11:21.09,0:11:24.47,Default,,0,0,0,,{\i1}Đúng vậy. Cô bé thực sự đã mang đến{\i0}\N{\i1}thách thức cần thiết.{\i0}
Dialogue: 0,0:11:27.43,0:11:32.06,Default,,0,0,0,,{\i1}Một cú đánh three-quarter bằng gậy driver sao?{\i0}
Dialogue: 0,0:11:32.35,0:11:33.65,Default,,0,0,0,,Làm được rồi!
Dialogue: 0,0:11:34.23,0:11:35.07,Default,,0,0,0,,Hay lắm.
Dialogue: 0,0:11:35.32,0:11:37.86,Default,,0,0,0,,Tsubura chỉ vung gậy từ đây đến đây thôi.
Dialogue: 0,0:11:38.19,0:11:39.86,Default,,0,0,0,,Vậy mà bóng vẫn bay xa!
Dialogue: 0,0:11:40.20,0:11:42.24,Default,,0,0,0,,Lúc nào cũng dùng cú swing three-quarter.
Dialogue: 0,0:11:42.32,0:11:44.45,Default,,0,0,0,,Đó là cách để trở thành người giỏi nhất Nhật Bản.
Dialogue: 0,0:11:44.99,0:11:45.83,Default,,0,0,0,,Nhật Bản á?
Dialogue: 0,0:11:46.03,0:11:46.87,Default,,0,0,0,,Ừ.
Dialogue: 0,0:11:47.08,0:11:50.41,Default,,0,0,0,,Huấn luyện viên đã nói rằng\Nnếu thành thạo cú đánh three-quarter,
Dialogue: 0,0:11:50.50,0:11:52.62,Default,,0,0,0,,thì có thể trở thành người giỏi nhất Nhật Bản.
Dialogue: 0,0:11:53.04,0:11:58.38,Default,,0,0,0,,Sau đó, có thể học cú full shot\Nkhi nhắm đến việc chinh phục thế giới.
Dialogue: 0,0:11:59.80,0:12:00.88,Default,,0,0,0,,Tuyệt quá.
Dialogue: 0,0:12:01.63,0:12:05.64,Default,,0,0,0,,Bằng tuổi Tonbo\Nmà đã nhắm đến thế giới rồi.
Dialogue: 0,0:12:07.26,0:12:11.39,Default,,0,0,0,,Không... Không muốn thua đâu!
Dialogue: 0,0:12:11.69,0:12:17.73,Default,,0,0,0,,{\i1}Tsubura có vẻ nửa ấn tượng{\i0}\N{\i1}nửa kinh ngạc với lối chơi golf đó.{\i0}
Dialogue: 0,0:12:18.82,0:12:22.15,Default,,0,0,0,,{\i1}Có lẽ tư thế đứng một chân là quá sức tưởng tượng.{\i0}
Dialogue: 0,0:12:22.40,0:12:23.61,Default,,0,0,0,,Vừa rồi là sao?!
Dialogue: 0,0:12:24.20,0:12:26.66,Default,,0,0,0,,Chẳng hiểu gì cả!
Dialogue: 0,0:12:28.99,0:12:30.54,Default,,0,0,0,,Cậu ấy đã mở mặt gậy!
Dialogue: 0,0:12:32.79,0:12:35.33,Default,,0,0,0,,Sẽ làm gì tiếp theo đây, Tonbo?
Dialogue: 0,0:12:36.21,0:12:40.26,Default,,0,0,0,,{\i1}Tsubura có vẻ thực sự{\i0}\N{\i1}sốc với cách chơi đó.{\i0}
Dialogue: 0,0:12:40.71,0:12:42.22,Default,,0,0,0,,{\i1}Cậu ấy còn ôm đầu cơ mà.{\i0}
Dialogue: 0,0:12:42.30,0:12:45.14,Default,,0,0,0,,{\i1}Chỉ làm như bình thường vẫn làm thôi.{\i0}
Dialogue: 0,0:12:45.68,0:12:48.72,Default,,0,0,0,,{\i1}Một ngày nào đó Tsubura sẽ trở thành đối thủ.{\i0}
Dialogue: 0,0:12:49.35,0:12:50.81,Default,,0,0,0,,{\i1}Chắc chắn là vậy.{\i0}
Dialogue: 0,0:12:51.18,0:12:53.06,Default,,0,0,0,,{\i1}Không biết Tsubura đã nghĩ gì nhỉ?{\i0}
Dialogue: 0,0:12:53.27,0:12:54.23,Default,,0,0,0,,{\i1}Cũng giống như bên này thôi.{\i0}
Dialogue: 0,0:12:54.73,0:12:56.94,Default,,0,0,0,,{\i1}Muốn Tonbo tiếp tục chơi golf.{\i0}
Dialogue: 0,0:12:57.61,0:13:00.48,Default,,0,0,0,,Đó là lý do cậu ấy cũng đã nói\Nnhững lời khắc nghiệt.
Dialogue: 0,0:13:02.19,0:13:03.03,Default,,0,0,0,,Đúng vậy!
Dialogue: 0,0:13:03.11,0:13:04.11,Default,,0,0,0,,Tiếp tục thôi!
Dialogue: 0,0:13:06.03,0:13:07.49,Default,,0,0,0,,Ước mơ của Tonbo là gì?
Dialogue: 0,0:13:07.57,0:13:08.53,Default,,0,0,0,,Ước mơ á?
Dialogue: 0,0:13:08.91,0:13:10.49,Default,,0,0,0,,Muốn trở thành gì?
Dialogue: 0,0:13:10.95,0:13:12.37,Default,,0,0,0,,Đang nhắm tới điều gì?
Dialogue: 0,0:13:13.75,0:13:16.71,Default,,0,0,0,,Muốn ở lại đảo.
Dialogue: 0,0:13:16.96,0:13:18.00,Default,,0,0,0,,Mãi mãi sao?
Dialogue: 0,0:13:18.17,0:13:19.17,Default,,0,0,0,,Rồi sẽ làm gì?
Dialogue: 0,0:13:19.67,0:13:20.80,Default,,0,0,0,,Ý là sao?
Dialogue: 0,0:13:21.17,0:13:23.01,Default,,0,0,0,,Cứ định ở lại đây mãi sao?
Dialogue: 0,0:13:23.09,0:13:24.68,Default,,0,0,0,,Đó là ước mơ của Tonbo sao?
Dialogue: 0,0:13:25.51,0:13:27.39,Default,,0,0,0,,Nghe có vẻ nhàm chán nhỉ.
Dialogue: 0,0:13:27.93,0:13:30.89,Default,,0,0,0,,Cuộc sống sẽ trống rỗng lắm.
Dialogue: 0,0:13:30.97,0:13:32.98,Default,,0,0,0,,Hòn đảo này có mọi thứ cần thiết rồi.
Dialogue: 0,0:13:33.14,0:13:35.10,Default,,0,0,0,,Cá chuồn và hươu râu đỏ!
Dialogue: 0,0:13:35.85,0:13:37.19,Default,,0,0,0,,Không hề chán chút nào.
Dialogue: 0,0:13:38.19,0:13:39.77,Default,,0,0,0,,Ở đây là ổn rồi.
Dialogue: 0,0:13:40.69,0:13:43.40,Default,,0,0,0,,Sẽ sống ở đây\Ncho đến hết đời.
Dialogue: 0,0:13:44.36,0:13:47.66,Default,,0,0,0,,Có chắc không phải chỉ đang\Ntự thuyết phục bản thân không?
Dialogue: 0,0:13:49.07,0:13:53.29,Default,,0,0,0,,Có lẽ chỉ đang trốn tránh sự thật\Nrằng có cả một thế giới ngoài kia chăng?
Dialogue: 0,0:13:54.62,0:13:56.96,Default,,0,0,0,,Có thể sẽ có những cảnh tượng đẹp hơn nữa.
Dialogue: 0,0:13:57.62,0:14:00.17,Default,,0,0,0,,{\i1}Lúc đầu nghe vậy đã rất sốc,{\i0}
Dialogue: 0,0:14:00.34,0:14:02.13,Default,,0,0,0,,{\i1}nhưng sau đó,{\i0}
Dialogue: 0,0:14:02.25,0:14:05.97,Default,,0,0,0,,{\i1}đã hiểu được niềm đam mê thực sự{\i0}\N{\i1}của Tsubura dành cho golf.{\i0}
Dialogue: 0,0:14:06.63,0:14:10.30,Default,,0,0,0,,Ông ấy đã lái\Ncùng một chiếc xe tải cũ kỹ suốt nhiều năm.
Dialogue: 0,0:14:10.89,0:14:12.18,Default,,0,0,0,,Là bố đấy.
Dialogue: 0,0:14:13.97,0:14:14.93,Default,,0,0,0,,Nó rỉ sét hết rồi.
Dialogue: 0,0:14:15.89,0:14:17.85,Default,,0,0,0,,Và thùng xe thì thủng lỗ chỗ.
Dialogue: 0,0:14:18.56,0:14:22.19,Default,,0,0,0,,Cho con cái\Nchơi golf tốn kém lắm.
Dialogue: 0,0:14:23.40,0:14:25.99,Default,,0,0,0,,Sẽ chơi golf thật giỏi.
Dialogue: 0,0:14:26.61,0:14:28.78,Default,,0,0,0,,Sẽ mua cho bố một chiếc xe tải mới.
Dialogue: 0,0:14:29.57,0:14:32.41,Default,,0,0,0,,Và có thứ này\Nmuốn tặng cho Tonbo.
Dialogue: 0,0:14:32.70,0:14:35.45,Default,,0,0,0,,{\i1}Đã rất ngạc nhiên{\i0}\N{\i1}khi cậu ấy tặng cho cây gậy đó.{\i0}
Dialogue: 0,0:14:35.66,0:14:36.87,Default,,0,0,0,,{\i1}Và đã bị thuyết phục.{\i0}
Dialogue: 0,0:14:37.46,0:14:41.00,Default,,0,0,0,,{\i1}-Rằng Tsubura sẽ là đối thủ--{\i0}\N{\i1}-Đã nói câu đó rồi.{\i0}
Dialogue: 0,0:14:42.50,0:14:44.55,Default,,0,0,0,,Hãy giữ gìn và sử dụng nó hết mình nhé.
Dialogue: 0,0:14:46.09,0:14:49.34,Default,,0,0,0,,{\i1}Đây là ý tưởng của người{\i0}\N{\i1}đã thiết kế sân golf.{\i0}
Dialogue: 0,0:14:49.84,0:14:52.43,Default,,0,0,0,,{\i1}Ông ấy tính toán rằng nó sẽ{\i0}\N{\i1}tạo ra một sân sáu lỗ.{\i0}
Dialogue: 0,0:14:52.51,0:14:56.06,Default,,0,0,0,,{\i1}Không phải mọi người trên đảo{\i0}\N{\i1}cùng nhau thiết kế sân đó sao?{\i0}
Dialogue: 0,0:14:56.56,0:14:57.89,Default,,0,0,0,,Họ đã xây dựng nó, đúng vậy.
Dialogue: 0,0:14:58.23,0:15:01.56,Default,,0,0,0,,Nhưng thiết kế là do một tay Kuta-san làm.
Dialogue: 0,0:15:02.52,0:15:03.52,Default,,0,0,0,,Cùng đi gặp ông ấy nào.
Dialogue: 0,0:15:04.40,0:15:06.49,Default,,0,0,0,,Người đã thiết kế sân golf.
Dialogue: 0,0:15:07.32,0:15:09.24,Default,,0,0,0,,Cùng đi thôi, Tonbo.
Dialogue: 0,0:15:10.28,0:15:12.03,Default,,0,0,0,,Cả đi cùng á?
Dialogue: 0,0:15:13.78,0:15:15.79,Default,,0,0,0,,{\i1}Lúc đầu, thực sự rất sợ.{\i0}
Dialogue: 0,0:15:15.87,0:15:20.04,Default,,0,0,0,,{\i1}Đã hứa là không bao giờ rời đảo,{\i0}\N{\i1}vậy mà Igaiga lại đưa đến đảo Akureki.{\i0}
Dialogue: 0,0:15:20.12,0:15:21.54,Default,,0,0,0,,{\i1}Còn đáng sợ hơn cả khuôn mặt này sao?{\i0}
Dialogue: 0,0:15:22.33,0:15:23.84,Default,,0,0,0,,{\i1}Đang do dự kìa?{\i0}
Dialogue: 0,0:15:24.04,0:15:25.13,Default,,0,0,0,,{\i1}Nhưng mà nhé,{\i0}
Dialogue: 0,0:15:25.25,0:15:29.34,Default,,0,0,0,,{\i1}đã rất ngạc nhiên khi{\i0}\N{\i1}Igaiga kể về bản thân đấy.{\i0}
Dialogue: 0,0:15:29.68,0:15:30.55,Default,,0,0,0,,{\i1}Ừ.{\i0}
Dialogue: 0,0:15:30.72,0:15:34.51,Default,,0,0,0,,{\i1}Biết là phải kể ra mà.{\i0}
Dialogue: 0,0:15:37.72,0:15:40.77,Default,,0,0,0,,Từng là một tay golf chuyên nghiệp.
Dialogue: 0,0:15:41.98,0:15:43.19,Default,,0,0,0,,Từng là sao?
Dialogue: 0,0:15:43.73,0:15:46.28,Default,,0,0,0,,Đã đánh mất golf, gia đình,
Dialogue: 0,0:15:46.53,0:15:48.82,Default,,0,0,0,,và hơn hết là lòng kiêu hãnh của một tay chuyên nghiệp.
Dialogue: 0,0:15:51.03,0:15:55.70,Default,,0,0,0,,Nhưng con người vẫn cần phải ăn mà.
Dialogue: 0,0:15:57.74,0:16:00.08,Default,,0,0,0,,Thật nực cười nhỉ.
Dialogue: 0,0:16:04.79,0:16:09.55,Default,,0,0,0,,Muốn Tonbo tìm hiểu\Nthêm về golf.
Dialogue: 0,0:16:11.01,0:16:13.93,Default,,0,0,0,,{\i1}Đã rất ngạc nhiên khi thấy những giọt nước mắt đó.{\i0}
Dialogue: 0,0:16:14.85,0:16:18.81,Default,,0,0,0,,{\i1}Chắc hẳn đã phải rất can đảm{\i0}\N{\i1}mới có thể nói ra điều đó.{\i0}
Dialogue: 0,0:16:19.73,0:16:23.73,Default,,0,0,0,,{\i1}Lúc đó mới nhận ra rằng bản thân{\i0}\N{\i1}cũng phải can đảm lên.{\i0}
Dialogue: 0,0:16:23.98,0:16:26.57,Default,,0,0,0,,{\i1}Tonbo...{\i0}
Dialogue: 0,0:16:31.61,0:16:34.07,Default,,0,0,0,,{\i1}Đã đi gặp{\i0}\N{\i1}Kuta-san trên đảo Akureki.{\i0}
Dialogue: 0,0:16:35.62,0:16:37.78,Default,,0,0,0,,{\i1}Ông ấy sống ở một nơi thật khó tin.{\i0}
Dialogue: 0,0:16:37.99,0:16:41.12,Default,,0,0,0,,{\i1}Con đường dẫn đến cửa nhà{\i0}\N{\i1}cứ như đường mòn của thú hoang vậy!{\i0}
Dialogue: 0,0:16:41.21,0:16:43.25,Default,,0,0,0,,Đây thực sự là nhà của Kuta-san sao?
Dialogue: 0,0:16:43.58,0:16:44.83,Default,,0,0,0,,Có vẻ là vậy.
Dialogue: 0,0:16:48.30,0:16:50.59,Default,,0,0,0,,St. Andrews lúc hoàng hôn.
Dialogue: 0,0:16:51.05,0:16:53.09,Default,,0,0,0,,Hoặc có thể là bình minh.
Dialogue: 0,0:16:54.43,0:16:59.39,Default,,0,0,0,,Đã xem vô số lần trên TV rồi, nhưng\Nnhìn trực tiếp lại mang đến ấn tượng khác hẳn.
Dialogue: 0,0:16:59.72,0:17:00.60,Default,,0,0,0,,Ai đó?
Dialogue: 0,0:17:04.23,0:17:07.94,Default,,0,0,0,,Nghe nói ông đã xây\Nmột sân golf nhỏ trên hòn đảo này.
Dialogue: 0,0:17:08.19,0:17:09.86,Default,,0,0,0,,Có đúng vậy không?
Dialogue: 0,0:17:10.03,0:17:13.36,Default,,0,0,0,,-Ừ, chắc là vậy.\N-Xin ông đấy!
Dialogue: 0,0:17:13.65,0:17:16.16,Default,,0,0,0,,Ông có thể cho Tonbo chơi ở đó được không?
Dialogue: 0,0:17:20.79,0:17:22.20,Default,,0,0,0,,Đúng là một sân golf tuyệt đẹp!
Dialogue: 0,0:17:22.45,0:17:24.67,Default,,0,0,0,,Khác hoàn toàn với Hinoshima!
Dialogue: 0,0:17:24.75,0:17:26.17,Default,,0,0,0,,{\i1}Igaiga đã từng nói rồi nhỉ.{\i0}
Dialogue: 0,0:17:26.88,0:17:29.17,Default,,0,0,0,,Bảo là sân golf này...\NGì ấy nhỉ?
Dialogue: 0,0:17:29.63,0:17:31.30,Default,,0,0,0,,"Bữa tối khó!"
Dialogue: 0,0:17:31.46,0:17:32.97,Default,,0,0,0,,Không! Là siêu khó!
Dialogue: 0,0:17:33.17,0:17:35.76,Default,,0,0,0,,"Bữa tối" thì liên quan gì chứ!
Dialogue: 0,0:17:48.98,0:17:51.28,Default,,0,0,0,,Đi nào! Quả bóng cá chuồn!
Dialogue: 0,0:17:54.57,0:17:55.99,Default,,0,0,0,,Cá chuồn, rẽ đi!
Dialogue: 0,0:18:01.95,0:18:04.33,Default,,0,0,0,,Bay lên, bay lên nào!
Dialogue: 0,0:18:09.88,0:18:11.00,Default,,0,0,0,,Làm được rồi!
Dialogue: 0,0:18:12.92,0:18:16.47,Default,,0,0,0,,Sân golf một lỗ của Kuta-san\Nthực sự rất vui.
Dialogue: 0,0:18:17.22,0:18:18.89,Default,,0,0,0,,{\i1}Và cũng "bữa tối" khó nữa.{\i0}
Dialogue: 0,0:18:19.18,0:18:20.05,Default,,0,0,0,,{\i1}Siêu khó!{\i0}
Dialogue: 0,0:18:20.30,0:18:22.31,Default,,0,0,0,,{\i1}Là cố tình nói vậy đúng không!{\i0}
Dialogue: 0,0:18:26.64,0:18:28.10,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:18:28.23,0:18:30.44,Default,,0,0,0,,Thấy hòn đảo thế nào?
Dialogue: 0,0:18:31.57,0:18:36.20,Default,,0,0,0,,Chơi ở một lỗ mới,\Nvà vùng green nhanh nhất từng thấy!
Dialogue: 0,0:18:36.57,0:18:37.78,Default,,0,0,0,,Thấy sao?
Dialogue: 0,0:18:38.16,0:18:38.99,Default,,0,0,0,,Rất vui.
Dialogue: 0,0:18:39.70,0:18:40.53,Default,,0,0,0,,Thực sự rất vui.
Dialogue: 0,0:18:44.45,0:18:47.50,Default,,0,0,0,,{\i1}Đưa Tonbo đến đảo Akureki{\i0}\N{\i1}là một quyết định đúng đắn.{\i0}
Dialogue: 0,0:18:48.12,0:18:49.67,Default,,0,0,0,,{\i1}Thực sự tin là vậy.{\i0}
Dialogue: 0,0:18:50.67,0:18:51.79,Default,,0,0,0,,{\i1}Biết không,{\i0}
Dialogue: 0,0:18:52.13,0:18:56.92,Default,,0,0,0,,{\i1}có lẽ cuối cùng đã hiểu hết những{\i0}\N{\i1}điều Igaiga từng nói rồi.{\i0}
Dialogue: 0,0:18:57.09,0:18:59.89,Default,,0,0,0,,{\i1}Ồ? Vậy đã nói những gì nào?{\i0}
Dialogue: 0,0:19:00.93,0:19:02.18,Default,,0,0,0,,{\i1}Ưm...{\i0}
Dialogue: 0,0:19:03.22,0:19:05.27,Default,,0,0,0,,{\i1}Được rồi, bỏ qua chuyện đó đi!{\i0}
Dialogue: 0,0:19:05.47,0:19:06.52,Default,,0,0,0,,{\i1}Này!{\i0}
Dialogue: 0,0:19:07.02,0:19:09.65,Default,,0,0,0,,Bây giờ đã có bốn cây gậy rồi.
Dialogue: 0,0:19:11.19,0:19:14.07,Default,,0,0,0,,Igaiga, Tsubura.
Dialogue: 0,0:19:14.90,0:19:16.74,Default,,0,0,0,,Cả Kuta-san nữa!\NVà tất nhiên là...
Dialogue: 0,0:19:19.74,0:19:22.16,Default,,0,0,0,,Bố và mẹ.
Dialogue: 0,0:19:22.91,0:19:25.95,Default,,0,0,0,,Đã đưa ra một quyết định lớn rồi.
Dialogue: 0,0:19:30.75,0:19:32.17,Default,,0,0,0,,Đã lựa chọn rồi.
Dialogue: 0,0:19:33.13,0:19:35.75,Default,,0,0,0,,Mùa xuân năm sau, sẽ rời khỏi đảo.
Dialogue: 0,0:19:40.18,0:19:43.60,Default,,0,0,0,,Bằng tốt nghiệp đây, Tonbo.
Dialogue: 0,0:19:44.89,0:19:48.68,Default,,0,0,0,,{\i1}Đã lớn lên rất nhiều từ{\i0}\N{\i1}cuối mùa hè cho đến lúc tốt nghiệp.{\i0}
Dialogue: 0,0:19:48.85,0:19:51.69,Default,,0,0,0,,{\i1}Chớp mắt một cái đã thấy mặc đồng phục rồi.{\i0}
Dialogue: 0,0:19:52.35,0:19:54.36,Default,,0,0,0,,{\i1}Sao vậy, Igaiga?{\i0}
Dialogue: 0,0:19:54.57,0:19:58.28,Default,,0,0,0,,{\i1}Nhìn thấy Tonbo trưởng thành thật là một niềm vui lớn.{\i0}
Dialogue: 0,0:19:58.78,0:20:01.66,Default,,0,0,0,,{\i1}Người ta nói càng lớn tuổi{\i0}\N{\i1}thì càng dễ xúc động mà.{\i0}
Dialogue: 0,0:20:02.57,0:20:07.91,Default,,0,0,0,,{\i1}Dù có lớn hơn chút, nhưng cũng không{\i0}\N{\i1}muốn bị một đứa nhóc nói câu đó đâu!{\i0}
Dialogue: 0,0:20:08.83,0:20:11.50,Default,,0,0,0,,{\i1}Đừng có làm cái mặt đáng sợ đó lúc khóc chứ!{\i0}
Dialogue: 0,0:20:19.42,0:20:22.18,Default,,0,0,0,,Ngày mai đừng có ngủ quên đấy.
Dialogue: 0,0:20:22.76,0:20:23.59,Default,,0,0,0,,Biết rồi.
Dialogue: 0,0:20:24.01,0:20:27.89,Default,,0,0,0,,Vào đêm cuối cùng này,\Nchẳng biết phải nói gì nữa.
Dialogue: 0,0:20:28.02,0:20:31.56,Default,,0,0,0,,Dù có\Nrất nhiều chuyện muốn nói.
Dialogue: 0,0:20:32.19,0:20:38.28,Default,,0,0,0,,{\i1}Chính Gon-jii là người luôn{\i0}\N{\i1}thúc đẩy và ủng hộ từ phía sau.{\i0}
Dialogue: 0,0:20:38.69,0:20:39.53,Default,,0,0,0,,{\i1}Đúng vậy.{\i0}
Dialogue: 0,0:20:40.19,0:20:44.62,Default,,0,0,0,,{\i1}Trên đời này không ai quan tâm{\i0}\N{\i1}đến Tonbo hơn Gon-jii đâu.{\i0}
Dialogue: 0,0:20:45.91,0:20:48.04,Default,,0,0,0,,Nhờ mọi người mới có ngày hôm nay!
Dialogue: 0,0:20:48.45,0:20:49.29,Default,,0,0,0,,Cảm ơn mọi người!
Dialogue: 0,0:20:49.58,0:20:50.66,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:21:07.22,0:21:09.14,Default,,0,0,0,,Sẽ không quên mọi người đâu!
Dialogue: 0,0:21:09.89,0:21:14.19,Default,,0,0,0,,Ông là ông nội,\Ncòn cháu là cháu gái của ông mà!
Dialogue: 0,0:21:14.56,0:21:18.11,Default,,0,0,0,,-Gon-jii.\N-Bất cứ lúc nào!
Dialogue: 0,0:21:18.32,0:21:20.61,Default,,0,0,0,,Cứ quay về bất cứ lúc nào!
Dialogue: 0,0:21:20.78,0:21:23.70,Default,,0,0,0,,Nếu thấy khó khăn quá,\Nthì cứ về với ông già này!
Dialogue: 0,0:21:24.49,0:21:29.20,Default,,0,0,0,,Lúc nào cũng có thể trở về hòn đảo này!
Dialogue: 0,0:21:30.33,0:21:34.71,Default,,0,0,0,,Gon-jii. Gon-jii!
Dialogue: 0,0:21:35.04,0:21:36.04,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:21:36.50,0:21:37.54,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:21:38.42,0:21:40.21,Default,,0,0,0,,Gon-jii!
Dialogue: 0,0:21:42.88,0:21:44.93,Default,,0,0,0,,Nhìn cho kỹ nhé, Tonbo.
Dialogue: 0,0:21:45.43,0:21:47.80,Default,,0,0,0,,Hòn đảo đó là quê hương của Tonbo.
Dialogue: 0,0:21:48.76,0:21:50.89,Default,,0,0,0,,Là nơi câu chuyện bắt đầu.
Dialogue: 0,0:21:51.89,0:21:54.10,Default,,0,0,0,,Là mái nhà đáng để tự hào.
Dialogue: 0,0:21:54.94,0:21:55.98,Default,,0,0,0,,Nhìn cho kỹ vào.
Dialogue: 0,0:21:57.86,0:22:00.61,Default,,0,0,0,,Tonbo, đây mới chỉ là khởi đầu thôi.
Dialogue: 0,0:22:01.23,0:22:02.07,Default,,0,0,0,,Vâng.
Dialogue: 0,0:22:02.69,0:22:04.03,Default,,0,0,0,,Cuối cùng cũng đến lúc rồi.
Dialogue: 0,0:22:05.11,0:22:07.45,Default,,0,0,0,,Nhìn kìa! Thấy Kagoshima rồi!
Dialogue: 0,0:22:07.61,0:22:10.08,Default,,0,0,0,,Oa, ánh đèn tuyệt quá!
Dialogue: 0,0:22:10.28,0:22:13.62,Default,,0,0,0,,-Đi ăn món gì đó ngon ngon không?\N-Hoan hô!
Dialogue: 0,0:22:13.75,0:22:16.29,Default,,0,0,0,,Đãi một bữa\Nbuffet ăn thỏa thích nhé!
Dialogue: 0,0:22:16.37,0:22:19.79,Default,,0,0,0,,Cái gì? Chờ chút đã, Tonbo.
Dialogue: 0,0:23:54.18,0:23:55.47,Default,,0,0,0,,Đi nào!
Dialogue: 0,0:23:55.56,0:23:59.48,Default,,0,0,0,,Đó là ánh mắt của người\Nchỉ lớn lên bằng cách nhìn về phía chân trời sao?
Dialogue: 0,0:23:59.56,0:24:01.10,Default,,0,0,0,,Tonbo đến rồi đây.
Dialogue: 0,0:24:02.81,0:24:04.77,Default,,0,0,0,,Tập tiếp theo của Oi! Tonbo!
Dialogue: 0,0:24:04.94,0:24:07.90,Default,,0,0,0,,Tonbo Ra Mắt Sân Golf Lớn!