Dialogue: 0,0:00:08.30,0:00:09.92,Default,,0,0,0,,Đến rồi kìa!
Dialogue: 0,0:00:10.59,0:00:11.67,Default,,0,0,0,,Oa!
Dialogue: 0,0:00:11.76,0:00:13.51,Default,,0,0,0,,Giờ nó lại thổi từ hướng này!
Dialogue: 0,0:00:15.34,0:00:17.51,Default,,0,0,0,,Gió thổi loạn xạ quá!
Dialogue: 0,0:00:17.97,0:00:19.72,Default,,0,0,0,,Có vẻ nhóm đi trước đánh xong rồi!
Dialogue: 0,0:00:23.10,0:00:25.73,Default,,0,0,0,,{\i1}Gió ở đây khác với{\i0}\N{\i1}trên green.{\i0}
Dialogue: 0,0:00:26.10,0:00:28.90,Default,,0,0,0,,{\i1}Giờ nó đang thổi theo hướng{\i0}\N{\i1}hoàn toàn ngược lại.{\i0}
Dialogue: 0,0:00:29.23,0:00:31.78,Default,,0,0,0,,{\i1}Không chỉ đơn thuần là{\i0}\N{\i1}đổi hướng đâu.{\i0}
Dialogue: 0,0:00:32.03,0:00:33.86,Default,,0,0,0,,Với vị trí cờ hôm nay,
Dialogue: 0,0:00:33.95,0:00:36.28,Default,,0,0,0,,dù có đánh trượt cờ\Nsang bên trái,
Dialogue: 0,0:00:36.37,0:00:39.83,Default,,0,0,0,,thì vẫn còn cú approach lên dốc.\NGiữ par sẽ dễ dàng thôi.
Dialogue: 0,0:00:40.62,0:00:44.83,Default,,0,0,0,,Dù có đưa ra lời khuyên nên nhắm đi đâu,\Nthì với cơn gió này cũng chẳng dễ dàng gì.
Dialogue: 0,0:00:45.46,0:00:49.13,Default,,0,0,0,,{\i1}Ngay cả Tonbo cũng sẽ không thể{\i0}\N{\i1}lợi dụng cơn gió này được đâu.{\i0}
Dialogue: 0,0:00:49.50,0:00:53.34,Default,,0,0,0,,{\i1}Rất khó để nương theo gió khi{\i0}\N{\i1}không thể đoán được hướng của nó.{\i0}
Dialogue: 0,0:00:53.80,0:00:57.68,Default,,0,0,0,,{\i1}Phán đoán duy nhất có thể đưa ra{\i0}\N{\i1}là chọn gậy nào để đánh thôi.{\i0}
Dialogue: 0,0:01:00.51,0:01:01.39,Default,,0,0,0,,{\i1}Không...{\i0}
Dialogue: 0,0:01:01.68,0:01:04.52,Default,,0,0,0,,{\i1}Tonbo đã cầm cây gậy đó{\i0}\N{\i1}từ nãy đến giờ rồi.{\i0}
Dialogue: 0,0:01:04.60,0:01:07.40,Default,,0,0,0,,{\i1}Đã biết mình muốn dùng gậy nào{\i0}\N{\i1}ngay từ đầu rồi.{\i0}
Dialogue: 0,0:01:07.60,0:01:12.28,Default,,0,0,0,,{\i1}Nghĩa là dù gió có đổi hướng liên tục thế này{\i0}\N{\i1}thì vẫn đọc được hướng gió sao?{\i0}
Dialogue: 0,0:01:16.24,0:01:17.20,Default,,0,0,0,,{\i1}Gió đang đùa giỡn.{\i0}
Dialogue: 0,0:01:18.20,0:01:19.83,Default,,0,0,0,,{\i1}Cứ như đang đánh golf trên đảo vậy.{\i0}
Dialogue: 0,0:02:52.67,0:02:53.63,Default,,0,0,0,,{\i1}Gậy sắt số 3.{\i0}
Dialogue: 0,0:02:54.42,0:02:58.47,Default,,0,0,0,,{\i1}150 yard đến cờ.{\i0}\N{\i1}Đang đoán là gió ngược sao?{\i0}
Dialogue: 0,0:02:59.13,0:03:02.18,Default,,0,0,0,,{\i1}Lúc chơi trên đảo{\i0}\N{\i1}chẳng bao giờ đội mũ cả.{\i0}
Dialogue: 0,0:03:02.39,0:03:04.64,Default,,0,0,0,,{\i1} Tóc lúc nào cũng{\i0}\N{\i1}bay phần phật thế này.{\i0}
Dialogue: 0,0:03:04.89,0:03:06.06,Default,,0,0,0,,{\i1}Có cả Igaiga ở đây nữa!{\i0}
Dialogue: 0,0:03:06.39,0:03:07.77,Default,,0,0,0,,{\i1}Mặt đất thì cứng.{\i0}
Dialogue: 0,0:03:08.27,0:03:10.31,Default,,0,0,0,,{\i1}Vui quá đi mất!{\i0}
Dialogue: 0,0:03:16.28,0:03:18.61,Default,,0,0,0,,Cú swing kiểu gì vậy?
Dialogue: 0,0:03:21.86,0:03:22.91,Default,,0,0,0,,Đánh lăn bóng sao?
Dialogue: 0,0:03:23.03,0:03:26.20,Default,,0,0,0,,Né hoàn toàn gió luôn kìa!
Dialogue: 0,0:03:32.67,0:03:33.54,Default,,0,0,0,,Vừa rồi có phải...?
Dialogue: 0,0:03:33.79,0:03:35.00,Default,,0,0,0,,Hole-in-one không?
Dialogue: 0,0:03:38.17,0:03:39.05,Default,,0,0,0,,Chắc là không rồi.
Dialogue: 0,0:03:40.92,0:03:43.89,Default,,0,0,0,,Bóng đã rơi vào \Nvị trí đẹp nhất có thể rồi.
Dialogue: 0,0:03:45.76,0:03:49.06,Default,,0,0,0,,{\i1}Mình sẽ chẳng bao giờ{\i0}\N{\i1}nghĩ đến việc làm vậy. {\i0}
Dialogue: 0,0:03:49.31,0:03:51.89,Default,,0,0,0,,{\i1}Mà dù có nghĩ ra,{\i0}\N{\i1}cũng sẽ chẳng làm đâu!{\i0}
Dialogue: 0,0:03:53.98,0:03:58.03,Default,,0,0,0,,{\i1}Cảm giác không thể gọi thế là ngầu được...{\i0}\N{\i1}Đấy có thực sự gọi là golf không vậy?{\i0}
Dialogue: 0,0:03:58.11,0:04:00.86,Default,,0,0,0,,{\i1}Khoan đã... mình là ai mà phán xét chứ?{\i0}
Dialogue: 0,0:04:02.74,0:04:05.03,Default,,0,0,0,,{\i1}Mình là ai mà quyết định xem thế nào mới là golf thực sự cơ chứ?{\i0}
Dialogue: 0,0:04:05.70,0:04:06.99,Default,,0,0,0,,Par đẹp đấy.
Dialogue: 0,0:04:08.54,0:04:09.49,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:04:16.17,0:04:17.21,Default,,0,0,0,,{\i1}Tonbo giữ được par rồi.{\i0}
Dialogue: 0,0:04:17.79,0:04:19.71,Default,,0,0,0,,{\i1}Tổng điểm vẫn là even par.{\i0}
Dialogue: 0,0:04:20.13,0:04:23.05,Default,,0,0,0,,{\i1}Đã vượt qua hố khó nhằn này{\i0}\N{\i1}một cách dễ dàng.{\i0}
Dialogue: 0,0:04:26.80,0:04:29.89,Default,,0,0,0,,{\i1}Có vẻ gió chủ yếu thổi{\i0}\N{\i1}sang bên phải.{\i0}
Dialogue: 0,0:04:30.68,0:04:32.10,Default,,0,0,0,,Cho gậy sắt số 7 đi.
Dialogue: 0,0:04:32.98,0:04:34.39,Default,,0,0,0,,{\i1}Mình sẽ đánh cược vào điều đó.{\i0}
Dialogue: 0,0:04:44.24,0:04:46.62,Default,,0,0,0,,{\i1}Không. Gió đang thổi sang trái.{\i0}
Dialogue: 0,0:05:01.46,0:05:03.22,Default,,0,0,0,,{\i1}Đổi thành gió ngược rồi. {\i0}
Dialogue: 0,0:05:03.30,0:05:05.63,Default,,0,0,0,,{\i1}Thế này thì tiêu tùng cả đám mất.{\i0}
Dialogue: 0,0:05:05.80,0:05:07.72,Default,,0,0,0,,{\i1}Tonbo sẽ vươn lên dẫn đầu mất!{\i0}
Dialogue: 0,0:05:08.47,0:05:09.39,Default,,0,0,0,,{\i1}Không. {\i0}
Dialogue: 0,0:05:09.47,0:05:12.64,Default,,0,0,0,,{\i1}Nếu kiên trì, mình có thể vượt qua{\i0}\N{\i1}Ema và Hinoki. {\i0}
Dialogue: 0,0:05:12.72,0:05:14.14,Default,,0,0,0,,{\i1}Mình có thể giành vị trí dẫn đầu!{\i0}
Dialogue: 0,0:05:14.94,0:05:16.23,Default,,0,0,0,,{\i1}Để làm được điều đó...{\i0}
Dialogue: 0,0:05:16.90,0:05:17.90,Default,,0,0,0,,Gậy spoon sao?
Dialogue: 0,0:05:20.65,0:05:21.65,Default,,0,0,0,,Đó là...
Dialogue: 0,0:05:23.40,0:05:24.70,Default,,0,0,0,,{\i1}Đang làm theo cách của Tonbo kìa.{\i0}
Dialogue: 0,0:05:29.45,0:05:31.20,Default,,0,0,0,,{\i1}Nhắm vào cùng một vị trí.{\i0}
Dialogue: 0,0:05:31.74,0:05:35.71,Default,,0,0,0,,{\i1}Mình không thể nương tay được.{\i0}\N{\i1}Mình sẽ chiến thắng!{\i0}
Dialogue: 0,0:05:45.17,0:05:49.22,Default,,0,0,0,,{\i1}Đánh gậy wedge và putter bằng{\i0}\N{\i1}tay phải. Rất giỏi nữa.{\i0}
Dialogue: 0,0:05:49.60,0:05:50.60,Default,,0,0,0,,Tới lượt mình rồi.
Dialogue: 0,0:05:50.80,0:05:52.26,Default,,0,0,0,,{\i1}Đánh rất mạnh,{\i0}
Dialogue: 0,0:05:52.35,0:05:55.93,Default,,0,0,0,,{\i1}nhưng có lẽ lối chơi trước đây{\i0}\N{\i1}đã sử dụng những kỹ thuật tinh tế.{\i0}
Dialogue: 0,0:06:06.07,0:06:09.28,Default,,0,0,0,,Không ai có thể\Nlơ là dù chỉ một giây.
Dialogue: 0,0:06:09.74,0:06:11.62,Default,,0,0,0,,{\i1}Mình nghĩ bản thân đang trụ vững.{\i0}
Dialogue: 0,0:06:11.70,0:06:15.62,Default,,0,0,0,,{\i1}Dù vậy, hố số 7{\i0}\N{\i1}chính là bước ngoặt.{\i0}
Dialogue: 0,0:06:15.79,0:06:18.08,Default,,0,0,0,,{\i1}Tất cả đều hòa nhau cho đến lúc đó.{\i0}
Dialogue: 0,0:06:31.85,0:06:34.06,Default,,0,0,0,,Có vẻ như\Nnhóm thứ hai đánh xong rồi.
Dialogue: 0,0:06:34.18,0:06:35.14,Default,,0,0,0,,Ừ.
Dialogue: 0,0:06:35.27,0:06:37.43,Default,,0,0,0,,Không biết nửa đầu của Tonbo thế nào rồi nhỉ?
Dialogue: 0,0:06:38.02,0:06:39.85,Default,,0,0,0,,Cho đến nay chỉ có vài người
Dialogue: 0,0:06:39.94,0:06:42.94,Default,,0,0,0,,kết thúc nửa đầu\Nvới số điểm ở đầu 3.
Dialogue: 0,0:06:43.19,0:06:48.11,Default,,0,0,0,,Và những người đạt được điều đó\Nđều đánh xong trước khi gió nổi lên.
Dialogue: 0,0:06:48.45,0:06:50.36,Default,,0,0,0,,Những người còn lại đều ở đầu 4.
Dialogue: 0,0:06:50.70,0:06:52.78,Default,,0,0,0,,Nên dù có rớt\Nnăm hay sáu gậy,
Dialogue: 0,0:06:52.95,0:06:54.24,Default,,0,0,0,,thì vẫn đang ở mức trung bình thôi.
Dialogue: 0,0:06:54.58,0:06:55.66,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:06:57.91,0:06:58.96,Default,,0,0,0,,Igaiga đang xem kìa.
Dialogue: 0,0:07:00.00,0:07:02.00,Default,,0,0,0,,Đang đánh gậy thứ ba\Ntừ fairway.
Dialogue: 0,0:07:02.25,0:07:04.50,Default,,0,0,0,,Chúng ta đang ở ngay sau cờ.\NCó nên di chuyển không?
Dialogue: 0,0:07:05.21,0:07:08.30,Default,,0,0,0,,Theo anh\Ntừ đó sẽ đánh thế nào?
Dialogue: 0,0:07:09.59,0:07:12.43,Default,,0,0,0,,Còn khoảng 35 yard\Nđể approach.
Dialogue: 0,0:07:12.68,0:07:14.72,Default,,0,0,0,,Không cần phải\Nlàm gì đặc biệt cả.
Dialogue: 0,0:07:14.81,0:07:17.98,Default,,0,0,0,,Chỉ cần tập trung vào khoảng cách,
Dialogue: 0,0:07:18.06,0:07:20.14,Default,,0,0,0,,nhưng với cơn gió này\Nthì sẽ không dễ đâu.
Dialogue: 0,0:07:20.98,0:07:23.11,Default,,0,0,0,,Ngay cả khi là gió ngược sao?
Dialogue: 0,0:07:23.36,0:07:25.98,Default,,0,0,0,,Nếu đánh quá tay và\Nbóng vượt quá cờ,
Dialogue: 0,0:07:26.11,0:07:28.69,Default,,0,0,0,,cú đánh thứ tư\Nsẽ là một cú putt xuống dốc.
Dialogue: 0,0:07:28.82,0:07:31.11,Default,,0,0,0,,Lúc đó gió sẽ\Nthổi từ phía sau bóng,
Dialogue: 0,0:07:31.28,0:07:33.37,Default,,0,0,0,,đẩy bóng đi rất mạnh.
Dialogue: 0,0:07:33.62,0:07:37.66,Default,,0,0,0,,Nếu không vào lỗ,\Ngió sẽ cuốn nó đi mất.
Dialogue: 0,0:07:37.83,0:07:38.79,Default,,0,0,0,,Ra là vậy.
Dialogue: 0,0:07:39.08,0:07:40.91,Default,,0,0,0,,Phải để bóng rơi dưới lỗ.
Dialogue: 0,0:07:41.12,0:07:44.04,Default,,0,0,0,,Dù không hoàn hảo,\Nthì cũng phải để lại một cú putt lên dốc.
Dialogue: 0,0:07:44.25,0:07:45.67,Default,,0,0,0,,Đó là cách approach.
Dialogue: 0,0:07:46.50,0:07:49.34,Default,,0,0,0,,{\i1}Igaiga đang ở bên cạnh mình. Được rồi.{\i0}
Dialogue: 0,0:07:52.01,0:07:53.05,Default,,0,0,0,,Ồ, Tonbo.
Dialogue: 0,0:08:09.57,0:08:11.40,Default,,0,0,0,,Được rồi! Trúng đích!
Dialogue: 0,0:08:13.28,0:08:14.20,Default,,0,0,0,,Biết ngay mà.
Dialogue: 0,0:08:14.32,0:08:15.32,Default,,0,0,0,,Anh biết sao?
Dialogue: 0,0:08:15.70,0:08:17.87,Default,,0,0,0,,Trên đảo hay làm thế lắm.
Dialogue: 0,0:08:17.95,0:08:19.79,Default,,0,0,0,,Bằng cách đánh một cú full lob\Nngược chiều gió,
Dialogue: 0,0:08:20.25,0:08:22.41,Default,,0,0,0,,bóng sẽ rơi xuống\Nvà dừng hẳn lại.
Dialogue: 0,0:08:23.33,0:08:25.63,Default,,0,0,0,,Tonbo rất thích kiểu đánh đó.
Dialogue: 0,0:08:27.21,0:08:30.46,Default,,0,0,0,,Đang định làm Igaiga hết hồn cơ.
Dialogue: 0,0:08:31.34,0:08:33.51,Default,,0,0,0,,Sao không đánh lăn bóng đi?
Dialogue: 0,0:08:33.59,0:08:36.55,Default,,0,0,0,,Chẳng có ai bình thường\Nmà lại đánh lob ở đây cả!
Dialogue: 0,0:08:43.44,0:08:45.48,Default,,0,0,0,,Được rồi! Điểm birdie đầu tiên!
Dialogue: 0,0:08:46.56,0:08:48.98,Default,,0,0,0,,Tonbo vừa chip in sao?
Dialogue: 0,0:08:49.32,0:08:50.61,Default,,0,0,0,,Birdie ư?
Dialogue: 0,0:08:50.82,0:08:52.49,Default,,0,0,0,,Đang hòa với Ema và mình rồi.
Dialogue: 0,0:08:54.28,0:08:55.61,Default,,0,0,0,,Điểm birdie đầu tiên hả?
Dialogue: 0,0:08:55.70,0:08:57.37,Default,,0,0,0,,Gió to phết nhỉ.
Dialogue: 0,0:08:57.45,0:08:59.24,Default,,0,0,0,,Bị bao nhiêu bogey rồi?
Dialogue: 0,0:08:59.45,0:09:00.45,Default,,0,0,0,,Không có cái nào.
Dialogue: 0,0:09:02.96,0:09:04.41,Default,,0,0,0,,Đang 1 under sao?
Dialogue: 0,0:09:04.83,0:09:06.00,Default,,0,0,0,,Ừ!
Dialogue: 0,0:09:12.21,0:09:13.63,Default,,0,0,0,,Vậy là không ai đạt được\Ngreen in regulation cả.
Dialogue: 0,0:09:13.97,0:09:15.38,Default,,0,0,0,,Kể cả nhóm cuối cùng,
Dialogue: 0,0:09:15.47,0:09:17.93,Default,,0,0,0,,cũng chẳng ai đánh tốt\Ntrong cơn gió này cả.
Dialogue: 0,0:09:21.72,0:09:23.18,Default,,0,0,0,,Đang mở mặt gậy kìa.
Dialogue: 0,0:09:23.35,0:09:24.94,Default,,0,0,0,,Định đánh lob sao?
Dialogue: 0,0:09:25.35,0:09:28.69,Default,,0,0,0,,Không. Chỉ có Tonbo mới\Nliều lĩnh như vậy thôi.
Dialogue: 0,0:09:37.24,0:09:38.95,Default,,0,0,0,,Đủ rồi! Dừng lại đi!
Dialogue: 0,0:09:42.12,0:09:43.83,Default,,0,0,0,,Đánh dấu lại đây!
Dialogue: 0,0:09:44.12,0:09:45.54,Default,,0,0,0,,Cú approach tốt đấy.
Dialogue: 0,0:09:45.87,0:09:46.83,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:09:50.63,0:09:52.42,Default,,0,0,0,,{\i1}Đây là thời khắc quyết định. {\i0}
Dialogue: 0,0:09:52.71,0:09:55.22,Default,,0,0,0,,{\i1}Nếu điểm của mình thấp hơn Tsubura{\i0}
Dialogue: 0,0:09:55.30,0:09:56.84,Default,,0,0,0,,{\i1}thì sẽ chẳng còn cơ hội chiến thắng.{\i0}
Dialogue: 0,0:09:57.01,0:10:00.35,Default,,0,0,0,,{\i1}Nếu có thể duy trì phong độ cho đến khi{\i0}\N{\i1}điểm của Tsubura tuột dốc{\i0}
Dialogue: 0,0:10:01.05,0:10:04.31,Default,,0,0,0,,{\i1}mình sẽ có thể gây áp lực{\i0}\N{\i1}và lấy lại được đà!{\i0}
Dialogue: 0,0:10:06.14,0:10:10.06,Default,,0,0,0,,{\i1}Không được mất bình tĩnh!{\i0}\N{\i1}Mọi thứ từ nãy đến giờ vẫn đang diễn ra tốt đẹp.{\i0}
Dialogue: 0,0:10:10.56,0:10:13.11,Default,,0,0,0,,{\i1}Phải kết thúc nửa đầu{\i0}\N{\i1}với lợi thế dẫn trước hai gậy.{\i0}
Dialogue: 0,0:10:22.03,0:10:23.54,Default,,0,0,0,,{\i1}Đánh trượt rồi!{\i0}
Dialogue: 0,0:10:40.76,0:10:41.76,Default,,0,0,0,,{\i1}Chính là lúc này.{\i0}
Dialogue: 0,0:10:41.85,0:10:43.76,Default,,0,0,0,,{\i1}Mọi chuyện đang xoay chuyển theo hướng có lợi cho mình. {\i0}
Dialogue: 0,0:10:43.85,0:10:46.02,Default,,0,0,0,,{\i1}Tsubura sẽ bị{\i0}\N{\i1}double bogey mất.{\i0}
Dialogue: 0,0:10:47.18,0:10:50.77,Default,,0,0,0,,{\i1}Mình đang hả hê trước sai lầm của đối thủ.{\i0}\N{\i1}Đang mong rắc rối xảy ra.{\i0}
Dialogue: 0,0:10:50.85,0:10:51.94,Default,,0,0,0,,{\i1} Nhưng tại sao chứ?{\i0}
Dialogue: 0,0:10:53.44,0:10:55.44,Default,,0,0,0,,{\i1}Tại sao không thể suy nghĩ tích cực hơn?{\i0}
Dialogue: 0,0:10:55.53,0:11:00.61,Default,,0,0,0,,{\i1}Tại sao không thể tập trung{\i0}\N{\i1}làm tốt nhất khả năng của mình?{\i0}
Dialogue: 0,0:11:02.20,0:11:03.33,Default,,0,0,0,,Hinoki.
Dialogue: 0,0:11:03.58,0:11:04.91,Default,,0,0,0,,Không đánh nháp sao?
Dialogue: 0,0:11:05.99,0:11:10.12,Default,,0,0,0,,{\i1}Mình không thích bản thân lúc này chút nào.{\i0}\N{\i1}Biết ngay là sẽ phải trả giá cho sự xấu tính đó mà.{\i0}
Dialogue: 0,0:11:17.63,0:11:19.47,Default,,0,0,0,,{\i1}Biết ngay mà, đây là hình phạt dành cho mình!{\i0}
Dialogue: 0,0:11:30.35,0:11:32.27,Default,,0,0,0,,Hoặc... có thể là không.
Dialogue: 0,0:11:51.12,0:11:54.75,Default,,0,0,0,,Họ bảo mình là người duy nhất\Nhoàn thành nửa đầu dưới par đấy!
Dialogue: 0,0:11:55.79,0:11:57.00,Default,,0,0,0,,Có vẻ vậy.
Dialogue: 0,0:11:57.30,0:11:58.96,Default,,0,0,0,,Igaiga không vui sao?
Dialogue: 0,0:12:00.30,0:12:02.63,Default,,0,0,0,,Sao lại tỏ thái độ như vậy chứ?
Dialogue: 0,0:12:03.05,0:12:07.10,Default,,0,0,0,,Nghĩ đây đã là nửa chặng đường\Nthì quá thong thả rồi đấy!
Dialogue: 0,0:12:07.43,0:12:11.23,Default,,0,0,0,,Trong golf chuyên nghiệp, qua hố thứ mười\Nmới là được một nửa!
Dialogue: 0,0:12:11.69,0:12:15.27,Default,,0,0,0,,Ba hố cuối cùng đòi hỏi năng lượng
Dialogue: 0,0:12:15.40,0:12:18.90,Default,,0,0,0,,ngang bằng hoặc thậm chí nhiều hơn\Nso với mười lăm hố trước đó.
Dialogue: 0,0:12:19.69,0:12:20.61,Default,,0,0,0,,Trời ạ.
Dialogue: 0,0:12:20.94,0:12:23.74,Default,,0,0,0,,Cứ tưởng Igaiga\Nsẽ tự hào lắm cơ.
Dialogue: 0,0:12:23.95,0:12:24.99,Default,,0,0,0,,Nhưng xem ra không phải rồi.
Dialogue: 0,0:12:25.28,0:12:26.53,Default,,0,0,0,,Chưa biết được đâu.
Dialogue: 0,0:12:32.83,0:12:36.00,Default,,0,0,0,,Tonbo kết thúc nửa đầu\Ndưới par rồi kìa!
Dialogue: 0,0:12:36.08,0:12:38.00,Default,,0,0,0,,Chỉ cách người dẫn đầu\Ncó một gậy thôi!
Dialogue: 0,0:12:38.34,0:12:40.38,Default,,0,0,0,,Có khi có cơ hội thật đấy!
Dialogue: 0,0:12:40.46,0:12:43.01,Default,,0,0,0,,Phải báo cho mọi người biết mới được!
Dialogue: 0,0:12:43.59,0:12:44.51,Default,,0,0,0,,Khoan đã.
Dialogue: 0,0:12:44.59,0:12:49.52,Default,,0,0,0,,Bunpei không có điện thoại.\NBiết nhắn cho ai bây giờ?
Dialogue: 0,0:12:50.64,0:12:51.68,Default,,0,0,0,,Biết rồi!
Dialogue: 0,0:12:54.35,0:12:55.35,Default,,0,0,0,,Vâng?
Dialogue: 0,0:12:55.48,0:12:57.44,Default,,0,0,0,,Tòa thị chính làng Toshima xin nghe.
Dialogue: 0,0:12:58.19,0:13:00.53,Default,,0,0,0,,X-xin chào, tôi là Igarashi.
Dialogue: 0,0:13:00.61,0:13:03.15,Default,,0,0,0,,Làm việc tại\NTrung tâm Phát triển Hinoshima.
Dialogue: 0,0:13:03.24,0:13:05.82,Default,,0,0,0,,Mọi người trên đảo hay gọi là "Igaiga".
Dialogue: 0,0:13:06.49,0:13:07.95,Default,,0,0,0,,Vâng...
Dialogue: 0,0:13:10.79,0:13:14.00,Default,,0,0,0,,{\i1}Xin chú ý. Đây là{\i0}\N{\i1}Trung tâm Phòng chống Thiên tai Làng Toshima.{\i0}
Dialogue: 0,0:13:14.12,0:13:19.29,Default,,0,0,0,,{\i1}Chúng tôi có một thông báo khẩn cấp{\i0}\N{\i1}từ một người tên là Igaiga.{\i0}
Dialogue: 0,0:13:20.25,0:13:21.26,Default,,0,0,0,,Igaiga?
Dialogue: 0,0:13:21.63,0:13:26.47,Default,,0,0,0,,{\i1}Tuy nhiên, tôi hoàn toàn không hiểu{\i0}\N{\i1}ông ấy đang nói về chuyện gì.{\i0}
Dialogue: 0,0:13:27.18,0:13:32.47,Default,,0,0,0,,{\i1}Dù khá bất thường,{\i0}\N{\i1}nhưng ông ấy bảo chuyện này rất quan trọng.{\i0}
Dialogue: 0,0:13:32.56,0:13:36.31,Default,,0,0,0,,{\i1}Nên tôi sẽ truyền đạt lại chính xác{\i0}\N{\i1}những gì ông ấy đã dặn:{\i0}
Dialogue: 0,0:13:37.69,0:13:40.98,Default,,0,0,0,,{\i1}Tonbo đã thu hẹp khoảng cách{\i0}\N{\i1}xuống chỉ còn một gậy{\i0}
Dialogue: 0,0:13:41.07,0:13:44.78,Default,,0,0,0,,{\i1}so với người dẫn đầu khi kết thúc{\i0}\N{\i1}nửa đầu của ngày thi đấu cuối cùng!{\i0}
Dialogue: 0,0:13:45.24,0:13:46.74,Default,,0,0,0,,{\i1}Hoặc... đại loại thế.{\i0}
Dialogue: 0,0:13:47.41,0:13:49.16,Default,,0,0,0,,Bunpei! Có nghe thấy\Nthông báo không?
Dialogue: 0,0:13:50.16,0:13:53.04,Default,,0,0,0,,Không thể gọi là "anh yêu" hay\Nđại loại thế được à?
Dialogue: 0,0:13:54.12,0:13:55.29,Default,,0,0,0,,Tuyệt vời quá nhỉ?
Dialogue: 0,0:13:56.54,0:13:57.83,Default,,0,0,0,,Ôi, Yoko!
Dialogue: 0,0:13:58.21,0:13:59.59,Default,,0,0,0,,Tôi xin nhắc lại:
Dialogue: 0,0:13:59.96,0:14:03.05,Default,,0,0,0,,{\i1}Tonbo đã thu hẹp khoảng cách{\i0}\N{\i1}xuống chỉ còn một gậy{\i0}
Dialogue: 0,0:14:03.13,0:14:07.01,Default,,0,0,0,,{\i1}so với người dẫn đầu khi kết thúc{\i0}\N{\i1}nửa đầu của ngày thi đấu cuối cùng!{\i0}
Dialogue: 0,0:14:07.47,0:14:10.26,Default,,0,0,0,,{\i1}Bản tin của chúng tôi đến đây là kết thúc.{\i0}
Dialogue: 0,0:14:11.60,0:14:13.52,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:14:14.43,0:14:15.35,Default,,0,0,0,,Hinoki!
Dialogue: 0,0:14:15.68,0:14:17.23,Default,,0,0,0,,Hinoki đâu rồi!
Dialogue: 0,0:14:17.73,0:14:18.60,Default,,0,0,0,,Xin lỗi ngài!
Dialogue: 0,0:14:18.69,0:14:22.11,Default,,0,0,0,,Ngài không thể vào\Nnhà câu lạc bộ với trang phục thế này được!
Dialogue: 0,0:14:22.69,0:14:24.36,Default,,0,0,0,,Hinoki!\NĐâu rồi?
Dialogue: 0,0:14:24.65,0:14:25.74,Default,,0,0,0,,Hinoki!
Dialogue: 0,0:14:27.36,0:14:29.16,Default,,0,0,0,,{\i1}Nếu nói với ông ấy là mình đánh 40...{\i0}
Dialogue: 0,0:14:31.24,0:14:34.66,Default,,0,0,0,,Vẫn giữ được vị trí dẫn đầu\Nbất chấp cơn gió mạnh này.
Dialogue: 0,0:14:34.83,0:14:38.00,Default,,0,0,0,,Không có lý do gì\Nphải ủ rũ thế cả!
Dialogue: 0,0:14:38.33,0:14:39.67,Default,,0,0,0,,Đánh tuyệt lắm.
Dialogue: 0,0:14:40.71,0:14:42.46,Default,,0,0,0,,Quản lý Nakase...
Dialogue: 0,0:14:43.59,0:14:45.38,Default,,0,0,0,,Cứ để đó cho tôi.
Dialogue: 0,0:14:48.47,0:14:49.68,Default,,0,0,0,,Hinoki!
Dialogue: 0,0:14:49.93,0:14:50.97,Default,,0,0,0,,Đâu rồi, Hinoki?
Dialogue: 0,0:14:51.26,0:14:52.39,Default,,0,0,0,,Ông Otoha.
Dialogue: 0,0:14:52.64,0:14:54.22,Default,,0,0,0,,Xin vui lòng rời khỏi đây ngay lập tức.
Dialogue: 0,0:14:55.22,0:14:57.39,Default,,0,0,0,,Nếu vẫn tiếp tục gây rối,
Dialogue: 0,0:14:57.77,0:15:00.56,Default,,0,0,0,,tôi sẽ phải dùng đến\Nbiện pháp mạnh đấy.
Dialogue: 0,0:15:01.61,0:15:02.98,Default,,0,0,0,,Biện pháp mạnh?
Dialogue: 0,0:15:03.36,0:15:06.19,Default,,0,0,0,,Trông thế này thôi chứ tôi có\Ný thức công lý mạnh mẽ lắm đấy.
Dialogue: 0,0:15:06.49,0:15:08.70,Default,,0,0,0,,Đây là sân golf của tôi!
Dialogue: 0,0:15:08.86,0:15:11.70,Default,,0,0,0,,Nếu không nghe lời,\Nông sẽ phải trả giá đấy!
Dialogue: 0,0:15:14.49,0:15:19.71,Default,,0,0,0,,Hinoki đã bước vào\Nnửa sau với vị trí dẫn đầu.
Dialogue: 0,0:15:20.50,0:15:21.54,Default,,0,0,0,,Vậy sao?
Dialogue: 0,0:15:21.75,0:15:22.67,Default,,0,0,0,,Tốt lắm.
Dialogue: 0,0:15:28.47,0:15:30.68,Default,,0,0,0,,{\i1}Giá mà đó là sự thật.{\i0}
Dialogue: 0,0:15:32.76,0:15:34.39,Default,,0,0,0,,{\i1}Ngay cả khi có thể giành chiến thắng,{\i0}
Dialogue: 0,0:15:34.81,0:15:36.81,Default,,0,0,0,,{\i1}cũng không thể chỉ thắng cách biệt một gậy.{\i0}
Dialogue: 0,0:15:37.39,0:15:41.52,Default,,0,0,0,,{\i1}Dù lúc đó có nhận phạt một gậy,{\i0}\N{\i1}thì mình vẫn có thể thắng.{\i0}
Dialogue: 0,0:15:42.35,0:15:46.86,Default,,0,0,0,,{\i1}Đó là lý do phải dẫn trước hai gậy.{\i0}\N{\i1}Phải thắng với cách biệt hai gậy!{\i0}
Dialogue: 0,0:15:51.74,0:15:53.82,Default,,0,0,0,,Không thấy Tonbo trên fairway.
Dialogue: 0,0:15:54.03,0:15:55.12,Default,,0,0,0,,Tìm thấy chưa?
Dialogue: 0,0:15:55.33,0:15:56.58,Default,,0,0,0,,Ở đây này!
Dialogue: 0,0:15:57.12,0:15:58.66,Default,,0,0,0,,{\i1}Chưa ra ngoài biên,{\i0}
Dialogue: 0,0:15:58.95,0:16:00.50,Default,,0,0,0,,{\i1}nhưng dù có đưa được bóng lên fairway,{\i0}
Dialogue: 0,0:16:00.75,0:16:02.29,Default,,0,0,0,,{\i1}thì cũng phải dùng gậy thứ ba{\i0}\N{\i1}mới lên được green.{\i0}
Dialogue: 0,0:16:02.50,0:16:04.25,Default,,0,0,0,,{\i1}Sẽ phải giải quyết trong một cú putt.{\i0}
Dialogue: 0,0:16:04.50,0:16:06.84,Default,,0,0,0,,{\i1}Thế này sẽ ảnh hưởng đến điểm số mất.{\i0}
Dialogue: 0,0:16:11.05,0:16:12.68,Default,,0,0,0,,Dù đánh đi đâu,
Dialogue: 0,0:16:12.93,0:16:15.47,Default,,0,0,0,,cũng phải nhắm thấp\Nđể tránh cành cây.
Dialogue: 0,0:16:16.01,0:16:19.35,Default,,0,0,0,,Chỗ rộng nhất là ở đây,\Nnhưng lại có bẫy cát.
Dialogue: 0,0:16:19.85,0:16:23.94,Default,,0,0,0,,{\i1}Phía bên phải khu rừng là một{\i0}\N{\i1}vùng trũng lùi lại so với fairway.{\i0}
Dialogue: 0,0:16:24.10,0:16:26.36,Default,,0,0,0,,{\i1}Đưa bóng lên fairway sẽ rất khó.{\i0}
Dialogue: 0,0:16:26.61,0:16:28.53,Default,,0,0,0,,{\i1}Có thể bị bogey hoặc tệ hơn.{\i0}
Dialogue: 0,0:16:33.16,0:16:35.28,Default,,0,0,0,,Đừng bận tâm đến việc giữ par.
Dialogue: 0,0:16:35.41,0:16:38.16,Default,,0,0,0,,Chỉ cần đảm bảo\Nkhông bị double bogey là được.
Dialogue: 0,0:16:39.91,0:16:41.33,Default,,0,0,0,,Đang nhắm đi đâu vậy?
Dialogue: 0,0:16:41.54,0:16:44.92,Default,,0,0,0,,Lệch sang phải quá nhiều rồi!\NThậm chí còn xa hơn cả green nữa!
Dialogue: 0,0:16:45.17,0:16:46.38,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:16:46.71,0:16:49.88,Default,,0,0,0,,Định đánh xuyên qua\Nkhoảng trống nhỏ đó sao?
Dialogue: 0,0:16:50.30,0:16:51.80,Default,,0,0,0,,Không thể nào!
Dialogue: 0,0:16:51.97,0:16:54.84,Default,,0,0,0,,Xa hơn chút nữa là \Nra ngoài biên mất!
Dialogue: 0,0:16:57.22,0:16:58.18,Default,,0,0,0,,Xuyên qua rồi kìa!
Dialogue: 0,0:16:58.43,0:16:59.72,Default,,0,0,0,,Cong đi, cong đi, cong đi!
Dialogue: 0,0:17:01.35,0:17:02.31,Default,,0,0,0,,Cong rồi!
Dialogue: 0,0:17:02.89,0:17:03.89,Default,,0,0,0,,Lên green rồi!
Dialogue: 0,0:17:05.60,0:17:06.94,Default,,0,0,0,,Lăn rồi!
Dialogue: 0,0:17:08.77,0:17:09.94,Default,,0,0,0,,Biến mất rồi!
Dialogue: 0,0:17:11.19,0:17:13.07,Default,,0,0,0,,Sẽ cần đánh bóng dự phòng đấy.
Dialogue: 0,0:17:13.57,0:17:14.49,Default,,0,0,0,,Ôi.
Dialogue: 0,0:17:15.28,0:17:17.24,Default,,0,0,0,,Đánh bóng dự phòng đây!
Dialogue: 0,0:17:17.45,0:17:19.37,Default,,0,0,0,,Lần này phải làm cho đúng mới được!
Dialogue: 0,0:17:19.58,0:17:22.00,Default,,0,0,0,,Nếu còn tự làm mình bị thương \Nthêm nữa thì...
Dialogue: 0,0:17:27.50,0:17:30.17,Default,,0,0,0,,{\i1}Bóng dự phòng.{\i0}\N{\i1}Tiếp theo sẽ là cú đánh thứ tư.{\i0}
Dialogue: 0,0:17:30.46,0:17:33.05,Default,,0,0,0,,{\i1}Một gậy lên fairway,{\i0}\N{\i1}rồi gậy thứ năm lên green.{\i0}
Dialogue: 0,0:17:33.34,0:17:35.30,Default,,0,0,0,,{\i1}Hai cú putt có thể khiến{\i0}\N{\i1}bị double bogey.{\i0}
Dialogue: 0,0:17:35.43,0:17:36.51,Default,,0,0,0,,{\i1}Nếu chuyện đó xảy ra,{\i0}
Dialogue: 0,0:17:36.68,0:17:40.35,Default,,0,0,0,,{\i1} Tonbo bất khả chiến bại sẽ bị{\i0}\N{\i1}loại khỏi cuộc đua.{\i0}
Dialogue: 0,0:17:40.93,0:17:42.14,Default,,0,0,0,,Bẫy cát là một vị trí an toàn.
Dialogue: 0,0:17:42.47,0:17:45.81,Default,,0,0,0,,Vẫn còn 180 yard. Chắc sẽ\Nkhông thành vấn đề với ch--
Dialogue: 0,0:17:47.10,0:17:49.15,Default,,0,0,0,,Lại nhắm vào green nữa sao?
Dialogue: 0,0:17:50.61,0:17:52.61,Default,,0,0,0,,Và lần này nhắm lên trên à?
Dialogue: 0,0:17:52.69,0:17:53.57,Default,,0,0,0,,{\i1}Lại nữa sao?{\i0}
Dialogue: 0,0:17:53.78,0:17:55.07,Default,,0,0,0,,{\i1}Bị điên rồi à?{\i0}
Dialogue: 0,0:17:55.45,0:18:00.12,Default,,0,0,0,,{\i1}Mình không thể mong người khác thất bại được.{\i0}\N{\i1}Tonbo. Đủ rồi đấy!{\i0}
Dialogue: 0,0:18:02.45,0:18:03.91,Default,,0,0,0,,Đang hẹp lại kìa.
Dialogue: 0,0:18:05.91,0:18:07.21,Default,,0,0,0,,Và lại rộng ra.
Dialogue: 0,0:18:08.25,0:18:10.13,Default,,0,0,0,,Lần tiếp theo nó đung đưa...
Dialogue: 0,0:18:13.92,0:18:14.88,Default,,0,0,0,,Bây giờ!
Dialogue: 0,0:18:19.55,0:18:21.85,Default,,0,0,0,,Đi nào! Bóng Robin!
Dialogue: 0,0:18:29.06,0:18:30.52,Default,,0,0,0,,Được rồi! Ngay sát cờ!
Dialogue: 0,0:18:30.98,0:18:32.27,Default,,0,0,0,,Không thể nào!
Dialogue: 0,0:18:32.65,0:18:34.44,Default,,0,0,0,,Có thể kết thúc bằng bogey sao?
Dialogue: 0,0:18:34.57,0:18:36.24,Default,,0,0,0,,Tìm thấy quả bóng đầu tiên rồi!
Dialogue: 0,0:18:39.57,0:18:41.83,Default,,0,0,0,,Và nó ở vị trí rất đẹp nữa!
Dialogue: 0,0:18:48.96,0:18:50.33,Default,,0,0,0,,Đánh trước đây!
Dialogue: 0,0:18:51.25,0:18:52.84,Default,,0,0,0,,Sau bao nhiêu náo động.
Dialogue: 0,0:18:53.21,0:18:54.67,Default,,0,0,0,,Rốt cuộc lại giữ được par.
Dialogue: 0,0:19:04.01,0:19:05.60,Default,,0,0,0,,Chắc là vậy rồi.
Dialogue: 0,0:19:10.35,0:19:14.57,Default,,0,0,0,,{\i1}Dừng lại sớm quá.{\i0}\N{\i1}Vẫn còn một cú putt dài.{\i0}
Dialogue: 0,0:19:17.53,0:19:18.86,Default,,0,0,0,,{\i1}Mắc kẹt hoàn toàn rồi. {\i0}
Dialogue: 0,0:19:19.03,0:19:22.74,Default,,0,0,0,,{\i1}Nếu rơi xuống, mình sẽ có thể{\i0}\N{\i1}đánh nó như gậy thứ hai.{\i0}
Dialogue: 0,0:19:23.83,0:19:25.20,Default,,0,0,0,,Thử rung cây xem sao.
Dialogue: 0,0:19:25.37,0:19:26.54,Default,,0,0,0,,Khoan đã.
Dialogue: 0,0:19:26.91,0:19:29.71,Default,,0,0,0,,Nếu quả bóng rơi xuống\Nthực sự là của cậu,
Dialogue: 0,0:19:29.79,0:19:32.29,Default,,0,0,0,,cậu sẽ bị phạt một gậy\Nvì làm di chuyển bóng.
Dialogue: 0,0:19:32.54,0:19:34.84,Default,,0,0,0,,Và cũng phải đặt nó lại chỗ cũ.
Dialogue: 0,0:19:35.13,0:19:36.26,Default,,0,0,0,,Vậy thì...
Dialogue: 0,0:19:36.34,0:19:37.63,Default,,0,0,0,,Nếu định làm vậy,
Dialogue: 0,0:19:37.88,0:19:43.89,Default,,0,0,0,,nếu đúng là bóng của cậu, cậu phải\Ntuyên bố không thể đánh được trước đã.
Dialogue: 0,0:19:44.81,0:19:46.01,Default,,0,0,0,,Và nếu làm vậy thì sao?
Dialogue: 0,0:19:46.18,0:19:49.56,Default,,0,0,0,,Không được tiến gần cờ hơn, \Ncậu có thể thả bóng thẳng xuống
Dialogue: 0,0:19:49.73,0:19:52.56,Default,,0,0,0,,và trong phạm vi hai chiều dài gậy\Nso với vị trí cũ,
Dialogue: 0,0:19:52.69,0:19:56.44,Default,,0,0,0,,hoặc thả dọc theo đường kéo dài\Ntừ điểm đó đến lỗ.
Dialogue: 0,0:19:56.82,0:19:58.99,Default,,0,0,0,,Cậu có thể thực hiện\Ncú đánh thứ ba từ đó.
Dialogue: 0,0:20:00.11,0:20:02.53,Default,,0,0,0,,Như vậy mình sẽ có thể\Nnhắm tới green.
Dialogue: 0,0:20:02.91,0:20:05.28,Default,,0,0,0,,Cách đó tốt hơn nhiều\Nso với các lựa chọn khác.
Dialogue: 0,0:20:05.58,0:20:08.54,Default,,0,0,0,,Nếu đúng là bóng của mình,\nthì mình xin tuyên bố bóng không thể đánh được!
Dialogue: 0,0:20:18.59,0:20:20.51,Default,,0,0,0,,Thôi nào! Rơi xuống đi!
Dialogue: 0,0:20:20.80,0:20:26.01,Default,,0,0,0,,{\i1}Sao không chịu rơi xuống chứ? Nếu không{\i0}\N{\i1}rơi xuống mình sẽ không thể thắng được!{\i0}
Dialogue: 0,0:20:26.35,0:20:28.39,Default,,0,0,0,,Bóng bị kẹt sao, Hinoki?
Dialogue: 0,0:20:29.56,0:20:30.48,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:20:30.60,0:20:33.77,Default,,0,0,0,,Phải chắc chắn\Nđó thực sự là bóng của mình đã!
Dialogue: 0,0:20:34.10,0:20:36.02,Default,,0,0,0,,Vậy thì xem thử đi!
Dialogue: 0,0:20:43.16,0:20:44.11,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:20:45.20,0:20:46.49,Default,,0,0,0,,Là bóng Callaway à?
Dialogue: 0,0:20:46.91,0:20:48.49,Default,,0,0,0,,Đúng rồi! Của mình đấy!
Dialogue: 0,0:20:49.12,0:20:50.29,Default,,0,0,0,,Để thả xuống cho.
Dialogue: 0,0:20:52.92,0:20:53.87,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:20:56.71,0:20:57.96,Default,,0,0,0,,Không sao chứ, Tonbo?
Dialogue: 0,0:20:59.38,0:21:00.34,Default,,0,0,0,,Đây!
Dialogue: 0,0:21:01.47,0:21:04.26,Default,,0,0,0,,Tonbo! Đang làm gì vậy?
Dialogue: 0,0:21:04.59,0:21:07.22,Default,,0,0,0,,Vẫn còn một cú putt nữa cơ mà!
Dialogue: 0,0:21:07.76,0:21:08.68,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:21:09.06,0:21:10.60,Default,,0,0,0,,Mọi người cố lên nhé!
Dialogue: 0,0:21:13.31,0:21:17.15,Default,,0,0,0,,Chạy đến tận đây\Nchỉ để tìm bóng thôi sao?
Dialogue: 0,0:21:18.27,0:21:20.23,Default,,0,0,0,,Tonbo lúc nào cũng vậy.
Dialogue: 0,0:21:21.24,0:21:23.49,Default,,0,0,0,,{\i1}Ngay cả lúc{\i0}\N{\i1}tập trên sân,{\i0}
Dialogue: 0,0:21:23.70,0:21:27.91,Default,,0,0,0,,{\i1} cũng chạy khắp nơi{\i0}\N{\i1}tìm bóng lạc.{\i0}
Dialogue: 0,0:21:28.87,0:21:30.74,Default,,0,0,0,,{\i1}Còn nhìn lại mình xem.{\i0}
Dialogue: 0,0:21:30.83,0:21:34.37,Default,,0,0,0,,{\i1}Thậm chí còn gian lận điểm số chỉ để{\i0}\N{\i1}thắng Tonbo.{\i0}
Dialogue: 0,0:21:34.75,0:21:38.67,Default,,0,0,0,,{\i1}Đây thực sự là con người{\i0}\N{\i1}mình muốn trở thành sao, Hinoki?{\i0}
Dialogue: 0,0:21:41.30,0:21:43.67,Default,,0,0,0,,Thở dốc thế kia sao mà putt được!
Dialogue: 0,0:21:44.22,0:21:46.26,Default,,0,0,0,,Tonbo trượt cú putt giữ par rồi à?
Dialogue: 0,0:21:46.59,0:21:47.68,Default,,0,0,0,,Bogey đầu tiên sao?
Dialogue: 0,0:21:49.26,0:21:50.89,Default,,0,0,0,,{\i1}Là lỗi của mình.{\i0}
Dialogue: 0,0:21:51.31,0:21:53.68,Default,,0,0,0,,{\i1}Chạy đến tìm bóng cho mình.{\i0}
Dialogue: 0,0:21:54.39,0:21:56.73,Default,,0,0,0,,{\i1}Là vì mình. Mình...{\i0}
Dialogue: 0,0:21:57.44,0:21:58.56,Default,,0,0,0,,{\i1}Mình...{\i0}
Dialogue: 0,0:22:01.82,0:22:03.32,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:22:05.36,0:22:06.24,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:22:06.78,0:22:07.78,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:22:08.37,0:22:09.20,Default,,0,0,0,,Mình...
Dialogue: 0,0:22:09.70,0:22:10.53,Default,,0,0,0,,Mình...
Dialogue: 0,0:22:12.08,0:22:14.54,Default,,0,0,0,,Mình đã làm di chuyển bóng!
Dialogue: 0,0:23:49.01,0:23:49.84,Default,,0,0,0,,Ema.
Dialogue: 0,0:23:50.09,0:23:52.43,Default,,0,0,0,,Đã bao giờ cảm thấy áp lực chưa?
Dialogue: 0,0:23:52.76,0:23:55.14,Default,,0,0,0,,Trong các trận đấu lúc nào cũng bị áp lực.
Dialogue: 0,0:23:55.22,0:23:58.06,Default,,0,0,0,,Bây giờ đang cảm thấy áp lực lắm luôn.
Dialogue: 0,0:23:58.23,0:23:59.18,Default,,0,0,0,,Có chuyện gì vậy?
Dialogue: 0,0:23:59.35,0:24:00.73,Default,,0,0,0,,Tập tiếp theo của Tonbo!
Dialogue: 0,0:24:01.02,0:24:02.27,Default,,0,0,0,,Lần Đầu Chịu Áp Lực
Dialogue: 0,0:24:02.90,0:24:06.02,Default,,0,0,0,,Bụng đang chịu áp lực\Ntừ bữa sáng đây này!
Dialogue: 0,0:24:06.19,0:24:08.03,Default,,0,0,0,,Đó gọi là ăn quá nhiều đấy.