Dialogue: 0,0:00:11.01,0:00:15.09,Default,,0,0,0,,{\i1}Được rồi. Ở hố đầu tiên,{\i0}\N{\i1}có thể đánh giá được tình trạng của bản thân,{\i0}
Dialogue: 0,0:00:15.18,0:00:18.14,Default,,0,0,0,,{\i1}đồng thời tránh tiêu hao{\i0}\N{\i1}quá nhiều thể lực.{\i0}
Dialogue: 0,0:00:19.18,0:00:23.39,Default,,0,0,0,,{\i1}Trông như một cú approach vậy.{\i0}\N{\i1}Không, giống một cú putt siêu dài hơn.{\i0}
Dialogue: 0,0:00:23.89,0:00:25.94,Default,,0,0,0,,Tsubura lúc nào cũng chuẩn xác!
Dialogue: 0,0:00:32.24,0:00:35.24,Default,,0,0,0,,{\i1}Có vẻ còn 253 yard nữa là đến rìa.{\i0}
Dialogue: 0,0:00:36.07,0:00:37.24,Default,,0,0,0,,{\i1}Gậy spoon sao?{\i0}
Dialogue: 0,0:00:37.87,0:00:39.87,Default,,0,0,0,,{\i1}Vậy là định đánh hai gậy à.{\i0}
Dialogue: 0,0:00:42.41,0:00:45.62,Default,,0,0,0,,Phải tự chịu trách nhiệm\Nbiến ước mơ của mình thành hiện thực đấy.
Dialogue: 0,0:00:46.12,0:00:50.84,Default,,0,0,0,,{\i1}Hinoki đang rất hừng hực khí thế nhờ những gì{\i0}\N{\i1}đã nói trước khi bắt đầu.{\i0}
Dialogue: 0,0:00:51.34,0:00:53.76,Default,,0,0,0,,{\i1}Có thể cảm nhận được đà vung{\i0}\N{\i1}trong những cú đánh nháp.{\i0}
Dialogue: 0,0:00:53.92,0:00:56.43,Default,,0,0,0,,{\i1}Sẽ dùng toàn lực{\i0}\N{\i1}ngay từ đầu luôn.{\i0}
Dialogue: 0,0:00:57.39,0:00:59.89,Default,,0,0,0,,{\i1}Một cú đánh 253 yard sẽ hơi thiếu lực một chút.{\i0}
Dialogue: 0,0:01:00.01,0:01:03.85,Default,,0,0,0,,{\i1}Không thể đánh xa đến thế được.{\i0}\N{\i1}Nếu vậy,{\i0}
Dialogue: 0,0:01:04.43,0:01:06.19,Default,,0,0,0,,{\i1}sẽ nhắm thả bóng xuống fairway{\i0}
Dialogue: 0,0:01:06.31,0:01:10.02,Default,,0,0,0,,{\i1}và hy vọng bóng lăn lên{\i0}\N{\i1}green. Tính toán là vậy nhỉ.{\i0}
Dialogue: 0,0:01:13.53,0:01:14.95,Default,,0,0,0,,Bay đi. Tới đó đi.
Dialogue: 0,0:01:18.37,0:01:19.41,Default,,0,0,0,,Tiếc quá!
Dialogue: 0,0:01:19.87,0:01:22.70,Default,,0,0,0,,Sang trái một chút nữa\Nlà hoàn hảo rồi.
Dialogue: 0,0:01:23.29,0:01:26.96,Default,,0,0,0,,{\i1}Làm cái gì vậy trời? Sẽ không dễ{\i0}\N{\i1}để thoát khỏi hố cát đó đâu.{\i0}
Dialogue: 0,0:01:27.83,0:01:29.67,Default,,0,0,0,,{\i1}Đã tốn chút sức lực cho cú này rồi,{\i0}
Dialogue: 0,0:01:29.84,0:01:32.38,Default,,0,0,0,,{\i1}và sẽ còn tốn nhiều sức hơn nữa{\i0}\N{\i1}cho cú tiếp theo.{\i0}
Dialogue: 0,0:01:33.84,0:01:37.55,Default,,0,0,0,,Đỉnh thật. Đã cách rìa green\Nkhoảng 210 yard rồi.
Dialogue: 0,0:01:38.18,0:01:40.22,Default,,0,0,0,,{\i1}Với cú thứ nhất và thứ hai,{\i0}
Dialogue: 0,0:01:40.30,0:01:44.73,Default,,0,0,0,,{\i1}đã chọn những cú đánh đơn giản{\i0}\N{\i1}để bảo toàn thể lực.{\i0}
Dialogue: 0,0:01:45.23,0:01:49.27,Default,,0,0,0,,{\i1}Những cú đánh không áp lực{\i0}\N{\i1}đưa bóng đi 240 yard trong hai lượt.{\i0}
Dialogue: 0,0:01:50.77,0:01:53.23,Default,,0,0,0,,-Bóng ở phía trước à?\N-Không đâu.
Dialogue: 0,0:01:53.40,0:01:55.32,Default,,0,0,0,,Quả này bay xa hơn một chút.
Dialogue: 0,0:01:57.11,0:02:02.49,Default,,0,0,0,,{\i1}Sẽ không được eagle đâu. Nhưng vẫn còn{\i0}\N{\i1}cơ hội để giành birdie.{\i0}
Dialogue: 0,0:02:03.41,0:02:07.00,Default,,0,0,0,,{\i1}Biết rằng tệ nhất cũng chắc chắn được par,{\i0}\N{\i1}nhất định phải lấy được birdie này.{\i0}
Dialogue: 0,0:02:07.33,0:02:09.25,Default,,0,0,0,,Đến lượt chưa nhỉ?
Dialogue: 0,0:02:09.46,0:02:11.00,Default,,0,0,0,,Háo hức quá đi!
Dialogue: 0,0:02:11.42,0:02:14.21,Default,,0,0,0,,{\i1}Đã đến được tận đây rồi.{\i0}\N{\i1}Có thể đưa bóng lên green được.{\i0}
Dialogue: 0,0:02:15.05,0:02:19.68,Default,,0,0,0,,{\i1}Phải nhắm gần cờ để ghi{\i0}\N{\i1}eagle. Nhưng phải tránh hố cát ra.{\i0}
Dialogue: 0,0:02:20.47,0:02:21.76,Default,,0,0,0,,{\i1}Để lấy birdie,{\i0}
Dialogue: 0,0:02:21.85,0:02:23.97,Default,,0,0,0,,{\i1}sẽ nhắm vào khu vực trung tâm{\i0}\N{\i1}bên trái cờ.{\i0}
Dialogue: 0,0:02:24.06,0:02:27.68,Default,,0,0,0,,{\i1}Sẽ đánh trong hai gậy.{\i0}\N{\i1}Thậm chí có thể chỉ cần một gậy.{\i0}
Dialogue: 0,0:02:27.77,0:02:30.02,Default,,0,0,0,,{\i1}Cũng có thể giành được eagle.{\i0}
Dialogue: 0,0:02:30.10,0:02:33.19,Default,,0,0,0,,{\i1}Nếu là mình thì sẽ làm vậy.{\i0}
Dialogue: 0,0:02:33.90,0:02:35.19,Default,,0,0,0,,Căng thẳng rồi đây.
Dialogue: 0,0:02:40.99,0:02:42.45,Default,,0,0,0,,Ngầu quá đi!
Dialogue: 0,0:02:45.91,0:02:48.12,Default,,0,0,0,,Đẹp lắm! Tuyệt vời!
Dialogue: 0,0:02:48.25,0:02:51.75,Default,,0,0,0,,{\i1}Hầu hết người chơi không ăn mừng{\i0}\N{\i1}khi đối thủ có một cú đánh tốt.{\i0}
Dialogue: 0,0:02:52.67,0:02:54.92,Default,,0,0,0,,Được rồi. Đến lượt rồi.
Dialogue: 0,0:04:27.64,0:04:28.93,Default,,0,0,0,,Nên làm thế nào đây nhỉ?
Dialogue: 0,0:04:29.64,0:04:31.18,Default,,0,0,0,,Có quá nhiều lựa chọn.
Dialogue: 0,0:04:34.39,0:04:36.40,Default,,0,0,0,,Này, cản trở quá đấy?
Dialogue: 0,0:04:36.48,0:04:39.65,Default,,0,0,0,,Không thể đoán được\NTonbo sẽ làm gì tiếp theo đâu.
Dialogue: 0,0:04:40.36,0:04:44.11,Default,,0,0,0,,Xem Tonbo chơi golf cứ như\Nđang mở hộp đồ chơi lò xo vậy!
Dialogue: 0,0:04:44.61,0:04:45.86,Default,,0,0,0,,Sẽ dùng Tsubura cho cú này!
Dialogue: 0,0:04:46.91,0:04:49.20,Default,,0,0,0,,Cây gậy này. Đã đặt tên nó là Tsubura đấy!
Dialogue: 0,0:04:51.29,0:04:54.21,Default,,0,0,0,,Đó là cây gậy đã được tặng đấy.
Dialogue: 0,0:04:58.84,0:05:00.13,Default,,0,0,0,,{\i1}Đang nhắm sang trái.{\i0}
Dialogue: 0,0:05:00.38,0:05:04.01,Default,,0,0,0,,{\i1}Không thể đoán được tư thế đó{\i0}\N{\i1}là đang định làm gì.{\i0}
Dialogue: 0,0:05:04.47,0:05:07.09,Default,,0,0,0,,{\i1}Có thể bay sang trái hoặc phải.{\i0}
Dialogue: 0,0:05:08.14,0:05:10.64,Default,,0,0,0,,{\i1}Sẽ đánh thế nào đây? Bóng sẽ bay đi đâu?{\i0}
Dialogue: 0,0:05:17.81,0:05:19.23,Default,,0,0,0,,Là bọ rùa kìa!
Dialogue: 0,0:05:36.37,0:05:37.29,Default,,0,0,0,,Không cố ý làm vậy đâu.
Dialogue: 0,0:05:37.75,0:05:38.92,Default,,0,0,0,,Đang nghĩ cái quái gì vậy?
Dialogue: 0,0:05:39.17,0:05:42.46,Default,,0,0,0,,Định đánh từ đó luôn sao?\NCó thể đánh lại được mà.
Dialogue: 0,0:05:42.80,0:05:43.67,Default,,0,0,0,,Biết rồi,
Dialogue: 0,0:05:43.76,0:05:45.67,Default,,0,0,0,,Chỉ là nghĩ có thể đánh trúng thôi!
Dialogue: 0,0:05:46.01,0:05:47.22,Default,,0,0,0,,Thật không thể tin nổi.
Dialogue: 0,0:05:47.93,0:05:51.97,Default,,0,0,0,,{\i1}Cách chơi golf này{\i0}\N{\i1}cứ như một đứa trẻ vậy.{\i0}
Dialogue: 0,0:05:53.43,0:05:55.73,Default,,0,0,0,,26, 27, 28
Dialogue: 0,0:05:57.60,0:06:00.15,Default,,0,0,0,,{\i1}Bóng lăn xa hơn dự tính một chút.{\i0}
Dialogue: 0,0:06:00.48,0:06:03.94,Default,,0,0,0,,{\i1}72 yard đến rìa và 79 yard đến cờ.{\i0}
Dialogue: 0,0:06:05.90,0:06:07.99,Default,,0,0,0,,{\i1}Sẽ dùng gậy này và nhắm thẳng vào cờ.{\i0}
Dialogue: 0,0:06:08.74,0:06:10.16,Default,,0,0,0,,{\i1}Rất thông minh.{\i0}
Dialogue: 0,0:06:10.49,0:06:14.20,Default,,0,0,0,,{\i1}Đã nhắm đến vị trí cú đánh thứ ba này{\i0}\N{\i1}ngay từ cú tee rồi.{\i0}
Dialogue: 0,0:06:15.25,0:06:18.00,Default,,0,0,0,,{\i1}Không có vật cản nào{\i0}\N{\i1}giữa bóng và cờ cả.{\i0}
Dialogue: 0,0:06:19.08,0:06:22.04,Default,,0,0,0,,{\i1}Đã thiết lập được vị trí này{\i0}\N{\i1}một cách hoàn hảo.{\i0}
Dialogue: 0,0:06:22.50,0:06:23.55,Default,,0,0,0,,{\i1}Và hơn nữa,{\i0}
Dialogue: 0,0:06:23.96,0:06:27.63,Default,,0,0,0,,{\i1}Có thể cảm nhận được chuyển động vai{\i0}\N{\i1}chuẩn xác đến mức nào.{\i0}
Dialogue: 0,0:06:30.39,0:06:34.26,Default,,0,0,0,,Đừng có nhảy nhót như thỏ nữa!\NLàm mất tập trung quá đấy!
Dialogue: 0,0:06:35.10,0:06:37.14,Default,,0,0,0,,Chỉ đang cố xem bóng ở đâu thôi mà!
Dialogue: 0,0:06:37.43,0:06:38.35,Default,,0,0,0,,Xin lỗi nhé!
Dialogue: 0,0:06:38.69,0:06:40.77,Default,,0,0,0,,Trời ạ. Buồn cười thật đấy, Tonbo.
Dialogue: 0,0:06:42.94,0:06:44.53,Default,,0,0,0,,{\i1}Chỉ khoảng 80 yard.{\i0}
Dialogue: 0,0:06:44.61,0:06:46.90,Default,,0,0,0,,{\i1}Có thể đưa bóng đáp thẳng xuống cờ.{\i0}
Dialogue: 0,0:06:46.99,0:06:49.24,Default,,0,0,0,,{\i1}Nhưng nếu đang tính toán{\i0}\N{\i1}cho cú đánh thứ tư,{\i0}
Dialogue: 0,0:06:50.24,0:06:53.91,Default,,0,0,0,,{\i1}Sẽ nhắm vào khu vực để lại một cú putt thẳng{\i0}\N{\i1}ở đoạn cuối cùng.{\i0}
Dialogue: 0,0:06:54.87,0:06:56.54,Default,,0,0,0,,{\i1}Một cú gimme.{\i0}
Dialogue: 0,0:07:04.09,0:07:05.59,Default,,0,0,0,,{\i1}Một cú gimme ngay chính giữa!{\i0}
Dialogue: 0,0:07:06.17,0:07:09.47,Default,,0,0,0,,Được rồi! Hay lắm, Tsubura!\NĂn birdie thôi!
Dialogue: 0,0:07:10.05,0:07:11.84,Default,,0,0,0,,Bóng đâu rồi nhỉ?
Dialogue: 0,0:07:12.30,0:07:17.14,Default,,0,0,0,,{\i1}Đã có thể chuẩn bị cho một cú birdie{\i0}\N{\i1}mà vẫn bảo toàn được tinh thần.{\i0}
Dialogue: 0,0:07:17.85,0:07:18.73,Default,,0,0,0,,Kia rồi!
Dialogue: 0,0:07:24.31,0:07:27.78,Default,,0,0,0,,{\i1}Nếu muốn đưa bóng thẳng tới cờ{\i0}\N{\i1}thì sẽ nhắm vào rìa green.{\i0}
Dialogue: 0,0:07:27.90,0:07:30.95,Default,,0,0,0,,{\i1}Khoảng trống so với hố cát{\i0}\N{\i1}sẽ không còn nhiều.{\i0}
Dialogue: 0,0:07:31.36,0:07:33.91,Default,,0,0,0,,{\i1}Nếu đánh thiếu lực,{\i0}\N{\i1}bóng sẽ rơi vào hố cát.{\i0}
Dialogue: 0,0:07:34.07,0:07:35.91,Default,,0,0,0,,{\i1}Nếu rơi vào đó thì sẽ bị bogey.{\i0}
Dialogue: 0,0:07:36.41,0:07:40.12,Default,,0,0,0,,{\i1}Chắc chắn thừa hiểu là không nên{\i0}\N{\i1}nhắm vào rìa green.{\i0}
Dialogue: 0,0:07:40.83,0:07:43.92,Default,,0,0,0,,{\i1}Quyết định đánh rồi.{\i0}\N{\i1}Sẽ lob bóng thẳng đến rìa.{\i0}
Dialogue: 0,0:07:44.92,0:07:47.96,Default,,0,0,0,,{\i1}Tonbo hoàn toàn không nghĩ gì{\i0}\N{\i1}đến điểm số cả.{\i0}
Dialogue: 0,0:07:49.05,0:07:51.55,Default,,0,0,0,,{\i1}Chỉ có sự phấn khích với cú đánh thôi.{\i0}
Dialogue: 0,0:07:54.97,0:07:56.10,Default,,0,0,0,,{\i1}Được rồi.{\i0}
Dialogue: 0,0:07:56.68,0:07:57.93,Default,,0,0,0,,{\i1}Đã chỉnh vuông góc mặt gậy sao?{\i0}
Dialogue: 0,0:07:58.14,0:07:59.68,Default,,0,0,0,,{\i1}Hướng bóng sang phải ư?{\i0}
Dialogue: 0,0:08:06.52,0:08:07.86,Default,,0,0,0,,{\i1}Bóng mất đà rồi.{\i0}
Dialogue: 0,0:08:08.65,0:08:09.53,Default,,0,0,0,,{\i1}Thú vị thật.{\i0}
Dialogue: 0,0:08:14.36,0:08:20.29,Default,,0,0,0,,Ôi không! Vòi phun nước sao? Không để ý\Nnó ẩn sau bãi cỏ luôn!
Dialogue: 0,0:08:23.04,0:08:27.00,Default,,0,0,0,,Bóng rơi trúng ngay\Nchỗ đã nhắm luôn!
Dialogue: 0,0:08:27.38,0:08:28.92,Default,,0,0,0,,{\i1}Thực sự nhắm vào đó sao?{\i0}
Dialogue: 0,0:08:29.25,0:08:32.22,Default,,0,0,0,,{\i1}Không thể tin được lại nhắm\N{\i1}vào một vị trí khó như vậy!{\i0}
Dialogue: 0,0:08:32.42,0:08:37.76,Default,,0,0,0,,{\i1}Không một tuyển thủ chuyên nghiệp nào dám liều lĩnh{\i0}\N{\i1}làm một việc như vậy cả.{\i0}
Dialogue: 0,0:08:37.89,0:08:39.68,Default,,0,0,0,,{\i1}Quá mạo hiểm.{\i0}
Dialogue: 0,0:08:39.89,0:08:44.14,Default,,0,0,0,,{\i1}Điểm mạnh lớn nhất của Tonbo{\i0}\N{\i1}chính là sự không biết sợ.{\i0}
Dialogue: 0,0:08:44.56,0:08:47.23,Default,,0,0,0,,{\i1}Đó cũng là{\i0}\N{\i1}điểm yếu lớn nhất.{\i0}
Dialogue: 0,0:08:48.11,0:08:50.07,Default,,0,0,0,,{\i1}Hoàn toàn không nghĩ đến những sai lầm. {\i0}
Dialogue: 0,0:08:50.23,0:08:53.74,Default,,0,0,0,,{\i1}Cú đánh rất hoàn hảo,{\i0}\N{\i1}nhưng cuối cùng lại thất bại.{\i0}
Dialogue: 0,0:08:55.20,0:08:56.95,Default,,0,0,0,,{\i1}Quả này Tonbo sẽ bị bogey rồi.{\i0}
Dialogue: 0,0:08:59.62,0:09:02.04,Default,,0,0,0,,{\i1}Hinoki vẫn còn cơ hội giành birdie.{\i0}
Dialogue: 0,0:09:03.54,0:09:05.37,Default,,0,0,0,,{\i1}Nếu muốn chắc chắn có được birdie,{\i0}
Dialogue: 0,0:09:05.54,0:09:08.71,Default,,0,0,0,,{\i1}thì phải đưa bóng rơi{\i0}\N{\i1}ngay bên trong green.{\i0}
Dialogue: 0,0:09:09.29,0:09:11.09,Default,,0,0,0,,{\i1}Chắc chắn không muốn đánh thiếu lực đâu.{\i0}
Dialogue: 0,0:09:11.17,0:09:15.76,Default,,0,0,0,,{\i1}Suy nghĩ về việc không đưa được bóng lên green{\i0}\N{\i1}chắc chắn sẽ ảnh hưởng đến cú đánh.{\i0}
Dialogue: 0,0:09:17.59,0:09:20.14,Default,,0,0,0,,{\i1}Sẽ cố gắng đánh vượt qua cờ.{\i0}
Dialogue: 0,0:09:20.89,0:09:22.22,Default,,0,0,0,,{\i1}Đã lên green rồi,{\i0}
Dialogue: 0,0:09:22.35,0:09:23.85,Default,,0,0,0,,{\i1}Một đường slice xuống dốc.{\i0}
Dialogue: 0,0:09:23.93,0:09:28.56,Default,,0,0,0,,{\i1}Chắc hẳn đang nghĩ rằng{\i0}\N{\i1}cú putt này sẽ không dễ ăn đâu.{\i0}
Dialogue: 0,0:09:31.94,0:09:34.49,Default,,0,0,0,,Phải đi vào hố cát\Ntừ điểm thấp nhất chứ!
Dialogue: 0,0:09:34.70,0:09:35.90,Default,,0,0,0,,Không thể cứ thế nhảy vào được đâu!
Dialogue: 0,0:09:35.99,0:09:37.49,Default,,0,0,0,,Xin lỗi nhé!
Dialogue: 0,0:09:38.20,0:09:39.91,Default,,0,0,0,,Bị mắng nhiều thật đấy.
Dialogue: 0,0:09:40.74,0:09:45.21,Default,,0,0,0,,{\i1}Sẽ không thực hiện thêm cú đánh nào{\i0}\N{\i1}có nguy cơ rơi vào hố cát nữa đâu.{\i0}
Dialogue: 0,0:09:45.58,0:09:47.96,Default,,0,0,0,,{\i1}Đã đến giới hạn rồi.{\i0}
Dialogue: 0,0:09:49.92,0:09:52.21,Default,,0,0,0,,{\i1}Các ngón tay gần như chạm vào cán gậy luôn rồi!{\i0}
Dialogue: 0,0:09:52.46,0:09:53.67,Default,,0,0,0,,{\i1}Tốc độ tay đó...{\i0}
Dialogue: 0,0:09:57.01,0:09:58.22,Default,,0,0,0,,{\i1}Tư thế đó là...!{\i0}
Dialogue: 0,0:09:59.47,0:10:00.39,Default,,0,0,0,,{\i1}Biết ngay mà!{\i0}
Dialogue: 0,0:10:00.76,0:10:02.72,Default,,0,0,0,,{\i1}Cú đánh đã thể hiện ở Hinoshima!{\i0}
Dialogue: 0,0:10:15.61,0:10:16.74,Default,,0,0,0,,Gần lắm rồi.
Dialogue: 0,0:10:17.28,0:10:19.32,Default,,0,0,0,,Ôi không. Bóng dừng lại mất rồi.
Dialogue: 0,0:10:20.03,0:10:22.33,Default,,0,0,0,,{\i1}Các hố cát ở Hinoshima{\i0}\N{\i1}có độ dốc lớn hơn.{\i0}
Dialogue: 0,0:10:23.33,0:10:25.45,Default,,0,0,0,,{\i1}Rất giỏi đánh ở những sườn dốc gần cờ.{\i0}
Dialogue: 0,0:10:26.25,0:10:28.29,Default,,0,0,0,,{\i1}Lại còn được thuận gió nữa.{\i0}
Dialogue: 0,0:10:29.37,0:10:31.88,Default,,0,0,0,,{\i1}Đã thử làm điều tương tự ở đây{\i0}\N{\i1}và bóng đã dừng lại.{\i0}
Dialogue: 0,0:10:45.31,0:10:46.48,Default,,0,0,0,,Cảm giác tốt lắm!
Dialogue: 0,0:10:46.68,0:10:47.98,Default,,0,0,0,,Birdie đẹp lắm!
Dialogue: 0,0:10:48.64,0:10:51.23,Default,,0,0,0,,{\i1}Đoạn cuối bẻ cong nhiều hơn mình nghĩ.{\i0}
Dialogue: 0,0:10:52.02,0:10:57.53,Default,,0,0,0,,{\i1}Ra là vậy. Hinoki không hề đánh quá tay. {\i0}\N{\i1}Đó là chủ đích đánh xa đến thế.{\i0}
Dialogue: 0,0:10:57.86,0:10:59.78,Default,,0,0,0,,Cú cuối cùng.
Dialogue: 0,0:11:01.91,0:11:06.41,Default,,0,0,0,,{\i1}Nếu đánh quá tay, bóng sẽ rơi{\i0}\N{\i1}cùng hàng với cú putt đầu tiên của mình.{\i0}
Dialogue: 0,0:11:06.70,0:11:08.29,Default,,0,0,0,,{\i1}Đó chính là mục đích.{\i0}
Dialogue: 0,0:11:08.87,0:11:11.04,Default,,0,0,0,,{\i1}Cơ hội đến rồi.{\i0}
Dialogue: 0,0:11:14.71,0:11:15.88,Default,,0,0,0,,Birdie đẹp lắm!
Dialogue: 0,0:11:16.42,0:11:21.80,Default,,0,0,0,,{\i1}Cứ tưởng là một cô bé ngoan ngoãn{\i0}\N{\i1}chỉ biết nghe lời bố thôi chứ. Sao lại vậy?{\i0}
Dialogue: 0,0:11:22.22,0:11:23.43,Default,,0,0,0,,{\i1}Thông minh thật đấy.{\i0}
Dialogue: 0,0:11:24.01,0:11:26.31,Default,,0,0,0,,{\i1}Có vẻ rất dày dạn kinh nghiệm thi đấu.{\i0}
Dialogue: 0,0:11:30.35,0:11:32.52,Default,,0,0,0,,Birdie kìa! Tuyệt vời!
Dialogue: 0,0:11:32.73,0:11:35.27,Default,,0,0,0,,Ai cũng giỏi cả! Đúng là một nhóm xuất sắc!
Dialogue: 0,0:11:35.86,0:11:37.53,Default,,0,0,0,,Được rồi. Đến lượt mình!
Dialogue: 0,0:11:43.66,0:11:44.78,Default,,0,0,0,,Được rồi, hay lắm!
Dialogue: 0,0:12:01.93,0:12:06.35,Default,,0,0,0,,Đã một tiếng trôi qua rồi. Sắp đến hố\Nthứ năm rồi. Ngay gần đây thôi.
Dialogue: 0,0:12:09.68,0:12:11.31,Default,,0,0,0,,Đi đâu vậy, Otoha-san?
Dialogue: 0,0:12:12.56,0:12:15.23,Default,,0,0,0,,Đi xem Hinoki thế nào rồi.
Dialogue: 0,0:12:16.19,0:12:17.15,Default,,0,0,0,,Không được làm vậy đâu.
Dialogue: 0,0:12:17.27,0:12:20.07,Default,,0,0,0,,Không ai được phép vào sân\Nngoài các tuyển thủ đâu.
Dialogue: 0,0:12:33.25,0:12:34.17,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:12:40.09,0:12:43.88,Default,,0,0,0,,{\i1}Birdie ở hố một, hai và bốn.{\i0}
Dialogue: 0,0:12:44.18,0:12:46.47,Default,,0,0,0,,{\i1}Phải giữ danh dự mới được.{\i0}
Dialogue: 0,0:12:46.68,0:12:49.81,Default,,0,0,0,,{\i1}Có lẽ đã hơi quá khích rồi.{\i0}
Dialogue: 0,0:12:50.18,0:12:53.31,Default,,0,0,0,,{\i1}Đã đạt âm ba gậy rồi.{\i0}
Dialogue: 0,0:12:55.73,0:12:57.48,Default,,0,0,0,,Cú swing đẹp thật đấy.
Dialogue: 0,0:12:59.86,0:13:02.28,Default,,0,0,0,,Đúng vậy! Cú swing của Hinoki ngầu quá đi!
Dialogue: 0,0:13:06.37,0:13:08.08,Default,,0,0,0,,Chà! Lại bay thẳng tắp kìa!
Dialogue: 0,0:13:08.37,0:13:11.04,Default,,0,0,0,,Một cú swing đẹp sẽ tạo ra một cú đánh đẹp.
Dialogue: 0,0:13:11.62,0:13:14.29,Default,,0,0,0,,Đó chính là kiểu golfer mà mình từng muốn trở thành.
Dialogue: 0,0:13:15.21,0:13:17.29,Default,,0,0,0,,Đó là con đường mà mình đã đi qua.
Dialogue: 0,0:13:21.09,0:13:22.92,Default,,0,0,0,,Tiếp tục đi!
Dialogue: 0,0:13:24.26,0:13:25.47,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:13:26.01,0:13:27.93,Default,,0,0,0,,{\i1}Ema hiện đang ở mức âm bốn gậy.{\i0}
Dialogue: 0,0:13:28.64,0:13:31.89,Default,,0,0,0,,{\i1}Sau khi bị một bogey, lại bị thêm một double{\i0}\N{\i1}bogey ở hố thứ ba.{\i0}
Dialogue: 0,0:13:32.02,0:13:34.89,Default,,0,0,0,,{\i1}Điểm số đã giảm đi ba,{\i0}\N{\i1}xuống còn âm hai gậy.{\i0}
Dialogue: 0,0:13:50.41,0:13:51.37,Default,,0,0,0,,Ema?
Dialogue: 0,0:13:51.45,0:13:52.49,Default,,0,0,0,,Sao vậy?
Dialogue: 0,0:13:57.29,0:13:59.79,Default,,0,0,0,,Cứ nghe tiếng nước bắn tung tóe là lại bị vậy.
Dialogue: 0,0:14:00.63,0:14:04.05,Default,,0,0,0,,Ở Mỹ, có đủ loại sinh vật\Nđáng sợ sống trong đầm lầy.
Dialogue: 0,0:14:04.46,0:14:06.09,Default,,0,0,0,,Có lẽ vì thế nên\Nmới phản ứng như vậy.
Dialogue: 0,0:14:07.22,0:14:09.18,Default,,0,0,0,,Ý là, cá sấu sao?
Dialogue: 0,0:14:09.72,0:14:11.89,Default,,0,0,0,,Sau khi vô địch giải World Junior Open...
Dialogue: 0,0:14:21.44,0:14:22.69,Default,,0,0,0,,...đã mất mười năm.
Dialogue: 0,0:14:24.23,0:14:27.40,Default,,0,0,0,,Chuyển đến Nhật vì công việc của bố,
Dialogue: 0,0:14:27.86,0:14:31.53,Default,,0,0,0,,nhưng cuối cùng cũng có thể thi đấu trở lại.
Dialogue: 0,0:14:32.49,0:14:33.99,Default,,0,0,0,,Nhưng tại sao chứ?
Dialogue: 0,0:14:34.41,0:14:36.58,Default,,0,0,0,,Tại sao lại làm tất cả những điều đó chỉ vì golf?
Dialogue: 0,0:14:37.12,0:14:38.33,Default,,0,0,0,,Tại sao ư?
Dialogue: 0,0:14:38.50,0:14:40.04,Default,,0,0,0,,Không hiểu nổi.
Dialogue: 0,0:14:40.25,0:14:45.13,Default,,0,0,0,,Sau một chấn thương như vậy, sau khi bị hoảng sợ\Nđến thế. Ngay cả việc đi lại chắc cũng rất khó khăn.
Dialogue: 0,0:14:45.46,0:14:48.84,Default,,0,0,0,,Trên đảo cũng có một người\Ncó những vết sẹo giống hệt Ema.
Dialogue: 0,0:14:49.59,0:14:51.93,Default,,0,0,0,,Bị cá mập tấn công khi đang câu cá.
Dialogue: 0,0:14:52.39,0:14:53.43,Default,,0,0,0,,Nhưng dù vậy,
Dialogue: 0,0:14:53.64,0:14:55.06,Default,,0,0,0,,đến giờ vẫn tiếp tục đi câu.
Dialogue: 0,0:14:55.52,0:14:57.48,Default,,0,0,0,,Tại sao chứ? Không sợ sao?
Dialogue: 0,0:14:59.10,0:15:02.90,Default,,0,0,0,,Chắc chắn là có sợ, nhưng\Nvì quá yêu thích việc câu cá.
Dialogue: 0,0:15:03.98,0:15:06.94,Default,,0,0,0,,Tình yêu đã chiến thắng nỗi sợ hãi.
Dialogue: 0,0:15:11.78,0:15:13.37,Default,,0,0,0,,Cũng giống vậy thôi.
Dialogue: 0,0:15:13.53,0:15:15.83,Default,,0,0,0,,Nếu có thứ gì đó cướp đi \Ngolf khỏi tay mình,
Dialogue: 0,0:15:16.41,0:15:17.58,Default,,0,0,0,,thì cũng sẽ làm như vậy.
Dialogue: 0,0:15:17.66,0:15:19.67,Default,,0,0,0,,Sẽ cố gắng hết sức để có thể chơi lại.
Dialogue: 0,0:15:22.42,0:15:27.59,Default,,0,0,0,,Đã mất đi khả năng vung gậy và\Nthực hiện những cú đánh đẹp như vậy rồi.
Dialogue: 0,0:15:28.26,0:15:29.17,Default,,0,0,0,,Tuy nhiên,
Dialogue: 0,0:15:29.55,0:15:31.09,Default,,0,0,0,,không phải mọi thứ đều tồi tệ.
Dialogue: 0,0:15:31.68,0:15:33.72,Default,,0,0,0,,Chỉ cần có thể chơi được là vui rồi.
Dialogue: 0,0:15:34.18,0:15:36.60,Default,,0,0,0,,Rất biết ơn vì vẫn có thể chơi golf.
Dialogue: 0,0:15:37.31,0:15:40.48,Default,,0,0,0,,Đó có lẽ là\Nđiểm mạnh lớn nhất đấy.
Dialogue: 0,0:15:41.98,0:15:44.61,Default,,0,0,0,,{\i1}Mọi người đều chơi golf{\i0}\N{\i1}vì yêu thích nó.{\i0}
Dialogue: 0,0:15:45.52,0:15:46.94,Default,,0,0,0,,{\i1}Có cảm thấy như vậy không nhỉ?{\i0}
Dialogue: 0,0:15:47.57,0:15:48.90,Default,,0,0,0,,{\i1}Mình...{\i0}
Dialogue: 0,0:15:50.57,0:15:53.37,Default,,0,0,0,,Đã bảo Hinoki là phải\Ngiành được vị trí dẫn đầu hôm nay rồi.
Dialogue: 0,0:15:53.57,0:15:54.66,Default,,0,0,0,,Nhưng mà...
Dialogue: 0,0:15:54.95,0:15:57.74,Default,,0,0,0,,Phải ra ngoài đó và\Nkhích lệ con bé đạt được điều đó.
Dialogue: 0,0:15:58.16,0:15:59.12,Default,,0,0,0,,Otoha-san.
Dialogue: 0,0:15:59.83,0:16:00.87,Default,,0,0,0,,Tại sao lại làm vậy chứ?
Dialogue: 0,0:16:01.33,0:16:04.50,Default,,0,0,0,,Tại sao lại quyết tâm biến Hinoki\Nthành số một đến vậy?
Dialogue: 0,0:16:06.96,0:16:08.38,Default,,0,0,0,,Khi còn trẻ,
Dialogue: 0,0:16:08.84,0:16:11.47,Default,,0,0,0,,thường đi loanh quanh ngó nghiêng\Ndưới các máy bán hàng tự động
Dialogue: 0,0:16:11.59,0:16:14.18,Default,,0,0,0,,để tìm những đồng tiền lẻ \Nmà người ta làm rơi.
Dialogue: 0,0:16:14.60,0:16:18.18,Default,,0,0,0,,Đã quỳ rạp xuống\Nvà tìm kiếm suốt nhiều giờ liền.
Dialogue: 0,0:16:18.89,0:16:22.14,Default,,0,0,0,,Những kẻ luôn miệng nói rằng\Ntiền không phải là tất cả
Dialogue: 0,0:16:22.27,0:16:24.90,Default,,0,0,0,,rõ ràng là chưa từng nếm trải\N cảm giác nghèo đói là thế nào.
Dialogue: 0,0:16:25.23,0:16:28.03,Default,,0,0,0,,Đó là một vấn đề khốn khổ. \NĐó là lý do tại sao lại thề.
Dialogue: 0,0:16:28.23,0:16:29.78,Default,,0,0,0,,Một lời thề phải trở nên giàu có.
Dialogue: 0,0:16:30.61,0:16:33.49,Default,,0,0,0,,Một lời thề phải giành vị trí số một \Nvà lấy được tiền thưởng.
Dialogue: 0,0:16:35.91,0:16:37.91,Default,,0,0,0,,Người ta thích nói những lời sáo rỗng.
Dialogue: 0,0:16:37.99,0:16:40.25,Default,,0,0,0,,Họ nói rằng chiến thắng không phải là tất cả.
Dialogue: 0,0:16:40.41,0:16:42.00,Default,,0,0,0,,Họ sai rồi.
Dialogue: 0,0:16:42.08,0:16:45.63,Default,,0,0,0,,Chỉ những ai nhắm đến vị trí số một\Nmới có thể giành được phần thưởng cao nhất.
Dialogue: 0,0:16:47.34,0:16:49.96,Default,,0,0,0,,Ai cũng muốn trở thành người chiến thắng.
Dialogue: 0,0:16:50.05,0:16:55.51,Default,,0,0,0,,Nhưng khi biết mình không thể làm được,\Nhọ lại cho rằng sự nỗ lực mới là điều quan trọng.
Dialogue: 0,0:16:55.72,0:16:57.64,Default,,0,0,0,,Nhưng sự thật không phải vậy.
Dialogue: 0,0:16:59.72,0:17:01.52,Default,,0,0,0,,Kết quả mới là thứ quan trọng.
Dialogue: 0,0:17:02.31,0:17:04.94,Default,,0,0,0,,Những người chứng minh được bằng kết quả\Nmới là những người nhận được lời khen ngợi.
Dialogue: 0,0:17:10.19,0:17:12.11,Default,,0,0,0,,Bị rẽ quá nhiều rồi.
Dialogue: 0,0:17:12.69,0:17:17.12,Default,,0,0,0,,Trong thế giới golf, có những tay golf\Nthiếu tinh thần thể thao,
Dialogue: 0,0:17:17.37,0:17:21.95,Default,,0,0,0,,nhưng vẫn có được người hâm mộ, địa vị,\Nvà sự giàu có nhờ vào chiến thắng của họ.
Dialogue: 0,0:17:22.37,0:17:23.41,Default,,0,0,0,,Tìm thấy chưa?
Dialogue: 0,0:17:23.87,0:17:25.04,Default,,0,0,0,,Rồi.
Dialogue: 0,0:17:25.33,0:17:27.75,Default,,0,0,0,,May quá! Tiếp theo là Tonbo.
Dialogue: 0,0:17:31.71,0:17:32.84,Default,,0,0,0,,Mặt khác,
Dialogue: 0,0:17:32.92,0:17:37.76,Default,,0,0,0,,có những tay golf tuân thủ đúng nghi thức\Nvà có thái độ tốt, nhưng chẳng bao giờ chiến thắng.
Dialogue: 0,0:17:38.10,0:17:40.14,Default,,0,0,0,,Có vô số những tay golf như vậy.
Dialogue: 0,0:17:47.48,0:17:49.57,Default,,0,0,0,,{\i1}Phải giành được vị trí số một.{\i0}
Dialogue: 0,0:17:50.73,0:17:53.11,Default,,0,0,0,,Không đồng ý sao, Hajime?
Dialogue: 0,0:17:54.74,0:17:58.41,Default,,0,0,0,,Con đường tiến lên chuyên nghiệp đã\Nbị đóng lại khi chùn bước.
Dialogue: 0,0:17:58.62,0:18:01.62,Default,,0,0,0,,Kể từ đó đến nay vẫn không thể\Ntiến thêm được bước nào.
Dialogue: 0,0:18:03.58,0:18:04.41,Default,,0,0,0,,Otoha-san.
Dialogue: 0,0:18:05.08,0:18:05.96,Default,,0,0,0,,Dù vậy,
Dialogue: 0,0:18:06.04,0:18:10.21,Default,,0,0,0,,ngay cả lúc rơi vào đáy vực,\Ncũng chưa từng cướp đoạt của ai cả.
Dialogue: 0,0:18:11.04,0:18:13.09,Default,,0,0,0,,Đó là điều đáng để tự hào.
Dialogue: 0,0:18:17.80,0:18:18.84,Default,,0,0,0,,Có vẻ ổn đấy.
Dialogue: 0,0:18:18.97,0:18:20.01,Default,,0,0,0,,Vào rồi.
Dialogue: 0,0:18:23.85,0:18:29.56,Default,,0,0,0,,{\i1}Phải giành được vị trí số một.{\i0}\N{\i1}Nếu không đứng thứ nhất... bố sẽ...{\i0}
Dialogue: 0,0:18:31.02,0:18:32.44,Default,,0,0,0,,Đã tìm thấy bóng chưa, Tonbo?
Dialogue: 0,0:18:32.77,0:18:33.94,Default,,0,0,0,,Đây rồi!
Dialogue: 0,0:18:37.28,0:18:38.32,Default,,0,0,0,,Bóng di chuyển rồi kìa!
Dialogue: 0,0:18:40.66,0:18:42.78,Default,,0,0,0,,Tsubura, phải làm gì bây giờ nhỉ?
Dialogue: 0,0:18:43.04,0:18:45.95,Default,,0,0,0,,Nếu làm bóng di chuyển,
Dialogue: 0,0:18:46.16,0:18:48.58,Default,,0,0,0,,sẽ bị phạt một gậy và\Nphải đặt lại vị trí cũ.
Dialogue: 0,0:18:49.58,0:18:50.83,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:18:51.29,0:18:52.59,Default,,0,0,0,,Sẽ đặt lại chỗ cũ.
Dialogue: 0,0:18:59.80,0:19:00.72,Default,,0,0,0,,Birdie đẹp lắm.
Dialogue: 0,0:19:00.97,0:19:01.93,Default,,0,0,0,,-Birdie đẹp lắm.\N-Birdie đẹp lắm.
Dialogue: 0,0:19:06.43,0:19:07.85,Default,,0,0,0,,Điểm số sao rồi?
Dialogue: 0,0:19:10.31,0:19:11.36,Default,,0,0,0,,Âm bốn gậy.
Dialogue: 0,0:19:11.81,0:19:13.86,Default,,0,0,0,,Đang đồng hạng nhất.
Dialogue: 0,0:19:16.57,0:19:18.86,Default,,0,0,0,,{\i1}Phải giành được vị trí số một.{\i0}
Dialogue: 0,0:19:28.96,0:19:30.37,Default,,0,0,0,,Bóng lại di chuyển nữa rồi!
Dialogue: 0,0:19:31.46,0:19:32.42,Default,,0,0,0,,Tsubura!
Dialogue: 0,0:19:32.84,0:19:35.25,Default,,0,0,0,,Nếu làm bóng di chuyển,
Dialogue: 0,0:19:35.46,0:19:37.76,Default,,0,0,0,,sẽ bị phạt một gậy và phải đặt lại vị trí cũ.
Dialogue: 0,0:19:38.09,0:19:39.05,Default,,0,0,0,,Đúng rồi.
Dialogue: 0,0:19:40.34,0:19:44.01,Default,,0,0,0,,{\i1}Tại sao? Tại sao lại bình tĩnh đến thế?{\i0}
Dialogue: 0,0:19:44.35,0:19:47.89,Default,,0,0,0,,{\i1} Sao mình không thể được như vậy?{\i0}
Dialogue: 0,0:19:49.02,0:19:49.94,Default,,0,0,0,,Được rồi.
Dialogue: 0,0:19:56.94,0:19:58.11,Default,,0,0,0,,Gì vậy?
Dialogue: 0,0:19:58.57,0:20:00.24,Default,,0,0,0,,Cú đánh trên thuyền của ông Gon!
Dialogue: 0,0:20:05.20,0:20:06.12,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:20:07.08,0:20:12.88,Default,,0,0,0,,Điểm số thì thảm hại, nhưng chưa từng thấy\Ntay golf nào đáng kinh ngạc đến vậy.
Dialogue: 0,0:20:20.97,0:20:23.14,Default,,0,0,0,,Sóng ngoài đó điên rồ thật đấy.
Dialogue: 0,0:20:23.34,0:20:24.18,Default,,0,0,0,,Đúng là một chuyến đi bão táp.
Dialogue: 0,0:20:25.89,0:20:28.85,Default,,0,0,0,,Tonbo! Igarashi-san đang đến đấy.
Dialogue: 0,0:20:29.98,0:20:30.98,Default,,0,0,0,,Đến đây sao?
Dialogue: 0,0:20:31.35,0:20:32.27,Default,,0,0,0,,Giờ đang ở đâu rồi?
Dialogue: 0,0:20:32.60,0:20:33.52,Default,,0,0,0,,Đang ở Kagoshima.
Dialogue: 0,0:20:33.98,0:20:36.65,Default,,0,0,0,,Bảo là không liên lạc được đấy.
Dialogue: 0,0:20:37.86,0:20:40.28,Default,,0,0,0,,Hết pin mất rồi.\NQuên không sạc.
Dialogue: 0,0:20:40.53,0:20:42.40,Default,,0,0,0,,Nếu giờ đang ở Kagoshima,
Dialogue: 0,0:20:42.61,0:20:44.41,Default,,0,0,0,,chắc khoảng hai tiếng nữa sẽ tới.
Dialogue: 0,0:20:45.24,0:20:46.70,Default,,0,0,0,,Nhưng sao tự nhiên lại đến đây?
Dialogue: 0,0:20:46.87,0:20:50.29,Default,,0,0,0,,Nghe tin đã đứng đầu ngày đầu tiên\Nnên muốn đến xem đấy.
Dialogue: 0,0:20:50.75,0:20:52.54,Default,,0,0,0,,Ra vậy. Hai tiếng nữa.
Dialogue: 0,0:20:57.13,0:20:59.80,Default,,0,0,0,,Ồ? Cứ tưởng sẽ vui hơn chứ.
Dialogue: 0,0:21:05.80,0:21:08.81,Default,,0,0,0,,Igaiga sắp đến rồi!
Dialogue: 0,0:21:10.02,0:21:11.85,Default,,0,0,0,,Đáng lẽ hôm nay phải cố gắng hơn mới đúng.
Dialogue: 0,0:21:12.39,0:21:13.31,Default,,0,0,0,,Đánh tận 77 gậy.
Dialogue: 0,0:21:14.90,0:21:17.31,Default,,0,0,0,,Kém hơn điểm hôm qua mười gậy lận.
Dialogue: 0,0:21:18.27,0:21:21.36,Default,,0,0,0,,Chắc sẽ vui lắm\Nnếu hôm nay mình lại đứng đầu.
Dialogue: 0,0:21:21.82,0:21:24.74,Default,,0,0,0,,Nhưng... có nghĩa là ngày mai\Ncũng sẽ có mặt ở đó.
Dialogue: 0,0:21:25.07,0:21:30.08,Default,,0,0,0,,Nếu ngày mai cố gắng hết sức thì có thể làm\Ncho Igaiga vui rồi! Được rồi! Cố lên nào!
Dialogue: 0,0:21:31.04,0:21:31.95,Default,,0,0,0,,Có người đang hào hứng kìa.
Dialogue: 0,0:21:32.66,0:21:34.33,Default,,0,0,0,,Cũng có lý do chính đáng mà.
Dialogue: 0,0:21:40.55,0:21:42.26,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:21:43.34,0:21:45.97,Default,,0,0,0,,Đang làm gì ở đây vậy?\NĐến đón sao?
Dialogue: 0,0:21:49.30,0:21:50.64,Default,,0,0,0,,Làm tốt lắm.
Dialogue: 0,0:21:58.81,0:22:00.23,Default,,0,0,0,,Sao lại khóc chứ?
Dialogue: 0,0:22:03.19,0:22:04.07,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:23:49.13,0:23:50.84,Default,,0,0,0,,Cảm ơn vì đã đến nhé, Igaiga.
Dialogue: 0,0:23:50.93,0:23:55.85,Default,,0,0,0,,Đừng tỏ ra xa cách thế chứ.\NBiết là mọi chuyện không hề dễ dàng mà.
Dialogue: 0,0:23:56.10,0:23:57.02,Default,,0,0,0,,Igaiga.
Dialogue: 0,0:23:57.56,0:23:59.10,Default,,0,0,0,,Tập tiếp theo của Tonbo!
Dialogue: 0,0:23:59.27,0:24:00.39,Default,,0,0,0,,"Những cơn gió đảo chiều"
Dialogue: 0,0:24:00.64,0:24:03.23,Default,,0,0,0,,Đáng tự hào quá đi mất!
Dialogue: 0,0:24:03.52,0:24:04.27,Default,,0,0,0,,Igaiga?
Dialogue: 0,0:24:04.90,0:24:05.94,Default,,0,0,0,,Mặt đáng sợ quá đấy.
Dialogue: 0,0:24:06.02,0:24:07.23,Default,,0,0,0,,Đang khóc đấy, được chưa?