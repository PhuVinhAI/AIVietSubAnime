Dialogue: 0,0:00:03.97,0:00:06.30,Default,,0,0,0,,Không ngờ lại học\Ncùng một trường đấy.
Dialogue: 0,0:00:06.40,0:00:07.37,Default,,0,0,0,,Thở phào nhẹ nhõm rồi!
Dialogue: 0,0:00:07.64,0:00:10.31,Default,,0,0,0,,Cứ lo phải đến trường\Nmột mình cơ.
Dialogue: 0,0:00:11.71,0:00:14.11,Default,,0,0,0,,{\i1}Đã một tuần trôi qua kể từ khi rời đảo,{\i0}
Dialogue: 0,0:00:14.24,0:00:16.31,Default,,0,0,0,,{\i1}và hôm nay trường cấp ba đã bắt đầu. {\i0}
Dialogue: 0,0:00:16.95,0:00:18.78,Default,,0,0,0,,{\i1}Mọi người vẫn khỏe chứ?{\i0}
Dialogue: 0,0:00:18.85,0:00:22.25,Default,,0,0,0,,{\i1}Đã khóc vài lần{\i0}\N{\i1}khi nghĩ về đảo đấy.{\i0}
Dialogue: 0,0:00:22.75,0:00:24.92,Default,,0,0,0,,{\i1}Đêm xuống có hơi cô đơn.{\i0}
Dialogue: 0,0:00:25.09,0:00:27.32,Default,,0,0,0,,{\i1}Nhất là khi không có tiếng ngáy của Gon-jii!{\i0}
Dialogue: 0,0:00:28.02,0:00:29.12,Default,,0,0,0,,Này,
Dialogue: 0,0:00:29.26,0:00:30.69,Default,,0,0,0,,trao đổi số điện thoại nhé?
Dialogue: 0,0:00:30.76,0:00:31.63,Default,,0,0,0,,Được thôi!
Dialogue: 0,0:00:31.73,0:00:33.90,Default,,0,0,0,,CẢM ƠN NHÉ!
Dialogue: 0,0:00:34.43,0:00:37.87,Default,,0,0,0,,{\i1}Kumamoto không có{\i0}\N{\i1}cây đa như trên đảo.{\i0}
Dialogue: 0,0:00:38.30,0:00:41.80,Default,,0,0,0,,{\i1}Nhưng lại có rất nhiều{\i0}\N{\i1}cây long não lớn ở khắp nơi.{\i0}
Dialogue: 0,0:00:41.94,0:00:43.61,Default,,0,0,0,,{\i1}Thậm chí ở trường cũng có một cây.{\i0}
Dialogue: 0,0:00:44.11,0:00:46.61,Default,,0,0,0,,{\i1}Không hiểu sao, \Nchúng vẫn gợi nhớ về đảo,{\i0}
Dialogue: 0,0:00:47.51,0:00:49.91,Default,,0,0,0,,{\i1}và đang dần thích chúng rồi!{\i0}
Dialogue: 0,0:00:53.05,0:00:54.62,Default,,0,0,0,,480 yên cơ á?!
Dialogue: 0,0:00:55.02,0:00:56.79,Default,,0,0,0,,Muốn ăn thử cái đó không?
Dialogue: 0,0:00:57.99,0:00:59.49,Default,,0,0,0,,Không sao đâu.
Dialogue: 0,0:01:00.36,0:01:04.19,Default,,0,0,0,,{\i1}Chắc chắn sẽ kiếm được bộn tiền{\i0}\N{\i1}nếu Gon-jii chuyển đến đây đấy.{\i0}
Dialogue: 0,0:01:05.69,0:01:08.43,Default,,0,0,0,,{\i1}Dù là ban đêm, đèn vẫn sáng khắp nơi.{\i0}
Dialogue: 0,0:01:09.20,0:01:10.47,Default,,0,0,0,,{\i1}Mọi thứ đều thật mới mẻ.{\i0}
Dialogue: 0,0:01:11.50,0:01:12.47,Default,,0,0,0,,{\i1}Dù vậy...{\i0}
Dialogue: 0,0:01:15.04,0:01:16.24,Default,,0,0,0,,{\i1}Vẫn đang sống rất tốt.{\i0}
Dialogue: 0,0:02:58.04,0:02:59.04,Default,,0,0,0,,Một giải đấu sao?
Dialogue: 0,0:02:59.24,0:03:00.18,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:03:00.28,0:03:02.34,Default,,0,0,0,,Giải Kyushu Women's Open sẽ diễn ra vào tháng sau.
Dialogue: 0,0:03:02.68,0:03:04.98,Default,,0,0,0,,Sẽ được tổ chức ở Chuo Country Club!
Dialogue: 0,0:03:05.55,0:03:06.75,Default,,0,0,0,,Định làm gì vậy, Tonbo?
Dialogue: 0,0:03:07.75,0:03:09.05,Default,,0,0,0,,Ý là sao?
Dialogue: 0,0:03:09.59,0:03:10.42,Default,,0,0,0,,Bố ơi!
Dialogue: 0,0:03:10.69,0:03:12.89,Default,,0,0,0,,Xin bố đấy, \Nnhượng lại thẻ hội viên Chuo Country Club đi!
Dialogue: 0,0:03:13.36,0:03:14.66,Default,,0,0,0,,Cần cái đó làm gì?
Dialogue: 0,0:03:15.12,0:03:17.39,Default,,0,0,0,,Bố có nhiều thẻ hội viên mà, đúng không?
Dialogue: 0,0:03:17.59,0:03:18.99,Default,,0,0,0,,Thì có, nhưng...
Dialogue: 0,0:03:19.33,0:03:20.33,Default,,0,0,0,,Cảm ơn bố!
Dialogue: 0,0:03:20.56,0:03:22.40,Default,,0,0,0,,Đổi tên thẻ hội viên sang cho Tonbo đi.
Dialogue: 0,0:03:23.30,0:03:25.77,Default,,0,0,0,,Ý là không phải cho con, mà là cho Tonbo sao?
Dialogue: 0,0:03:26.17,0:03:27.14,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:03:27.20,0:03:29.54,Default,,0,0,0,,Sẽ đưa Tonbo\Ntham gia Kyushu Women's Open!
Dialogue: 0,0:03:30.11,0:03:33.64,Default,,0,0,0,,Người tham gia phải\Nthuộc Liên đoàn Golf Kyushu
Dialogue: 0,0:03:33.74,0:03:36.41,Default,,0,0,0,,và có handicap tối đa là 13.4.
Dialogue: 0,0:03:37.68,0:03:39.78,Default,,0,0,0,,Giải đấu sẽ diễn ra trong một tháng nữa.
Dialogue: 0,0:03:39.88,0:03:44.22,Default,,0,0,0,,Cần phải nộp\Nnăm bảng điểm để lấy handicap.
Dialogue: 0,0:03:44.55,0:03:48.59,Default,,0,0,0,,Không có nhiều thời gian\Nđể chơi sau giờ học đâu nhỉ?
Dialogue: 0,0:03:49.42,0:03:51.86,Default,,0,0,0,,Tonbo, mấy giờ tan học?
Dialogue: 0,0:03:52.26,0:03:54.36,Default,,0,0,0,,Tầm bốn giờ.
Dialogue: 0,0:03:54.76,0:03:56.50,Default,,0,0,0,,Dù có lái xe nhanh,
Dialogue: 0,0:03:56.77,0:03:58.93,Default,,0,0,0,,cũng phải gần năm giờ mới bắt đầu được.
Dialogue: 0,0:03:59.47,0:04:02.27,Default,,0,0,0,,6:30 là trời tối rồi.
Dialogue: 0,0:04:02.64,0:04:05.91,Default,,0,0,0,,"Vậy nghĩa là chỉ có\Nchín mươi phút cho một vòng sao?"
Dialogue: 0,0:04:06.04,0:04:08.48,Default,,0,0,0,,Cũng phải nghĩ cho\Nnhững người chơi khác nữa.
Dialogue: 0,0:04:08.94,0:04:10.68,Default,,0,0,0,,Đó là lựa chọn duy nhất thôi.
Dialogue: 0,0:04:11.38,0:04:13.32,Default,,0,0,0,,Không thể lãng phí một ngày nào đâu.
Dialogue: 0,0:04:17.92,0:04:19.22,Default,,0,0,0,,Trông cậy vào Fumi đấy.
Dialogue: 0,0:04:19.29,0:04:20.16,Default,,0,0,0,,Vâng!
Dialogue: 0,0:04:21.42,0:04:23.16,Default,,0,0,0,,Tan học rồi đây!
Dialogue: 0,0:04:25.43,0:04:28.16,Default,,0,0,0,,Quản đốc Nakase đã kể hết rồi!\NRa sân đi!
Dialogue: 0,0:04:28.93,0:04:29.83,Default,,0,0,0,,Bắt đầu từ in course nhé!
Dialogue: 0,0:04:30.47,0:04:31.17,Default,,0,0,0,,In course sao?
Dialogue: 0,0:04:31.23,0:04:32.10,Default,,0,0,0,,Không biết à?
Dialogue: 0,0:04:32.94,0:04:35.34,Default,,0,0,0,,Chín lỗ đầu tiên\Nđược gọi là {\i1}out course{\i0}.
Dialogue: 0,0:04:35.44,0:04:38.24,Default,,0,0,0,,Từ lỗ 10 đến 18\Nđược gọi là {\i1}in course{\i0}.
Dialogue: 0,0:04:38.81,0:04:42.41,Default,,0,0,0,,Tuyệt quá! Chưa từng chơi\Nmột vòng từ {\i1}in course{\i0} bao giờ!
Dialogue: 0,0:04:43.41,0:04:44.45,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:04:45.15,0:04:46.75,Default,,0,0,0,,Không vung nháp sao?
Dialogue: 0,0:04:49.75,0:04:50.79,Default,,0,0,0,,Úi.
Dialogue: 0,0:04:51.22,0:04:52.99,Default,,0,0,0,,Cú đánh đầu tiên đã ra ngoài biên rồi.
Dialogue: 0,0:04:54.66,0:04:57.26,Default,,0,0,0,,Handicap lý tưởng là 13.4.
Dialogue: 0,0:04:58.03,0:05:00.66,Default,,0,0,0,,Tức là điểm trung bình khoảng tám mươi lăm.
Dialogue: 0,0:05:00.93,0:05:03.43,Default,,0,0,0,,Thật sự có thể kết thúc\Nvới số điểm đó sao?
Dialogue: 0,0:05:03.60,0:05:06.40,Default,,0,0,0,,Hajime bảo với Tonbo thì không thành vấn đề.
Dialogue: 0,0:05:10.81,0:05:11.71,Default,,0,0,0,,Sao rồi?
Dialogue: 0,0:05:13.81,0:05:14.84,Default,,0,0,0,,Được chín mươi.
Dialogue: 0,0:05:15.44,0:05:17.41,Default,,0,0,0,,Tưởng bảo không thành vấn đề mà!
Dialogue: 0,0:05:17.68,0:05:20.25,Default,,0,0,0,,Mới nửa chừng đã hết hơi rồi.
Dialogue: 0,0:05:20.82,0:05:22.72,Default,,0,0,0,,Ba lỗ cuối trời tối đen như mực luôn!
Dialogue: 0,0:05:22.95,0:05:24.49,Default,,0,0,0,,Vui lắm luôn!
Dialogue: 0,0:05:27.86,0:05:28.89,Default,,0,0,0,,Đừng lo.
Dialogue: 0,0:05:28.99,0:05:30.43,Default,,0,0,0,,Vẫn có thể gỡ gạc được.
Dialogue: 0,0:05:34.50,0:05:35.83,Default,,0,0,0,,Lên đi, Taiga!
Dialogue: 0,0:05:35.96,0:05:37.73,Default,,0,0,0,,Vẫn còn là trẻ con mà!
Dialogue: 0,0:05:37.80,0:05:40.20,Default,,0,0,0,,Chạy 18 lỗ\Nchắc không thành vấn đề đâu!
Dialogue: 0,0:05:40.50,0:05:41.34,Default,,0,0,0,,Vâng!
Dialogue: 0,0:05:41.84,0:05:43.34,Default,,0,0,0,,Tám mươi tư sao?!
Dialogue: 0,0:05:43.64,0:05:44.47,Default,,0,0,0,,Ừ.
Dialogue: 0,0:05:44.61,0:05:46.91,Default,,0,0,0,,Lỗ cuối cùng lại tối đen như mực.
Dialogue: 0,0:05:47.51,0:05:49.31,Default,,0,0,0,,Thôi nào, Taiga.
Dialogue: 0,0:05:49.65,0:05:52.98,Default,,0,0,0,,Tonbo chỉ có năm gậy thôi!
Dialogue: 0,0:05:53.55,0:05:56.29,Default,,0,0,0,,Phải vác túi gậy chạy\Nsuốt cả quãng đường đấy!
Dialogue: 0,0:05:56.75,0:05:58.55,Default,,0,0,0,,Đúng là tra tấn mà!
Dialogue: 0,0:06:01.19,0:06:03.33,Default,,0,0,0,,Lần tới đi cùng thì sao nhỉ?
Dialogue: 0,0:06:03.99,0:06:05.46,Default,,0,0,0,,Hinoki!
Dialogue: 0,0:06:05.89,0:06:08.33,Default,,0,0,0,,Chơi xong trước khi mặt trời lặn nhé!
Dialogue: 0,0:06:09.00,0:06:10.00,Default,,0,0,0,,Vâng!
Dialogue: 0,0:06:10.90,0:06:12.40,Default,,0,0,0,,Hinoki, mang gì thế?
Dialogue: 0,0:06:12.63,0:06:14.54,Default,,0,0,0,,Cũng sẽ thử chơi với năm gậy xem sao!
Dialogue: 0,0:06:15.10,0:06:16.24,Default,,0,0,0,,Cảm ơn ạ!
Dialogue: 0,0:06:17.57,0:06:18.91,Default,,0,0,0,,Chúc may mắn nhé!
Dialogue: 0,0:06:19.58,0:06:20.51,Default,,0,0,0,,Ồ?
Dialogue: 0,0:06:21.11,0:06:22.51,Default,,0,0,0,,Cô bé đó sao?
Dialogue: 0,0:06:23.01,0:06:24.18,Default,,0,0,0,,Ồ, quản đốc!
Dialogue: 0,0:06:24.75,0:06:26.78,Default,,0,0,0,,Vâng. Là cô bé ở chỗ Udo.
Dialogue: 0,0:06:27.38,0:06:29.65,Default,,0,0,0,,Cô bé đến từ Tokara, đúng không?
Dialogue: 0,0:06:31.59,0:06:32.79,Default,,0,0,0,,Đến lượt Hinoki đấy!
Dialogue: 0,0:06:35.39,0:06:36.43,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:06:38.49,0:06:39.70,Default,,0,0,0,,Bảy mươi tám!
Dialogue: 0,0:06:40.50,0:06:42.53,Default,,0,0,0,,Và thậm chí còn xong trước khi trời tối nữa!
Dialogue: 0,0:06:42.87,0:06:44.90,Default,,0,0,0,,Được rồi! Thế mới đúng chứ!
Dialogue: 0,0:06:45.10,0:06:46.54,Default,,0,0,0,,Làm tốt lắm, Hinoki!
Dialogue: 0,0:06:46.94,0:06:50.67,Default,,0,0,0,,Đáng lẽ nên để\NHinoki chơi cùng ngay từ đầu!
Dialogue: 0,0:06:51.11,0:06:52.74,Default,,0,0,0,,Xin lỗi chuyện lúc trước nhé.
Dialogue: 0,0:06:53.44,0:06:54.28,Default,,0,0,0,,Thành thật mà nói,
Dialogue: 0,0:06:54.44,0:06:56.38,Default,,0,0,0,,hôm nay không thể vượt qua mức chín mươi được.
Dialogue: 0,0:06:58.71,0:07:01.85,Default,,0,0,0,,Không thể chơi chỉ với năm gậy được.
Dialogue: 0,0:07:02.85,0:07:04.45,Default,,0,0,0,,Không thể sánh bằng Tonbo được.
Dialogue: 0,0:07:06.05,0:07:08.16,Default,,0,0,0,,VÀI NGÀY SAU
Dialogue: 0,0:07:08.62,0:07:09.63,Default,,0,0,0,,Mười một sao?
Dialogue: 0,0:07:10.29,0:07:13.40,Default,,0,0,0,,Giấy báo này ghi handicap là 11.
Dialogue: 0,0:07:13.73,0:07:16.73,Default,,0,0,0,,Vậy là có thể\Ntham gia Kyushu Women's Open rồi!
Dialogue: 0,0:07:17.17,0:07:18.20,Default,,0,0,0,,Chúc mừng nhé!
Dialogue: 0,0:07:18.47,0:07:19.43,Default,,0,0,0,,Là lần đầu tiên đấy.
Dialogue: 0,0:07:21.07,0:07:22.00,Default,,0,0,0,,Thấy không,
Dialogue: 0,0:07:22.30,0:07:24.47,Default,,0,0,0,,đây sẽ là giải đấu đầu tiên trong đời.
Dialogue: 0,0:07:25.07,0:07:26.24,Default,,0,0,0,,Và không chỉ riêng golf đâu.
Dialogue: 0,0:07:26.58,0:07:29.18,Default,,0,0,0,,Chưa từng tham gia\Nbất kỳ giải đấu nào luôn.
Dialogue: 0,0:07:29.95,0:07:31.21,Default,,0,0,0,,Không biết sẽ thế nào nhỉ?
Dialogue: 0,0:07:31.55,0:07:33.55,Default,,0,0,0,,Chắc sẽ có nhiều người lắm nhỉ?
Dialogue: 0,0:07:34.32,0:07:36.05,Default,,0,0,0,,Có khi lên tới mười người!
Dialogue: 0,0:07:38.32,0:07:41.32,Default,,0,0,0,,Phải\Nnghĩ lớn hơn thế chứ!
Dialogue: 0,0:07:42.96,0:07:44.93,Default,,0,0,0,,Một giải đấu thực sự.
Dialogue: 0,0:07:45.46,0:07:47.00,Default,,0,0,0,,Háo hức thật đấy.
Dialogue: 0,0:07:54.74,0:07:55.77,Default,,0,0,0,,Ai đó?
Dialogue: 0,0:07:55.97,0:07:59.21,Default,,0,0,0,,-Tránh xa ra!\N-Bình tĩnh nào!
Dialogue: 0,0:07:59.74,0:08:01.01,Default,,0,0,0,,Xin lỗi vì đã làm giật mình nhé.
Dialogue: 0,0:08:01.74,0:08:04.15,Default,,0,0,0,,Thật ra đây là phòng ngủ đấy.
Dialogue: 0,0:08:18.46,0:08:20.46,Default,,0,0,0,,Cuối cùng cũng gặp Tonbo rồi nhỉ.
Dialogue: 0,0:08:20.76,0:08:22.03,Default,,0,0,0,,Đây là con gái.
Dialogue: 0,0:08:22.23,0:08:24.30,Default,,0,0,0,,Là Nikome Udo. Rất vui được gặp!
Dialogue: 0,0:08:24.50,0:08:26.54,Default,,0,0,0,,Có tin được nó là dân chuyên nghiệp không?
Dialogue: 0,0:08:26.64,0:08:28.44,Default,,0,0,0,,Không cần phải nói thế đâu!
Dialogue: 0,0:08:29.47,0:08:31.01,Default,,0,0,0,,Trả đây!
Dialogue: 0,0:08:31.64,0:08:33.94,Default,,0,0,0,,Đáng lẽ phải\Nđang ở giải đấu nữ chứ.
Dialogue: 0,0:08:34.24,0:08:37.68,Default,,0,0,0,,Nhưng không qua được vòng loại\Nnên đã về nhà sớm hơn dự kiến.
Dialogue: 0,0:08:38.38,0:08:42.42,Default,,0,0,0,,Lúc nãy còn buồn thiu mà.\NPhục hồi nhanh thật đấy!
Dialogue: 0,0:08:43.02,0:08:44.49,Default,,0,0,0,,Y hệt mẹ nó luôn.
Dialogue: 0,0:08:44.79,0:08:46.26,Default,,0,0,0,,Đừng có chỉ tay như thế!
Dialogue: 0,0:08:46.66,0:08:48.12,Default,,0,0,0,,Đừng so sánh con với mẹ!
Dialogue: 0,0:08:48.49,0:08:51.46,Default,,0,0,0,,Và có thể ngừng\Nmặc mấy bộ đồ quê mùa đó được không?
Dialogue: 0,0:08:51.56,0:08:54.16,Default,,0,0,0,,Dùng tiền thưởng mua cho ông ấy đi!
Dialogue: 0,0:08:54.26,0:08:55.33,Default,,0,0,0,,Không có chuyện đó đâu.
Dialogue: 0,0:08:55.53,0:08:56.67,Default,,0,0,0,,Đừng có xen vào!
Dialogue: 0,0:08:57.90,0:09:00.57,Default,,0,0,0,,Hai người thân nhau thật đấy!
Dialogue: 0,0:09:00.74,0:09:02.40,Default,,0,0,0,,Ừ, đúng rồi đấy!
Dialogue: 0,0:09:08.88,0:09:10.75,Default,,0,0,0,,Độ cao của bóng loạn hết cả lên rồi.
Dialogue: 0,0:09:12.51,0:09:14.68,Default,,0,0,0,,Có nghĩa là điểm tiếp xúc không đều.
Dialogue: 0,0:09:15.25,0:09:16.82,Default,,0,0,0,,Cú vung gậy cũng không có độ mềm mại.
Dialogue: 0,0:09:17.52,0:09:19.49,Default,,0,0,0,,Cứ thế này thì không bao giờ vào được chung kết đâu.
Dialogue: 0,0:09:21.62,0:09:23.29,Default,,0,0,0,,Trước khi rơi vào bế tắc,
Dialogue: 0,0:09:23.39,0:09:25.13,Default,,0,0,0,,nên ôn lại những điều cơ bản đi.
Dialogue: 0,0:09:26.76,0:09:28.23,Default,,0,0,0,,Muốn bắt đầu từ đó sao?
Dialogue: 0,0:09:29.00,0:09:30.30,Default,,0,0,0,,Chịu thua luôn.
Dialogue: 0,0:09:32.67,0:09:33.94,Default,,0,0,0,,Trở lại cơ bản sao?
Dialogue: 0,0:09:57.43,0:09:58.46,Default,,0,0,0,,Trục gậy!
Dialogue: 0,0:09:59.56,0:10:01.33,Default,,0,0,0,,Anh trai đã dạy cho đấy.
Dialogue: 0,0:10:01.83,0:10:05.63,Default,,0,0,0,,Dù có thể bị đánh giá thấp\Nvới tư cách là một giáo viên chuyên nghiệp
Dialogue: 0,0:10:05.70,0:10:08.97,Default,,0,0,0,,nhưng với tư cách là người chơi, \Nkỹ năng của anh ấy vẫn không bằng đâu!
Dialogue: 0,0:10:09.94,0:10:11.67,Default,,0,0,0,,Sao lại đánh bóng lăn trên mặt đất vậy?
Dialogue: 0,0:10:11.94,0:10:13.58,Default,,0,0,0,,Không nghe thấy anh ấy nói gì sao?
Dialogue: 0,0:10:13.81,0:10:16.11,Default,,0,0,0,,Điểm tiếp xúc không đều.
Dialogue: 0,0:10:17.08,0:10:19.78,Default,,0,0,0,,Đánh bóng lăn giúp\Ntiếp xúc ổn định hơn
Dialogue: 0,0:10:19.85,0:10:22.25,Default,,0,0,0,,và cũng cải thiện góc va chạm nữa.
Dialogue: 0,0:10:23.62,0:10:29.89,Default,,0,0,0,,Cố gắng đánh vào tâm bóng với\Nmép dẫn song song với mặt đất.
Dialogue: 0,0:10:31.16,0:10:32.56,Default,,0,0,0,,Khi đã tiến bộ hơn,
Dialogue: 0,0:10:32.69,0:10:34.73,Default,,0,0,0,,sẽ cố gắng kiểm soát bóng từ trên xuống.
Dialogue: 0,0:10:34.96,0:10:38.20,Default,,0,0,0,,Nhưng khi tư thế bắt đầu hỏng,\Nsẽ rất nguy hiểm đấy.
Dialogue: 0,0:10:38.73,0:10:42.27,Default,,0,0,0,,Nếu quét bóng từ bên cạnh,\Ncó thể tạo ra một cú đánh khá tốt.
Dialogue: 0,0:10:42.37,0:10:44.34,Default,,0,0,0,,Không cần phải đánh dập xuống đâu.
Dialogue: 0,0:10:44.81,0:10:48.31,Default,,0,0,0,,Đó là lý do tại sao lại tập quét bóng\Nmột cách chính xác và chuẩn xác.
Dialogue: 0,0:10:48.71,0:10:50.81,Default,,0,0,0,,Anh trai nói thế đấy!
Dialogue: 0,0:10:51.95,0:10:52.92,Default,,0,0,0,,Nếu làm được như vậy,
Dialogue: 0,0:10:53.18,0:10:55.48,Default,,0,0,0,,có thể tập khoảng cách\Nvới những quả bóng lăn.
Dialogue: 0,0:10:56.12,0:10:58.52,Default,,0,0,0,,Tiếp theo, cần thêm độ uốn cho trục gậy.
Dialogue: 0,0:10:58.72,0:10:59.72,Default,,0,0,0,,Độ uốn sao?
Dialogue: 0,0:11:00.32,0:11:02.02,Default,,0,0,0,,Bằng cách xử lý thật mềm mại.
Dialogue: 0,0:11:03.13,0:11:05.16,Default,,0,0,0,,Giống như trò ảo thuật cây bút chì mềm oặt ấy.
Dialogue: 0,0:11:05.46,0:11:07.80,Default,,0,0,0,,Cái mà trông giống như\Nxúc tu của bạch tuộc ấy!
Dialogue: 0,0:11:09.60,0:11:12.50,Default,,0,0,0,,Sau đó, khi đã nắm vững\Nđiểm tiếp xúc và độ uốn,
Dialogue: 0,0:11:13.54,0:11:16.61,Default,,0,0,0,,hạ thấp vị trí\Nđặt mép dẫn xuống một chút.
Dialogue: 0,0:11:17.74,0:11:21.84,Default,,0,0,0,,Căn chỉnh mép dẫn với tâm\Ncủa bóng và mặt đất.
Dialogue: 0,0:11:26.48,0:11:29.65,Default,,0,0,0,,Nếu có thể nhớ được\Ncách tiếp cận mềm mại từ bên cạnh này,
Dialogue: 0,0:11:30.12,0:11:35.96,Default,,0,0,0,,những vị trí bóng ướt, bóng lún và cả\Nbóng trên cát sẽ trở nên dễ dàng hơn nhiều.
Dialogue: 0,0:11:37.13,0:11:38.89,Default,,0,0,0,,Cũng muốn thử nữa!
Dialogue: 0,0:11:42.50,0:11:46.70,Default,,0,0,0,,Hajime, tính sao về\Nquần áo và gậy cho giải đấu đây?
Dialogue: 0,0:11:47.14,0:11:51.71,Default,,0,0,0,,Bộ đồ thể thao đó không được đâu.\NCũng phải tìm một đôi giày nữa.
Dialogue: 0,0:11:53.01,0:11:55.04,Default,,0,0,0,,Tonbo không có giày golf sao?
Dialogue: 0,0:11:55.51,0:11:57.15,Default,,0,0,0,,Không có.
Dialogue: 0,0:11:58.15,0:11:58.98,Default,,0,0,0,,Cỡ giày bao nhiêu?
Dialogue: 0,0:12:00.42,0:12:01.78,Default,,0,0,0,,Cỡ hai mươi sáu.
Dialogue: 0,0:12:02.62,0:12:03.92,Default,,0,0,0,,Thật sao? Vừa in luôn!
Dialogue: 0,0:12:04.25,0:12:06.92,Default,,0,0,0,,Dù không cao lắm nhưng chân lại to!
Dialogue: 0,0:12:07.39,0:12:08.86,Default,,0,0,0,,Sẽ cho một đôi nhé!
Dialogue: 0,0:12:09.22,0:12:10.63,Default,,0,0,0,,Thật sự cho sao?
Dialogue: 0,0:12:12.26,0:12:14.26,Default,,0,0,0,,Lấp lánh quá!
Dialogue: 0,0:12:14.73,0:12:16.53,Default,,0,0,0,,Vẫn còn nhiều đôi dự phòng lắm.
Dialogue: 0,0:12:17.60,0:12:18.93,Default,,0,0,0,,Cảm ơn nhé!
Dialogue: 0,0:12:19.47,0:12:22.04,Default,,0,0,0,,Vậy là giải quyết xong\Nvấn đề về giày rồi.
Dialogue: 0,0:12:24.24,0:12:25.47,Default,,0,0,0,,Ngủ trên giường đi.
Dialogue: 0,0:12:26.01,0:12:27.78,Default,,0,0,0,,Dù sao đây cũng là phòng ngủ mà.
Dialogue: 0,0:12:28.11,0:12:29.04,Default,,0,0,0,,Không sao đâu.
Dialogue: 0,0:12:29.11,0:12:32.21,Default,,0,0,0,,Bị loại khỏi vòng chung kết\Nvà về nhà sớm cơ mà.
Dialogue: 0,0:12:32.51,0:12:33.55,Default,,0,0,0,,Nhưng...
Dialogue: 0,0:12:33.62,0:12:37.49,Default,,0,0,0,,Ngày mai lại đi tour khác rồi.\NChỉ một đêm thôi.
Dialogue: 0,0:12:41.26,0:12:44.29,Default,,0,0,0,,Tonbo có muốn trở thành dân chuyên nghiệp vào một ngày nào đó không?
Dialogue: 0,0:12:45.39,0:12:46.73,Default,,0,0,0,,Cũng không chắc nữa.
Dialogue: 0,0:12:47.00,0:12:48.00,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:12:48.13,0:12:50.67,Default,,0,0,0,,Vẫn chưa tham gia\Ngiải đấu nào mà.
Dialogue: 0,0:12:51.67,0:12:53.54,Default,,0,0,0,,Không sao đâu.
Dialogue: 0,0:12:53.67,0:12:56.71,Default,,0,0,0,,Trước tiên, phải yêu thích\Ntrò chơi golf đã.
Dialogue: 0,0:12:56.87,0:12:57.81,Default,,0,0,0,,Đó là điều quan trọng nhất.
Dialogue: 0,0:12:59.14,0:13:00.74,Default,,0,0,0,,Yêu thích golf sao.
Dialogue: 0,0:13:01.14,0:13:02.78,Default,,0,0,0,,Khi thực sự yêu thích một điều gì đó,
Dialogue: 0,0:13:03.15,0:13:05.25,Default,,0,0,0,,sẽ không thể không cố gắng hết sức.
Dialogue: 0,0:13:05.48,0:13:06.58,Default,,0,0,0,,Ngủ ngon.
Dialogue: 0,0:13:07.78,0:13:08.82,Default,,0,0,0,,Ngủ ngon nhé.
Dialogue: 0,0:13:12.39,0:13:13.76,Default,,0,0,0,,{\i1}Gon-jii.{\i0}
Dialogue: 0,0:13:14.12,0:13:16.26,Default,,0,0,0,,{\i1}Thật sự rất may mắn.{\i0}
Dialogue: 0,0:13:16.89,0:13:19.56,Default,,0,0,0,,{\i1}Đã rất sợ khi phải rời đảo,{\i0}
Dialogue: 0,0:13:19.66,0:13:22.30,Default,,0,0,0,,{\i1}nhưng ở đây lại được bao quanh{\i0}\N{\i1}bởi những người thực sự đáng yêu.{\i0}
Dialogue: 0,0:13:30.51,0:13:32.61,Default,,0,0,0,,Việc luyện tập thực sự có kết quả rồi.
Dialogue: 0,0:13:33.51,0:13:36.11,Default,,0,0,0,,Trục gậy đã bắt đầu uốn cong rồi.
Dialogue: 0,0:13:38.88,0:13:42.32,Default,,0,0,0,,Đã chuẩn bị một chiếc túi mới\Ncho giải Kyushu Women's Open rồi đây.
Dialogue: 0,0:13:42.55,0:13:43.75,Default,,0,0,0,,Vứt cái cũ đi.
Dialogue: 0,0:13:44.29,0:13:45.25,Default,,0,0,0,,Bố?
Dialogue: 0,0:13:45.85,0:13:49.32,Default,,0,0,0,,Sẽ bỏ bộ gậy mới vào đó.\NVứt mấy cây cũ đi hộ nhé.
Dialogue: 0,0:13:49.63,0:13:51.83,Default,,0,0,0,,Yêu cầu hơi quá rồi đấy, Otoha-san.
Dialogue: 0,0:13:52.13,0:13:54.90,Default,,0,0,0,,Sẽ trả phí vứt rác sau.
Dialogue: 0,0:13:55.30,0:13:57.57,Default,,0,0,0,,Tại sao lúc nào bố cũng làm mấy chuyện thế này vậy?
Dialogue: 0,0:13:58.27,0:14:00.67,Default,,0,0,0,,Sao không hỏi ý kiến con trước?
Dialogue: 0,0:14:01.04,0:14:02.80,Default,,0,0,0,,Dù sao đó cũng là túi gậy của con mà!
Dialogue: 0,0:14:03.34,0:14:05.91,Default,,0,0,0,,Chưa từng thấy Hinoki cãi lại bao giờ.
Dialogue: 0,0:14:08.61,0:14:10.85,Default,,0,0,0,,Nếu muốn cãi lại,
Dialogue: 0,0:14:10.95,0:14:13.82,Default,,0,0,0,,thì hãy làm thế sau khi tự mua được thứ gì đó\Nbằng tiền của chính mình đi.
Dialogue: 0,0:14:16.49,0:14:17.89,Default,,0,0,0,,Bất công quá, bố à.
Dialogue: 0,0:14:18.35,0:14:19.76,Default,,0,0,0,,Bố chẳng quan tâm đến điều gì cả.
Dialogue: 0,0:14:28.00,0:14:30.20,Default,,0,0,0,,Thật sự chắc chứ, Hinoki?
Dialogue: 0,0:14:30.53,0:14:32.77,Default,,0,0,0,,Ừ. Dù chỉ là đồ dùng lại,
Dialogue: 0,0:14:33.24,0:14:35.07,Default,,0,0,0,,nhưng cứ nhận lấy cho vui nhé.
Dialogue: 0,0:14:35.37,0:14:36.54,Default,,0,0,0,,Cảm ơn nhiều nhé.
Dialogue: 0,0:14:38.01,0:14:39.68,Default,,0,0,0,,Cảm giác như dân chuyên nghiệp vậy!
Dialogue: 0,0:14:40.38,0:14:41.91,Default,,0,0,0,,Dễ bị ấn tượng thật đấy.
Dialogue: 0,0:14:43.35,0:14:45.18,Default,,0,0,0,,Vậy là xong chuyện cái túi luôn rồi.
Dialogue: 0,0:14:46.75,0:14:48.55,Default,,0,0,0,,Vấn đề là bộ gậy đó.
Dialogue: 0,0:14:49.12,0:14:49.95,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:14:50.02,0:14:51.05,Default,,0,0,0,,Với những gì đang có hiện tại,
Dialogue: 0,0:14:51.25,0:14:53.79,Default,,0,0,0,,cả bộ gậy sắt hoàn toàn không có.
Dialogue: 0,0:14:54.89,0:14:58.49,Default,,0,0,0,,Có lẽ sẽ lén bỏ thêm\Nvài cây nữa cho thành một bộ hoàn chỉnh.
Dialogue: 0,0:14:58.76,0:15:04.00,Default,,0,0,0,,Sẽ nhận ra ngay\Nnếu bỏ những cây gậy xịn vào đó đấy.
Dialogue: 0,0:15:12.27,0:15:13.81,Default,,0,0,0,,Chưa từng thấy cây gậy này bao giờ.
Dialogue: 0,0:15:14.28,0:15:16.58,Default,,0,0,0,,Không nhận ra nó ở trong túi luôn.
Dialogue: 0,0:15:16.91,0:15:17.95,Default,,0,0,0,,Không biết có phải là Hajime không nhỉ?
Dialogue: 0,0:15:18.41,0:15:19.85,Default,,0,0,0,,Là gậy sắt số sáu.
Dialogue: 0,0:15:20.05,0:15:21.02,Default,,0,0,0,,Đánh thử xem!
Dialogue: 0,0:15:21.15,0:15:22.95,Default,,0,0,0,,Khoảng cách cũng vừa đẹp luôn.
Dialogue: 0,0:15:23.29,0:15:24.72,Default,,0,0,0,,Đánh thật thẳng nhé!
Dialogue: 0,0:15:26.79,0:15:30.23,Default,,0,0,0,,Không chắc lắm\Nvề cách đánh thẳng.
Dialogue: 0,0:15:30.96,0:15:33.46,Default,,0,0,0,,Biết rồi. Sẽ thử trò cây bút chì mềm oặt!
Dialogue: 0,0:15:34.06,0:15:35.60,Default,,0,0,0,,Trò cây bút chì mềm oặt sao?
Dialogue: 0,0:15:42.70,0:15:44.34,Default,,0,0,0,,Trục gậy cứ như đang sống vậy!
Dialogue: 0,0:15:46.07,0:15:47.34,Default,,0,0,0,,Cây gậy này tuyệt quá!
Dialogue: 0,0:15:47.81,0:15:48.68,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:15:56.45,0:15:59.09,Default,,0,0,0,,Mặt đất rung chuyển luôn!
Dialogue: 0,0:15:59.92,0:16:01.89,Default,,0,0,0,,Bay thẳng về phía mặt trời rồi!
Dialogue: 0,0:16:02.49,0:16:03.56,Default,,0,0,0,,Cú đánh đẹp lắm!
Dialogue: 0,0:16:09.90,0:16:12.17,Default,,0,0,0,,Quản đốc Nakase! Ngạc nhiên thật đấy.
Dialogue: 0,0:16:12.77,0:16:14.30,Default,,0,0,0,,Hôm nay cũng luyện tập sao?
Dialogue: 0,0:16:14.90,0:16:15.74,Default,,0,0,0,,Vâng.
Dialogue: 0,0:16:15.97,0:16:18.81,Default,,0,0,0,,Thật ra, đây là món đồ\Nmột khách hàng bỏ quên.
Dialogue: 0,0:16:19.34,0:16:22.88,Default,,0,0,0,,Đã giữ nó năm năm rồi\Nvà đáng lẽ nên vứt đi,
Dialogue: 0,0:16:22.98,0:16:25.18,Default,,0,0,0,,nhưng nó là một cây gậy khá tốt.
Dialogue: 0,0:16:26.35,0:16:29.38,Default,,0,0,0,,Chắc là hơi quá tầm\Nvới một người như chú.
Dialogue: 0,0:16:38.86,0:16:41.06,Default,,0,0,0,,Âm thanh tuyệt quá!
Dialogue: 0,0:16:42.40,0:16:43.40,Default,,0,0,0,,Chào buổi tối.
Dialogue: 0,0:16:43.50,0:16:44.53,Default,,0,0,0,,Chào buổi tối.
Dialogue: 0,0:16:46.67,0:16:48.44,Default,,0,0,0,,Có phiền đánh thử cái này không?
Dialogue: 0,0:16:49.00,0:16:50.34,Default,,0,0,0,,Gậy sắt số chín sao?
Dialogue: 0,0:16:50.87,0:16:55.41,Default,,0,0,0,,Không tài nào làm quen được.\NKhông biết nó có vấn đề gì không nữa.
Dialogue: 0,0:16:55.84,0:16:57.61,Default,,0,0,0,,Tuyệt vời quá!
Dialogue: 0,0:16:58.68,0:17:00.88,Default,,0,0,0,,Phần giữa mặt gậy hoàn hảo luôn!
Dialogue: 0,0:17:16.06,0:17:17.87,Default,,0,0,0,,Cây gậy này cầm thích thật!
Dialogue: 0,0:17:18.40,0:17:19.33,Default,,0,0,0,,Tặng luôn đấy.
Dialogue: 0,0:17:20.07,0:17:21.87,Default,,0,0,0,,Không! Không cần phải thế đâu ạ!
Dialogue: 0,0:17:22.70,0:17:25.31,Default,,0,0,0,,Dù sao thì cây gậy này\Nsẽ hạnh phúc hơn đấy.
Dialogue: 0,0:17:26.81,0:17:28.81,Default,,0,0,0,,Vậy là được nửa bộ rồi!
Dialogue: 0,0:17:30.08,0:17:31.01,Default,,0,0,0,,Nửa bộ sao.
Dialogue: 0,0:17:31.58,0:17:34.12,Default,,0,0,0,,Tuyệt quá. Cảm giác như dân chuyên nghiệp vậy!
Dialogue: 0,0:17:40.39,0:17:43.83,Default,,0,0,0,,NGÀY ĐẦU TIÊN, KYUSHU WOMEN'S OPEN
Dialogue: 0,0:17:44.26,0:17:45.63,Default,,0,0,0,,Đông người quá!
Dialogue: 0,0:17:45.73,0:17:47.56,Default,,0,0,0,,Và đều trạc tuổi mình nữa!
Dialogue: 0,0:17:47.96,0:17:49.90,Default,,0,0,0,,Giải Kyushu Women's Open
Dialogue: 0,0:17:50.00,0:17:52.57,Default,,0,0,0,,chủ yếu dành cho những người tham gia ở độ tuổi thanh thiếu niên.
Dialogue: 0,0:17:53.30,0:17:56.71,Default,,0,0,0,,Có thể gọi đây là giải đấu\Ndành cho thế hệ những người mộng mơ.
Dialogue: 0,0:18:59.94,0:18:01.08,Default,,0,0,0,,Ichika Matsuda. Mười bốn gậy.
Dialogue: 0,0:18:01.31,0:18:02.04,Default,,0,0,0,,Vâng.
Dialogue: 0,0:18:02.44,0:18:04.88,Default,,0,0,0,,Shoko Ikeuchi. Cũng mười bốn gậy.
Dialogue: 0,0:18:05.31,0:18:06.11,Default,,0,0,0,,Vâng.
Dialogue: 0,0:18:06.38,0:18:08.28,Default,,0,0,0,,Và Tonbo Oi. Để xem nào.
Dialogue: 0,0:18:08.35,0:18:09.02,Default,,0,0,0,,Hả?
Dialogue: 0,0:18:11.45,0:18:13.49,Default,,0,0,0,,Chỉ có bảy gậy thôi sao?
Dialogue: 0,0:18:13.76,0:18:14.69,Default,,0,0,0,,Vâng!
Dialogue: 0,0:18:15.32,0:18:16.16,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:18:16.23,0:18:17.73,Default,,0,0,0,,Chơi với nửa bộ gậy sao?
Dialogue: 0,0:18:17.79,0:18:20.50,Default,,0,0,0,,Nhìn cây gậy sắt số ba kìa!\NNó mòn vẹt luôn rồi!
Dialogue: 0,0:18:21.33,0:18:22.76,Default,,0,0,0,,Chưa từng có người tham gia nào như vậy cả.
Dialogue: 0,0:18:23.60,0:18:24.77,Default,,0,0,0,,Và một người nữa.
Dialogue: 0,0:18:25.57,0:18:26.77,Default,,0,0,0,,Là đây.
Dialogue: 0,0:18:28.10,0:18:29.40,Default,,0,0,0,,Là Michiko Shima.
Dialogue: 0,0:18:30.34,0:18:32.64,Default,,0,0,0,,Là Tonbo Oi. Rất vui được gặp.
Dialogue: 0,0:18:33.64,0:18:34.94,Default,,0,0,0,,Cứ như bà thím ấy.
Dialogue: 0,0:18:35.68,0:18:38.68,Default,,0,0,0,,Đeo găng tay cả hai bên sao? Nghiệp dư quá.
Dialogue: 0,0:18:40.68,0:18:41.65,Default,,0,0,0,,Nghe này, Hinoki.
Dialogue: 0,0:18:43.29,0:18:44.49,Default,,0,0,0,,Phải giành chiến thắng đấy.
Dialogue: 0,0:18:44.59,0:18:48.46,Default,,0,0,0,,Đừng để con nhóc năm nhất\NTsubura Adaniya đánh bại.
Dialogue: 0,0:18:48.66,0:18:50.46,Default,,0,0,0,,Xin hãy ra khỏi sân!
Dialogue: 0,0:18:51.79,0:18:52.63,Default,,0,0,0,,Được rồi, được rồi.
Dialogue: 0,0:18:52.69,0:18:54.00,Default,,0,0,0,,Xin hãy rời khỏi khu vực green.
Dialogue: 0,0:18:54.06,0:18:55.36,Default,,0,0,0,,Đã nói những gì cần nói rồi đấy.
Dialogue: 0,0:18:55.63,0:18:56.80,Default,,0,0,0,,Tonbo?
Dialogue: 0,0:18:57.30,0:18:58.83,Default,,0,0,0,,Đúng là Tonbo rồi!
Dialogue: 0,0:18:59.54,0:19:00.47,Default,,0,0,0,,Tsubura!
Dialogue: 0,0:19:03.81,0:19:05.71,Default,,0,0,0,,Đang học cấp ba ở Kumamoto đây.
Dialogue: 0,0:19:06.18,0:19:08.64,Default,,0,0,0,,Thật sao? Tuyệt quá!
Dialogue: 0,0:19:09.14,0:19:10.18,Default,,0,0,0,,Dũng cảm thật đấy.
Dialogue: 0,0:19:10.38,0:19:11.45,Default,,0,0,0,,Vui quá đi mất!
Dialogue: 0,0:19:12.01,0:19:12.95,Default,,0,0,0,,Cảm ơn nhé.
Dialogue: 0,0:19:14.08,0:19:16.08,Default,,0,0,0,,Là ứng cử viên vô địch, Tsubura Adaniya.
Dialogue: 0,0:19:16.52,0:19:17.95,Default,,0,0,0,,Cô gái đi cùng là ai vậy?
Dialogue: 0,0:19:18.49,0:19:20.56,Default,,0,0,0,,Tonbo là bạn của Tsubura Adaniya sao?
Dialogue: 0,0:19:21.66,0:19:23.09,Default,,0,0,0,,Thật thiếu chuyên nghiệp.
Dialogue: 0,0:19:23.99,0:19:25.73,Default,,0,0,0,,Gì cơ? Có bảy gậy sao?
Dialogue: 0,0:19:26.09,0:19:27.00,Default,,0,0,0,,Đúng không?
Dialogue: 0,0:19:27.10,0:19:28.26,Default,,0,0,0,,Tin được không?
Dialogue: 0,0:19:28.46,0:19:29.63,Default,,0,0,0,,Nhiều hơn hẳn so với trước kia luôn!
Dialogue: 0,0:19:31.10,0:19:33.04,Default,,0,0,0,,Đã dần dần có thêm nhiều gậy hơn
Dialogue: 0,0:19:33.10,0:19:35.10,Default,,0,0,0,,kể từ khi được tặng cây gậy gỗ số năm đấy.
Dialogue: 0,0:19:35.47,0:19:36.81,Default,,0,0,0,,Bảy gậy.
Dialogue: 0,0:19:37.87,0:19:40.94,Default,,0,0,0,,Khi chơi cùng nhau\Nở Hinoshima, chỉ có hai cây thôi.
Dialogue: 0,0:19:41.51,0:19:43.88,Default,,0,0,0,,Dù vậy lối chơi vẫn rất ấn tượng.
Dialogue: 0,0:19:44.51,0:19:45.38,Default,,0,0,0,,Và giờ đã có bảy cây rồi!
Dialogue: 0,0:19:47.98,0:19:48.82,Default,,0,0,0,,Tsubura?
Dialogue: 0,0:19:49.35,0:19:50.99,Default,,0,0,0,,Căng rồi đây.
Dialogue: 0,0:19:51.12,0:19:53.89,Default,,0,0,0,,Có khi sẽ nẫng mất chức vô địch\NKyushu Women's Open mất, Tonbo!
Dialogue: 0,0:19:56.59,0:19:58.16,Default,,0,0,0,,Nhưng hôm nay không định thua đâu.
Dialogue: 0,0:19:58.36,0:19:59.66,Default,,0,0,0,,Sẽ tiếp tục tiến lên thôi!
Dialogue: 0,0:20:02.87,0:20:03.90,Default,,0,0,0,,Hẹn gặp lại sau nhé!
Dialogue: 0,0:20:05.87,0:20:06.97,Default,,0,0,0,,Không ai biết...
Dialogue: 0,0:20:08.10,0:20:12.57,Default,,0,0,0,,...một tay golf đáng gờm\Ntừ một hòn đảo vô danh đang ở đây.
Dialogue: 0,0:20:14.24,0:20:18.85,Default,,0,0,0,,Nhóm bảy, bắt đầu lúc 8:24.\NVui lòng tập trung ở khu vực phát bóng.
Dialogue: 0,0:20:25.35,0:20:28.32,Default,,0,0,0,,Bắt đầu thôi. Giải đấu đầu tiên của mình.
Dialogue: 0,0:20:28.39,0:20:30.63,Default,,0,0,0,,Rất thích những trải nghiệm mới.
Dialogue: 0,0:20:32.03,0:20:35.26,Default,,0,0,0,,Đã rời đảo\Nđể tìm hiểu thêm về thế giới.
Dialogue: 0,0:20:36.23,0:20:41.44,Default,,0,0,0,,Đã rời đảo để học hỏi thêm\Nvề môn golf mà mình vô cùng yêu thích.
Dialogue: 0,0:20:41.57,0:20:44.04,Default,,0,0,0,,Và giờ thì đang thi đấu đây!
Dialogue: 0,0:20:45.44,0:20:50.15,Default,,0,0,0,,Khi thực hiện cú đánh đầu tiên,\Nhầu hết người chơi đều tập trung vào điểm rơi.
Dialogue: 0,0:20:50.28,0:20:54.28,Default,,0,0,0,,Những người khác lại tập trung vào nơi\Nhọ không muốn đánh bóng tới.
Dialogue: 0,0:20:55.55,0:20:56.89,Default,,0,0,0,,Không biết Tonbo sẽ đánh đi đâu nhỉ.
Dialogue: 0,0:20:58.55,0:21:04.09,Default,,0,0,0,,Không phải điểm rơi hay ngoài biên.\NGreen sao? Không. Còn xa hơn nữa.
Dialogue: 0,0:21:05.43,0:21:07.46,Default,,0,0,0,,Các vận động viên, xin mời bắt đầu!
Dialogue: 0,0:21:14.60,0:21:17.34,Default,,0,0,0,,Gần cao bằng\Nnúi Ontake ở Hinoshima luôn.
Dialogue: 0,0:21:18.24,0:21:19.24,Default,,0,0,0,,Cô Oi, đến lượt cô rồi!
Dialogue: 0,0:21:19.68,0:21:20.68,Default,,0,0,0,,Vâng!
Dialogue: 0,0:21:22.31,0:21:25.11,Default,,0,0,0,,Tonbo từng nói chưa bao giờ cảm thấy\Nsợ hãi khi chơi golf.
Dialogue: 0,0:21:25.98,0:21:28.92,Default,,0,0,0,,Nhưng đây là giải đấu đầu tiên của con bé.
Dialogue: 0,0:21:29.02,0:21:33.62,Default,,0,0,0,,Với chừng này người xem,\Nchắc chắn con bé sẽ thấy hồi hộp.
Dialogue: 0,0:21:36.09,0:21:37.39,Default,,0,0,0,,Không dùng găng tay sao?
Dialogue: 0,0:21:38.13,0:21:40.90,Default,,0,0,0,,{\i1}Bay đi, Tonbo. Bay đi.{\i0}
Dialogue: 0,0:21:41.26,0:21:44.10,Default,,0,0,0,,{\i1}Ai cũng thấy hồi hộp{\i0}\N{\i1}vào sáng sớm cả.{\i0}
Dialogue: 0,0:21:44.30,0:21:47.20,Default,,0,0,0,,{\i1}Không phải do kỹ năng. Mà là do tâm lý.{\i0}
Dialogue: 0,0:21:47.30,0:21:51.41,Default,,0,0,0,,{\i1}Cho mọi người thấy đi, Tonbo.{\i0}
Dialogue: 0,0:21:52.51,0:21:53.64,Default,,0,0,0,,Igaia.
Dialogue: 0,0:21:53.81,0:21:59.21,Default,,0,0,0,,{\i1}Gon-jii. Setsu. Yoko. Bunpei. Hidaka.{\i0}
Dialogue: 0,0:22:00.42,0:22:03.85,Default,,0,0,0,,{\i1}Cú đánh này là hướng về đảo.{\i0}\N{\i1}Dành cho tất cả mọi người.{\i0}
Dialogue: 0,0:22:07.12,0:22:09.73,Default,,0,0,0,,Tonbo đang nhón gót sao?
Dialogue: 0,0:23:49.12,0:23:51.73,Default,,0,0,0,,Tsubura, thấy hồi hộp quá!
Dialogue: 0,0:23:51.86,0:23:55.13,Default,,0,0,0,,Không cần phải căng thẳng đâu.\NCứ chơi như mọi khi là được!
Dialogue: 0,0:23:55.23,0:23:56.80,Default,,0,0,0,,Đúng nhỉ.
Dialogue: 0,0:23:57.23,0:23:58.80,Default,,0,0,0,,Chỉ cần là chính mình thôi!
Dialogue: 0,0:23:58.97,0:24:00.47,Default,,0,0,0,,-Đúng vậy!\N-Đi đây!
Dialogue: 0,0:24:00.80,0:24:02.14,Default,,0,0,0,,Tư thế một chân kìa!
Dialogue: 0,0:24:02.24,0:24:03.61,Default,,0,0,0,,Không phải cái đó! Khoan đã!
Dialogue: 0,0:24:03.91,0:24:05.34,Default,,0,0,0,,Trong tập tiếp theo của Tonbo!
Dialogue: 0,0:24:05.44,0:24:07.41,Default,,0,0,0,,"Số Gậy Trung Bình Sự Nghiệp!"