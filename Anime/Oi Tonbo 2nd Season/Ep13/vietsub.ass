Dialogue: 0,0:00:13.18,0:00:16.51,Default,,0,0,0,,TONBO!
Dialogue: 0,0:01:34.55,0:01:36.59,Default,,0,0,0,,TẬP 26: THỬ THÁCH CỦA TONBO\NNHỮNG NỮ ANH HÙNG KYUSHU
Dialogue: 0,0:01:36.68,0:01:41.31,Default,,0,0,0,,{\i1}Khi còn nhỏ, Tonbo Oi đã chuyển đến{\i0}\N{\i1}Hinoshima thuộc quần đảo Tokara.{\i0}
Dialogue: 0,0:01:42.31,0:01:46.39,Default,,0,0,0,,{\i1}Với cây gậy sắt số 3 yêu quý của người cha quá cố,{\i0}\N{\i1}cô bé đã bắt đầu hành trình với golf.{\i0}
Dialogue: 0,0:01:46.48,0:01:49.31,Default,,0,0,0,,{\i1}Tài năng golf thiên bẩm ngày càng nở rộ,{\i0}
Dialogue: 0,0:01:50.31,0:01:53.73,Default,,0,0,0,,{\i1}Tonbo đã lên trung học ở Kumamoto.{\i0}
Dialogue: 0,0:01:53.82,0:01:59.03,Default,,0,0,0,,{\i1}Tại đây, cô bé đã đạt được một kỳ tích khó tin,{\i0}\N{\i1}đó là vô địch Giải Golf Nữ Kyushu.{\i0}
Dialogue: 0,0:01:59.11,0:02:02.08,Default,,0,0,0,,{\i1}Giờ đây, cô bé đã trở về Hinoshima,{\i0}\N{\i1}trong sự chào đón như một nhà vô địch.{\i0}
Dialogue: 0,0:02:03.45,0:02:07.54,Default,,0,0,0,,Này, Igaiga. Sao mặt đáng sợ vậy?\NĐang lầm bầm một mình kìa!
Dialogue: 0,0:02:07.62,0:02:09.83,Default,,0,0,0,,Á! K-Không có gì!
Dialogue: 0,0:02:11.00,0:02:14.30,Default,,0,0,0,,Hoàng hôn trên Hinoshima sau ngần ấy thời gian\Nthấy thế nào hả?
Dialogue: 0,0:02:14.38,0:02:17.59,Default,,0,0,0,,Tuyệt vời lắm, y như trong ký ức vậy.
Dialogue: 0,0:02:17.67,0:02:19.51,Default,,0,0,0,,Hinoshima đúng là một nơi tuyệt vời!
Dialogue: 0,0:02:19.97,0:02:24.26,Default,,0,0,0,,Nhưng chắc khoảng thời gian rời đảo\Ncũng thú vị lắm nhỉ.
Dialogue: 0,0:02:24.68,0:02:28.23,Default,,0,0,0,,Tất nhiên rồi! Hồi hộp\Nđến mức chóng cả mặt luôn!
Dialogue: 0,0:02:28.31,0:02:30.90,Default,,0,0,0,,Điều ấn tượng nhất là...
Dialogue: 0,0:02:31.40,0:02:32.69,Default,,0,0,0,,Là gì thế?
Dialogue: 0,0:02:32.77,0:02:34.61,Default,,0,0,0,,Bát ramen đã ăn ở Kagoshima!
Dialogue: 0,0:02:34.69,0:02:35.65,Default,,0,0,0,,{\i1}Hả?! Ramen á?!{\i0}
Dialogue: 0,0:02:36.24,0:02:37.61,Default,,0,0,0,,Của quý khách đây!
Dialogue: 0,0:02:43.24,0:02:46.83,Default,,0,0,0,,Gì thế này? Lần đầu tiên\Nthấy thứ như thế này đấy!
Dialogue: 0,0:02:47.50,0:02:51.17,Default,,0,0,0,,{\i1}Thật tình, dù ở đâu\Ncũng không bao giờ mất cảm giác thèm ăn nhỉ.{\i0}
Dialogue: 0,0:02:52.08,0:02:55.34,Default,,0,0,0,,{\i1}Lúc trên đường đến nhà chú Udo\Nđã rất hồi hộp đấy.{\i0}
Dialogue: 0,0:02:55.42,0:02:58.09,Default,,0,0,0,,{\i1}Không phải đã ngủ say tít thò lò\Ntrên tàu siêu tốc sao?{\i0}
Dialogue: 0,0:03:00.09,0:03:04.51,Default,,0,0,0,,{\i1}Sân tập golf chú ấy điều hành\Nđẹp đến mức kinh ngạc luôn.{\i0}
Dialogue: 0,0:03:04.60,0:03:06.47,Default,,0,0,0,,{\i1}Ban đêm thì sáng rực rỡ!{\i0}
Dialogue: 0,0:03:06.56,0:03:10.14,Default,,0,0,0,,{\i1}Vợ chồng chú Udo\Ncũng rất vui vẻ nữa.{\i0}
Dialogue: 0,0:03:10.23,0:03:15.69,Default,,0,0,0,,{\i1}Ừ, cô Yaya rất được khách hàng yêu quý.{\i0}
Dialogue: 0,0:03:15.77,0:03:17.61,Default,,0,0,0,,Đánh thử xem nào.
Dialogue: 0,0:03:17.69,0:03:18.82,Default,,0,0,0,,{\i1}Gậy driver á?{\i0}
Dialogue: 0,0:03:20.11,0:03:24.12,Default,,0,0,0,,{\i1}Đột nhiên bị bảo dùng gậy driver\Nlàm bất ngờ lắm luôn.{\i0}
Dialogue: 0,0:03:24.20,0:03:28.83,Default,,0,0,0,,{\i1}Ừ, lúc đó cũng toát mồ hôi hột đấy.{\i0}
Dialogue: 0,0:03:31.04,0:03:31.92,Default,,0,0,0,,Vâng!
Dialogue: 0,0:03:40.13,0:03:42.93,Default,,0,0,0,,Dùng gậy driver khó thật đấy...
Dialogue: 0,0:03:43.93,0:03:46.47,Default,,0,0,0,,{\i1}À, nhắc đến cô chú Udo mới nhớ...{\i0}
Dialogue: 0,0:03:46.56,0:03:47.72,Default,,0,0,0,,{\i1}Sao cơ?{\i0}
Dialogue: 0,0:03:47.81,0:03:51.31,Default,,0,0,0,,{\i1}-Bữa sáng họ làm ngon tuyệt vời!{\i0}\N{\i1}-Hả?!{\i0}
Dialogue: 0,0:03:51.39,0:03:54.98,Default,,0,0,0,,{\i1}Ấn tượng đầu tiên khi nghĩ đến họ\Nlại là bữa sáng à?{\i0}
Dialogue: 0,0:03:55.06,0:03:56.36,Default,,0,0,0,,{\i1}Kh-Không phải đâu!{\i0}
Dialogue: 0,0:03:56.44,0:03:59.99,Default,,0,0,0,,{\i1}Con trai của họ, anh Hajime, là huấn luyện viên golf.{\i0}
Dialogue: 0,0:04:00.61,0:04:03.78,Default,,0,0,0,,Igarashi-san có kể rồi. Có muốn đi cùng không?
Dialogue: 0,0:04:04.24,0:04:05.12,Default,,0,0,0,,Có ạ!
Dialogue: 0,0:04:06.53,0:04:08.41,Default,,0,0,0,,Mọi người ơi, lại đây nào!
Dialogue: 0,0:04:08.87,0:04:12.04,Default,,0,0,0,,Giới thiệu bạn mới nhé. Đến từ Tokara--
Dialogue: 0,0:04:12.92,0:04:15.29,Default,,0,0,0,,Mình là Tonbo Oi! Rất vui được--
Dialogue: 0,0:04:16.63,0:04:18.96,Default,,0,0,0,,Đánh thử cái này đi!
Dialogue: 0,0:04:19.05,0:04:24.47,Default,,0,0,0,,{\i1}Chưa từng ở quanh nhiều người cùng tuổi\Nnhư vậy bao giờ nên run lắm.{\i0}
Dialogue: 0,0:04:24.97,0:04:26.43,Default,,0,0,0,,{\i1}Với lại,{\i0}
Dialogue: 0,0:04:26.51,0:04:31.52,Default,,0,0,0,,{\i1}Chỉ cách Hinoki có một tuổi thôi\Nmà cậu ấy trông trưởng thành quá.{\i0}
Dialogue: 0,0:04:31.60,0:04:36.40,Default,,0,0,0,,{\i1}Đó là người bạn đầu tiên\Nquen được ở Kumamoto nhỉ?{\i0}
Dialogue: 0,0:04:37.06,0:04:38.57,Default,,0,0,0,,Lần đầu tiên thấy cậu đấy.
Dialogue: 0,0:04:39.82,0:04:42.11,Default,,0,0,0,,-Vâng, đúng vậy.\N-Tôi là Hinoki Otoha.
Dialogue: 0,0:04:42.19,0:04:44.66,Default,,0,0,0,,Học sinh năm hai trung học.\NRất vui được gặp.
Dialogue: 0,0:04:52.66,0:04:55.21,Default,,0,0,0,,Rộng quá! Xanh rì! Đẹp quá!
Dialogue: 0,0:05:07.05,0:05:09.30,Default,,0,0,0,,Được rồi, Tonbo! Lần đầu ra sân nhé!
Dialogue: 0,0:05:10.26,0:05:11.85,Default,,0,0,0,,Vâng!
Dialogue: 0,0:05:17.44,0:05:18.56,Default,,0,0,0,,Bay thấp quá!
Dialogue: 0,0:05:18.65,0:05:22.32,Default,,0,0,0,,{\i1}Đó là lần đầu tiên chơi trên sân thật.\NThấy thế nào?{\i0}
Dialogue: 0,0:05:22.40,0:05:24.11,Default,,0,0,0,,{\i1}Khác hẳn với trên đảo.{\i0}
Dialogue: 0,0:05:24.19,0:05:28.37,Default,,0,0,0,,{\i1}Không có gió biển mạnh,\Nvà bóng lăn cũng khác nữa.{\i0}
Dialogue: 0,0:05:28.45,0:05:33.37,Default,,0,0,0,,{\i1}Cứ như hồi chơi trên sân đảo\Ncủa chú Kuta vậy, vui lắm!{\i0}
Dialogue: 0,0:05:33.45,0:05:36.96,Default,,0,0,0,,{\i1}Tích lũy những trải nghiệm mới\Nvà thử thách những điều mới.{\i0}
Dialogue: 0,0:05:37.04,0:05:39.75,Default,,0,0,0,,{\i1}-Đúng như Kuta nói.\N-Vâng.{\i0}
Dialogue: 0,0:05:44.80,0:05:47.01,Default,,0,0,0,,Được rồi! Vui quá đi mất!
Dialogue: 0,0:05:47.47,0:05:48.34,Default,,0,0,0,,Gậy driver á?
Dialogue: 0,0:05:48.43,0:05:52.01,Default,,0,0,0,,{\i1}Đó là lúc Igaiga tặng gậy mới nhỉ.{\i0}
Dialogue: 0,0:05:52.10,0:05:54.39,Default,,0,0,0,,{\i1}À... Phải rồi.{\i0}
Dialogue: 0,0:05:56.14,0:05:57.81,Default,,0,0,0,,Sao vậy? Có vấn đề gì à?
Dialogue: 0,0:05:57.90,0:06:00.19,Default,,0,0,0,,Tận 15,309 yên lận!
Dialogue: 0,0:06:01.11,0:06:04.11,Default,,0,0,0,,{\i1}Món quà chia tay đó làm vui lắm đấy!{\i0}
Dialogue: 0,0:06:04.19,0:06:06.70,Default,,0,0,0,,{\i1}Lúc đó ngại muốn chết...{\i0}
Dialogue: 0,0:06:07.20,0:06:08.49,Default,,0,0,0,,Ừ-Ừm...
Dialogue: 0,0:06:08.57,0:06:11.99,Default,,0,0,0,,-Ừm. Thế là khá rẻ rồi.\N-Còn là gậy cũ nữa.
Dialogue: 0,0:06:16.58,0:06:18.08,Default,,0,0,0,,Đừng có đánh xoáy ở đó!
Dialogue: 0,0:06:18.17,0:06:19.50,Default,,0,0,0,,Sẽ bay xuống vách đá mất!
Dialogue: 0,0:06:19.58,0:06:22.50,Default,,0,0,0,,{\i1}Cố lên! Hy vọng là chọn đúng gậy driver!{\i0}
Dialogue: 0,0:06:22.92,0:06:24.00,Default,,0,0,0,,Tuyệt chiêu chim én!
Dialogue: 0,0:06:28.59,0:06:29.51,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:06:29.59,0:06:31.01,Default,,0,0,0,,Thành công rồi!
Dialogue: 0,0:06:34.97,0:06:35.93,Default,,0,0,0,,Lọt qua rồi!
Dialogue: 0,0:06:36.02,0:06:38.56,Default,,0,0,0,,Bay đi! Cú đánh cá chuồn!
Dialogue: 0,0:06:39.19,0:06:42.65,Default,,0,0,0,,{\i1}Mọi người đều bị choáng ngợp{\i0}\N{\i1}bởi lối chơi đó đấy.{\i0}
Dialogue: 0,0:06:42.73,0:06:45.69,Default,,0,0,0,,{\i1}Chỉ là chơi như bình thường thôi mà.{\i0}
Dialogue: 0,0:06:45.78,0:06:49.70,Default,,0,0,0,,{\i1}Chính cái "bình thường" đó{\i0}\N{\i1}mới làm người ta choáng ngợp đấy.{\i0}
Dialogue: 0,0:06:50.45,0:06:51.66,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:06:52.82,0:06:55.12,Default,,0,0,0,,Không ngờ lại học\Ncùng trường đấy.
Dialogue: 0,0:06:55.20,0:06:56.04,Default,,0,0,0,,Nhẹ cả người!
Dialogue: 0,0:06:56.50,0:06:59.04,Default,,0,0,0,,Cứ lo phải đến trường\Nmột mình cơ.
Dialogue: 0,0:07:02.00,0:07:03.54,Default,,0,0,0,,{\i1}Sao lại khóc thế?{\i0}
Dialogue: 0,0:07:03.63,0:07:06.96,Default,,0,0,0,,{\i1}Tại vì đã lớn{\i0}\N{\i1}thành học sinh trung học rồi...{\i0}
Dialogue: 0,0:07:07.05,0:07:10.59,Default,,0,0,0,,{\i1}Còn trao đổi thông tin liên lạc với tiền bối nữa...{\i0}
Dialogue: 0,0:07:10.68,0:07:13.85,Default,,0,0,0,,{\i1}Lễ tốt nghiệp cũng nói\Nnhững lời tương tự nhỉ.{\i0}
Dialogue: 0,0:07:15.81,0:07:17.81,Default,,0,0,0,,{\i1}Igaiga, nước mũi chảy kìa!{\i0}
Dialogue: 0,0:07:19.77,0:07:21.31,Default,,0,0,0,,Ba mươi tám á?
Dialogue: 0,0:07:22.06,0:07:24.23,Default,,0,0,0,,Đã bảo là không được quá một gậy cơ mà!
Dialogue: 0,0:07:25.19,0:07:28.86,Default,,0,0,0,,{\i1}Đó là lúc đột nhiên\Nnổi cáu với bố cậu ấy nhỉ.{\i0}
Dialogue: 0,0:07:28.94,0:07:31.82,Default,,0,0,0,,{\i1}Ừ, lúc đó lỡ mất bình tĩnh\Nmột chút thôi.{\i0}
Dialogue: 0,0:07:32.74,0:07:35.70,Default,,0,0,0,,Sao ông nghĩ\Nđó chỉ là gió nhẹ hả?
Dialogue: 0,0:07:36.95,0:07:39.87,Default,,0,0,0,,Ông ở trong nhà mà?\NLàm sao mà biết được?
Dialogue: 0,0:07:41.54,0:07:44.59,Default,,0,0,0,,{\i1}Nếu có cuộc thi làm mặt đáng sợ,{\i0}\N{\i1}chắc chắn Igaiga sẽ thắng đấy.{\i0}
Dialogue: 0,0:07:44.71,0:07:45.84,Default,,0,0,0,,{\i1}Thôi đi...{\i0}
Dialogue: 0,0:07:51.30,0:07:53.30,Default,,0,0,0,,-Một giải đấu á?\N-Đúng vậy.
Dialogue: 0,0:07:53.43,0:07:56.01,Default,,0,0,0,,Giải Kyushu Women's Open vào tháng sau.
Dialogue: 0,0:07:56.10,0:07:58.72,Default,,0,0,0,,Sẽ tổ chức ở Chuo Country Club!
Dialogue: 0,0:07:58.81,0:08:00.89,Default,,0,0,0,,Sẽ làm gì đây, Tonbo?
Dialogue: 0,0:08:00.98,0:08:02.35,Default,,0,0,0,,Ý chú là sao?
Dialogue: 0,0:08:02.77,0:08:03.81,Default,,0,0,0,,Bố!
Dialogue: 0,0:08:03.90,0:08:07.36,Default,,0,0,0,,{\i1}Lúc biết mình sẽ tham gia giải đấu\Nđã sốc lắm đấy!{\i0}
Dialogue: 0,0:08:07.44,0:08:08.40,Default,,0,0,0,,Không đời nào.
Dialogue: 0,0:08:08.48,0:08:11.70,Default,,0,0,0,,Đó là lý do ngay từ đầu\NTonbo đã rời đảo cơ mà!
Dialogue: 0,0:08:11.78,0:08:15.66,Default,,0,0,0,,{\i1}Anh Hajime đã nỗ lực rất nhiều để giúp đỡ.{\i0}
Dialogue: 0,0:08:15.74,0:08:18.87,Default,,0,0,0,,{\i1}Thật không biết cảm ơn gia đình Udo sao cho đủ.{\i0}
Dialogue: 0,0:08:19.41,0:08:22.62,Default,,0,0,0,,Sẽ đưa Tonbo\Nvào giải Kyushu Women's Open!
Dialogue: 0,0:08:23.21,0:08:27.09,Default,,0,0,0,,{\i1}Hình như còn một người nữa\Ntrong gia đình Udo đã giúp đỡ nhỉ?{\i0}
Dialogue: 0,0:08:27.21,0:08:29.63,Default,,0,0,0,,{\i1}Người khác á?{\i0}
Dialogue: 0,0:08:33.76,0:08:35.84,Default,,0,0,0,,Ai đó? Tránh xa ra!
Dialogue: 0,0:08:35.93,0:08:38.39,Default,,0,0,0,,Bình tĩnh nào, Tonbo!
Dialogue: 0,0:08:38.93,0:08:40.89,Default,,0,0,0,,Xin lỗi vì đã làm em sợ nhé.
Dialogue: 0,0:08:40.97,0:08:43.64,Default,,0,0,0,,Thực ra đây từng là phòng ngủ của chị.
Dialogue: 0,0:08:45.52,0:08:47.81,Default,,0,0,0,,{\i1}Nikome Udo, một tay golf chuyên nghiệp.{\i0}
Dialogue: 0,0:08:48.52,0:08:53.36,Default,,0,0,0,,{\i1}Cô ấy về nhà trong tình trạng suy sụp\Nmỗi khi không qua vòng loại.{\i0}
Dialogue: 0,0:08:53.45,0:08:55.57,Default,,0,0,0,,{\i1}Cảm giác đó tôi hiểu quá rõ mà...{\i0}
Dialogue: 0,0:08:55.66,0:08:58.08,Default,,0,0,0,,{\i1}Chị ấy đã tặng giày golf{\i0}
Dialogue: 0,0:08:58.16,0:09:03.33,Default,,0,0,0,,{\i1}và dạy cho một điều rất quan trọng\Nđể có thể tiếp tục chơi golf.{\i0}
Dialogue: 0,0:09:04.58,0:09:07.88,Default,,0,0,0,,Tonbo có muốn trở thành tuyển thủ chuyên nghiệp không?
Dialogue: 0,0:09:08.79,0:09:11.34,Default,,0,0,0,,-Em cũng không rõ nữa.\N-Chị hiểu rồi.
Dialogue: 0,0:09:11.42,0:09:13.88,Default,,0,0,0,,Em thậm chí còn chưa từng\Ntham gia giải đấu nào mà.
Dialogue: 0,0:09:15.09,0:09:16.80,Default,,0,0,0,,Không sao đâu.
Dialogue: 0,0:09:16.89,0:09:19.56,Default,,0,0,0,,Trước tiên, em phải yêu golf đã.
Dialogue: 0,0:09:20.18,0:09:21.39,Default,,0,0,0,,Đó là điều quan trọng nhất.
Dialogue: 0,0:09:22.43,0:09:23.89,Default,,0,0,0,,Yêu golf.
Dialogue: 0,0:09:24.43,0:09:28.61,Default,,0,0,0,,Khi thực sự yêu thích một điều gì đó,\Nchắc chắn em sẽ cố gắng hết mình.
Dialogue: 0,0:09:29.06,0:09:30.40,Default,,0,0,0,,Ngủ ngon nhé.
Dialogue: 0,0:09:31.78,0:09:33.90,Default,,0,0,0,,{\i1}Hinoki đã tặng túi đựng gậy.{\i0}
Dialogue: 0,0:09:33.99,0:09:35.90,Default,,0,0,0,,{\i1}Anh Hajime tặng gậy sắt số 6.{\i0}
Dialogue: 0,0:09:35.99,0:09:40.78,Default,,0,0,0,,{\i1}Và một người ở câu lạc bộ\Nđã tặng gậy sắt số 9.{\i0}
Dialogue: 0,0:09:45.08,0:09:48.88,Default,,0,0,0,,{\i1}Cùng với cây gậy sắt số 3 nữa,\Ntổng cộng là bảy cây.{\i0}
Dialogue: 0,0:09:48.96,0:09:52.38,Default,,0,0,0,,{\i1}-Thế gọi là một nửa bộ gậy.\N-Biết rồi mà!{\i0}
Dialogue: 0,0:09:53.55,0:09:54.88,Default,,0,0,0,,Một nửa bộ gậy...
Dialogue: 0,0:09:54.97,0:09:57.80,Default,,0,0,0,,Ngầu quá. Cứ như dân chuyên nghiệp vậy!
Dialogue: 0,0:10:03.56,0:10:07.81,Default,,0,0,0,,{\i1}Đã tình cờ gặp một người vào ngày đầu tiên\Ncủa giải Kyushu Women's Open đấy!{\i0}
Dialogue: 0,0:10:07.90,0:10:08.90,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:10:09.40,0:10:11.57,Default,,0,0,0,,Đúng là cậu rồi!
Dialogue: 0,0:10:12.11,0:10:12.98,Default,,0,0,0,,Tsubura!
Dialogue: 0,0:10:14.32,0:10:16.24,Default,,0,0,0,,Cậu thực sự ở đây này!
Dialogue: 0,0:10:16.32,0:10:18.20,Default,,0,0,0,,Đang học trung học ở Kumamoto.
Dialogue: 0,0:10:18.78,0:10:21.45,Default,,0,0,0,,Giỏi quá đi. Vui quá!
Dialogue: 0,0:10:26.87,0:10:31.63,Default,,0,0,0,,{\i1}Igaiga. Ông Gon. Setsu. Yoko.{\i0}
Dialogue: 0,0:10:31.71,0:10:34.67,Default,,0,0,0,,{\i1}Bunpei. Hidaka.{\i0}
Dialogue: 0,0:10:34.76,0:10:38.93,Default,,0,0,0,,{\i1}Giải đấu đầu tiên đã bắt đầu rồi.{\i0}
Dialogue: 0,0:10:39.01,0:10:41.64,Default,,0,0,0,,{\i1}Ước gì lúc đó được ở đấy!{\i0}
Dialogue: 0,0:10:41.72,0:10:44.93,Default,,0,0,0,,{\i1}Đừng lo. Đã đánh quả bóng\Nbay thẳng về đảo rồi mà.{\i0}
Dialogue: 0,0:11:06.75,0:11:07.91,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:11:08.00,0:11:10.87,Default,,0,0,0,,Eagle đ-đẹp lắm.
Dialogue: 0,0:11:10.96,0:11:14.00,Default,,0,0,0,,{\i1}Eagle sao? Màn ra mắt quá đỉnh!{\i0}
Dialogue: 0,0:11:14.09,0:11:16.46,Default,,0,0,0,,{\i1}Ước gì được tận mắt nhìn thấy!{\i0}
Dialogue: 0,0:11:16.55,0:11:19.01,Default,,0,0,0,,{\i1}Lẽ ra không nên về đảo!{\i0}
Dialogue: 0,0:11:19.42,0:11:21.89,Default,,0,0,0,,{\i1}Hidaka và Bunpei sẽ buồn lắm đấy!{\i0}
Dialogue: 0,0:11:24.22,0:11:28.56,Default,,0,0,0,,{\i1}Cô Shima trong nhóm\Nđã tham gia lần thứ ba rồi.{\i0}
Dialogue: 0,0:11:28.68,0:11:30.73,Default,,0,0,0,,{\i1}Cô ấy là một người rất tốt.{\i0}
Dialogue: 0,0:11:30.81,0:11:34.02,Default,,0,0,0,,Xin lỗi. Có làm phiền mọi người không?
Dialogue: 0,0:11:39.15,0:11:41.49,Default,,0,0,0,,{\i1}Chị Matsuda, người cũng ở trong nhóm,{\i0}
Dialogue: 0,0:11:41.57,0:11:44.66,Default,,0,0,0,,{\i1}đang mất phong độ, và trông rất đáng sợ.{\i0}
Dialogue: 0,0:11:44.74,0:11:46.74,Default,,0,0,0,,{\i1}Nhưng sau đó, cô Shima đã nói...{\i0}
Dialogue: 0,0:11:47.20,0:11:48.37,Default,,0,0,0,,Nhưng cháu biết không,
Dialogue: 0,0:11:48.45,0:11:52.33,Default,,0,0,0,,không thể sửa chữa sai lầm\Nchỉ trong một sớm một chiều đâu.
Dialogue: 0,0:11:53.46,0:11:56.38,Default,,0,0,0,,Có tận 18 lỗ\Nđể làm lại từ đầu mà.
Dialogue: 0,0:11:56.80,0:12:00.51,Default,,0,0,0,,Nếu đã đến cuối trận\Nmà không thể làm gì được nữa,
Dialogue: 0,0:12:01.05,0:12:03.64,Default,,0,0,0,,thì vẫn còn cả một đời\Nở phía trước.
Dialogue: 0,0:12:04.05,0:12:06.39,Default,,0,0,0,,Nếu có thể cải thiện\Nsố gậy trung bình cả đời
Dialogue: 0,0:12:06.47,0:12:09.39,Default,,0,0,0,,dù chỉ là một điểm thôi, thì đó\Ncũng là điều đáng tự hào rồi!
Dialogue: 0,0:12:11.10,0:12:13.81,Default,,0,0,0,,Trung bình cả đời sao?
Dialogue: 0,0:12:13.90,0:12:16.65,Default,,0,0,0,,{\i1}Thật là những lời thông thái...{\i0}
Dialogue: 0,0:12:16.73,0:12:19.65,Default,,0,0,0,,{\i1}Nhờ những lời đó,{\i0}\N{\i1}một người tưởng chừng như đáng sợ,{\i0}
Dialogue: 0,0:12:19.74,0:12:22.65,Default,,0,0,0,,{\i1}bỗng trở nên dễ gần hơn hẳn.{\i0}
Dialogue: 0,0:12:23.78,0:12:27.12,Default,,0,0,0,,{\i1}Chà! Đứng nhất luôn! Đỉnh quá!{\i0}
Dialogue: 0,0:12:27.20,0:12:30.70,Default,,0,0,0,,{\i1}-Ước gì được tận mắt nhìn thấy...\N-Đủ rồi đấy!{\i0}
Dialogue: 0,0:12:32.21,0:12:33.50,Default,,0,0,0,,{\i1}Cô Shima...{\i0}
Dialogue: 0,0:12:34.08,0:12:37.54,Default,,0,0,0,,{\i1}-Tiếc thật đấy...\N-Vâng.{\i0}
Dialogue: 0,0:12:37.63,0:12:41.47,Default,,0,0,0,,{\i1}Nhưng cô ấy đã dạy một điều rất quan trọng.{\i0}
Dialogue: 0,0:12:41.55,0:12:44.64,Default,,0,0,0,,{\i1}Ừ. Thật may vì đã gặp được cô ấy.{\i0}
Dialogue: 0,0:12:44.72,0:12:46.43,Default,,0,0,0,,Yêu golf đến mức đó đấy.
Dialogue: 0,0:12:47.89,0:12:51.93,Default,,0,0,0,,Cháu rất vui vì được chơi\Ncùng cô, cô Shima.
Dialogue: 0,0:12:52.64,0:12:55.60,Default,,0,0,0,,Cháu rất muốn được chơi cùng cô lần nữa.
Dialogue: 0,0:12:55.69,0:12:57.90,Default,,0,0,0,,Cảm ơn cháu, Tonbo.
Dialogue: 0,0:13:03.61,0:13:05.49,Default,,0,0,0,,Đông thật đấy.
Dialogue: 0,0:13:05.57,0:13:07.66,Default,,0,0,0,,{\i1}Vào ngày thứ hai, đã gặp một người mới.{\i0}
Dialogue: 0,0:13:08.45,0:13:11.91,Default,,0,0,0,,{\i1}Ema Kurisu, cựu{\i0}\N{\i1}Nhà vô địch Trẻ Thế giới.{\i0}
Dialogue: 0,0:13:13.87,0:13:15.21,Default,,0,0,0,,{\i1}Thuận tay trái sao?{\i0}
Dialogue: 0,0:13:15.83,0:13:18.75,Default,,0,0,0,,{\i1}Chị ấy bị chấn thương nặng ở chân trái{\i0}
Dialogue: 0,0:13:18.84,0:13:22.59,Default,,0,0,0,,{\i1}và bắt đầu chơi bằng tay trái\Nđể vượt qua chấn thương.{\i0}
Dialogue: 0,0:13:30.43,0:13:35.85,Default,,0,0,0,,{\i1}Đã chơi một vòng cùng chị ấy,{\i0}\N{\i1}Tsubura và Hinoki.{\i0}
Dialogue: 0,0:13:36.31,0:13:41.23,Default,,0,0,0,,Lần này lại làm caddy cho cô nhé, Hata.\NRất mong được giúp đỡ.
Dialogue: 0,0:13:41.32,0:13:43.44,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:13:56.33,0:13:59.42,Default,,0,0,0,,{\i1}Sự quyết tâm của Ema thực sự truyền cảm hứng.{\i0}
Dialogue: 0,0:13:59.54,0:14:03.17,Default,,0,0,0,,{\i1}Làm nhớ lại lúc Tsubura chia sẻ{\i0}\N{\i1}về ước mơ hồi ở Hinoshima.{\i0}
Dialogue: 0,0:14:03.26,0:14:05.80,Default,,0,0,0,,{\i1}Niềm đam mê golf của cậu ấy...{\i0}
Dialogue: 0,0:14:06.43,0:14:08.55,Default,,0,0,0,,{\i1}Bản thân mình cũng có thể học hỏi từ đó.{\i0}
Dialogue: 0,0:14:08.64,0:14:12.72,Default,,0,0,0,,{\i1}Mọi người đều có sự cống hiến tuyệt vời{\i0}\N{\i1}cho môn thể thao này.{\i0}
Dialogue: 0,0:14:13.97,0:14:17.73,Default,,0,0,0,,Ở Mỹ, có đủ loại sinh vật đáng sợ\Nsống trong các hồ nước trên sân golf.
Dialogue: 0,0:14:18.98,0:14:20.98,Default,,0,0,0,,Ý chị là cá sấu á?
Dialogue: 0,0:14:21.44,0:14:26.49,Default,,0,0,0,,Chị đã mất khả năng vung gậy và\Nthực hiện những cú đánh đẹp như em.
Dialogue: 0,0:14:27.45,0:14:30.82,Default,,0,0,0,,Tuy nhiên, cũng không hẳn là tệ.
Dialogue: 0,0:14:30.91,0:14:33.29,Default,,0,0,0,,Vẫn có thể chơi được là vui rồi.
Dialogue: 0,0:14:33.37,0:14:36.25,Default,,0,0,0,,Chị biết ơn vì mình vẫn có thể chơi golf.
Dialogue: 0,0:14:36.33,0:14:39.75,Default,,0,0,0,,Có lẽ đó chính là\Nđiểm mạnh lớn nhất của chị.
Dialogue: 0,0:14:40.63,0:14:45.84,Default,,0,0,0,,{\i1}Ngày thứ hai, đã đánh 77 gậy,{\i0}\N{\i1}tệ hơn 10 gậy so với vòng mở màn...{\i0}
Dialogue: 0,0:14:45.96,0:14:47.59,Default,,0,0,0,,{\i1}Đó là lúc...{\i0}
Dialogue: 0,0:14:53.85,0:14:55.02,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:14:56.39,0:14:59.23,Default,,0,0,0,,Làm gì ở đây thế?\NĐến đón hả?
Dialogue: 0,0:15:02.36,0:15:03.73,Default,,0,0,0,,Đang làm rất tốt đấy.
Dialogue: 0,0:15:06.82,0:15:08.78,Default,,0,0,0,,{\i1}Lúc đó tự nhiên khóc òa lên.{\i0}
Dialogue: 0,0:15:08.90,0:15:11.62,Default,,0,0,0,,{\i1}Gặp lại vui đến thế cơ à?{\i0}
Dialogue: 0,0:15:11.70,0:15:14.12,Default,,0,0,0,,{\i1}Không! Không phải thế. Chỉ là...{\i0}
Dialogue: 0,0:15:14.20,0:15:17.12,Default,,0,0,0,,{\i1}Chỉ là thấy vui khi gặp lại{\i0}\N{\i1}sau ngần ấy thời gian thôi.{\i0}
Dialogue: 0,0:15:17.20,0:15:19.37,Default,,0,0,0,,{\i1}Nhớ hòn đảo quá.{\i0}
Dialogue: 0,0:15:19.46,0:15:23.59,Default,,0,0,0,,{\i1}-Chỉ là nhớ nhà thôi!\N-Chắc ý là "homesick" nhỉ?{\i0}
Dialogue: 0,0:15:26.05,0:15:29.38,Default,,0,0,0,,Nhớ cái dụng cụ dùng\Nđể đập bạch tuộc và cá không?
Dialogue: 0,0:15:31.55,0:15:34.47,Default,,0,0,0,,{\i1}Lúc đầu, chẳng hiểu lời khuyên đó đâu.{\i0}
Dialogue: 0,0:15:34.56,0:15:37.56,Default,,0,0,0,,{\i1}-Nhưng hiệu quả phết!\N-Thấy chưa?!{\i0}
Dialogue: 0,0:15:41.44,0:15:45.73,Default,,0,0,0,,Có bất ngờ khi nghe tin\Nđứng nhất vào ngày đầu tiên không?
Dialogue: 0,0:15:45.82,0:15:48.57,Default,,0,0,0,,Thực ra cũng không\Nbất ngờ lắm đâu.
Dialogue: 0,0:15:48.65,0:15:49.53,Default,,0,0,0,,Ồ?
Dialogue: 0,0:15:49.95,0:15:53.07,Default,,0,0,0,,Hơn hết là thấy rất vui.
Dialogue: 0,0:15:54.28,0:15:55.53,Default,,0,0,0,,Và không chỉ mình tôi đâu.
Dialogue: 0,0:15:56.08,0:15:58.54,Default,,0,0,0,,{\i1}Mọi người trên đảo đều cười rất tươi.{\i0}
Dialogue: 0,0:15:59.08,0:16:03.04,Default,,0,0,0,,{\i1}Mọi người trên đảo đều đang cổ vũ đấy.{\i0}
Dialogue: 0,0:16:03.46,0:16:08.67,Default,,0,0,0,,Cứ như thể đã trở thành\Nniềm tự hào của cả đảo vậy.
Dialogue: 0,0:16:08.76,0:16:10.76,Default,,0,0,0,,Họ rất vui vì có một người như vậy.
Dialogue: 0,0:16:13.64,0:16:16.43,Default,,0,0,0,,Đừng bận tâm đến điểm số!
Dialogue: 0,0:16:16.93,0:16:21.64,Default,,0,0,0,,Cứ chơi theo cách của mình! Cho xem\Nphong cách Tonbo đặc biệt đó đi!
Dialogue: 0,0:16:22.10,0:16:22.94,Default,,0,0,0,,Vâng!
Dialogue: 0,0:16:27.23,0:16:29.65,Default,,0,0,0,,Bay đi! Cú đánh cá chuồn!
Dialogue: 0,0:16:31.61,0:16:34.41,Default,,0,0,0,,Gì vậy? Tư thế đó!
Dialogue: 0,0:16:38.29,0:16:40.29,Default,,0,0,0,,Tránh được hố cát rồi!
Dialogue: 0,0:16:44.08,0:16:44.92,Default,,0,0,0,,Sao cơ?
Dialogue: 0,0:16:45.00,0:16:47.92,Default,,0,0,0,,Biết ngay là được mà! Vui quá đi!
Dialogue: 0,0:16:48.71,0:16:51.67,Default,,0,0,0,,{\i1}Igaiga ở đằng kia. Được rồi.{\i0}
Dialogue: 0,0:16:58.64,0:17:01.31,Default,,0,0,0,,Tuyệt! Trúng đích rồi! Ơ?
Dialogue: 0,0:17:07.48,0:17:09.65,Default,,0,0,0,,Được rồi! Birdie đầu tiên!
Dialogue: 0,0:17:10.61,0:17:13.95,Default,,0,0,0,,Nếu mắc sai lầm ở lỗ này,\Nsẽ bị dẫn trước bốn gậy.
Dialogue: 0,0:17:14.03,0:17:16.11,Default,,0,0,0,,Bị dẫn trước bốn gậy khi chỉ còn ba lỗ.
Dialogue: 0,0:17:16.20,0:17:17.91,Default,,0,0,0,,Sẽ không thể thắng được đâu.
Dialogue: 0,0:17:18.33,0:17:22.29,Default,,0,0,0,,Nói cách khác, đừng có đánh bogey\Nnếu vẫn muốn giành chiến thắng.
Dialogue: 0,0:17:25.54,0:17:27.67,Default,,0,0,0,,Nếu vẫn muốn chiến thắng...
Dialogue: 0,0:17:28.17,0:17:32.51,Default,,0,0,0,,{\i1}Vẫn luôn chờ đợi điều gì đó{\i0}\N{\i1}bùng cháy bên trong.{\i0}
Dialogue: 0,0:17:32.59,0:17:36.68,Default,,0,0,0,,{\i1}Ừ. Có thể cảm nhận được điều đó{\i0}\N{\i1}từ lỗ thứ 15 trở đi.{\i0}
Dialogue: 0,0:17:36.76,0:17:38.47,Default,,0,0,0,,{\i1}Gì thế này?{\i0}
Dialogue: 0,0:17:38.55,0:17:40.68,Default,,0,0,0,,{\i1}Không. Muốn thắng.{\i0}
Dialogue: 0,0:17:40.76,0:17:44.10,Default,,0,0,0,,{\i1}Mọi người trên đảo{\i0}\N{\i1}sẽ rất vui nếu giành chiến thắng.{\i0}
Dialogue: 0,0:17:44.18,0:17:46.81,Default,,0,0,0,,{\i1}Muốn làm họ vui. Muốn thắng.{\i0}
Dialogue: 0,0:17:47.73,0:17:48.81,Default,,0,0,0,,{\i1}Hiểu rồi.{\i0}
Dialogue: 0,0:17:49.73,0:17:52.61,Default,,0,0,0,,{\i1}Đang rất run.{\i0}
Dialogue: 0,0:17:52.69,0:17:54.53,Default,,0,0,0,,{\i1}Đang chịu áp lực.{\i0}
Dialogue: 0,0:17:55.70,0:17:57.70,Default,,0,0,0,,Không quan tâm đến cơ hội nữa.
Dialogue: 0,0:17:59.62,0:18:02.45,Default,,0,0,0,,Bằng cách thừa nhận áp lực đang gánh chịu,
Dialogue: 0,0:18:04.12,0:18:06.21,Default,,0,0,0,,Đã sẵn sàng đối mặt trực tiếp với nó.
Dialogue: 0,0:18:07.08,0:18:09.46,Default,,0,0,0,,{\i1}Có thể sẽ thất bại.{\i0}
Dialogue: 0,0:18:10.04,0:18:12.21,Default,,0,0,0,,{\i1}Đây là một cú đánh đáng sợ.{\i0}
Dialogue: 0,0:18:14.05,0:18:16.22,Default,,0,0,0,,{\i1}Đây là lần đầu tiên{\i0}\N{\i1}cảm nhận được điều này.{\i0}
Dialogue: 0,0:18:17.80,0:18:20.72,Default,,0,0,0,,{\i1}Ra đây là golf thực sự.{\i0}
Dialogue: 0,0:18:24.43,0:18:26.19,Default,,0,0,0,,{\i1}Cố lên. Cú đánh con cua!{\i0}
Dialogue: 0,0:18:27.77,0:18:29.69,Default,,0,0,0,,Làm ơn! Tới đó đi!
Dialogue: 0,0:18:32.19,0:18:33.48,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:18:40.37,0:18:42.37,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:18:44.58,0:18:49.08,Default,,0,0,0,,{\i1}Đây là lỗ đầu tiên cảm nhận được{\i0}\N{\i1}áp lực mà Igaiga đã cảnh báo đấy.{\i0}
Dialogue: 0,0:18:49.33,0:18:51.34,Default,,0,0,0,,{\i1}Và cảm giác đó kéo dài đến tận lỗ cuối cùng.{\i0}
Dialogue: 0,0:18:51.54,0:18:52.38,Default,,0,0,0,,{\i1}Tonbo...{\i0}
Dialogue: 0,0:18:52.92,0:18:56.72,Default,,0,0,0,,{\i1}Nhưng biết không, mỗi khi{\i0}\N{\i1}bắt đầu suy nghĩ quá nhiều,{\i0}
Dialogue: 0,0:18:56.80,0:18:59.26,Default,,0,0,0,,{\i1}lại nghe thấy tiếng cổ vũ đấy.{\i0}
Dialogue: 0,0:19:00.05,0:19:00.89,Default,,0,0,0,,Đi đây.
Dialogue: 0,0:19:01.64,0:19:04.39,Default,,0,0,0,,Đúng như Igaiga đã nói.
Dialogue: 0,0:19:06.52,0:19:09.65,Default,,0,0,0,,Hoàn toàn không nhắm vào fairway luôn!
Dialogue: 0,0:19:12.77,0:19:16.15,Default,,0,0,0,,Đúng như đã nói.\NĐiểm số không quan trọng.
Dialogue: 0,0:19:24.28,0:19:27.50,Default,,0,0,0,,Cố hết sức đi! Giành chiến thắng nào!
Dialogue: 0,0:19:30.83,0:19:35.75,Default,,0,0,0,,{\i1}Nhờ có Igaiga, cuối cùng đã nhận ra{\i0}\N{\i1}ý nghĩa thực sự của golf.{\i0}
Dialogue: 0,0:19:36.09,0:19:38.63,Default,,0,0,0,,{\i1}Suýt nữa thì!{\i0}
Dialogue: 0,0:19:38.72,0:19:42.01,Default,,0,0,0,,{\i1}Sao lại không vào chứ?!{\i0}
Dialogue: 0,0:19:42.51,0:19:45.14,Default,,0,0,0,,{\i1}Tại Igaiga làm xui đấy.{\i0}
Dialogue: 0,0:19:45.97,0:19:47.35,Default,,0,0,0,,{\i1}Vui quá đi!{\i0}
Dialogue: 0,0:19:52.02,0:19:57.57,Default,,0,0,0,,{\i1}Nhóm cuối cùng gồm Tsubura,{\i0}\N{\i1}Hinoki, Ema và mình.{\i0}
Dialogue: 0,0:19:57.65,0:19:59.49,Default,,0,0,0,,Lọt qua đi!
Dialogue: 0,0:19:59.57,0:20:03.53,Default,,0,0,0,,{\i1}Đến ngày thứ ba,{\i0}\N{\i1}tình trạng căng cơ ở chân đã trở nên tồi tệ hơn.{\i0}
Dialogue: 0,0:20:08.20,0:20:09.75,Default,,0,0,0,,Thành công rồi!
Dialogue: 0,0:20:10.29,0:20:15.09,Default,,0,0,0,,{\i1}Nhưng Ema đã cố nén{\i0}\N{\i1}cơn đau và cuối cùng ngã gục.{\i0}
Dialogue: 0,0:20:15.17,0:20:19.26,Default,,0,0,0,,{\i1}Sự quyết tâm tinh thần như vậy{\i0}\N{\i1}rất hiếm thấy ở các tuyển thủ.{\i0}
Dialogue: 0,0:20:19.34,0:20:22.68,Default,,0,0,0,,{\i1}Dù vậy, các giải đấu vẫn có thể rất tàn nhẫn...{\i0}
Dialogue: 0,0:20:24.60,0:20:26.60,Default,,0,0,0,,Yahoo!
Dialogue: 0,0:20:30.14,0:20:34.65,Default,,0,0,0,,Giờ là vòng playoff rồi, Hinoki!
Dialogue: 0,0:20:37.73,0:20:39.74,Default,,0,0,0,,Không. Sai rồi.
Dialogue: 0,0:20:43.82,0:20:44.87,Default,,0,0,0,,Sao cơ?
Dialogue: 0,0:20:49.24,0:20:50.41,Default,,0,0,0,,Hinoki.
Dialogue: 0,0:20:53.29,0:20:55.67,Default,,0,0,0,,Hôm qua, ở lỗ thứ năm.
Dialogue: 0,0:20:56.54,0:20:57.75,Default,,0,0,0,,Đã làm bóng di chuyển!
Dialogue: 0,0:20:57.96,0:20:59.67,Default,,0,0,0,,Nhưng lại không báo cáo!
Dialogue: 0,0:21:00.46,0:21:04.05,Default,,0,0,0,,Mà vẫn tiếp tục chơi. Vẫn tiếp tục!
Dialogue: 0,0:21:06.39,0:21:07.76,Default,,0,0,0,,Tôi...
Dialogue: 0,0:21:09.39,0:21:10.43,Default,,0,0,0,,Tôi...
Dialogue: 0,0:21:10.52,0:21:12.31,Default,,0,0,0,,...xin bỏ cuộc!
Dialogue: 0,0:21:14.14,0:21:17.94,Default,,0,0,0,,{\i1}Đó hẳn là một tình huống{\i0}\N{\i1}rất khó khăn đối với Hinoki.{\i0}
Dialogue: 0,0:21:18.07,0:21:20.11,Default,,0,0,0,,{\i1}Dù sao thì phạm luật vẫn là phạm luật.{\i0}
Dialogue: 0,0:21:20.19,0:21:22.24,Default,,0,0,0,,{\i1}Phải can đảm lắm mới dám thú nhận điều đó.{\i0}
Dialogue: 0,0:21:22.49,0:21:23.95,Default,,0,0,0,,{\i1}Thật đáng nể.{\i0}
Dialogue: 0,0:21:24.03,0:21:25.20,Default,,0,0,0,,{\i1}Đúng vậy.{\i0}
Dialogue: 0,0:21:27.37,0:21:30.83,Default,,0,0,0,,{\i1}Đã nói với Hinoki những lời tốt đẹp{\i0}
Dialogue: 0,0:21:30.99,0:21:34.04,Default,,0,0,0,,{\i1}và anh Hajime cũng động viên nữa.{\i0}
Dialogue: 0,0:21:34.16,0:21:38.04,Default,,0,0,0,,{\i1}Thật sự rất vui vì điều đó.{\i0}
Dialogue: 0,0:21:39.00,0:21:41.00,Default,,0,0,0,,Hinoki.
Dialogue: 0,0:21:41.59,0:21:43.59,Default,,0,0,0,,Cậu sẽ không bỏ cuộc đâu nhỉ?
Dialogue: 0,0:21:44.93,0:21:45.97,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:21:49.43,0:21:51.52,Default,,0,0,0,,Không bỏ cuộc đâu.
Dialogue: 0,0:21:56.31,0:21:58.23,Default,,0,0,0,,Biết không, Igaiga...
Dialogue: 0,0:21:58.36,0:22:03.53,Default,,0,0,0,,Kể từ khi rời đảo,\Nđã ngày càng yêu golf hơn.
Dialogue: 0,0:22:03.94,0:22:07.95,Default,,0,0,0,,Không phải là đặt ra mục tiêu\Nhayo hướng tới điều gì đó.
Dialogue: 0,0:22:08.07,0:22:11.83,Default,,0,0,0,,Chỉ cần yêu thích môn thể thao này là đủ rồi.
Dialogue: 0,0:22:11.95,0:22:13.33,Default,,0,0,0,,Đó là điều đã nhận ra.
Dialogue: 0,0:22:13.75,0:22:15.16,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:22:15.25,0:22:22.05,Default,,0,0,0,,Và điều đó có nghĩa là sẽ\Ntiếp tục yêu golf nhiều hơn nữa!
Dialogue: 0,0:22:22.13,0:22:23.59,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:22:23.67,0:22:27.51,Default,,0,0,0,,Cùng ăn cá của ông Gon và đồ ăn\NSetsu nấu cho đến khi no căng bụng nào!
Dialogue: 0,0:22:27.59,0:22:29.60,Default,,0,0,0,,Không tập luyện à?
Dialogue: 0,0:22:29.72,0:22:31.85,Default,,0,0,0,,Đúng chuẩn Tonbo nhỉ?
Dialogue: 0,0:22:31.93,0:22:34.64,Default,,0,0,0,,Được rồi! Tắm thôi rồi ăn tối nào!
Dialogue: 0,0:22:34.73,0:22:36.73,Default,,0,0,0,,Tuyệt!