Dialogue: 0,0:00:04.25,0:00:05.08,Default,,0,0,0,,Tonbo Oi?
Dialogue: 0,0:00:05.21,0:00:06.04,Default,,0,0,0,,Ai vậy?
Dialogue: 0,0:00:06.17,0:00:08.30,Default,,0,0,0,,Nghe nói đây là giải đấu đầu tiên đấy.
Dialogue: 0,0:00:08.50,0:00:10.34,Default,,0,0,0,,Âm năm gậy ngay giải đấu đầu tiên sao?
Dialogue: 0,0:00:10.42,0:00:13.26,Default,,0,0,0,,Nghe nói còn chỉ dùng\Nmột nửa bộ gậy nữa chứ!
Dialogue: 0,0:00:13.63,0:00:16.05,Default,,0,0,0,,Tonbo đã có màn ra mắt thật ấn tượng trong hôm nay!
Dialogue: 0,0:00:16.26,0:00:18.51,Default,,0,0,0,,Đúng vậy.\NTốt hơn những gì có thể tưởng tượng.
Dialogue: 0,0:00:20.39,0:00:23.77,Default,,0,0,0,,Còn Tsubura Adaniya thì sao? Chắc chắn sẽ\Nvượt qua được thành tích 67 gậy của Tonbo thôi.
Dialogue: 0,0:00:25.85,0:00:27.90,Default,,0,0,0,,Có điểm mới rồi!
Dialogue: 0,0:00:29.19,0:00:30.36,Default,,0,0,0,,Tsubura đang đứng thứ hai!
Dialogue: 0,0:00:30.69,0:00:33.57,Default,,0,0,0,,Có vẻ Tsubura Adaniya\Nđang ở mức âm hai gậy.
Dialogue: 0,0:00:36.32,0:00:38.28,Default,,0,0,0,,Nhóm đánh out course vừa hoàn thành xong.
Dialogue: 0,0:00:38.83,0:00:41.29,Default,,0,0,0,,Nhóm đánh in course sẽ kết thúc cuối cùng.
Dialogue: 0,0:00:41.50,0:00:44.67,Default,,0,0,0,,Nếu một người chỉ dùng nửa bộ gậy\Nmà giành chiến thắng giải đấu này
Dialogue: 0,0:00:44.75,0:00:45.87,Default,,0,0,0,,thì sẽ là tin chấn động đấy.
Dialogue: 0,0:00:46.08,0:00:47.84,Default,,0,0,0,,Tsubura Adaniya đang đứng thứ hai,
Dialogue: 0,0:00:47.92,0:00:49.63,Default,,0,0,0,,và Hinoki Otaha đứng thứ ba.
Dialogue: 0,0:00:49.71,0:00:51.55,Default,,0,0,0,,Đều là những tay golf đáng chú ý cả.
Dialogue: 0,0:00:52.17,0:00:53.34,Default,,0,0,0,,Đánh đây!
Dialogue: 0,0:01:00.18,0:01:01.39,Default,,0,0,0,,Ôi, không.
Dialogue: 0,0:01:01.47,0:01:03.93,Default,,0,0,0,,Đó không phải là vị trí tốt\Ncho hố cuối cùng đâu.
Dialogue: 0,0:01:04.02,0:01:06.40,Default,,0,0,0,,Chắc là sẽ không\Nvui với cú đó đâu.
Dialogue: 0,0:02:47.08,0:02:48.83,Default,,0,0,0,,Mong là sẽ lọt vào vòng chung kết nhé!
Dialogue: 0,0:02:49.37,0:02:50.25,Default,,0,0,0,,Vâng.
Dialogue: 0,0:02:50.42,0:02:52.46,Default,,0,0,0,,Hai năm qua đều không lọt vào được.
Dialogue: 0,0:02:53.04,0:02:56.34,Default,,0,0,0,,Trước khi mất, chồng tôi từng nói\Nrằng anh ấy muốn được chơi ở vòng chung kết.
Dialogue: 0,0:02:56.67,0:02:57.51,Default,,0,0,0,,Nên là,
Dialogue: 0,0:02:58.05,0:02:59.59,Default,,0,0,0,,muốn làm điều đó vì anh ấy.
Dialogue: 0,0:03:04.39,0:03:05.35,Default,,0,0,0,,Làm gì thế!
Dialogue: 0,0:03:06.81,0:03:07.85,Default,,0,0,0,,Tsubura?
Dialogue: 0,0:03:08.31,0:03:10.10,Default,,0,0,0,,Mọi người đều đang rất bất ngờ đấy!
Dialogue: 0,0:03:11.06,0:03:16.86,Default,,0,0,0,,Ai cũng đang bàn tán xôn xao về\Ncô bé mới đến chỉ dùng nửa bộ gậy kìa!
Dialogue: 0,0:03:18.36,0:03:20.90,Default,,0,0,0,,Chẳng thấy bất ngờ chút nào!
Dialogue: 0,0:03:22.16,0:03:23.99,Default,,0,0,0,,{\i1}Tất nhiên đó là nói dối rồi.{\i0}
Dialogue: 0,0:03:24.91,0:03:26.74,Default,,0,0,0,,{\i1}Không thể tin được là lại âm năm gậy.{\i0}
Dialogue: 0,0:03:28.08,0:03:32.37,Default,,0,0,0,,Có thêm hai cây gậy sắt mới trong túi\Ngiúp đánh dễ hơn hẳn.
Dialogue: 0,0:03:33.08,0:03:35.13,Default,,0,0,0,,Chắc là do ăn may thôi.
Dialogue: 0,0:03:35.59,0:03:38.88,Default,,0,0,0,,Chưa bao giờ đạt được số điểm\Nnhư thế này luôn!
Dialogue: 0,0:03:40.72,0:03:43.64,Default,,0,0,0,,Nhóm cuối cùng vừa mới về.
Dialogue: 0,0:03:43.97,0:03:46.35,Default,,0,0,0,,Những vị trí dẫn đầu\Nchắc sẽ không thay đổi đâu.
Dialogue: 0,0:03:46.47,0:03:49.68,Default,,0,0,0,,Việc chia nhóm ngày mai\Nsẽ dựa trên bảng xếp hạng hiện tại,
Dialogue: 0,0:03:49.77,0:03:52.14,Default,,0,0,0,,nên có lẽ ngày mai\Nchúng ta sẽ chơi cùng nhau đấy.
Dialogue: 0,0:03:52.60,0:03:54.02,Default,,0,0,0,,Được chơi cùng nhau à?
Dialogue: 0,0:03:54.40,0:03:55.69,Default,,0,0,0,,Yahoo!
Dialogue: 0,0:04:00.94,0:04:02.99,Default,,0,0,0,,Điểm của nhóm cuối cùng đang được cập nhật.
Dialogue: 0,0:04:03.99,0:04:07.66,Default,,0,0,0,,{\i1}Với số điểm hiện tại thì đang đứng thứ 99.{\i0}
Dialogue: 0,0:04:09.24,0:04:13.67,Default,,0,0,0,,{\i1}Họ vừa thêm một cái tên nữa ở trên.{\i0}\N{\i1}Thế là tụt xuống thứ 100 rồi.{\i0}
Dialogue: 0,0:04:14.54,0:04:16.38,Default,,0,0,0,,{\i1}Lại là hạng 100.{\i0}
Dialogue: 0,0:04:18.21,0:04:20.01,Default,,0,0,0,,{\i1}Đứng chót bảng rồi.{\i0}
Dialogue: 0,0:04:22.38,0:04:23.30,Default,,0,0,0,,Là cô bé đó sao?
Dialogue: 0,0:04:23.88,0:04:26.05,Default,,0,0,0,,Ngay hố đầu tiên đã đánh 8 gậy kìa.
Dialogue: 0,0:04:27.39,0:04:28.56,Default,,0,0,0,,{\i1}Có lẽ vẫn còn cơ hội.{\i0}
Dialogue: 0,0:04:36.52,0:04:37.56,Default,,0,0,0,,Sáu mươi chín?
Dialogue: 0,0:04:37.90,0:04:41.24,Default,,0,0,0,,Lại thêm một người có điểm số\Nđầu sáu vào phút chót!
Dialogue: 0,0:04:41.90,0:04:44.95,Default,,0,0,0,,Sáu mươi chín gậy dù bị double par sao?
Dialogue: 0,0:04:45.28,0:04:47.20,Default,,0,0,0,,Thế là âm bảy gậy rồi.
Dialogue: 0,0:04:48.53,0:04:51.08,Default,,0,0,0,,Đánh với cơ số sáu mươi lăm gậy sao?
Dialogue: 0,0:04:55.04,0:04:56.08,Default,,0,0,0,,Shima-san.
Dialogue: 0,0:04:57.54,0:05:00.71,Default,,0,0,0,,Bị gạch một đường ngang\Ntrên tên mình như thế
Dialogue: 0,0:05:01.55,0:05:05.09,Default,,0,0,0,,cứ như bị người ta bảo rằng\Nmình là kẻ vô dụng vậy.
Dialogue: 0,0:05:05.55,0:05:06.84,Default,,0,0,0,,Đau lòng thật đấy.
Dialogue: 0,0:05:09.56,0:05:10.72,Default,,0,0,0,,Nhưng mà...
Dialogue: 0,0:05:10.81,0:05:12.35,Default,,0,0,0,,Đúng như lời chồng tôi đã nói.
Dialogue: 0,0:05:12.81,0:05:15.60,Default,,0,0,0,,Golf chẳng bao giờ diễn ra theo ý mình muốn.
Dialogue: 0,0:05:16.19,0:05:19.86,Default,,0,0,0,,Sẽ cố gắng hết sức để chuẩn bị lại\Ncho năm sau.
Dialogue: 0,0:05:20.19,0:05:22.23,Default,,0,0,0,,Vì tôi yêu golf đến vậy mà.
Dialogue: 0,0:05:23.69,0:05:27.74,Default,,0,0,0,,Thật vui vì đã được chơi\Ncùng Shima-san.
Dialogue: 0,0:05:28.45,0:05:30.74,Default,,0,0,0,,Mong là một ngày nào đó sẽ lại được chơi cùng nhau.
Dialogue: 0,0:05:31.33,0:05:33.37,Default,,0,0,0,,Cảm ơn nhé, Tonbo.
Dialogue: 0,0:05:37.17,0:05:39.59,Default,,0,0,0,,Đây là hệ thống phát thanh\Nphòng chống thiên tai làng Toshima.
Dialogue: 0,0:05:39.79,0:05:42.30,Default,,0,0,0,,Chúng tôi có một thông báo.
Dialogue: 0,0:05:42.59,0:05:49.30,Default,,0,0,0,,Về giải Kyushu Women's Open\Nvừa bắt đầu hôm nay--
Dialogue: 0,0:05:49.39,0:05:54.18,Default,,0,0,0,,-Đó là một giải đấu golf, và--\N-Mau nói vào trọng tâm đi!
Dialogue: 0,0:05:54.60,0:06:00.90,Default,,0,0,0,,Đúng rồi. Một cư dân của hòn đảo này và là\Nhọc sinh trường Trung học Tsuboi...
Dialogue: 0,0:06:01.48,0:06:03.03,Default,,0,0,0,,Nói dài dòng quá rồi đấy!
Dialogue: 0,0:06:03.65,0:06:07.40,Default,,0,0,0,,Mọi người ơi! Tonbo đang đứng hạng nhất\Nngay trong giải đấu đầu tiên đấy!
Dialogue: 0,0:06:07.65,0:06:11.83,Default,,0,0,0,,{\i1}Này! Đã bảo để tôi nói mà!{\i0}\N{\i1}Dù gì tôi cũng là người nghe được tin này đầu tiên!{\i0}
Dialogue: 0,0:06:12.12,0:06:15.08,Default,,0,0,0,,{\i1}Mọi người ơi! Phải ăn mừng thôi!{\i0}
Dialogue: 0,0:06:15.29,0:06:18.83,Default,,0,0,0,,{\i1}Hôm nay mới là ngày đầu tiên thôi!{\i0}\N{\i1}Giải đấu kéo dài tận ba ngày cơ mà!{\i0}
Dialogue: 0,0:06:19.08,0:06:25.26,Default,,0,0,0,,{\i1}Thì vẫn phải ăn mừng chứ!{\i0}\N{\i1}Uống thôi! Cố lên Tonbo!{\i0}
Dialogue: 0,0:06:28.76,0:06:31.05,Default,,0,0,0,,Chẳng để cho người ta nói gì cả!
Dialogue: 0,0:06:31.14,0:06:34.31,Default,,0,0,0,,Tại cứ lề mề luyên thuyên\Nmấy thứ vớ vẩn quá cơ!
Dialogue: 0,0:06:35.89,0:06:36.98,Default,,0,0,0,,Này.
Dialogue: 0,0:06:37.06,0:06:39.14,Default,,0,0,0,,Ít ra cũng phải\Ntắt micro đi chứ.
Dialogue: 0,0:06:39.23,0:06:40.98,Default,,0,0,0,,Đúng rồi! Tất nhiên rồi, Yoko!
Dialogue: 0,0:06:42.27,0:06:44.07,Default,,0,0,0,,Tonbo đứng hạng nhất,
Dialogue: 0,0:06:44.15,0:06:45.57,Default,,0,0,0,,còn Tsubura đứng hạng ba.
Dialogue: 0,0:06:46.90,0:06:49.95,Default,,0,0,0,,Rời khỏi hòn đảo và\Nthi đấu với biết bao nhiêu người...
Dialogue: 0,0:06:50.91,0:06:53.45,Default,,0,0,0,,Không biết Tonbo đang cảm thấy thế nào nhỉ?
Dialogue: 0,0:06:54.12,0:06:56.45,Default,,0,0,0,,Đừng lo!\NChắc chắn Tonbo vẫn ổn thôi.
Dialogue: 0,0:06:57.04,0:06:58.12,Default,,0,0,0,,Đúng vậy.
Dialogue: 0,0:06:58.79,0:07:01.96,Default,,0,0,0,,Chắc hẳn con bé đang chăm chỉ\Ntập luyện cho ngày mai rồi.
Dialogue: 0,0:07:09.17,0:07:11.13,Default,,0,0,0,,Liệu có khô kịp cho ngày mai không nhỉ?
Dialogue: 0,0:07:12.93,0:07:16.60,Default,,0,0,0,,Đó là bộ quần áo duy nhất\Nđể mặc thi đấu đấy.
Dialogue: 0,0:07:16.89,0:07:18.06,Default,,0,0,0,,Ý là sao?
Dialogue: 0,0:07:18.43,0:07:21.10,Default,,0,0,0,,Nếu không khô kịp\Nthì cứ mượn đồ của tôi!
Dialogue: 0,0:07:22.90,0:07:24.23,Default,,0,0,0,,Tonbo!
Dialogue: 0,0:07:27.57,0:07:29.03,Default,,0,0,0,,Thích bộ nào?
Dialogue: 0,0:07:30.32,0:07:31.86,Default,,0,0,0,,Để cho con bé yên đi.
Dialogue: 0,0:07:32.20,0:07:33.03,Default,,0,0,0,,Thật tình.
Dialogue: 0,0:07:33.57,0:07:34.49,Default,,0,0,0,,Nói gì cơ?
Dialogue: 0,0:07:40.00,0:07:41.29,Default,,0,0,0,,Ema Kurisu.
Dialogue: 0,0:07:42.00,0:07:43.04,Default,,0,0,0,,Ema?
Dialogue: 0,0:07:43.83,0:07:45.00,Default,,0,0,0,,Nhớ ra rồi!
Dialogue: 0,0:07:45.13,0:07:46.42,Default,,0,0,0,,Chuyện gì vậy?
Dialogue: 0,0:07:47.13,0:07:50.30,Default,,0,0,0,,Ema Kurisu!\NBiết ngay là từng nghe cái tên này ở đâu rồi mà.
Dialogue: 0,0:07:51.13,0:07:52.55,Default,,0,0,0,,Nổi tiếng lắm sao?
Dialogue: 0,0:07:52.68,0:07:55.35,Default,,0,0,0,,Là một nhà vô địch cực kỳ tài năng đấy.
Dialogue: 0,0:07:56.10,0:07:57.81,Default,,0,0,0,,Đã mười năm rồi sao?
Dialogue: 0,0:07:58.27,0:08:02.02,Default,,0,0,0,,Có một cô bé đã liên tục vô địch\Ncác giải đấu thế giới từ năm mười hai tuổi.
Dialogue: 0,0:08:02.10,0:08:03.52,Default,,0,0,0,,Một cô gái người Mỹ gốc Nhật.
Dialogue: 0,0:08:03.77,0:08:06.48,Default,,0,0,0,,Hình như tên là Ema Kurisu.
Dialogue: 0,0:08:08.15,0:08:09.99,Default,,0,0,0,,Nhà vô địch trẻ thế giới sao?
Dialogue: 0,0:08:10.44,0:08:13.99,Default,,0,0,0,,Tuy nhiên, sau đó,\Ncái tên ấy không còn được nhắc đến nữa.
Dialogue: 0,0:08:15.16,0:08:17.41,Default,,0,0,0,,Suốt một thập kỷ qua\Nđã làm gì vậy nhỉ?
Dialogue: 0,0:08:18.41,0:08:20.58,Default,,0,0,0,,Đông thật đấy.
Dialogue: 0,0:08:22.41,0:08:23.54,Default,,0,0,0,,Có chỗ kìa.
Dialogue: 0,0:08:37.05,0:08:38.26,Default,,0,0,0,,Vết cá mập cắn sao?
Dialogue: 0,0:08:39.31,0:08:42.60,Default,,0,0,0,,Trước đây từng thấy vết thương do cá mập cắn\Nở trên đảo rồi.
Dialogue: 0,0:08:44.19,0:08:45.65,Default,,0,0,0,,Trông y hệt luôn.
Dialogue: 0,0:08:57.45,0:08:58.49,Default,,0,0,0,,Thuận tay trái sao?
Dialogue: 0,0:08:58.58,0:09:02.12,Default,,0,0,0,,Từng nghe về những chức vô địch đó,\Nnhưng chưa từng nghe nói là người thuận tay trái.
Dialogue: 0,0:09:02.50,0:09:05.33,Default,,0,0,0,,Nhưng cây gậy wedge vừa dùng\Nlại là gậy dành cho người thuận tay phải.
Dialogue: 0,0:09:06.54,0:09:08.17,Default,,0,0,0,,Khoan đã, gì cơ?
Dialogue: 0,0:09:08.54,0:09:14.13,Default,,0,0,0,,Gậy 58 và gậy putter là tay phải,\Nnhưng những gậy còn lại đều là tay trái sao?
Dialogue: 0,0:09:18.97,0:09:20.14,Default,,0,0,0,,Tư thế đứng đó là sao?
Dialogue: 0,0:09:21.64,0:09:23.98,Default,,0,0,0,,Đang dồn trọng tâm\Nvào chân phải.
Dialogue: 0,0:09:40.24,0:09:41.91,Default,,0,0,0,,Đó gọi là cú swing một trục.
Dialogue: 0,0:09:43.04,0:09:45.87,Default,,0,0,0,,Dù vậy, cách dồn trọng tâm đó\Ncũng thú vị thật.
Dialogue: 0,0:10:00.18,0:10:01.26,Default,,0,0,0,,Ơn trời!
Dialogue: 0,0:10:14.11,0:10:18.16,Default,,0,0,0,,Liệu con gái tôi có thể\Nchơi golf lại được không?
Dialogue: 0,0:10:18.49,0:10:19.32,Default,,0,0,0,,Golf sao?
Dialogue: 0,0:10:20.45,0:10:23.33,Default,,0,0,0,,Tôi vẫn chưa dám chắc\Nliệu cô bé có thể đi lại được hay không.
Dialogue: 0,0:10:23.87,0:10:25.62,Default,,0,0,0,,Chúng ta phải bắt đầu từ việc đó trước đã.
Dialogue: 0,0:10:34.88,0:10:36.63,Default,,0,0,0,,{\i1}Không thể đánh xa như trước nữa.{\i0}
Dialogue: 0,0:10:36.84,0:10:38.05,Default,,0,0,0,,{\i1}Chân trái của mình...{\i0}
Dialogue: 0,0:10:38.59,0:10:39.55,Default,,0,0,0,,Bố ơi.
Dialogue: 0,0:10:39.64,0:10:41.30,Default,,0,0,0,,Con muốn dùng gậy tay trái.
Dialogue: 0,0:10:43.72,0:10:44.64,Default,,0,0,0,,Nếu dùng những cây gậy này
Dialogue: 0,0:10:44.85,0:10:45.77,Default,,0,0,0,,biết đâu con có thể chơi lại được.
Dialogue: 0,0:10:46.98,0:10:50.73,Default,,0,0,0,,Tại sao gậy 58 và putter lại là tay phải?
Dialogue: 0,0:10:51.23,0:10:53.27,Default,,0,0,0,,Con muốn chơi theo cách con vẫn luôn chơi.
Dialogue: 0,0:10:53.86,0:10:57.90,Default,,0,0,0,,Với những kỹ thuật nhỏ, sẽ không có\Nquá nhiều áp lực lên mắt cá chân trái.
Dialogue: 0,0:11:02.57,0:11:04.20,Default,,0,0,0,,Khi dùng những cây gậy lớn hơn
Dialogue: 0,0:11:04.41,0:11:06.79,Default,,0,0,0,,mắt cá chân trái của con không thể chịu được trọng lượng.
Dialogue: 0,0:11:08.58,0:11:11.67,Default,,0,0,0,,"Không cần chuyển trọng tâm\Ntrong quá trình backswing."
Dialogue: 0,0:11:12.25,0:11:16.00,Default,,0,0,0,,Nếu làm thế này thì sẽ có thể vung gậy\Nmà không dồn trọng lượng lên chân trái!
Dialogue: 0,0:11:16.96,0:11:19.63,Default,,0,0,0,,{\i1}Nữa. Nữa đi.{\i0}
Dialogue: 0,0:11:20.05,0:11:23.68,Default,,0,0,0,,{\i1}Phải nỗ lực nhiều hơn nữa.{\i0}
Dialogue: 0,0:11:27.98,0:11:31.23,Default,,0,0,0,,{\i1}Biết đâu cuối cùng mình có thể thi đấu trở lại.{\i0}
Dialogue: 0,0:11:34.48,0:11:35.98,Default,,0,0,0,,{\i1}Mất tận mười năm dài đằng đẵng,{\i0}
Dialogue: 0,0:11:36.23,0:11:39.82,Default,,0,0,0,,{\i1}nhưng cuối cùng mình cũng được thi đấu trở lại rồi.{\i0}
Dialogue: 0,0:11:40.24,0:11:42.11,Default,,0,0,0,,{\i1}Những nỗ lực đã được đền đáp.{\i0}
Dialogue: 0,0:11:42.32,0:11:45.53,Default,,0,0,0,,Đã chơi ở sân này\Nhàng trăm lần rồi!
Dialogue: 0,0:11:58.76,0:12:02.18,Default,,0,0,0,,Đã chơi ở sân này\Nnhiều hơn bất cứ ai ở đây.
Dialogue: 0,0:12:02.26,0:12:04.51,Default,,0,0,0,,Đánh dưới chuẩn (under par) thì không thành vấn đề.
Dialogue: 0,0:12:05.14,0:12:07.51,Default,,0,0,0,,Không được đánh quá 69 gậy đâu đấy.
Dialogue: 0,0:12:08.31,0:12:10.43,Default,,0,0,0,,Hôm nay phải giành vị trí thứ nhất. Rõ chưa?
Dialogue: 0,0:12:12.02,0:12:14.94,Default,,0,0,0,,Bố sẽ không bao giờ hài lòng.
Dialogue: 0,0:12:16.44,0:12:18.23,Default,,0,0,0,,Có đang nghe không hả, Hinoki?
Dialogue: 0,0:12:18.69,0:12:20.40,Default,,0,0,0,,{\i1}Mình không phải là Hinoki.{\i0}
Dialogue: 0,0:12:21.07,0:12:24.32,Default,,0,0,0,,Golf sẽ rất dễ dàng nếu có thể\Ntiến bộ chỉ nhờ bị mắng mỏ.
Dialogue: 0,0:12:25.82,0:12:28.37,Default,,0,0,0,,Điểm số đâu thể kiểm soát được.
Dialogue: 0,0:12:30.16,0:12:34.75,Default,,0,0,0,,Nếu không hiểu điều đó, thì ông không\Ncó quyền mắng người khác đâu.
Dialogue: 0,0:12:34.88,0:12:36.54,Default,,0,0,0,,Thái độ kiểu gì vậy hả!
Dialogue: 0,0:12:47.51,0:12:49.06,Default,,0,0,0,,{\i1}Tonbo!{\i0}
Dialogue: 0,0:12:58.57,0:12:59.82,Default,,0,0,0,,Ui da.
Dialogue: 0,0:13:02.57,0:13:06.37,Default,,0,0,0,,{\i1}Cô bé làm mình nhớ lại {\i0}\N{\i1}bản thân từng tận hưởng việc chơi golf ra sao.{\i0}
Dialogue: 0,0:13:13.83,0:13:15.21,Default,,0,0,0,,Tsubura!
Dialogue: 0,0:13:16.21,0:13:17.42,Default,,0,0,0,,Đánh cùng nhé.
Dialogue: 0,0:13:20.38,0:13:24.05,Default,,0,0,0,,{\i1}Không hề có thái độ của một người{\i0}\N{\i1}chuẩn bị thi đấu giải chút nào.{\i0}
Dialogue: 0,0:13:27.59,0:13:28.51,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:13:28.72,0:13:31.22,Default,,0,0,0,,Khi chơi golf ở trên đảo\Nchỉ là để cho vui,
Dialogue: 0,0:13:31.47,0:13:32.39,Default,,0,0,0,,nhưng ở đây thì khác.
Dialogue: 0,0:13:33.35,0:13:35.19,Default,,0,0,0,,Muốn biến ước mơ thành hiện thực.
Dialogue: 0,0:13:35.35,0:13:38.36,Default,,0,0,0,,Sẽ chiến thắng và tiến vào giải\NJapan Women's Amateur Open.
Dialogue: 0,0:13:40.65,0:13:41.94,Default,,0,0,0,,Giải Japan Women's Amateur sao?
Dialogue: 0,0:13:42.11,0:13:43.90,Default,,0,0,0,,Sẽ vô địch giải Amateur Open,
Dialogue: 0,0:13:44.49,0:13:46.82,Default,,0,0,0,,và chứng minh tài năng thực sự.
Dialogue: 0,0:13:48.24,0:13:50.37,Default,,0,0,0,,Giải Japan Junior và Japan Amateur Open.
Dialogue: 0,0:13:50.91,0:13:54.87,Default,,0,0,0,,Với hai danh hiệu lớn đó,\Nsẽ có thể tiến lên con đường chuyên nghiệp.
Dialogue: 0,0:13:55.71,0:13:58.13,Default,,0,0,0,,Sau đó, sẽ tham gia một giải đấu chuyên nghiệp
Dialogue: 0,0:13:58.67,0:14:00.13,Default,,0,0,0,,và giành chiến thắng.
Dialogue: 0,0:14:01.59,0:14:03.76,Default,,0,0,0,,Sẽ vô địch giải chuyên nghiệp\Nngay khi vẫn còn là dân nghiệp dư,
Dialogue: 0,0:14:04.30,0:14:05.67,Default,,0,0,0,,rồi tự mình bước vào giới chuyên nghiệp.
Dialogue: 0,0:14:09.18,0:14:10.51,Default,,0,0,0,,Còn Tonbo thì sao?
Dialogue: 0,0:14:11.22,0:14:12.31,Default,,0,0,0,,Tớ á?
Dialogue: 0,0:14:13.31,0:14:15.60,Default,,0,0,0,,Muốn một tương lai như thế nào trong môn golf?
Dialogue: 0,0:14:17.31,0:14:18.44,Default,,0,0,0,,À thì,
Dialogue: 0,0:14:18.56,0:14:22.07,Default,,0,0,0,,rời khỏi đảo là vì\Nmuốn tìm hiểu thêm về golf.
Dialogue: 0,0:14:23.07,0:14:24.99,Default,,0,0,0,,Nhưng lại nghĩ là không làm được.
Dialogue: 0,0:14:25.94,0:14:26.99,Default,,0,0,0,,Không nghĩ vậy sao?
Dialogue: 0,0:14:28.78,0:14:33.37,Default,,0,0,0,,Mọi người đều có mục tiêu và ước mơ.
Dialogue: 0,0:14:33.54,0:14:36.21,Default,,0,0,0,,Tất cả đều đang hướng tới việc\Ntrở thành những tay golf xuất sắc nhất có thể.
Dialogue: 0,0:14:36.46,0:14:40.00,Default,,0,0,0,,Cứ nghĩ rằng nếu không có mục tiêu\Nhay ước mơ như thế,
Dialogue: 0,0:14:40.17,0:14:44.13,Default,,0,0,0,,có lẽ không nên\Nchơi golf chút nào.
Dialogue: 0,0:14:45.46,0:14:48.01,Default,,0,0,0,,Nghĩ rằng có lẽ bản thân chưa đủ nghiêm túc.
Dialogue: 0,0:14:49.30,0:14:50.34,Default,,0,0,0,,Nhưng biết không?
Dialogue: 0,0:14:50.43,0:14:53.72,Default,,0,0,0,,Hôm qua đã được chơi\Ncùng với một người tên là Shima-san.
Dialogue: 0,0:14:53.89,0:14:55.64,Default,,0,0,0,,Cô ấy đã giúp nhận ra là mình đã sai.
Dialogue: 0,0:15:00.02,0:15:01.73,Default,,0,0,0,,{\i1}Gậy!{\i0}
Dialogue: 0,0:15:09.28,0:15:11.99,Default,,0,0,0,,Chơi golf chỉ vì thích\Ncũng không sao cả.
Dialogue: 0,0:15:12.49,0:15:14.66,Default,,0,0,0,,Thúc đẩy bản thân để giỏi hơn cũng không sao.
Dialogue: 0,0:15:14.79,0:15:18.75,Default,,0,0,0,,Chỉ cần có suy nghĩ đó thôi cũng đã là\Nđủ lý do để dồn hết tâm sức vào golf rồi.
Dialogue: 0,0:15:20.46,0:15:26.63,Default,,0,0,0,,Tonbo đã tiến bộ rất nhiều kể từ khi\Nđến đây, cả về kỹ thuật lẫn tinh thần.
Dialogue: 0,0:15:28.22,0:15:29.09,Default,,0,0,0,,Xin lỗi.
Dialogue: 0,0:15:30.88,0:15:32.80,Default,,0,0,0,,Cảm ơn vì đã nói chuyện với bố nhé.
Dialogue: 0,0:15:33.43,0:15:36.35,Default,,0,0,0,,Đây là Hinoki Otoha. Học trên\Nmột lớp ở trường cấp ba.
Dialogue: 0,0:15:36.64,0:15:39.85,Default,,0,0,0,,Biết chứ. Là nhà vô địch\NKyushu Junior năm ngoái mà.
Dialogue: 0,0:15:40.39,0:15:42.40,Default,,0,0,0,,Đó không phải là bản thân mình.
Dialogue: 0,0:15:44.02,0:15:46.40,Default,,0,0,0,,Mỗi sáng đều cố gắng là chính mình,
Dialogue: 0,0:15:46.65,0:15:48.61,Default,,0,0,0,,nhưng chẳng bao giờ thực sự làm được.
Dialogue: 0,0:15:48.90,0:15:51.82,Default,,0,0,0,,Bố hay mắng là phải là chính mình.
Dialogue: 0,0:15:52.41,0:15:53.57,Default,,0,0,0,,Cũng có nghe qua chuyện đó.
Dialogue: 0,0:15:54.28,0:15:58.58,Default,,0,0,0,,Đó là phương châm đúng không? Cố gắng hết sức \Nđể ngày mai sẽ là chính mình thực sự.
Dialogue: 0,0:15:59.04,0:16:01.33,Default,,0,0,0,,Ý là ngày mai sẽ làm tốt hơn, đúng chứ?
Dialogue: 0,0:16:01.62,0:16:02.71,Default,,0,0,0,,À thì...
Dialogue: 0,0:16:02.92,0:16:04.38,Default,,0,0,0,,Không nghĩ như vậy là đúng đâu.
Dialogue: 0,0:16:04.75,0:16:05.63,Default,,0,0,0,,Không sao?
Dialogue: 0,0:16:05.92,0:16:07.59,Default,,0,0,0,,"Ngày mai sẽ là chính mình."
Dialogue: 0,0:16:07.67,0:16:09.46,Default,,0,0,0,,Nói vậy, với suy nghĩ là sẽ làm tốt hơn.
Dialogue: 0,0:16:09.92,0:16:12.05,Default,,0,0,0,,Nhưng như thế nghĩa là sẽ chẳng bao giờ cố gắng hết sức.
Dialogue: 0,0:16:12.22,0:16:14.05,Default,,0,0,0,,Sẽ cứ nói mãi câu phương châm đó thôi.
Dialogue: 0,0:16:15.30,0:16:18.14,Default,,0,0,0,,Giống như những người hay nói\N"giá như mình cố gắng hết sức" vậy.
Dialogue: 0,0:16:18.56,0:16:21.73,Default,,0,0,0,,Họ cứ nói mãi\Nmà chẳng bao giờ thực sự cố gắng.
Dialogue: 0,0:16:22.44,0:16:25.98,Default,,0,0,0,,Đổ lỗi cho người khác về sự bất tài của mình.
Dialogue: 0,0:16:26.69,0:16:27.86,Default,,0,0,0,,Tsubura...
Dialogue: 0,0:16:28.69,0:16:31.65,Default,,0,0,0,,Chỉ bản thân mới có thể tự chịu trách nhiệm cho việc\Ntrở thành người mà mình muốn trở thành.
Dialogue: 0,0:16:34.95,0:16:38.16,Default,,0,0,0,,Vẫn còn sớm, nhưng hay là\Nchúng ta chuẩn bị bắt đầu đi?
Dialogue: 0,0:16:58.60,0:17:03.06,Default,,0,0,0,,Phải trở thành con người thật\Ncủa mình bắt đầu từ hôm nay!
Dialogue: 0,0:17:04.14,0:17:08.90,Default,,0,0,0,,Xin mời nhóm 9:46\Ntiến đến khu vực phát bóng.
Dialogue: 0,0:17:09.36,0:17:12.15,Default,,0,0,0,,Một lần nữa, tôi tên là Hata và \Nsẽ là caddie của mọi người hôm nay.
Dialogue: 0,0:17:12.36,0:17:14.11,Default,,0,0,0,,Rất mong được đồng hành cùng mọi người.
Dialogue: 0,0:17:14.36,0:17:15.91,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:17:16.41,0:17:18.16,Default,,0,0,0,,Nhà vô địch Kyushu Junior.
Dialogue: 0,0:17:18.87,0:17:20.41,Default,,0,0,0,,Nhà vô địch Japan Junior.
Dialogue: 0,0:17:21.12,0:17:22.66,Default,,0,0,0,,Và nhà vô địch trẻ thế giới.
Dialogue: 0,0:17:23.16,0:17:26.67,Default,,0,0,0,,Một nhóm với kỹ năng cao\Nthật xứng đáng với thứ tự hôm nay!
Dialogue: 0,0:17:27.13,0:17:29.67,Default,,0,0,0,,Và giữa những nhân vật tầm cỡ đó, có Tonbo.
Dialogue: 0,0:17:30.13,0:17:32.84,Default,,0,0,0,,Không có bất kỳ danh hiệu nào,
Dialogue: 0,0:17:32.92,0:17:35.09,Default,,0,0,0,,chẳng thể nói trước được\Nkhả năng sẽ tiến xa đến đâu.
Dialogue: 0,0:17:39.14,0:17:40.72,Default,,0,0,0,,Đang nhìn gì vậy?
Dialogue: 0,0:17:41.39,0:17:42.98,Default,,0,0,0,,Có thể thấy một con {\i1}kobu{\i0} đang giăng tơ.
Dialogue: 0,0:17:43.14,0:17:46.31,Default,,0,0,0,,Hôm nay sẽ không có gió đâu,\Ny như hôm qua vậy.
Dialogue: 0,0:17:46.52,0:17:47.65,Default,,0,0,0,,{\i1}Kobu{\i0}?
Dialogue: 0,0:17:47.77,0:17:51.19,Default,,0,0,0,,Đó là cách gọi nhện\Nở trên đảo.
Dialogue: 0,0:17:52.32,0:17:55.57,Default,,0,0,0,,Chúng chỉ giăng tơ vào những ngày\Nmà gió không quá mạnh thôi.
Dialogue: 0,0:17:56.03,0:17:57.49,Default,,0,0,0,,Gon luôn nói vậy.
Dialogue: 0,0:17:57.78,0:17:58.70,Default,,0,0,0,,Gon?
Dialogue: 0,0:17:59.03,0:18:01.08,Default,,0,0,0,,Đó cũng là một loại bọ à?
Dialogue: 0,0:18:01.79,0:18:02.83,Default,,0,0,0,,Là ông nội đó!
Dialogue: 0,0:18:03.54,0:18:05.08,Default,,0,0,0,,Không phải bọ đâu!
Dialogue: 0,0:18:05.75,0:18:07.62,Default,,0,0,0,,{\i1}Hôm nay cũng không có gió.{\i0}
Dialogue: 0,0:18:17.51,0:18:19.43,Default,,0,0,0,,{\i1}Tee cắm cao hơn bình thường.{\i0}
Dialogue: 0,0:18:21.05,0:18:22.97,Default,,0,0,0,,{\i1}Cách cầm gậy cũng cao hơn bình thường.{\i0}
Dialogue: 0,0:18:23.89,0:18:28.44,Default,,0,0,0,,{\i1}Tư thế đứng cũng rộng hơn.{\i0}\N{\i1}Khoảng cách tới bóng cũng xa hơn.{\i0}
Dialogue: 0,0:18:33.36,0:18:34.82,Default,,0,0,0,,{\i1}Đường backswing cũng lớn hơn.{\i0}
Dialogue: 0,0:18:42.08,0:18:44.49,Default,,0,0,0,,Đánh xa ngang ngửa Tonbo hôm qua luôn.
Dialogue: 0,0:18:45.33,0:18:51.00,Default,,0,0,0,,Đã thêm một chút vào mọi thứ.\NBình thường cũng đánh bóng xa
Dialogue: 0,0:18:51.63,0:18:55.09,Default,,0,0,0,,nhưng chưa bao giờ thấy Hinoki vung gậy\Nnhư vậy ngay đầu buổi sáng.
Dialogue: 0,0:19:00.72,0:19:02.97,Default,,0,0,0,,{\i1}Có lẽ đã truyền đạt được đến cô ấy rồi.{\i0}
Dialogue: 0,0:19:05.10,0:19:08.27,Default,,0,0,0,,Cú đánh thứ ba sẽ từ bên trái\Ncủa fairway.
Dialogue: 0,0:19:10.02,0:19:12.94,Default,,0,0,0,,Muốn đánh cú thứ hai từ\Nbên phải.
Dialogue: 0,0:19:13.02,0:19:16.19,Default,,0,0,0,,Nghĩa là sẽ\Nphải phát bóng từ bên trái.
Dialogue: 0,0:19:17.07,0:19:21.11,Default,,0,0,0,,Một cú phát bóng như thế sẽ khiến\Ncác đối thủ khác phải sợ hãi đấy!
Dialogue: 0,0:19:21.70,0:19:23.37,Default,,0,0,0,,Xin giữ trật tự.
Dialogue: 0,0:19:24.91,0:19:28.71,Default,,0,0,0,,{\i1}Còn 420 yard tới cú đánh thứ ba.{\i0}\N{\i1}Sẽ phải đến đó trong hai gậy.{\i0}
Dialogue: 0,0:19:29.46,0:19:31.21,Default,,0,0,0,,{\i1}Không có gì phải sợ cả.{\i0}
Dialogue: 0,0:19:31.71,0:19:34.75,Default,,0,0,0,,Cú vung gậy yếu ớt gì thế kia?
Dialogue: 0,0:19:35.38,0:19:37.59,Default,,0,0,0,,{\i1}Thế mới gọi là một cú đánh tốt.{\i0}
Dialogue: 0,0:19:42.85,0:19:45.14,Default,,0,0,0,,Chà! Lâu rồi mới thấy\Nlàm cú đó đấy!
Dialogue: 0,0:19:45.85,0:19:47.89,Default,,0,0,0,,Gọi là gì ấy nhỉ?
Dialogue: 0,0:19:48.35,0:19:49.89,Default,,0,0,0,,Igaiga từng nói một lần rồi.
Dialogue: 0,0:19:50.23,0:19:52.27,Default,,0,0,0,,Đúng rồi! {\i1}Great One Pattern{\i0}!
Dialogue: 0,0:19:53.11,0:19:54.61,Default,,0,0,0,,Vị trí tốt đấy.
Dialogue: 0,0:19:55.90,0:19:58.19,Default,,0,0,0,,Dù sao thì cũng là\NNhà vô địch trẻ thế giới mà.
Dialogue: 0,0:19:58.57,0:20:00.07,Default,,0,0,0,,Hiểu vấn đề đấy.
Dialogue: 0,0:20:02.53,0:20:04.24,Default,,0,0,0,,{\i1}Cú swing một trục{\i0}
Dialogue: 0,0:20:04.32,0:20:07.62,Default,,0,0,0,,{\i1}đặc trưng ở việc hướng{\i0}\N{\i1}xương ức ra xa khỏi quả bóng.{\i0}
Dialogue: 0,0:20:19.46,0:20:20.63,Default,,0,0,0,,Nảy tốt thật!
Dialogue: 0,0:20:21.43,0:20:22.51,Default,,0,0,0,,Đánh hay lắm.
Dialogue: 0,0:20:22.93,0:20:23.93,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:20:39.15,0:20:43.49,Default,,0,0,0,,{\i1}Tee không cắm xuống dễ dàng được.{\i0}\N{\i1}Là do dạo này nắng nhiều quá sao?{\i0}
Dialogue: 0,0:20:46.70,0:20:47.87,Default,,0,0,0,,{\i1}Cắm tee cao lên rồi.{\i0}
Dialogue: 0,0:20:48.29,0:20:49.75,Default,,0,0,0,,Đang định tung một cú mạnh đây.
Dialogue: 0,0:20:53.17,0:20:56.38,Default,,0,0,0,,{\i1}Tư thế tay đi trước (hand-first) với gậy driver sao? {\i0}
Dialogue: 0,0:20:56.59,0:21:01.72,Default,,0,0,0,,{\i1}Đặt bóng ở giữa ư?{\i0}\N{\i1}Thế thì sẽ làm bóng bay bổng lên như một bức tường thẳng đứng mất.{\i0}
Dialogue: 0,0:21:04.05,0:21:06.51,Default,,0,0,0,,Định dùng\Nnửa trên của mặt gậy sao?
Dialogue: 0,0:21:13.31,0:21:14.52,Default,,0,0,0,,Hạ thấp tư thế rồi!
Dialogue: 0,0:21:18.07,0:21:20.32,Default,,0,0,0,,Đường thứ ba từ bên phải!
Dialogue: 0,0:21:20.53,0:21:22.28,Default,,0,0,0,,Đi nào! Cú đánh Ánh dương!
Dialogue: 0,0:21:26.07,0:21:28.03,Default,,0,0,0,,Làm sao để bóng lăn được như vậy chứ?
Dialogue: 0,0:21:28.20,0:21:29.70,Default,,0,0,0,,Đường thứ ba từ bên phải.
Dialogue: 0,0:21:29.83,0:21:31.50,Default,,0,0,0,,Những đường cắt cỏ trên fairway.
Dialogue: 0,0:21:32.33,0:21:33.54,Default,,0,0,0,,Đường cắt cỏ sao?
Dialogue: 0,0:21:33.96,0:21:35.62,Default,,0,0,0,,Theo lời một tay golf chuyên nghiệp lão làng,
Dialogue: 0,0:21:36.33,0:21:39.55,Default,,0,0,0,,ở một hố dài, nên\Nnhắm vào một điểm sáng trên fairway.
Dialogue: 0,0:21:39.71,0:21:41.00,Default,,0,0,0,,Đó là một kỹ thuật cũ.
Dialogue: 0,0:21:41.76,0:21:42.88,Default,,0,0,0,,Điểm sáng ở đây,
Dialogue: 0,0:21:43.17,0:21:45.72,Default,,0,0,0,,là ý chỉ những khu vực trên fairway\Ntrông có màu sáng hơn.
Dialogue: 0,0:21:45.84,0:21:48.05,Default,,0,0,0,,Đó chính là những đường cắt cỏ.
Dialogue: 0,0:21:49.68,0:21:50.56,Default,,0,0,0,,Được rồi!
Dialogue: 0,0:21:50.81,0:21:53.06,Default,,0,0,0,,Ngang hàng với bóng của Ema Kurisu rồi!
Dialogue: 0,0:21:53.18,0:21:56.60,Default,,0,0,0,,Không ngờ một cú đánh thấp như thế\Nlại bay xa đến vậy!
Dialogue: 0,0:21:57.06,0:21:58.44,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:21:58.56,0:22:02.36,Default,,0,0,0,,Tonbo đã tính đến việc\Nmặt đất khô và cứng
Dialogue: 0,0:22:02.69,0:22:05.99,Default,,0,0,0,,và tung ra một cú đánh biết chắc sẽ lăn xa.
Dialogue: 0,0:22:06.15,0:22:08.28,Default,,0,0,0,,Làm sao mà tính toán được như thế chứ?
Dialogue: 0,0:22:08.70,0:22:11.33,Default,,0,0,0,,Thực ra là nhắm vào đường thứ năm cơ!
Dialogue: 0,0:22:12.83,0:22:14.37,Default,,0,0,0,,Igaiga! Mọi người ơi!
Dialogue: 0,0:22:15.96,0:22:17.00,Default,,0,0,0,,Hôm nay là một ngày mới!
Dialogue: 0,0:23:49.30,0:23:50.13,Default,,0,0,0,,Tonbo.
Dialogue: 0,0:23:50.26,0:23:52.72,Default,,0,0,0,,Không thể đưa ra lời khuyên\Nnhư Igarashi-san được.
Dialogue: 0,0:23:52.93,0:23:53.97,Default,,0,0,0,,Cảm ơn nhé!
Dialogue: 0,0:23:54.18,0:23:57.68,Default,,0,0,0,,Không sao đâu, Hajime!\NCó thứ mà Igaiga không có mà.
Dialogue: 0,0:23:57.98,0:23:59.23,Default,,0,0,0,,Thế á? Thật sao?
Dialogue: 0,0:23:59.52,0:24:01.19,Default,,0,0,0,,Trong tập tiếp theo của Tonbo!
Dialogue: 0,0:24:01.31,0:24:02.73,Default,,0,0,0,,Golf hộp đồ chơi
Dialogue: 0,0:24:02.86,0:24:04.52,Default,,0,0,0,,Tonbo! Thế thứ mà mình có là gì?
Dialogue: 0,0:24:04.69,0:24:05.94,Default,,0,0,0,,Mặt không đáng sợ!
Dialogue: 0,0:24:06.07,0:24:07.28,Default,,0,0,0,,Thôi nào!