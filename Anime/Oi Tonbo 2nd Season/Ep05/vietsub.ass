Dialogue: 0,0:00:11.04,0:00:11.97,Default,,0,0,0,,{\i1}Làm được rồi.{\i0}
Dialogue: 0,0:00:12.07,0:00:13.48,Default,,0,0,0,,{\i1}Cú đánh hoàn hảo.{\i0}
Dialogue: 0,0:00:14.14,0:00:15.31,Default,,0,0,0,,{\i1}Mọi người trên đảo ơi.{\i0}
Dialogue: 0,0:00:15.64,0:00:16.71,Default,,0,0,0,,{\i1}Nhận lấy này!{\i0}
Dialogue: 0,0:00:18.25,0:00:20.18,Default,,0,0,0,,Cú draw lớn thật.
Dialogue: 0,0:00:25.62,0:00:26.66,Default,,0,0,0,,Đánh hay lắm!
Dialogue: 0,0:00:27.06,0:00:28.09,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:00:28.82,0:00:30.86,Default,,0,0,0,,Hố này dài 514 yard cơ mà.
Dialogue: 0,0:00:31.19,0:00:32.09,Default,,0,0,0,,Cứ đà này...
Dialogue: 0,0:00:32.19,0:00:34.16,Default,,0,0,0,,Sẽ lên green trong hai gậy mất.
Dialogue: 0,0:00:38.20,0:00:39.33,Default,,0,0,0,,{\i1}Giải đấu này,{\i0}
Dialogue: 0,0:00:40.10,0:00:41.37,Default,,0,0,0,,{\i1}Quả nhiên Tonbo sẽ làm nên chuyện.{\i0}
Dialogue: 0,0:00:42.50,0:00:45.91,Default,,0,0,0,,{\i1}Bắt đầu rồi. Giải đấu đầu tiên của mình!{\i0}
Dialogue: 0,0:02:21.00,0:02:23.51,Default,,0,0,0,,Tuyển thủ đó năm nay cũng tham gia à?
Dialogue: 0,0:02:23.77,0:02:24.67,Default,,0,0,0,,Ừ.
Dialogue: 0,0:02:24.77,0:02:26.91,Default,,0,0,0,,Là người lớn tuổi nhất\Ngiải đấu năm nay đấy.
Dialogue: 0,0:02:29.81,0:02:34.48,Default,,0,0,0,,{\i1}Shin-chan, năm nay em lại{\i0}\N{\i1}được đứng trên sân khấu này rồi.{\i0}
Dialogue: 0,0:02:37.69,0:02:39.49,Default,,0,0,0,,Cùng chơi chung đi, Michiko!
Dialogue: 0,0:02:39.82,0:02:41.72,Default,,0,0,0,,Làm gì có thời gian rảnh chứ.
Dialogue: 0,0:02:42.09,0:02:44.63,Default,,0,0,0,,Chỉ cần Shin-chan thấy vui là đủ rồi.
Dialogue: 0,0:02:44.96,0:02:47.63,Default,,0,0,0,,Anh sẽ làm việc chăm chỉ hơn nữa mà.
Dialogue: 0,0:02:47.96,0:02:49.83,Default,,0,0,0,,Thôi được rồi, được rồi.
Dialogue: 0,0:02:50.20,0:02:52.84,Default,,0,0,0,,Anh cũng muốn Michiko biết được.
Dialogue: 0,0:02:53.10,0:02:54.97,Default,,0,0,0,,Sự thú vị của golf.
Dialogue: 0,0:03:02.04,0:03:03.25,Default,,0,0,0,,{\i1}Shin-chan...{\i0}
Dialogue: 0,0:03:06.98,0:03:08.35,Default,,0,0,0,,{\i1}Đánh trượt mất rồi.{\i0}
Dialogue: 0,0:03:09.28,0:03:10.52,Default,,0,0,0,,Xin lỗi! Tới ngay đây!
Dialogue: 0,0:03:13.59,0:03:16.59,Default,,0,0,0,,Không cần phải vội thế đâu.
Dialogue: 0,0:03:23.23,0:03:24.50,Default,,0,0,0,,Thôi nào.
Dialogue: 0,0:03:24.73,0:03:26.87,Default,,0,0,0,,Vẫn còn tuốt phía sau chúng ta kìa.
Dialogue: 0,0:03:27.14,0:03:29.37,Default,,0,0,0,,Làm rối hết cả nhịp độ mất.
Dialogue: 0,0:03:30.87,0:03:31.77,Default,,0,0,0,,Đi đây!
Dialogue: 0,0:03:33.98,0:03:35.61,Default,,0,0,0,,Khác với giải chuyên nghiệp,
Dialogue: 0,0:03:35.71,0:03:37.75,Default,,0,0,0,,chúng ta chỉ đi được đến đây thôi nhỉ.
Dialogue: 0,0:03:38.51,0:03:39.68,Default,,0,0,0,,Trúng rồi!
Dialogue: 0,0:03:40.25,0:03:42.18,Default,,0,0,0,,Trúng thôi mà cũng mừng.
Dialogue: 0,0:03:42.52,0:03:43.79,Default,,0,0,0,,Tha cho tôi đi.
Dialogue: 0,0:03:46.76,0:03:47.62,Default,,0,0,0,,Aaa!
Dialogue: 0,0:03:49.02,0:03:51.43,Default,,0,0,0,,Tại phải thấy hình ảnh xấu đấy!
Dialogue: 0,0:03:54.03,0:03:58.23,Default,,0,0,0,,Chà. Đến tận chỗ cách cây anh đào dại\N30 yard luôn kìa.
Dialogue: 0,0:03:59.03,0:04:01.97,Default,,0,0,0,,Chắc cách mép green khoảng 230 yard.
Dialogue: 0,0:04:02.07,0:04:03.61,Default,,0,0,0,,Dùng gậy fairway wood được không nhỉ.
Dialogue: 0,0:04:05.34,0:04:06.34,Default,,0,0,0,,Vâng. Cảm ơn ạ.
Dialogue: 0,0:04:07.04,0:04:08.04,Default,,0,0,0,,Gậy số 5 à?
Dialogue: 0,0:04:08.28,0:04:10.91,Default,,0,0,0,,Dùng gậy số 3 thì có khi 2 gậy lên green được,
Dialogue: 0,0:04:11.31,0:04:13.45,Default,,0,0,0,,Cờ nằm tuốt sâu bên trái.
Dialogue: 0,0:04:13.52,0:04:15.78,Default,,0,0,0,,Thực tế cách đến gần 260 yard lận.
Dialogue: 0,0:04:17.99,0:04:19.05,Default,,0,0,0,,{\i1}Igaiga.{\i0}
Dialogue: 0,0:04:19.12,0:04:21.96,Default,,0,0,0,,{\i1}Lúc đánh cú tee shot ban nãy, tim đập thình thịch luôn.{\i0}
Dialogue: 0,0:04:22.66,0:04:24.83,Default,,0,0,0,,{\i1}Chơi golf mà bị vậy là lần đầu tiên đấy.{\i0}
Dialogue: 0,0:04:25.46,0:04:27.63,Default,,0,0,0,,{\i1}Lúc muốn đánh xa thì đánh vào phần trên.{\i0}
Dialogue: 0,0:04:32.73,0:04:33.60,Default,,0,0,0,,Đi nào!
Dialogue: 0,0:04:33.74,0:04:35.37,Default,,0,0,0,,Bóng chim én!
Dialogue: 0,0:04:37.71,0:04:38.67,Default,,0,0,0,,Lại nữa à?
Dialogue: 0,0:04:38.74,0:04:41.28,Default,,0,0,0,,Thấp vậy mà cứ tưởng không đủ khoảng cách chứ!
Dialogue: 0,0:04:45.38,0:04:46.38,Default,,0,0,0,,Không thể nào.
Dialogue: 0,0:04:46.48,0:04:48.75,Default,,0,0,0,,Sao lại lăn được như thế chứ?
Dialogue: 0,0:04:49.99,0:04:51.79,Default,,0,0,0,,Igaiga không nói dối.
Dialogue: 0,0:04:55.62,0:04:56.49,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:04:56.66,0:04:59.36,Default,,0,0,0,,N-Nice eagle.
Dialogue: 0,0:05:00.00,0:05:01.00,Default,,0,0,0,,Thật luôn?
Dialogue: 0,0:05:05.47,0:05:07.17,Default,,0,0,0,,Tuyệt quá. Giữ được double bogey rồi.
Dialogue: 0,0:05:07.80,0:05:10.94,Default,,0,0,0,,Ghi double bogey ở hố par 5 mà cũng mừng kìa.
Dialogue: 0,0:05:11.77,0:05:14.94,Default,,0,0,0,,Lần đầu tiên tận mắt thấy eagle đấy.
Dialogue: 0,0:05:15.28,0:05:17.18,Default,,0,0,0,,Thật sự có người ghi được luôn kìa.
Dialogue: 0,0:05:17.51,0:05:19.05,Default,,0,0,0,,Bất ngờ thật đấy.
Dialogue: 0,0:05:19.41,0:05:21.32,Default,,0,0,0,,Cháu cũng bất ngờ lắm ạ.
Dialogue: 0,0:05:31.16,0:05:34.06,Default,,0,0,0,,Cô bé đó hình như bảo đây là giải đấu đầu tiên nhỉ.
Dialogue: 0,0:05:34.50,0:05:36.27,Default,,0,0,0,,Vừa ra mắt đã ghi eagle luôn?
Dialogue: 0,0:05:36.50,0:05:37.67,Default,,0,0,0,,May mắn quá thôi.
Dialogue: 0,0:05:40.34,0:05:43.67,Default,,0,0,0,,{\i1}Chỗ này quả nhiên giống hố số 1 trên đảo thật.{\i0}
Dialogue: 0,0:05:45.17,0:05:47.51,Default,,0,0,0,,{\i1}Ở đảo thì bên trái là biển.{\i0}
Dialogue: 0,0:05:48.18,0:05:50.35,Default,,0,0,0,,{\i1}Được rồi, cứ đánh như vậy đi.{\i0}
Dialogue: 0,0:05:52.81,0:05:54.08,Default,,0,0,0,,Hướng về rặng cây bên trái à?
Dialogue: 0,0:05:55.08,0:05:56.72,Default,,0,0,0,,Bên trái là OB cơ mà.
Dialogue: 0,0:05:59.92,0:06:00.82,Default,,0,0,0,,Bay thẳng vào rặng cây luôn!
Dialogue: 0,0:06:02.82,0:06:04.36,Default,,0,0,0,,Phía trên khu OB...
Dialogue: 0,0:06:04.56,0:06:05.49,Default,,0,0,0,,Slice?
Dialogue: 0,0:06:05.69,0:06:08.36,Default,,0,0,0,,Cô bé đó phân biệt đánh hook với slice luôn à?
Dialogue: 0,0:06:10.57,0:06:12.10,Default,,0,0,0,,Quà chia tay tuyệt lắm!
Dialogue: 0,0:06:12.47,0:06:13.64,Default,,0,0,0,,Quà chia tay á?
Dialogue: 0,0:06:13.84,0:06:14.77,Default,,0,0,0,,Vâng.
Dialogue: 0,0:06:14.84,0:06:18.37,Default,,0,0,0,,15.309 yên! Quà chia tay của Igaiga đấy ạ!
Dialogue: 0,0:06:18.71,0:06:19.88,Default,,0,0,0,,Igaiga?
Dialogue: 0,0:06:28.02,0:06:29.75,Default,,0,0,0,,Đang cố bình tĩnh lại à.
Dialogue: 0,0:06:29.85,0:06:31.59,Default,,0,0,0,,Đúng là nặc mùi nghiệp dư.
Dialogue: 0,0:06:36.66,0:06:38.19,Default,,0,0,0,,Đánh bóng dự phòng đây!
Dialogue: 0,0:06:40.60,0:06:41.96,Default,,0,0,0,,An toàn rồi!
Dialogue: 0,0:06:43.23,0:06:44.50,Default,,0,0,0,,May quá.
Dialogue: 0,0:06:49.24,0:06:51.14,Default,,0,0,0,,Chỉ mới ra fairway thôi.
Dialogue: 0,0:06:53.44,0:06:55.08,Default,,0,0,0,,{\i1}Rõ ràng là đã chuẩn bị kỹ rồi mà.{\i0}
Dialogue: 0,0:07:10.93,0:07:12.03,Default,,0,0,0,,{\i1}Được rồi!{\i0}
Dialogue: 0,0:07:12.46,0:07:14.60,Default,,0,0,0,,Đến mép green là 140 yard.
Dialogue: 0,0:07:14.76,0:07:18.23,Default,,0,0,0,,Cờ nằm gần phía trước.\NCách mép khoảng 5 yard.
Dialogue: 0,0:07:18.33,0:07:20.07,Default,,0,0,0,,Tổng cộng là 145 yard.
Dialogue: 0,0:07:21.80,0:07:26.94,Default,,0,0,0,,Cờ nằm ngay chóp dốc\Ngiữa hai hố cát.
Dialogue: 0,0:07:27.18,0:07:28.74,Default,,0,0,0,,Phía trước đó là một cái dốc trượt lớn.
Dialogue: 0,0:07:29.31,0:07:30.81,Default,,0,0,0,,145 yard.
Dialogue: 0,0:07:31.08,0:07:33.88,Default,,0,0,0,,Dùng gậy sắt số 7 hoặc 8\Nthì hợp lý,
Dialogue: 0,0:07:34.18,0:07:35.62,Default,,0,0,0,,Nhưng lại không có hai gậy đó.
Dialogue: 0,0:07:35.95,0:07:37.12,Default,,0,0,0,,Sẽ làm thế nào đây?
Dialogue: 0,0:07:37.99,0:07:41.16,Default,,0,0,0,,{\i1}Chỉ còn cách dùng gậy sắt số 6{\i0}\N{\i1}đánh nhẹ thôi...{\i0}
Dialogue: 0,0:07:42.82,0:07:43.99,Default,,0,0,0,,Gậy số 3 á?
Dialogue: 0,0:07:45.33,0:07:47.00,Default,,0,0,0,,Thế chẳng phải quá lớn sao...
Dialogue: 0,0:07:49.60,0:07:50.50,Default,,0,0,0,,Vào dốc trượt.
Dialogue: 0,0:07:58.74,0:08:00.51,Default,,0,0,0,,Ồ, có vẻ hơi ngắn nhỉ.
Dialogue: 0,0:08:00.84,0:08:02.64,Default,,0,0,0,,Hóa ra không quá lớn.
Dialogue: 0,0:08:03.35,0:08:08.02,Default,,0,0,0,,Đánh bóng thấp chạm vào sườn dốc\Nđể điều chỉnh khoảng cách sao.
Dialogue: 0,0:08:11.49,0:08:14.36,Default,,0,0,0,,Dùng gậy putter\Ncách green tận 30 yard á?
Dialogue: 0,0:08:15.19,0:08:20.26,Default,,0,0,0,,Cờ nằm ngay phía trước.\NDùng gậy wedge thì phải đánh thật mềm mại.
Dialogue: 0,0:08:20.53,0:08:21.90,Default,,0,0,0,,Nhưng tay mình...
Dialogue: 0,0:08:22.46,0:08:24.07,Default,,0,0,0,,Vẫn còn đang run...
Dialogue: 0,0:08:24.63,0:08:27.14,Default,,0,0,0,,Dùng putter chắc sẽ ổn thôi.
Dialogue: 0,0:08:33.01,0:08:33.94,Default,,0,0,0,,Hay lắm!
Dialogue: 0,0:08:34.01,0:08:34.94,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:08:38.38,0:08:39.25,Default,,0,0,0,,Tuyệt quá!
Dialogue: 0,0:08:39.52,0:08:40.52,Default,,0,0,0,,Nice bogey.
Dialogue: 0,0:08:41.88,0:08:44.05,Default,,0,0,0,,Tự khen mình luôn kìa.
Dialogue: 0,0:08:44.39,0:08:45.55,Default,,0,0,0,,Matsuda-san thì sao?
Dialogue: 0,0:08:46.52,0:08:48.02,Default,,0,0,0,,Tôi cũng bogey.
Dialogue: 0,0:08:49.73,0:08:54.06,Default,,0,0,0,,{\i1}Sẽ chơi hết sức mình{\i0}\N{\i1}với vị trí bóng hiện tại.{\i0}
Dialogue: 0,0:08:56.40,0:08:58.27,Default,,0,0,0,,Vẫn còn nhóm phía trước nhỉ.
Dialogue: 0,0:08:59.03,0:09:00.70,Default,,0,0,0,,Đến đây là 5 over rồi.
Dialogue: 0,0:09:01.04,0:09:03.27,Default,,0,0,0,,Tụt một điểm so với nhịp bogey rồi!
Dialogue: 0,0:09:03.97,0:09:07.34,Default,,0,0,0,,Chỉ vì tốt hơn nhịp bogey mà cũng mừng,
Dialogue: 0,0:09:07.48,0:09:09.88,Default,,0,0,0,,thì tham gia giải nữ Kyushu để làm gì chứ.
Dialogue: 0,0:09:10.28,0:09:13.08,Default,,0,0,0,,Trình độ đó thì làm sao mà lọt top được.
Dialogue: 0,0:09:13.55,0:09:14.58,Default,,0,0,0,,Tham gia làm gì chứ.
Dialogue: 0,0:09:14.92,0:09:16.92,Default,,0,0,0,,Nhưng tôi cũng 3 over rồi.
Dialogue: 0,0:09:17.19,0:09:19.99,Default,,0,0,0,,Ài, tệ đến mức này cơ chứ.
Dialogue: 0,0:09:20.39,0:09:24.03,Default,,0,0,0,,Cảm giác khó chơi quá, hay là bỏ cuộc nhỉ.
Dialogue: 0,0:09:25.19,0:09:26.30,Default,,0,0,0,,Xin lỗi nhé.
Dialogue: 0,0:09:26.56,0:09:28.36,Default,,0,0,0,,Có làm phiền không?
Dialogue: 0,0:09:28.43,0:09:30.00,Default,,0,0,0,,Không ạ.
Dialogue: 0,0:09:31.20,0:09:32.90,Default,,0,0,0,,Được dùng nhiều thật đấy.
Dialogue: 0,0:09:34.07,0:09:35.04,Default,,0,0,0,,Là kỷ vật ạ.
Dialogue: 0,0:09:37.31,0:09:39.01,Default,,0,0,0,,Gậy của bố.
Dialogue: 0,0:09:40.08,0:09:41.08,Default,,0,0,0,,Vậy à.
Dialogue: 0,0:09:41.14,0:09:42.58,Default,,0,0,0,,Kỷ vật
Dialogue: 0,0:09:43.15,0:09:44.08,Default,,0,0,0,,của bố sao?
Dialogue: 0,0:09:46.01,0:09:51.39,Default,,0,0,0,,Bộ gậy của tôi cũng là quà\Ntừ chồng tôi. Món quà cuối cùng.
Dialogue: 0,0:09:52.72,0:09:53.99,Default,,0,0,0,,Cuối cùng ạ?
Dialogue: 0,0:10:10.24,0:10:11.61,Default,,0,0,0,,Vâng, Shima nghe đây.
Dialogue: 0,0:10:12.74,0:10:15.41,Default,,0,0,0,,Món hàng ngài Shima đặt đã được giao đến rồi ạ.
Dialogue: 0,0:10:18.15,0:10:22.28,Default,,0,0,0,,Làm quà sinh nhật cho phu nhân đấy ạ.\NChồng bà chu đáo thật đấy!
Dialogue: 0,0:10:23.89,0:10:25.95,Default,,0,0,0,,{\i1}Cùng chơi chung đi, Michiko!{\i0}
Dialogue: 0,0:10:26.12,0:10:29.63,Default,,0,0,0,,{\i1}Anh cũng muốn Michiko biết được.{\i0}\N{\i1}Sự thú vị của golf!{\i0}
Dialogue: 0,0:10:30.56,0:10:34.23,Default,,0,0,0,,Lúc đó, sao mình lại không chơi cùng anh ấy chứ.
Dialogue: 0,0:10:34.46,0:10:37.93,Default,,0,0,0,,Sao mình lại không đáp lại lời anh ấy ngay chứ.
Dialogue: 0,0:10:39.64,0:10:40.80,Default,,0,0,0,,Á, không được đâu!
Dialogue: 0,0:10:42.34,0:10:44.97,Default,,0,0,0,,Bám đầy bụi rồi. Cất công mua cho vậy mà.
Dialogue: 0,0:10:46.81,0:10:51.08,Default,,0,0,0,,Hơn một năm trời, không thể nào chạm vào được.
Dialogue: 0,0:10:51.98,0:10:55.98,Default,,0,0,0,,Nhưng rồi cũng lấy hết can đảm\Nđến sân tập mà chồng thường hay lui tới.
Dialogue: 0,0:10:57.19,0:11:01.86,Default,,0,0,0,,Ở đó, những người bạn chơi golf của chồng\Nđã cho rất nhiều lời khuyên.
Dialogue: 0,0:11:03.26,0:11:05.69,Default,,0,0,0,,Thấy golf thú vị chưa?
Dialogue: 0,0:11:06.40,0:11:08.63,Default,,0,0,0,,Lập tức bị cuốn hút luôn.
Dialogue: 0,0:11:09.70,0:11:13.00,Default,,0,0,0,,Golf ấy mà, hầu như chẳng bao giờ đi theo ý mình cả.
Dialogue: 0,0:11:13.20,0:11:15.97,Default,,0,0,0,,Nếu so với tình yêu thì giống như bị đá liên tục vậy.
Dialogue: 0,0:11:16.31,0:11:17.97,Default,,0,0,0,,Ví von kiểu gì thế.
Dialogue: 0,0:11:18.11,0:11:20.01,Default,,0,0,0,,Bỏ cuộc luôn thì nhẹ nhõm hơn.
Dialogue: 0,0:11:20.54,0:11:27.05,Default,,0,0,0,,Nhưng nếu cứ tiếp tục kiên trì, thỉnh thoảng\Nhọ sẽ ngoảnh lại và mỉm cười với mình.
Dialogue: 0,0:11:27.52,0:11:30.99,Default,,0,0,0,,Chỉ với khoảnh khắc đó thôi là lại có thể tiếp tục.
Dialogue: 0,0:11:35.49,0:11:38.66,Default,,0,0,0,,Có vẻ như đã hiểu được\Ný nghĩa của câu nói đó rồi.
Dialogue: 0,0:11:40.23,0:11:43.30,Default,,0,0,0,,Cờ nằm ngay bên phải.\NKhoảng 148 yard.
Dialogue: 0,0:11:45.37,0:11:46.90,Default,,0,0,0,,Lại gậy số 3 à?
Dialogue: 0,0:11:47.24,0:11:49.00,Default,,0,0,0,,Nhìn sao cũng thấy quá lớn mà!
Dialogue: 0,0:12:00.92,0:12:03.32,Default,,0,0,0,,Đánh hơi mỏng quá rồi.
Dialogue: 0,0:12:04.02,0:12:07.32,Default,,0,0,0,,{\i1}Cô bé này chắc chắn có thể yêu quý điểm số của mình.{\i0}
Dialogue: 0,0:12:08.72,0:12:10.16,Default,,0,0,0,,{\i1}Dù cho nó có ra sao.{\i0}
Dialogue: 0,0:12:10.59,0:12:14.00,Default,,0,0,0,,{\i1}Đó là kết quả của việc{\i0}\N{\i1}chơi hết mình trong từng cú đánh.{\i0}
Dialogue: 0,0:12:14.26,0:12:19.03,Default,,0,0,0,,{\i1}Mỗi cú đánh đều đáng trân trọng.{\i0}\N{\i1}Anh đã nói vậy mà, Shin-chan.{\i0}
Dialogue: 0,0:12:19.80,0:12:23.24,Default,,0,0,0,,Từ lúc nào mà thứ tự đánh\Nlại xếp sau bà cô đó rồi.
Dialogue: 0,0:12:23.57,0:12:25.07,Default,,0,0,0,,Tệ thật đấy.
Dialogue: 0,0:12:28.48,0:12:29.81,Default,,0,0,0,,Thẳng tắp tới cờ luôn!
Dialogue: 0,0:12:32.58,0:12:33.62,Default,,0,0,0,,Tiếc quá!
Dialogue: 0,0:12:33.75,0:12:34.98,Default,,0,0,0,,Hú hồn.
Dialogue: 0,0:12:39.76,0:12:42.89,Default,,0,0,0,,{\i1}Có vẻ Tonbo đã mở mặt gậy rộng hơn.{\i0}
Dialogue: 0,0:12:49.23,0:12:52.30,Default,,0,0,0,,{\i1}Âm thanh của con bé nghe hay hơn nhiều.{\i0}
Dialogue: 0,0:12:55.10,0:12:55.97,Default,,0,0,0,,{\i1}Hay lắm!{\i0}
Dialogue: 0,0:12:56.10,0:12:57.37,Default,,0,0,0,,{\i1}Nice birdie!{\i0}
Dialogue: 0,0:13:00.41,0:13:02.51,Default,,0,0,0,,{\i1}Không ngờ lại ngủ quên trong xe mất!{\i0}
Dialogue: 0,0:13:02.61,0:13:05.51,Default,,0,0,0,,{\i1}Giờ chắc Tonbo sắp đánh xong nửa đầu rồi!{\i0}
Dialogue: 0,0:13:05.65,0:13:07.28,Default,,0,0,0,,{\i1}Chết tiệt!{\i0}
Dialogue: 0,0:13:07.35,0:13:09.82,Default,,0,0,0,,À, ừm, xin lỗi.
Dialogue: 0,0:13:09.92,0:13:10.92,Default,,0,0,0,,Vâng?
Dialogue: 0,0:13:11.15,0:13:13.22,Default,,0,0,0,,Tonbo, cô bé dùng bộ gậy half set.
Dialogue: 0,0:13:13.56,0:13:14.66,Default,,0,0,0,,Thế nào rồi?
Dialogue: 0,0:13:15.16,0:13:17.79,Default,,0,0,0,,Lúc nào cũng đánh sau cùng đấy.
Dialogue: 0,0:13:18.29,0:13:20.03,Default,,0,0,0,,Hả?
Dialogue: 0,0:13:22.03,0:13:24.57,Default,,0,0,0,,Quả nhiên là không được rồi!
Dialogue: 0,0:13:24.80,0:13:27.70,Default,,0,0,0,,Không không. Nếu là cú tee shot thì có thể,
Dialogue: 0,0:13:28.04,0:13:32.17,Default,,0,0,0,,nhưng có lẽ ý cô ấy là\NTonbo luôn đánh cú thứ hai sau cùng.
Dialogue: 0,0:13:32.27,0:13:34.58,Default,,0,0,0,,Là cái nào vậy Tonbo. Nói đi!
Dialogue: 0,0:13:36.78,0:13:38.15,Default,,0,0,0,,Tonbo! Thế nào rồi?
Dialogue: 0,0:13:39.18,0:13:43.29,Default,,0,0,0,,Cháu cứ xem Hinoki-san suốt!\NỞ hố số 9 cô ấy đánh chuẩn lắm!
Dialogue: 0,0:13:43.59,0:13:45.05,Default,,0,0,0,,À không, còn cháu thì sao?
Dialogue: 0,0:13:46.46,0:13:48.69,Default,,0,0,0,,Ở hố số 9 cháu chip-in đấy!
Dialogue: 0,0:13:49.83,0:13:52.63,Default,,0,0,0,,Xin lỗi, đi vệ sinh cái đã!
Dialogue: 0,0:13:52.83,0:13:55.13,Default,,0,0,0,,Nghe nói ở hố số 1 ghi được eagle đấy.
Dialogue: 0,0:13:55.30,0:13:58.97,Default,,0,0,0,,Nếu hố số 9 chip-in birdie,\Nthì chỉ riêng thế đã là 3 under rồi.
Dialogue: 0,0:13:59.20,0:14:00.27,Default,,0,0,0,,Ừ.
Dialogue: 0,0:14:00.34,0:14:04.37,Default,,0,0,0,,Dù 7 hố còn lại có đánh thế nào\Nthì chắc cũng không tệ đâu.
Dialogue: 0,0:14:18.62,0:14:20.86,Default,,0,0,0,,Đánh tee shot sau cùng á?
Dialogue: 0,0:14:21.09,0:14:23.99,Default,,0,0,0,,Chẳng phải cháu bảo\Nhố số 9 chip-in sao Tonbo?
Dialogue: 0,0:14:25.09,0:14:27.10,Default,,0,0,0,,Là chip-in bogey ạ!
Dialogue: 0,0:14:29.83,0:14:32.23,Default,,0,0,0,,Rốt cuộc là mấy gậy vậy!
Dialogue: 0,0:14:35.90,0:14:36.84,Default,,0,0,0,,Trông vui vẻ ghê.
Dialogue: 0,0:14:38.04,0:14:39.04,Default,,0,0,0,,Ừ.
Dialogue: 0,0:14:39.11,0:14:40.78,Default,,0,0,0,,Nửa đầu 41.
Dialogue: 0,0:14:41.11,0:14:43.31,Default,,0,0,0,,Lấy lại được\Nđiểm số mục tiêu rồi.
Dialogue: 0,0:14:43.65,0:14:45.31,Default,,0,0,0,,Điểm số mục tiêu?
Dialogue: 0,0:14:45.65,0:14:48.92,Default,,0,0,0,,Đây là lần thứ 3\Ntôi tham gia giải này rồi.
Dialogue: 0,0:14:50.52,0:14:52.79,Default,,0,0,0,,Lúc nào cũng nhắm mốc 82,
Dialogue: 0,0:14:53.12,0:14:55.06,Default,,0,0,0,,vì điểm cắt loại vòng loại hàng năm
Dialogue: 0,0:14:55.12,0:14:56.99,Default,,0,0,0,,luôn xoay quanh mức đó.
Dialogue: 0,0:14:57.13,0:14:58.86,Default,,0,0,0,,Mục tiêu là 82 sao?
Dialogue: 0,0:15:00.63,0:15:03.00,Default,,0,0,0,,Giả sử có lách qua được vòng loại đi nữa,
Dialogue: 0,0:15:03.10,0:15:05.27,Default,,0,0,0,,thì sau đó sẽ lấy gì làm mục tiêu?
Dialogue: 0,0:15:05.53,0:15:10.34,Default,,0,0,0,,Không thể lọt vào top trên,\Nqua được vòng loại cũng chẳng được gì.
Dialogue: 0,0:15:11.07,0:15:12.94,Default,,0,0,0,,Thế tham gia giải đấu để làm gì?
Dialogue: 0,0:15:13.28,0:15:14.21,Default,,0,0,0,,Vô nghĩa thôi.
Dialogue: 0,0:15:16.45,0:15:17.58,Default,,0,0,0,,Vô nghĩa, sao.
Dialogue: 0,0:15:18.81,0:15:23.02,Default,,0,0,0,,Với những người trẻ tuổi\Nđang nhắm đến con đường chuyên nghiệp như các cô,
Dialogue: 0,0:15:23.19,0:15:26.72,Default,,0,0,0,,thì việc một người như tôi\Ntham gia giải đấu có lẽ là vô nghĩa thật.
Dialogue: 0,0:15:27.29,0:15:31.43,Default,,0,0,0,,Nhưng đâu phải ai mơ làm chuyên nghiệp\Ncũng đều thành hiện thực.
Dialogue: 0,0:15:31.69,0:15:35.10,Default,,0,0,0,,Thậm chí số người bỏ cuộc\Ngiữa chừng còn nhiều hơn.
Dialogue: 0,0:15:36.93,0:15:40.34,Default,,0,0,0,,Cô nghĩ những người đó cũng vô nghĩa sao?
Dialogue: 0,0:15:40.70,0:15:44.87,Default,,0,0,0,,Việc chơi golf ngay từ đầu\Nchẳng phải cũng thành vô nghĩa sao.
Dialogue: 0,0:15:45.81,0:15:49.48,Default,,0,0,0,,Đừng lấy việc có trở thành con người\Ntrong mơ hay không làm đích đến.
Dialogue: 0,0:15:49.95,0:15:54.35,Default,,0,0,0,,Phải xem bản thân có thể nỗ lực đến đâu\Nđể trở thành con người đó.
Dialogue: 0,0:15:54.95,0:15:58.32,Default,,0,0,0,,Quan trọng là có thể tự hào\Nvề quá trình đó hay không.
Dialogue: 0,0:15:58.82,0:16:00.96,Default,,0,0,0,,Không phải là việc có thể bay hay không.
Dialogue: 0,0:16:01.12,0:16:04.13,Default,,0,0,0,,Mà là có thể dốc hết sức chạy đà để bay lên.
Dialogue: 0,0:16:05.73,0:16:07.63,Default,,0,0,0,,Tôi tin vào điều đó.
Dialogue: 0,0:16:08.46,0:16:10.73,Default,,0,0,0,,Cũng có những golfer chơi theo cách đó.
Dialogue: 0,0:16:16.31,0:16:17.91,Default,,0,0,0,,Nhưng mà...
Dialogue: 0,0:16:19.21,0:16:21.64,Default,,0,0,0,,Không muốn thua bọn họ.
Dialogue: 0,0:16:30.39,0:16:34.69,Default,,0,0,0,,Điểm tee tiến lên 5 bước, và cờ\Ncách tâm green 10 bước. 147 yard.
Dialogue: 0,0:16:34.82,0:16:36.73,Default,,0,0,0,,147 yard.
Dialogue: 0,0:16:37.39,0:16:41.76,Default,,0,0,0,,Dù sao thì gậy số 9 cũng không tới được,\Nchắc sẽ dùng gậy sắt số 6 thôi.
Dialogue: 0,0:16:43.93,0:16:47.40,Default,,0,0,0,,Gì thế này? Cảm giác không ổn chút nào.
Dialogue: 0,0:16:48.97,0:16:50.37,Default,,0,0,0,,Igaiga.
Dialogue: 0,0:16:51.37,0:16:55.88,Default,,0,0,0,,Ra khỏi đảo,\Ncách chơi của cháu có thể sẽ bị bàn tán.
Dialogue: 0,0:16:56.18,0:16:59.72,Default,,0,0,0,,Dù vậy, cứ chơi theo cách cháu muốn.
Dialogue: 0,0:16:59.85,0:17:04.49,Default,,0,0,0,,Hãy chơi golf bằng cảm nhận\Nvà hình ảnh nảy sinh trong đầu.
Dialogue: 0,0:17:04.62,0:17:06.96,Default,,0,0,0,,Chắc chắn không sai đâu. Chú đảm bảo đấy.
Dialogue: 0,0:17:07.86,0:17:08.72,Default,,0,0,0,,{\i1}Hãy tin chú.{\i0}
Dialogue: 0,0:17:11.39,0:17:12.73,Default,,0,0,0,,Gậy sắt số 9?
Dialogue: 0,0:17:19.80,0:17:21.24,Default,,0,0,0,,Sao lại lăn xa thế được?
Dialogue: 0,0:17:22.80,0:17:24.44,Default,,0,0,0,,Chắc chắn birdie rồi.
Dialogue: 0,0:17:24.81,0:17:26.28,Default,,0,0,0,,Cái thứ 5 hôm nay rồi!
Dialogue: 0,0:17:27.11,0:17:31.38,Default,,0,0,0,,Cháu tin mà, Igaiga. Đương nhiên rồi.
Dialogue: 0,0:17:41.42,0:17:44.83,Default,,0,0,0,,Lại gậy sắt số 6, nhưng lần này\Nbóng dừng lại ngay lập tức!
Dialogue: 0,0:17:45.06,0:17:47.56,Default,,0,0,0,,Nếu vào\Nthì sẽ là birdie thứ 6!
Dialogue: 0,0:17:50.03,0:17:51.67,Default,,0,0,0,,Á, chịu hết nổi rồi!
Dialogue: 0,0:17:54.27,0:17:57.71,Default,,0,0,0,,Tôi không thể nào đối xử với gậy của bố như thế.
Dialogue: 0,0:17:57.84,0:17:58.84,Default,,0,0,0,,Tôi cũng vậy.
Dialogue: 0,0:17:58.91,0:18:02.71,Default,,0,0,0,,Tức giận, mất bình tĩnh\Nhay ném gậy là điều không thể nào.
Dialogue: 0,0:18:03.98,0:18:08.52,Default,,0,0,0,,Tôi biết một người rất yêu golf và muốn\Ntiếp tục chơi hơn bất kỳ ai.
Dialogue: 0,0:18:08.62,0:18:12.62,Default,,0,0,0,,Chỉ cần nghĩ đến điều đó\Nthì việc được chơi golf đã là hạnh phúc rồi.
Dialogue: 0,0:18:18.19,0:18:19.19,Default,,0,0,0,,Qua đi!
Dialogue: 0,0:18:21.76,0:18:22.60,Default,,0,0,0,,Tuyệt!
Dialogue: 0,0:18:22.66,0:18:23.57,Default,,0,0,0,,Nice on!
Dialogue: 0,0:18:23.87,0:18:24.77,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:18:25.10,0:18:27.90,Default,,0,0,0,,Nếu từ đó dùng 2 putt ghi được par,
Dialogue: 0,0:18:28.24,0:18:30.74,Default,,0,0,0,,thì vẫn còn cơ hội\Nlọt vào chung kết!
Dialogue: 0,0:18:31.74,0:18:34.28,Default,,0,0,0,,{\i1}Thật mừng vì được chơi cùng Shima-san.{\i0}
Dialogue: 0,0:18:39.45,0:18:41.25,Default,,0,0,0,,Rốt cuộc lại 3 putt kìa.
Dialogue: 0,0:18:42.99,0:18:46.62,Default,,0,0,0,,Đánh xa tít tắp thế mà còn reo lên vui sướng cơ chứ.
Dialogue: 0,0:18:48.12,0:18:53.13,Default,,0,0,0,,{\i1}Lại nữa rồi.{\i0}\N{\i1}Cảm giác không ổn chút nào. Nhưng tại sao chứ?{\i0}
Dialogue: 0,0:18:55.16,0:18:57.17,Default,,0,0,0,,{\i1}Giống hệt lúc đó.{\i0}
Dialogue: 0,0:19:04.24,0:19:05.77,Default,,0,0,0,,{\i1}Cô bé này sao vậy?{\i0}
Dialogue: 0,0:19:07.11,0:19:09.58,Default,,0,0,0,,{\i1}Đánh kiểu kỳ cục vậy mà.{\i0}
Dialogue: 0,0:19:09.68,0:19:12.95,Default,,0,0,0,,{\i1}Chỉ là may mắn trong giải đấu đầu tiên thôi.{\i0}
Dialogue: 0,0:19:17.82,0:19:21.32,Default,,0,0,0,,{\i1}Không. Họ đâu có nói gì.{\i0}\N{\i1}Chỉ là mình tưởng tượng ra thôi.{\i0}
Dialogue: 0,0:19:26.16,0:19:26.73,Default,,0,0,0,,Á.
Dialogue: 0,0:19:28.40,0:19:31.40,Default,,0,0,0,,{\i1}Sợ quá. Con người thật đáng sợ.{\i0}
Dialogue: 0,0:19:34.97,0:19:36.31,Default,,0,0,0,,Đánh trước nhé.
Dialogue: 0,0:19:40.31,0:19:41.21,Default,,0,0,0,,Gì vậy?
Dialogue: 0,0:19:42.68,0:19:44.18,Default,,0,0,0,,Kh-Không có gì!
Dialogue: 0,0:19:46.18,0:19:50.19,Default,,0,0,0,,Chắc hẳn cô đang chơi\Ndưới sức mình rất nhiều nhỉ.
Dialogue: 0,0:19:51.65,0:19:56.56,Default,,0,0,0,,Sự bực dọc đó khiến mọi thứ\Nđổ vỡ đến mức không thể cứu vãn.
Dialogue: 0,0:19:57.43,0:19:59.49,Default,,0,0,0,,Nên mới đánh cho có như vậy.
Dialogue: 0,0:20:00.96,0:20:02.10,Default,,0,0,0,,Nhưng mà,
Dialogue: 0,0:20:02.20,0:20:05.97,Default,,0,0,0,,đâu cần phải gỡ lại\Nngay lập tức những sai lầm đó.
Dialogue: 0,0:20:07.50,0:20:10.31,Default,,0,0,0,,Dùng cả 18 hố để gỡ lại là được.
Dialogue: 0,0:20:10.77,0:20:13.91,Default,,0,0,0,,Nếu chỉ còn hố cuối và cảm thấy\Nkhông thể làm gì được nữa,
Dialogue: 0,0:20:14.84,0:20:17.51,Default,,0,0,0,,thì dùng cả đời để gỡ lại cũng được.
Dialogue: 0,0:20:17.75,0:20:20.08,Default,,0,0,0,,Chỉ cần cải thiện số gậy trung bình\Ntrong cả cuộc đời
Dialogue: 0,0:20:20.22,0:20:23.32,Default,,0,0,0,,dù chỉ một gậy thôi\Ncũng đã tốt rồi mà!
Dialogue: 0,0:20:24.85,0:20:27.56,Default,,0,0,0,,Trung bình cả đời sao?
Dialogue: 0,0:20:27.89,0:20:30.56,Default,,0,0,0,,Đến tuổi của tôi rồi thì ngoài golf ra\Ncòn mắc nhiều sai lầm khác,
Dialogue: 0,0:20:30.76,0:20:32.86,Default,,0,0,0,,Không chỉ trong golf đâu.
Dialogue: 0,0:20:33.60,0:20:37.40,Default,,0,0,0,,đôi khi là những sai lầm\Nđể lại sự hối tiếc sâu sắc.
Dialogue: 0,0:20:38.00,0:20:41.10,Default,,0,0,0,,Nhưng rốt cuộc thì\Nthời gian không thể quay lại được.
Dialogue: 0,0:20:41.37,0:20:45.54,Default,,0,0,0,,Dù vậy vẫn đang nỗ lực\Ndùng cả đời để khắc phục.
Dialogue: 0,0:20:45.87,0:20:49.75,Default,,0,0,0,,Cô hay tôi đều có những vị trí bóng của riêng mình.
Dialogue: 0,0:20:49.88,0:20:52.11,Default,,0,0,0,,Và không thể thay đổi được!
Dialogue: 0,0:20:52.25,0:20:56.95,Default,,0,0,0,,Nên chỉ còn cách tiếp tục\Nchơi hết mình cho đến phút cuối.
Dialogue: 0,0:21:03.09,0:21:04.96,Default,,0,0,0,,{\i1}Số gậy trung bình cả đời.{\i0}
Dialogue: 0,0:21:06.76,0:21:08.53,Default,,0,0,0,,{\i1}Chưa từng nghĩ đến điều đó bao giờ.{\i0}
Dialogue: 0,0:21:11.60,0:21:13.40,Default,,0,0,0,,{\i1}Thật mừng vì đã rời khỏi đảo.{\i0}
Dialogue: 0,0:21:14.84,0:21:19.91,Default,,0,0,0,,{\i1}Nếu cứ ở lại đảo thì có nghĩa là{\i0}\N{\i1}sẽ mãi nằm yên ở vị trí bóng đó.{\i0}
Dialogue: 0,0:21:21.14,0:21:26.78,Default,,0,0,0,,{\i1}Chính vì đã quyết tâm đánh và rời khỏi{\i0}\N{\i1}đảo, nên mới có thể gặp gỡ.{\i0}
Dialogue: 0,0:21:35.89,0:21:38.49,Default,,0,0,0,,{\i1}Nếu đưa cú par putt này vào sẽ là 83.{\i0}
Dialogue: 0,0:21:38.63,0:21:41.00,Default,,0,0,0,,{\i1}Có thể sẽ lọt vào{\i0}\N{\i1}được vòng chung kết.{\i0}
Dialogue: 0,0:21:50.91,0:21:51.94,Default,,0,0,0,,{\i1}Làm được mà.{\i0}
Dialogue: 0,0:21:52.24,0:21:53.58,Default,,0,0,0,,Vào đi!
Dialogue: 0,0:21:58.98,0:22:00.52,Default,,0,0,0,,Nice par, Shima-san.
Dialogue: 0,0:22:01.98,0:22:02.89,Default,,0,0,0,,Cảm ơn.
Dialogue: 0,0:22:15.03,0:22:16.23,Default,,0,0,0,,Nhìn kìa!
Dialogue: 0,0:22:16.43,0:22:18.10,Default,,0,0,0,,Chà!
Dialogue: 0,0:23:49.09,0:23:51.59,Default,,0,0,0,,Vô địch giải trẻ Nhật Bản.\NĐúng không, Tsubura?
Dialogue: 0,0:23:51.76,0:23:56.87,Default,,0,0,0,,Nhưng giải nữ Kyushu này cũng sẽ vô địch\Nvà tiếp tục vươn lên đỉnh cao!
Dialogue: 0,0:23:58.00,0:24:01.17,Default,,0,0,0,,{\i1}Tập tiếp theo của{\i0} Tonbo! {\i1}Đối thủ là nhà vô địch!{\i0}
Dialogue: 0,0:24:01.70,0:24:04.94,Default,,0,0,0,,Tôi cũng từng vô địch một lần rồi đấy!\NỞ giải Cúp Chia Tay Tonbo trên đảo Hinoshima!
Dialogue: 0,0:24:05.11,0:24:06.98,Default,,0,0,0,,Tôi cũng muốn tham gia giải đó nữa!
Dialogue: 0,0:24:07.08,0:24:07.94,Default,,0,0,0,,Tuyệt!