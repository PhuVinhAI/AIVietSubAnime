Dialogue: 0,0:00:16.99,0:00:20.28,Default,,0,0,0,,Cùng xem dự báo thời tiết tuần này \Nở khu vực Kaga nhé.
Dialogue: 0,0:00:20.80,0:00:23.57,Default,,0,0,0,,Thời tiết sẽ có chút thay đổi \Ntrong vài ngày tới.
Dialogue: 0,0:00:23.68,0:00:26.43,Default,,0,0,0,,Ngon quá đi mất!
Dialogue: 0,0:00:26.43,0:00:29.51,Default,,0,0,0,,Dù chỉ là trứng rán bình thường.
Dialogue: 0,0:00:29.51,0:00:33.08,Default,,0,0,0,,Yu-yu rán trứng đỉnh thật đấy!
Dialogue: 0,0:00:33.08,0:00:35.01,Default,,0,0,0,,Nên phần thưởng đây, cho một ít này.
Dialogue: 0,0:00:35.71,0:00:37.87,Default,,0,0,0,,Nh-Nhưng mà thích... nước tương hơn...
Dialogue: 0,0:00:38.92,0:00:40.25,Default,,0,0,0,,Cô bé à...
Dialogue: 0,0:00:40.25,0:00:42.60,Default,,0,0,0,,Nước tương? Sốt Worcestershire? Vớ vẩn!
Dialogue: 0,0:00:42.60,0:00:44.11,Default,,0,0,0,,Tương cà mới là chân lý!
Dialogue: 0,0:00:44.11,0:00:47.27,Default,,0,0,0,,Với lòng đỏ trứng béo ngậy thế này, \Nchỉ có vị chua ngọt của tương cà mới hợp thôi!
Dialogue: 0,0:00:48.27,0:00:50.70,Default,,0,0,0,,Sao cũng được. Sốt Worcestershire cũng ngon mà.
Dialogue: 0,0:00:50.70,0:00:51.40,Default,,0,0,0,,Ăn đây...
Dialogue: 0,0:00:51.40,0:00:52.78,Default,,0,0,0,,Nói cả ngàn lần rồi, tương cà là nhất!\NĂn đây...
Dialogue: 0,0:00:52.78,0:00:54.50,Default,,0,0,0,,Nói cả ngàn lần rồi, tương cà là nhất!
Dialogue: 0,0:00:54.50,0:00:55.81,Default,,0,0,0,,À, đúng rồi.
Dialogue: 0,0:00:55.81,0:00:57.30,Default,,0,0,0,,Này, Yu-yu.
Dialogue: 0,0:00:57.83,0:01:01.54,Default,,0,0,0,,Hôm nay đã hứa rồi, nhớ chứ?
Dialogue: 0,0:01:07.46,0:01:11.24,Default,,0,0,0,,Yu-yu, trông đáng yêu quá đi!
Dialogue: 0,0:01:11.24,0:01:14.16,Default,,0,0,0,,Và lớp trang điểm này cũng hợp lắm đấy.
Dialogue: 0,0:01:14.16,0:01:16.07,Default,,0,0,0,,Vẫn chưa chán trò này à?
Dialogue: 0,0:01:16.07,0:01:18.05,Default,,0,0,0,,Yu-yu, cứ từ chối cũng được mà.
Dialogue: 0,0:01:19.02,0:01:21.66,Default,,0,0,0,,Yu-yu thực sự là con trai sao?
Dialogue: 0,0:01:21.66,0:01:24.18,Default,,0,0,0,,Chuẩn chưa?! Nghệ sĩ cả đấy!
Dialogue: 0,0:01:24.18,0:01:26.19,Default,,0,0,0,,Chà, cũng nhờ \Nnguyên liệu gốc tốt nữa.
Dialogue: 0,0:01:26.19,0:01:29.39,Default,,0,0,0,,Viên ngọc thô này \Nđang tỏa sáng trong bức ảnh nghệ thuật này.
Dialogue: 0,0:01:29.39,0:01:32.07,Default,,0,0,0,,Yu-yu, cho mọi người xem ảnh này nhé?
Dialogue: 0,0:01:32.35,0:01:33.75,Default,,0,0,0,,Tốt nhất là đừng...
Dialogue: 0,0:01:33.75,0:01:35.56,Default,,0,0,0,,Sẽ quay video luôn.
Dialogue: 0,0:01:35.56,0:01:37.47,Default,,0,0,0,,Thế còn tệ hơn!
Dialogue: 0,0:01:37.47,0:01:39.07,Default,,0,0,0,,Chờ chút đã.
Dialogue: 0,0:01:39.38,0:01:42.20,Default,,0,0,0,,Nếu đã quay video...
Dialogue: 0,0:01:42.47,0:01:43.15,Default,,0,0,0,,Đây!
Dialogue: 0,0:01:43.15,0:01:44.53,Default,,0,0,0,,Mặc cái này vào đi!
Dialogue: 0,0:01:44.53,0:01:45.70,Default,,0,0,0,,Ồ!
Dialogue: 0,0:01:46.36,0:01:50.14,Default,,0,0,0,,Nghe nói khi ra trận, các samurai kỳ cựu \Nluôn sẵn sàng cắt đứt đai lưng
Dialogue: 0,0:01:50.14,0:01:51.71,Default,,0,0,0,,và xông lên chỉ với chiếc khố!
Dialogue: 0,0:01:52.38,0:01:54.06,Default,,0,0,0,,Phải thay đổi từ trong ra ngoài chứ.
Dialogue: 0,0:01:54.06,0:01:55.59,Default,,0,0,0,,Từ đã.
Dialogue: 0,0:01:56.81,0:01:57.71,Default,,0,0,0,,Thử màu đỏ xem.
Dialogue: 0,0:01:57.71,0:01:59.59,Default,,0,0,0,,Đừng có ngốc thế!
Dialogue: 0,0:01:59.84,0:02:01.87,Default,,0,0,0,,Chủ đề hôm nay là sự thuần khiết.
Dialogue: 0,0:02:01.87,0:02:03.34,Default,,0,0,0,,Không cần mấy thứ khêu gợi đâu.
Dialogue: 0,0:02:03.34,0:02:05.25,Default,,0,0,0,,Hết nói nổi.
Dialogue: 0,0:02:05.25,0:02:06.48,Default,,0,0,0,,Thì cứ nhìn xem.
Dialogue: 0,0:02:06.85,0:02:09.46,Default,,0,0,0,,Chắc là đúng rồi. Thiết kế này ổn chứ?
Dialogue: 0,0:02:09.46,0:02:10.82,Default,,0,0,0,,Hay là cho mượn cái này nhỉ?
Dialogue: 0,0:02:10.82,0:02:12.18,Default,,0,0,0,,Vô duyên quá đấy, Onee-chan!
Dialogue: 0,0:02:12.18,0:02:13.11,Default,,0,0,0,,Thấy sao hả, Yu-yu?
Dialogue: 0,0:02:13.11,0:02:13.98,Default,,0,0,0,,Cá nhân thì, sẽ chọn--
Dialogue: 0,0:02:17.90,0:02:20.74,Default,,0,0,0,,Chỉ là một... từ đơn giản...
Dialogue: 0,0:02:21.15,0:02:22.99,Default,,0,0,0,,Nhưng sao lại không thể nói ra?
Dialogue: 0,0:02:23.93,0:02:27.00,Default,,0,0,0,,Sao lại không thể nói "Không" chứ?!
Dialogue: 0,0:04:27.09,0:04:31.09,Default,,0,0,0,,Đêm ở Công Viên Giải Trí
Dialogue: 0,0:04:33.08,0:04:35.02,Default,,0,0,0,,Phải làm sao đây?
Dialogue: 0,0:04:35.02,0:04:36.60,Default,,0,0,0,,Này, cô em!
Dialogue: 0,0:04:36.60,0:04:38.85,Default,,0,0,0,,Đang làm gì thế?
Dialogue: 0,0:04:38.85,0:04:40.36,Default,,0,0,0,,Này.
Dialogue: 0,0:04:40.94,0:04:42.24,Default,,0,0,0,,Rảnh không? Đi hát karaoke đi.
Dialogue: 0,0:04:42.24,0:04:43.61,Default,,0,0,0,,Ư-Ừm...\NRảnh không? Đi hát karaoke đi.
Dialogue: 0,0:04:43.99,0:04:47.14,Default,,0,0,0,,Thôi nào, hát hò chút thôi mà? Vui lắm đấy!
Dialogue: 0,0:04:47.14,0:04:47.86,Default,,0,0,0,,Khoan đã...
Dialogue: 0,0:04:48.35,0:04:51.33,Default,,0,0,0,,Xin lỗi nhé. Rõ ràng là người ta không muốn đi mà.
Dialogue: 0,0:04:52.17,0:04:53.88,Default,,0,0,0,,Không muốn--
Dialogue: 0,0:04:55.48,0:04:57.62,Default,,0,0,0,,Chà, còn tuyệt hơn nữa!
Dialogue: 0,0:04:57.62,0:05:00.00,Default,,0,0,0,,Chết tiệt, dễ thương thật đấy.
Dialogue: 0,0:05:00.25,0:05:03.75,Default,,0,0,0,,Nói thật đấy. Đi hát karaoke đi.
Dialogue: 0,0:05:03.75,0:05:06.51,Default,,0,0,0,,Bỏ tay ra! Thật không có...
Dialogue: 0,0:05:06.51,0:05:08.01,Default,,0,0,0,,...ý tứ gì cả!
Dialogue: 0,0:05:11.53,0:05:13.65,Default,,0,0,0,,Đáng đời nhé.
Dialogue: 0,0:05:18.72,0:05:19.78,Default,,0,0,0,,Đi thôi.
Dialogue: 0,0:05:25.67,0:05:26.53,Default,,0,0,0,,Không sao chứ?
Dialogue: 0,0:05:26.87,0:05:29.39,Default,,0,0,0,,C-Cảm ơn.
Dialogue: 0,0:05:29.39,0:05:32.64,Default,,0,0,0,,Đã dễ thương, \Nthì phải biết cách nói "không" đấy.
Dialogue: 0,0:05:32.64,0:05:36.40,Default,,0,0,0,,Ưm, chuyện là...
Dialogue: 0,0:05:36.40,0:05:39.04,Default,,0,0,0,,Mấy tên thích tán tỉnh như hắn đúng là cặn bã.
Dialogue: 0,0:05:41.08,0:05:43.31,Default,,0,0,0,,"Chết tiệt, dễ thương thật đấy!"
Dialogue: 0,0:05:43.31,0:05:44.58,Default,,0,0,0,,Tên biến thái.
Dialogue: 0,0:05:46.57,0:05:50.40,Default,,0,0,0,,Giá mà đàn ông ai cũng tử tế \Nnhư Aniki thì tốt. Thế đâu có đòi hỏi gì nhiều.
Dialogue: 0,0:05:50.40,0:05:51.55,Default,,0,0,0,,Aniki sao?
Dialogue: 0,0:05:52.75,0:05:54.56,Default,,0,0,0,,Thực ra không phải anh ruột đâu.
Dialogue: 0,0:05:55.24,0:05:57.39,Default,,0,0,0,,Nhưng chuẩn hình mẫu anh lớn luôn.
Dialogue: 0,0:05:57.39,0:05:59.24,Default,,0,0,0,,Chắc gọi là người hay lo chuyện bao đồng nhỉ?
Dialogue: 0,0:05:59.24,0:06:04.82,Default,,0,0,0,,Nhưng cũng rất thông minh, đáng tin cậy, tốt bụng,\Nvà đã giúp đỡ không biết bao nhiêu lần rồi.
Dialogue: 0,0:06:06.73,0:06:08.07,Default,,0,0,0,,Thích người đó lắm nhỉ?
Dialogue: 0,0:06:09.40,0:06:12.30,Default,,0,0,0,,Không, không phải thế đâu!
Dialogue: 0,0:06:12.30,0:06:15.45,Default,,0,0,0,,Giống như... có một \Nmối liên kết rất mạnh mẽ.
Dialogue: 0,0:06:15.45,0:06:17.08,Default,,0,0,0,,Kiểu như, ưm...
Dialogue: 0,0:06:17.35,0:06:19.00,Default,,0,0,0,,Kiểu như sự tôn trọng à?
Dialogue: 0,0:06:19.00,0:06:21.51,Default,,0,0,0,,Đúng, chính là từ đó! "Tôn trọng"!
Dialogue: 0,0:06:21.51,0:06:24.59,Default,,0,0,0,,Kiểu như... ngưỡng mộ? Hay... truyền cảm hứng nhỉ?
Dialogue: 0,0:06:25.31,0:06:27.45,Default,,0,0,0,,Là con gái mà tinh ý thật đấy.
Dialogue: 0,0:06:27.45,0:06:28.80,Default,,0,0,0,,Th-Thực ra, là--
Dialogue: 0,0:06:28.80,0:06:31.09,Default,,0,0,0,,Ôi, chưa giới thiệu bản thân nữa.
Dialogue: 0,0:06:31.79,0:06:33.84,Default,,0,0,0,,Tên là Megumi. Còn tên là gì vậy?
Dialogue: 0,0:06:34.94,0:06:37.35,Default,,0,0,0,,Tên... Tên là Yu-yu.
Dialogue: 0,0:06:37.61,0:06:39.56,Default,,0,0,0,,Yu-yu à?
Dialogue: 0,0:06:41.69,0:06:42.60,Default,,0,0,0,,Giày này...
Dialogue: 0,0:06:43.39,0:06:45.23,Default,,0,0,0,,Là giày con trai phải không?
Dialogue: 0,0:06:45.23,0:06:46.33,Default,,0,0,0,,Cả ba lô nữa.
Dialogue: 0,0:06:48.12,0:06:52.48,Default,,0,0,0,,Nghe này, nếu đang gặp rắc rối, \Nthì muốn giúp một tay.
Dialogue: 0,0:06:53.23,0:06:54.62,Default,,0,0,0,,Sẽ giới thiệu với Aniki luôn.
Dialogue: 0,0:06:55.29,0:06:56.33,Default,,0,0,0,,Thật sao?
Dialogue: 0,0:06:56.33,0:06:58.12,Default,,0,0,0,,Tất nhiên rồi!
Dialogue: 0,0:06:58.86,0:07:01.17,Default,,0,0,0,,Chắc chắn mọi người sẽ chào đón nhiệt tình.
Dialogue: 0,0:07:01.17,0:07:02.12,Default,,0,0,0,,Mọi người sao?
Dialogue: 0,0:07:02.48,0:07:05.50,Default,,0,0,0,,Ừ! Mọi người ở "Đêm Công Viên Giải Trí"!
Dialogue: 0,0:07:05.75,0:07:07.91,Default,,0,0,0,,Khoan... vừa nói là "Đêm" sao?
Dialogue: 0,0:07:07.91,0:07:10.85,Default,,0,0,0,,Đó là chỗ hay tụ tập.
Dialogue: 0,0:07:13.00,0:07:15.86,Default,,0,0,0,,Chà chà! Lại gặp nhau rồi!
Dialogue: 0,0:07:15.86,0:07:18.81,Default,,0,0,0,,Giờ thì phải đi hát karaoke rồi nhé.
Dialogue: 0,0:07:18.81,0:07:20.83,Default,,0,0,0,,Trời ạ, đúng là đồ phiền phức!
Dialogue: 0,0:07:20.83,0:07:23.81,Default,,0,0,0,,Này, đừng có phũ phàng thế chứ.
Dialogue: 0,0:07:23.81,0:07:29.48,Default,,0,0,0,,Chỉ là, đi chơi cùng một chút,\N rồi sẽ tha cho cú đá ban nãy.
Dialogue: 0,0:07:29.48,0:07:31.36,Default,,0,0,0,,Đáng đời thôi.
Dialogue: 0,0:07:32.43,0:07:34.88,Default,,0,0,0,,Sẽ phải hối hận đấy.
Dialogue: 0,0:07:34.88,0:07:36.03,Default,,0,0,0,,Ý gì đây?
Dialogue: 0,0:07:36.63,0:07:39.28,Default,,0,0,0,,Sẽ lỡ mất cơ hội nghe giọng hát ngọt ngào này đấy.
Dialogue: 0,0:07:39.60,0:07:41.53,Default,,0,0,0,,Không muốn nghe thêm tiếng nào nữa đâu!
Dialogue: 0,0:07:41.53,0:07:43.56,Default,,0,0,0,,G-Gì thế hả?!
Dialogue: 0,0:07:46.00,0:07:48.21,Default,,0,0,0,,P-Phân chim?! Tởm quá!
Dialogue: 0,0:07:48.21,0:07:49.23,Default,,0,0,0,,Á, bẩn hết quần áo rồi!
Dialogue: 0,0:07:49.23,0:07:51.00,Default,,0,0,0,,Khoan! Mặc áo vào đi!
Dialogue: 0,0:07:51.00,0:07:52.71,Default,,0,0,0,,Vết bẩn! Có sạch không đây?!
Dialogue: 0,0:07:52.71,0:07:53.30,Default,,0,0,0,,Bốc mùi quá!
Dialogue: 0,0:07:55.05,0:07:56.55,Default,,0,0,0,,Phát hiện kẻ biến thái!
Dialogue: 0,0:07:57.47,0:07:59.61,Default,,0,0,0,,Ơ, không phải như thế đâu!
Dialogue: 0,0:07:59.61,0:08:00.81,Default,,0,0,0,,Giống như đang phục vụ--
Dialogue: 0,0:08:01.06,0:08:02.56,Default,,0,0,0,,Bắt được rồi nhé!
Dialogue: 0,0:08:03.58,0:08:04.43,Default,,0,0,0,,Đi thôi!
Dialogue: 0,0:08:04.43,0:08:04.75,Default,,0,0,0,,Xin hàng... Xin hàng ạ...
Dialogue: 0,0:08:04.75,0:08:05.70,Default,,0,0,0,,Phải rồi!\NXin hàng... Xin hàng ạ...
Dialogue: 0,0:08:05.70,0:08:07.18,Default,,0,0,0,,Đi thôi, Yu-yu!\NXin hàng... Xin hàng ạ...
Dialogue: 0,0:08:07.18,0:08:08.94,Default,,0,0,0,,V-Vâng!
Dialogue: 0,0:08:15.22,0:08:18.27,Default,,0,0,0,,Mệt rã rời... vì chạy nãy giờ.
Dialogue: 0,0:08:18.27,0:08:22.48,Default,,0,0,0,,Cũng vậy. Tim đập nhanh quá.
Dialogue: 0,0:08:33.02,0:08:35.22,Default,,0,0,0,,Thế này có khi lại ổn.
Dialogue: 0,0:08:35.54,0:08:38.36,Default,,0,0,0,,Một "tình bạn thiếu nữ" thực sự.
Dialogue: 0,0:08:39.00,0:08:41.47,Default,,0,0,0,,Đây là lần đầu tiên đấy.
Dialogue: 0,0:08:42.32,0:08:44.90,Default,,0,0,0,,Lần đầu tiên cùng cười đùa với một cô gái khác...
Dialogue: 0,0:08:45.65,0:08:46.48,Default,,0,0,0,,Này...
Dialogue: 0,0:08:47.73,0:08:49.74,Default,,0,0,0,,Uống thử đi, sẽ mát hơn đấy.
Dialogue: 0,0:08:49.74,0:08:52.11,Default,,0,0,0,,V-Vâng...
Dialogue: 0,0:08:53.19,0:08:55.92,Default,,0,0,0,,Quyết định vậy đi! Đi cùng nhé!
Dialogue: 0,0:08:55.92,0:08:58.97,Default,,0,0,0,,Sẽ giới thiệu với mọi người \Nở "Đêm Công Viên Giải Trí".
Dialogue: 0,0:08:58.97,0:09:01.65,Default,,0,0,0,,Ư-Ừm, chuyện đó...
Dialogue: 0,0:09:01.65,0:09:02.24,Default,,0,0,0,,Sao thế?
Dialogue: 0,0:09:02.71,0:09:07.46,Default,,0,0,0,,"Đêm Công Viên Giải Trí" \Nlà công viên bỏ hoang đó sao?
Dialogue: 0,0:09:07.46,0:09:10.00,Default,,0,0,0,,Nghe đồn ở đó \Nhay có ma với bắt cóc...
Dialogue: 0,0:09:10.42,0:09:14.58,Default,,0,0,0,,V-Và còn bị cấm đến đó \Nvì là nơi tụ tập của đám du côn nữa.
Dialogue: 0,0:09:16.01,0:09:16.95,Default,,0,0,0,,Đồn Cảnh Sát Odateno
Dialogue: 0,0:09:16.95,0:09:21.26,Default,,0,0,0,,Hiểu rồi. Một bé trai 15 tuổi, cao 1m55.\NĐồn Cảnh Sát Odateno
Dialogue: 0,0:09:21.69,0:09:24.37,Default,,0,0,0,,Rời khỏi nhà tầm trưa, \Nvà chưa thấy về sao?
Dialogue: 0,0:09:24.37,0:09:27.14,Default,,0,0,0,,Vâng. Ồ, cái này à?
Dialogue: 0,0:09:27.83,0:09:30.15,Default,,0,0,0,,Vâng, đã nhận được dữ liệu.
Dialogue: 0,0:09:30.40,0:09:32.49,Default,,0,0,0,,Sẽ gọi lại sớm ạ.
Dialogue: 0,0:09:34.67,0:09:37.10,Default,,0,0,0,,Trời ạ. Mới chiều muộn thôi mà.
Dialogue: 0,0:09:37.10,0:09:39.51,Default,,0,0,0,,Tầm tuổi đó thế là bình thường.
Dialogue: 0,0:09:39.51,0:09:42.44,Default,,0,0,0,,Dạo này--Hả?
Dialogue: 0,0:09:42.44,0:09:44.16,Default,,0,0,0,,Đây chẳng phải là đứa đi cùng Megumi sao?
Dialogue: 0,0:09:44.67,0:09:45.97,Default,,0,0,0,,Sẽ ổn thôi mà!
Dialogue: 0,0:09:45.97,0:09:47.25,Default,,0,0,0,,Nh-Nhưng...
Dialogue: 0,0:09:47.25,0:09:50.42,Default,,0,0,0,,Chưa từng thấy con ma nào ở đó cả, \Nvà bạn bè đều là người tốt hết.
Dialogue: 0,0:09:50.71,0:09:52.01,Default,,0,0,0,,Nhưng...
Dialogue: 0,0:09:53.31,0:09:53.92,Default,,0,0,0,,Á!
Dialogue: 0,0:09:54.96,0:09:57.32,Default,,0,0,0,,Chà, suýt nữa thì thức tỉnh rồi...
Dialogue: 0,0:10:00.35,0:10:02.19,Default,,0,0,0,,Cái tên này...!
Dialogue: 0,0:10:02.19,0:10:05.04,Default,,0,0,0,,Có biết nãy giờ đã gây ra chuyện gì không hả?!
Dialogue: 0,0:10:05.04,0:10:07.85,Default,,0,0,0,,Tự chuốc lấy thôi!
Dialogue: 0,0:10:08.11,0:10:10.82,Default,,0,0,0,,Và ta sẽ là người kết thúc chuyện này.
Dialogue: 0,0:10:11.60,0:10:13.86,Default,,0,0,0,,Đứng im đó.
Dialogue: 0,0:10:23.49,0:10:24.62,Default,,0,0,0,,Cẩn thận!
Dialogue: 0,0:10:32.32,0:10:34.57,Default,,0,0,0,,Bắt hay lắm!
Dialogue: 0,0:10:34.57,0:10:35.88,Default,,0,0,0,,Không sao chứ?
Dialogue: 0,0:10:37.38,0:10:41.11,Default,,0,0,0,,Lúc nào cũng tự khen mình. \NĐó là điểm thú vị của cậu đấy, Danji.
Dialogue: 0,0:10:41.11,0:10:43.23,Default,,0,0,0,,Nhưng bắt rõ hay mà, đúng không?
Dialogue: 0,0:10:43.23,0:10:44.83,Default,,0,0,0,,Aniki! Zakusa!
Dialogue: 0,0:10:44.83,0:10:45.76,Default,,0,0,0,,Chào.
Dialogue: 0,0:10:46.17,0:10:48.27,Default,,0,0,0,,C-Các người là ai hả?
Dialogue: 0,0:10:49.82,0:10:51.27,Default,,0,0,0,,Là Aniki của con bé.
Dialogue: 0,0:10:51.52,0:10:53.04,Default,,0,0,0,,Là Aniki sao?
Dialogue: 0,0:10:53.04,0:10:54.65,Default,,0,0,0,,Ừ. Ngầu lắm đúng không?
Dialogue: 0,0:10:56.45,0:10:57.59,Default,,0,0,0,,To lớn thật...
Dialogue: 0,0:10:57.59,0:11:01.43,Default,,0,0,0,,Ừ, to lớn về nhiều mặt lắm!
Dialogue: 0,0:11:01.43,0:11:03.78,Default,,0,0,0,,Tuyệt đối không được đánh phụ nữ.
Dialogue: 0,0:11:04.03,0:11:06.91,Default,,0,0,0,,Đương nhiên, cũng không được đánh đàn ông.
Dialogue: 0,0:11:06.91,0:11:08.91,Default,,0,0,0,,Động vật cũng không.
Dialogue: 0,0:11:08.91,0:11:09.79,Default,,0,0,0,,Gì nữa nhỉ...
Dialogue: 0,0:11:10.06,0:11:13.44,Default,,0,0,0,,Và, nước ngọt không phải \Nđể ném vào người khác.
Dialogue: 0,0:11:13.44,0:11:16.04,Default,,0,0,0,,Danji, chắc đang khát nhỉ.
Dialogue: 0,0:11:16.29,0:11:18.90,Default,,0,0,0,,Nhắc mới nhớ, khát thật.
Dialogue: 0,0:11:20.67,0:11:21.80,Default,,0,0,0,,Đần đến thế à?
Dialogue: 0,0:11:22.05,0:11:23.05,Default,,0,0,0,,Không tới lượt lên tiếng đâu!
Dialogue: 0,0:11:23.05,0:11:23.93,Default,,0,0,0,,Sparkling Citrus\NKhông tới lượt lên tiếng đâu!
Dialogue: 0,0:11:23.93,0:11:25.05,Default,,0,0,0,,Không tới lượt lên tiếng đâu!
Dialogue: 0,0:11:25.30,0:11:28.08,Default,,0,0,0,,G-Gì chứ?! \NĐó chỉ là chai soda rỗng thôi mà!
Dialogue: 0,0:11:28.08,0:11:29.68,Default,,0,0,0,,Thế thì cũng làm được!
Dialogue: 0,0:11:30.22,0:11:32.18,Default,,0,0,0,,Vậy, thử sức chút không?
Dialogue: 0,0:11:32.90,0:11:34.37,Default,,0,0,0,,Đây.
Dialogue: 0,0:11:34.37,0:11:35.23,Default,,0,0,0,,Cảm ơn nhé!
Dialogue: 0,0:11:44.45,0:11:45.45,Default,,0,0,0,,Đến lượt đấy.
Dialogue: 0,0:11:45.45,0:11:46.99,Default,,0,0,0,,Nếp nhăn đẹp đấy.
Dialogue: 0,0:11:46.99,0:11:48.37,Default,,0,0,0,,Không xé nổi luôn?!
Dialogue: 0,0:11:49.06,0:11:50.80,Default,,0,0,0,,Là ấn bản tuần này đấy.
Dialogue: 0,0:11:50.80,0:11:51.87,Default,,0,0,0,,Vẫn chưa đọc đâu.
Dialogue: 0,0:11:52.93,0:11:55.12,Default,,0,0,0,,Chỉ là phán đoán chớp nhoáng thôi.
Dialogue: 0,0:11:55.37,0:11:58.88,Default,,0,0,0,,T-Tên này là ai vậy? Thật phiền phức.
Dialogue: 0,0:12:01.48,0:12:04.38,Default,,0,0,0,,Đây. Trả lại \Nmọi thứ đã làm rơi này!
Dialogue: 0,0:12:07.52,0:12:08.39,Default,,0,0,0,,Không thể nào...
Dialogue: 0,0:12:08.69,0:12:10.64,Default,,0,0,0,,Đúng rồi! Nhặt đi!
Dialogue: 0,0:12:11.98,0:12:14.39,Default,,0,0,0,,Đã bảo là trả lại rồi mà.
Dialogue: 0,0:12:14.91,0:12:17.90,Default,,0,0,0,,V-V-Vâng!
Dialogue: 0,0:12:18.22,0:12:20.58,Default,,0,0,0,,Tốt nhất là dọn sạch hết đi!
Dialogue: 0,0:12:21.09,0:12:22.78,Default,,0,0,0,,Cho hắn một lối thoát êm đẹp nhỉ.
Dialogue: 0,0:12:23.12,0:12:24.52,Default,,0,0,0,,Cho hắn đi sao?
Dialogue: 0,0:12:24.52,0:12:26.88,Default,,0,0,0,,Aniki vừa mạnh mẽ vừa tốt bụng mà.
Dialogue: 0,0:12:26.88,0:12:28.78,Default,,0,0,0,,Cảm ơn nhé, Aniki. Cả Zakusa nữa.
Dialogue: 0,0:12:29.09,0:12:29.98,Default,,0,0,0,,Không có chi.
Dialogue: 0,0:12:29.98,0:12:32.39,Default,,0,0,0,,Không vấn đề. Rất vui là đằng khác.
Dialogue: 0,0:12:32.39,0:12:33.79,Default,,0,0,0,,Cho này...
Dialogue: 0,0:12:34.66,0:12:37.42,Default,,0,0,0,,Còn cô bé? Không sao chứ?
Dialogue: 0,0:12:37.78,0:12:39.07,Default,,0,0,0,,Vâng!
Dialogue: 0,0:12:39.07,0:12:41.42,Default,,0,0,0,,C-Cảm ơn ạ...
Dialogue: 0,0:12:42.93,0:12:45.44,Default,,0,0,0,,C-Chuyện nhỏ thôi mà.
Dialogue: 0,0:12:45.44,0:12:47.31,Default,,0,0,0,,Ngại cái gì vậy?
Dialogue: 0,0:12:47.31,0:12:48.80,Default,,0,0,0,,Có ngại đâu!
Dialogue: 0,0:12:49.87,0:12:51.05,Default,,0,0,0,,Vậy, đây là ai?
Dialogue: 0,0:12:51.90,0:12:55.04,Default,,0,0,0,,Mới gặp lúc nãy thôi. Tên là Yu-yu.
Dialogue: 0,0:12:55.04,0:12:58.06,Default,,0,0,0,,Ồ, rất vui được gặp...
Dialogue: 0,0:12:58.31,0:13:00.02,Default,,0,0,0,,Đây là Zakusa Ishigame.
Dialogue: 0,0:13:00.02,0:13:00.69,Default,,0,0,0,,Chào.
Dialogue: 0,0:13:00.93,0:13:02.82,Default,,0,0,0,,Và như đã nói, đây là "Aniki".
Dialogue: 0,0:13:02.82,0:13:04.82,Default,,0,0,0,,Chào nhé. Là Danji Momoyama.
Dialogue: 0,0:13:05.87,0:13:08.32,Default,,0,0,0,,Sao lại đỏ mặt thế, Danji?
Dialogue: 0,0:13:08.32,0:13:09.82,Default,,0,0,0,,Aniki...
Dialogue: 0,0:13:10.51,0:13:12.27,Default,,0,0,0,,Ưm, à... ồ, đúng rồi!
Dialogue: 0,0:13:12.27,0:13:14.22,Default,,0,0,0,,Đến giờ rồi! Tốt nhất là nên đi thôi!
Dialogue: 0,0:13:14.22,0:13:15.53,Default,,0,0,0,,Đúng không, Zakusa?
Dialogue: 0,0:13:15.53,0:13:17.12,Default,,0,0,0,,Đổi chủ đề hay đấy.
Dialogue: 0,0:13:17.12,0:13:20.61,Default,,0,0,0,,Không thể để khách cất công đến đây \Nphải chờ đợi được, đúng chứ?!
Dialogue: 0,0:13:20.61,0:13:21.33,Default,,0,0,0,,Nên đi thôi!
Dialogue: 0,0:13:23.07,0:13:25.10,Default,,0,0,0,,Thấy chưa? Đâu có đáng sợ chút nào đúng không?
Dialogue: 0,0:13:25.10,0:13:26.98,Default,,0,0,0,,V-Vâng.
Dialogue: 0,0:13:27.52,0:13:28.84,Default,,0,0,0,,Megumi!
Dialogue: 0,0:13:29.19,0:13:31.34,Default,,0,0,0,,Cô bé đó có tâm sự nhỉ?
Dialogue: 0,0:13:31.64,0:13:34.79,Default,,0,0,0,,Vâng! Dẫn theo được chứ?!
Dialogue: 0,0:13:34.79,0:13:35.72,Default,,0,0,0,,Được thôi!
Dialogue: 0,0:13:35.97,0:13:37.85,Default,,0,0,0,,Team Blackout...
Dialogue: 0,0:13:38.25,0:13:40.85,Default,,0,0,0,,...không bao giờ từ chối ai! Đúng chứ?!
Dialogue: 0,0:13:45.50,0:13:47.86,Default,,0,0,0,,Aniki! Nhất định phải thắng đấy!
Dialogue: 0,0:13:52.17,0:13:54.24,Default,,0,0,0,,Đi thôi. Chúng ta cũng đi nào.
Dialogue: 0,0:13:56.25,0:13:57.11,Default,,0,0,0,,Vâng.
Dialogue: 0,0:13:58.49,0:13:59.58,Default,,0,0,0,,Alo?
Dialogue: 0,0:13:59.58,0:14:02.25,Default,,0,0,0,,Vâng. Hình như đang đi cùng bạn bè.
Dialogue: 0,0:14:02.57,0:14:06.33,Default,,0,0,0,,Vâng. Vâng. Đã rõ.
Dialogue: 0,0:14:09.86,0:14:12.72,Default,,0,0,0,,N-Nơi này là...
Dialogue: 0,0:14:19.38,0:14:20.70,Default,,0,0,0,,Không...
Dialogue: 0,0:14:21.48,0:14:22.90,Default,,0,0,0,,Không muốn đâu...
Dialogue: 0,0:15:25.50,0:15:27.36,Default,,0,0,0,,Đợi ở đây một lát nhé.
Dialogue: 0,0:15:28.32,0:15:30.50,Default,,0,0,0,,M-Megumi?!
Dialogue: 0,0:15:31.53,0:15:33.04,Default,,0,0,0,,Kappa sao?
Dialogue: 0,0:15:39.63,0:15:43.63,Default,,0,0,0,,Fun Fun
Dialogue: 0,0:15:44.65,0:15:46.89,Default,,0,0,0,,Xin lỗi vì đã để phải chờ!
Dialogue: 0,0:15:46.89,0:15:47.70,Default,,0,0,0,,Megumi!
Dialogue: 0,0:15:47.70,0:15:48.62,Default,,0,0,0,,Đi thôi!
Dialogue: 0,0:15:48.62,0:15:49.51,Default,,0,0,0,,Hướng này!
Dialogue: 0,0:15:49.76,0:15:51.02,Default,,0,0,0,,Bộ đồ đó...
Dialogue: 0,0:15:51.02,0:15:53.08,Default,,0,0,0,,Đây là đồng phục chiến đấu đấy.
Dialogue: 0,0:15:53.08,0:15:55.02,Default,,0,0,0,,Lần nào đến đây cũng mặc bộ này.
Dialogue: 0,0:15:56.12,0:15:58.27,Default,,0,0,0,,Đồng phục chiến đấu?
Dialogue: 0,0:15:58.52,0:16:01.25,Default,,0,0,0,,Đó là phong cách Vanguard!
Dialogue: 0,0:16:02.12,0:16:04.78,Default,,0,0,0,,Chào mừng đến với quảng trường của những giấc mơ, Wonder Hill!
Dialogue: 0,0:16:30.61,0:16:31.98,Default,,0,0,0,,Lối này.
Dialogue: 0,0:16:32.96,0:16:35.77,Default,,0,0,0,,Mọi người tổ chức đấu Vanguard ở đây. Thấy sao?
Dialogue: 0,0:16:36.31,0:16:36.62,Default,,0,0,0,,Vanguard... trò chơi thẻ bài đó sao?
Dialogue: 0,0:16:36.62,0:16:39.06,Default,,0,0,0,,Này mọi người! \NVanguard... trò chơi thẻ bài đó sao?
Dialogue: 0,0:16:39.06,0:16:40.20,Default,,0,0,0,,Sau đêm nay, câu lạc bộ này sẽ trở thành huyền thoại!
Dialogue: 0,0:16:40.20,0:16:41.31,Default,,0,0,0,,Đó chẳng phải là...?\NSau đêm nay, câu lạc bộ này sẽ trở thành huyền thoại!
Dialogue: 0,0:16:41.31,0:16:43.45,Default,,0,0,0,,Đêm nay, có một trận đấu \Nkhông thể nào thua.\NSau đêm nay, câu lạc bộ này sẽ trở thành huyền thoại!
Dialogue: 0,0:16:43.45,0:16:43.93,Default,,0,0,0,,Nhưng Aniki sẽ không thua đâu.\NSau đêm nay, câu lạc bộ này sẽ trở thành huyền thoại!
Dialogue: 0,0:16:43.93,0:16:45.07,Default,,0,0,0,,Không thể để thua trận đấu này,\NNhưng Aniki sẽ không thua đâu.
Dialogue: 0,0:16:45.07,0:16:45.55,Default,,0,0,0,,Không thể để thua trận đấu này,
Dialogue: 0,0:16:45.55,0:16:46.31,Default,,0,0,0,,nhất là khi độc quyền sử dụng Wonder Hill \Nvà lá cờ của Team Blackout đang bị đặt cược!
Dialogue: 0,0:16:46.31,0:16:48.32,Default,,0,0,0,,Chào mừng, Yu-yu.\Nnhất là khi độc quyền sử dụng Wonder Hill \Nvà lá cờ của Team Blackout đang bị đặt cược!
Dialogue: 0,0:16:48.32,0:16:48.57,Default,,0,0,0,,nhất là khi độc quyền sử dụng Wonder Hill \Nvà lá cờ của Team Blackout đang bị đặt cược!
Dialogue: 0,0:16:48.57,0:16:49.23,Default,,0,0,0,,Một đêm tuyệt vời nhỉ.\Nnhất là khi độc quyền sử dụng Wonder Hill \Nvà lá cờ của Team Blackout đang bị đặt cược!
Dialogue: 0,0:16:49.23,0:16:50.34,Default,,0,0,0,,Tuy nhiên!\NMột đêm tuyệt vời nhỉ.
Dialogue: 0,0:16:50.34,0:16:51.00,Default,,0,0,0,,Nhà vô địch của chúng ta đã gạt bỏ \Náp lực đó và liên tục giành chiến thắng,\NMột đêm tuyệt vời nhỉ.
Dialogue: 0,0:16:51.00,0:16:53.08,Default,,0,0,0,,Được giữ kín như ngọn lửa ủ trong tro,\NNhà vô địch của chúng ta đã gạt bỏ \Náp lực đó và liên tục giành chiến thắng,
Dialogue: 0,0:16:53.08,0:16:53.40,Default,,0,0,0,,Nhà vô địch của chúng ta đã gạt bỏ \Náp lực đó và liên tục giành chiến thắng,
Dialogue: 0,0:16:53.40,0:16:54.70,Default,,0,0,0,,nhưng rực rỡ như một ngọn lửa bùng cháy.\NNhà vô địch của chúng ta đã gạt bỏ \Náp lực đó và liên tục giành chiến thắng,
Dialogue: 0,0:16:54.70,0:16:55.28,Default,,0,0,0,,với chuỗi 19 trận thắng liên tiếp!\Nnhưng rực rỡ như một ngọn lửa bùng cháy.
Dialogue: 0,0:16:55.28,0:16:57.08,Default,,0,0,0,,Mong là sẽ thích.\Nvới chuỗi 19 trận thắng liên tiếp!
Dialogue: 0,0:16:57.08,0:17:00.05,Default,,0,0,0,,Nhưng liệu kỷ lục đó có bị chặn đứng \Nngay trong đêm nay không?!
Dialogue: 0,0:17:00.05,0:17:03.87,Default,,0,0,0,,Ồ! Ra rồi kìa!
Dialogue: 0,0:17:03.87,0:17:06.59,Default,,0,0,0,,Đúng vậy! Kẻ xâm lược đêm nay đã xuất hiện!
Dialogue: 0,0:17:06.59,0:17:10.09,Default,,0,0,0,,Đã liên tục giành chiến thắng trong các trận đấu chính thức,
Dialogue: 0,0:17:10.26,0:17:13.22,Default,,0,0,0,,nhưng lai lịch của kẻ thách thức lạnh lùng \Nvà mạnh mẽ này vẫn còn là một bí ẩn!
Dialogue: 0,0:17:13.22,0:17:15.16,Default,,0,0,0,,19 trận thắng liên tiếp sao?\Nnhưng lai lịch của kẻ thách thức lạnh lùng \Nvà mạnh mẽ này vẫn còn là một bí ẩn!
Dialogue: 0,0:17:15.16,0:17:15.67,Default,,0,0,0,,Chẳng mấy ấn tượng với kẻ \Nchỉ biết khoe khoang việc đi săn người chơi yếu.
Dialogue: 0,0:17:15.67,0:17:17.35,Default,,0,0,0,,Đó là Tohya Ebata!\NChẳng mấy ấn tượng với kẻ \Nchỉ biết khoe khoang việc đi săn người chơi yếu.
Dialogue: 0,0:17:17.35,0:17:20.35,Default,,0,0,0,,Đó là Tohya Ebata!
Dialogue: 0,0:17:20.35,0:17:20.88,Default,,0,0,0,,Đối đầu với thủ lĩnh của Team Blackout, \Nngười chưa từng thua một trận nào tại đây!
Dialogue: 0,0:17:20.88,0:17:22.17,Default,,0,0,0,,Đừng nói thế chứ.\NĐối đầu với thủ lĩnh của Team Blackout, \Nngười chưa từng thua một trận nào tại đây!
Dialogue: 0,0:17:22.17,0:17:23.86,Default,,0,0,0,,Cứ đấu rồi sẽ biết,\NĐối đầu với thủ lĩnh của Team Blackout, \Nngười chưa từng thua một trận nào tại đây!
Dialogue: 0,0:17:23.86,0:17:25.36,Default,,0,0,0,,xem có phải là kẻ yếu hay không.\NĐối đầu với thủ lĩnh của Team Blackout, \Nngười chưa từng thua một trận nào tại đây!
Dialogue: 0,0:17:25.36,0:17:26.12,Default,,0,0,0,,"Ai đó cản tôi lại đi"!\Nxem có phải là kẻ yếu hay không.
Dialogue: 0,0:17:26.12,0:17:27.74,Default,,0,0,0,,"Ai đó cản tôi lại đi"!
Dialogue: 0,0:17:27.74,0:17:29.61,Default,,0,0,0,,Danji Momoyama!
Dialogue: 0,0:17:31.98,0:17:34.15,Default,,0,0,0,,Được rồi, được rồi, được rồi!
Dialogue: 0,0:17:34.21,0:17:37.31,Default,,0,0,0,,Được rồi, được rồi, được rồi!
Dialogue: 0,0:17:37.31,0:17:38.50,Default,,0,0,0,,Hai quý ngài, xin mời!
Dialogue: 0,0:17:38.75,0:17:41.00,Default,,0,0,0,,Stand up, Vanguard!
Dialogue: 0,0:17:41.65,0:17:44.09,Default,,0,0,0,,Danji đi trước, và rút bài.
Dialogue: 0,0:17:44.09,0:17:47.89,Default,,0,0,0,,Ride Steve, kích hoạt kỹ năng, \Nvà call Matt!
Dialogue: 0,0:17:47.89,0:17:49.13,Default,,0,0,0,,Kết thúc lượt.
Dialogue: 0,0:17:49.13,0:17:50.54,Default,,0,0,0,,Tohya rút bài!
Dialogue: 0,0:17:50.54,0:17:53.70,Default,,0,0,0,,Liệu có thể chấm dứt huyền thoại của Danji không?!
Dialogue: 0,0:17:53.70,0:17:56.72,Default,,0,0,0,,Ride Fort, kích hoạt kỹ năng, \Nvà sắp xếp lại bài!
Dialogue: 0,0:17:56.72,0:17:57.77,Default,,0,0,0,,Tấn công.\NRide Fort, kích hoạt kỹ năng, \Nvà sắp xếp lại bài!
Dialogue: 0,0:17:57.77,0:17:59.76,Default,,0,0,0,,Tấn công bằng Vanguard!
Dialogue: 0,0:17:59.76,0:18:00.52,Default,,0,0,0,,No guard.
Dialogue: 0,0:18:00.79,0:18:02.86,Default,,0,0,0,,Tohya, với một chuỗi tấn công!
Dialogue: 0,0:18:02.86,0:18:03.52,Default,,0,0,0,,No guard.\NTohya, với một chuỗi tấn công!
Dialogue: 0,0:18:03.82,0:18:04.63,Default,,0,0,0,,Cả hai đều không rút được trigger!
Dialogue: 0,0:18:04.63,0:18:06.45,Default,,0,0,0,,Hoàn toàn không phòng thủ.\NCả hai đều không rút được trigger!
Dialogue: 0,0:18:06.45,0:18:07.97,Default,,0,0,0,,Cũng không hề do dự luôn?
Dialogue: 0,0:18:07.97,0:18:09.42,Default,,0,0,0,,Được rồi! Lượt của Danji!\NDù không chắc chắn về bài trên tay, vẫn giữ vững lập trường.
Dialogue: 0,0:18:09.42,0:18:11.16,Default,,0,0,0,,Ride, và kích hoạt kỹ năng!\NDù không chắc chắn về bài trên tay, vẫn giữ vững lập trường.
Dialogue: 0,0:18:11.16,0:18:13.66,Default,,0,0,0,,Sau đó gia tăng số lượng bài trên tay \Nbằng cách rút thêm một lá!
Dialogue: 0,0:18:13.84,0:18:15.66,Default,,0,0,0,,Tấn công Vanguard.
Dialogue: 0,0:18:15.66,0:18:16.54,Default,,0,0,0,,Tohya không phòng thủ!
Dialogue: 0,0:18:16.54,0:18:17.75,Default,,0,0,0,,Giữ vững lập trường nhỉ?\NTohya không phòng thủ!
Dialogue: 0,0:18:17.75,0:18:19.91,Default,,0,0,0,,Lượt của Danji kết thúc, đến lượt của Tohya!
Dialogue: 0,0:18:20.69,0:18:23.17,Default,,0,0,0,,Cứ tưởng là sẽ táo bạo hơn thế này chứ.
Dialogue: 0,0:18:23.42,0:18:27.17,Default,,0,0,0,,Painkiller và Fort đổi chỗ. \NSau đó Vanguard tấn công.
Dialogue: 0,0:18:27.59,0:18:28.80,Default,,0,0,0,,No guard.
Dialogue: 0,0:18:29.07,0:18:31.18,Default,,0,0,0,,Fort được boost tấn công.
Dialogue: 0,0:18:31.38,0:18:32.50,Default,,0,0,0,,No guard.
Dialogue: 0,0:18:32.50,0:18:34.35,Default,,0,0,0,,Vẫn không có trigger!
Dialogue: 0,0:18:34.35,0:18:34.83,Default,,0,0,0,,Nữ thần của những trận chiến chân chính \Nkhông dễ bị lung lay thế đâu!
Dialogue: 0,0:18:34.83,0:18:36.25,Default,,0,0,0,,Kết thúc lượt.\NNữ thần của những trận chiến chân chính \Nkhông dễ bị lung lay thế đâu!
Dialogue: 0,0:18:36.25,0:18:38.42,Default,,0,0,0,,Rất nhiều mưu mẹo đấy.\NNữ thần của những trận chiến chân chính \Nkhông dễ bị lung lay thế đâu!
Dialogue: 0,0:18:38.42,0:18:39.02,Default,,0,0,0,,Nhìn nét mặt là biết đã lên kế hoạch hết rồi.
Dialogue: 0,0:18:39.02,0:18:40.69,Default,,0,0,0,,Chà, Danji đã để Tohya dẫn trước một khoảng khá xa,\NNhìn nét mặt là biết đã lên kế hoạch hết rồi.
Dialogue: 0,0:18:40.69,0:18:40.94,Default,,0,0,0,,Chà, Danji đã để Tohya dẫn trước một khoảng khá xa,
Dialogue: 0,0:18:40.94,0:18:42.68,Default,,0,0,0,,Có cảm giác là đã chuẩn bị \Nrất nhiều cho đêm nay.\NChà, Danji đã để Tohya dẫn trước một khoảng khá xa,
Dialogue: 0,0:18:42.68,0:18:43.85,Default,,0,0,0,,nhưng từ giờ mọi chuyện sẽ diễn biến thế nào đây?!\NCó cảm giác là đã chuẩn bị \Nrất nhiều cho đêm nay.
Dialogue: 0,0:18:43.85,0:18:44.69,Default,,0,0,0,,nhưng từ giờ mọi chuyện sẽ diễn biến thế nào đây?!
Dialogue: 0,0:18:44.69,0:18:46.29,Default,,0,0,0,,Ride Bruce.\Nnhưng từ giờ mọi chuyện sẽ diễn biến thế nào đây?!
Dialogue: 0,0:18:46.29,0:18:49.33,Default,,0,0,0,,Tuy nhiên, đây không phải là một cuộc đi săn.
Dialogue: 0,0:18:49.33,0:18:53.84,Default,,0,0,0,,Khi cả hai người chơi đều liều mạng, \Nthì dù có chuẩn bị kỹ đến đâu cũng không dễ dàng đâu.
Dialogue: 0,0:18:53.84,0:18:56.05,Default,,0,0,0,,Không có đường lùi đâu.
Dialogue: 0,0:18:56.05,0:18:57.16,Default,,0,0,0,,Ngay cả khi thấy sợ hãi...
Dialogue: 0,0:18:57.91,0:19:00.21,Default,,0,0,0,,...vẫn phải tiến về phía trước.
Dialogue: 0,0:19:00.21,0:19:02.51,Default,,0,0,0,,Cách để sống sót...
Dialogue: 0,0:19:02.51,0:19:05.74,Default,,0,0,0,,...ngay cả khi chìm trong bóng tối...
Dialogue: 0,0:19:05.74,0:19:06.82,Default,,0,0,0,,Danji tấn công!
Dialogue: 0,0:19:06.82,0:19:07.97,Default,,0,0,0,,Đang nói cái gì thế?!\NDanji tấn công!
Dialogue: 0,0:19:07.97,0:19:08.46,Default,,0,0,0,,Đang nói cái gì thế?!
Dialogue: 0,0:19:08.46,0:19:10.46,Default,,0,0,0,,Twin drive... ra rồi!
Dialogue: 0,0:19:11.03,0:19:12.84,Default,,0,0,0,,Critical trigger!
Dialogue: 0,0:19:20.17,0:19:21.65,Default,,0,0,0,,Chảy máu sao?!
Dialogue: 0,0:19:22.41,0:19:23.37,Default,,0,0,0,,Không...
Dialogue: 0,0:19:23.37,0:19:24.81,Default,,0,0,0,,Sao thế?
Dialogue: 0,0:19:25.74,0:19:27.19,Default,,0,0,0,,Kết thúc lượt.
Dialogue: 0,0:19:27.98,0:19:30.19,Default,,0,0,0,,Thấy vui chưa?
Dialogue: 0,0:19:30.53,0:19:31.94,Default,,0,0,0,,Stand and draw!
Dialogue: 0,0:19:32.37,0:19:33.47,Default,,0,0,0,,Đã sẵn sàng cho việc này!
Dialogue: 0,0:19:33.47,0:19:34.20,Default,,0,0,0,,Tohya bắt đầu hành động!\NĐã sẵn sàng cho việc này!
Dialogue: 0,0:19:34.20,0:19:36.32,Default,,0,0,0,,Với lượt này, sẽ cho thấy \Nsức mạnh thực sự của bộ bài này!\NTohya bắt đầu hành động!
Dialogue: 0,0:19:36.32,0:19:36.67,Default,,0,0,0,,Với lượt này, sẽ cho thấy \Nsức mạnh thực sự của bộ bài này!
Dialogue: 0,0:19:36.67,0:19:38.33,Default,,0,0,0,,Thế trận đang hoàn toàn nghiêng về một bên!\NVới lượt này, sẽ cho thấy \Nsức mạnh thực sự của bộ bài này!
Dialogue: 0,0:19:38.58,0:19:40.41,Default,,0,0,0,,Đừng nghĩ có thể dễ dàng phán xét thế!
Dialogue: 0,0:19:40.41,0:19:43.35,Default,,0,0,0,,Giờ sẽ biết cơ hội của mình mỏng manh đến mức nào!
Dialogue: 0,0:19:43.35,0:19:44.12,Default,,0,0,0,,Guard.
Dialogue: 0,0:19:44.39,0:19:46.12,Default,,0,0,0,,Dark Strain boost!
Dialogue: 0,0:19:46.12,0:19:47.59,Default,,0,0,0,,Bastion tấn công!
Dialogue: 0,0:19:47.84,0:19:48.44,Default,,0,0,0,,No guard.
Dialogue: 0,0:19:48.44,0:19:49.96,Default,,0,0,0,,Chà! No guard sao?!
Dialogue: 0,0:19:49.96,0:19:52.01,Default,,0,0,0,,Này! Đang coi thường nhau đấy à?!\NChà! No guard sao?!
Dialogue: 0,0:19:52.01,0:19:53.76,Default,,0,0,0,,Sao? Thấy bị xúc phạm à?
Dialogue: 0,0:19:53.76,0:19:55.62,Default,,0,0,0,,Nếu rút được critical, \NDanji chắc chắn sẽ thua!
Dialogue: 0,0:19:55.62,0:19:57.45,Default,,0,0,0,,Drive check đi. Nhanh lên.\NNếu rút được critical, \NDanji chắc chắn sẽ thua!
Dialogue: 0,0:19:57.45,0:19:59.18,Default,,0,0,0,,Được, rút đây.
Dialogue: 0,0:19:59.78,0:20:04.58,Default,,0,0,0,,Chỉ một lần rút này là ranh giới giữa \Nchiến thắng và thất bại. Có nhận ra không?
Dialogue: 0,0:20:04.58,0:20:08.40,Default,,0,0,0,,Đang nói gì thế? Rằng nó sẽ định đoạt số phận sao?
Dialogue: 0,0:20:08.95,0:20:11.30,Default,,0,0,0,,Đằng nào cũng chuẩn bị sẵn tinh thần rồi.
Dialogue: 0,0:20:12.30,0:20:13.64,Default,,0,0,0,,Sao thế?
Dialogue: 0,0:20:14.34,0:20:15.57,Default,,0,0,0,,Không rút được à?
Dialogue: 0,0:20:15.57,0:20:17.19,Default,,0,0,0,,Vẫn chưa nhìn nữa.
Dialogue: 0,0:20:17.19,0:20:20.10,Default,,0,0,0,,Không nghe thấy tiếng reo hò sao?
Dialogue: 0,0:20:21.13,0:20:22.97,Default,,0,0,0,,Lượt này vẫn chưa kết thúc đâu!
Dialogue: 0,0:20:22.97,0:20:23.70,Default,,0,0,0,,Tấn công!
Dialogue: 0,0:20:24.39,0:20:26.49,Default,,0,0,0,,Guard hết.
Dialogue: 0,0:20:27.77,0:20:30.21,Default,,0,0,0,,Kết thúc lượt rồi đấy.
Dialogue: 0,0:20:30.21,0:20:32.81,Default,,0,0,0,,Trận đấu cần sự bền bỉ,
Dialogue: 0,0:20:32.81,0:20:36.51,Default,,0,0,0,,nhưng khi mọi thứ trở nên khó khăn, \Nchiến thắng cần có quyết tâm và lòng can đảm.
Dialogue: 0,0:20:36.51,0:20:40.03,Default,,0,0,0,,Phải tiếp tục bước tới \Nqua màn đêm tăm tối.
Dialogue: 0,0:20:40.03,0:20:42.30,Default,,0,0,0,,Thấy an toàn trong bộ giáp logic đó sao?
Dialogue: 0,0:20:42.30,0:20:46.14,Default,,0,0,0,,Cảm giác an toàn đó \Nsẽ dẫn đến sự bất cẩn và lơ là đấy!
Dialogue: 0,0:20:46.86,0:20:49.71,Default,,0,0,0,,2 damage! Tưởng chuyện này đơn giản lắm sao?!
Dialogue: 0,0:20:49.71,0:20:51.34,Default,,0,0,0,,Ngây thơ quá!
Dialogue: 0,0:20:51.34,0:20:52.87,Default,,0,0,0,,Với trình độ này sao?!
Dialogue: 0,0:20:52.87,0:20:55.61,Default,,0,0,0,,Đó là ánh mắt của kẻ đang trong trận quyết tử sao?!
Dialogue: 0,0:20:57.42,0:21:00.24,Default,,0,0,0,,Cứ tưởng trận này sẽ gay cấn hơn cơ...
Dialogue: 0,0:21:00.49,0:21:02.45,Default,,0,0,0,,...nhưng sẽ kết thúc tại đây thôi!
Dialogue: 0,0:21:09.39,0:21:10.98,Default,,0,0,0,,Chỉ thế thôi sao?!
Dialogue: 0,0:21:10.98,0:21:13.22,Default,,0,0,0,,Tưởng không đỡ nổi chiêu này à?!
Dialogue: 0,0:21:13.22,0:21:17.04,Default,,0,0,0,,Sẽ cho xem thanh gươm của hoàng đế!
Dialogue: 0,0:21:21.91,0:21:23.17,Default,,0,0,0,,Đúng rồi!
Dialogue: 0,0:21:23.17,0:21:26.89,Default,,0,0,0,,Thế này mới đáng để nghiền nát chứ!
Dialogue: 0,0:21:29.43,0:21:31.15,Default,,0,0,0,,Cảm giác tuyệt thật.
Dialogue: 0,0:21:31.53,0:21:33.51,Default,,0,0,0,,Giờ sẽ cho xem cái này.
Dialogue: 0,0:21:33.51,0:21:35.36,Default,,0,0,0,,Một khối quyết tâm!
Dialogue: 0,0:21:35.36,0:21:40.53,Default,,0,0,0,,Một nhịp đập bạo chúa sẽ làm rung chuyển linh hồn!
Dialogue: 0,0:21:44.99,0:21:48.22,Default,,0,0,0,,Đ-Đây là "Violence" Bruce!
Dialogue: 0,0:21:48.22,0:21:50.50,Default,,0,0,0,,Đây là sức mạnh của Danji Momoyama sao?!
Dialogue: 0,0:22:00.30,0:22:03.89,Default,,0,0,0,,Rất thích sự kiên cường ở phút cuối đấy. \NHôm nào lại đấu tiếp nhé.
Dialogue: 0,0:22:04.15,0:22:06.42,Default,,0,0,0,,Đấu tiếp sao?
Dialogue: 0,0:22:07.77,0:22:10.64,Default,,0,0,0,,Chắc chắn rồi. Và thề là lần sau sẽ thắng!
Dialogue: 0,0:22:10.96,0:22:12.54,Default,,0,0,0,,Vậy là bị đánh tơi bời rồi nhỉ?
Dialogue: 0,0:22:12.54,0:22:15.15,Default,,0,0,0,,Im đi. Chỉ là tính toán sai thôi.
Dialogue: 0,0:22:15.15,0:22:17.65,Default,,0,0,0,,Aniki! Chúc mừng nhé!
Dialogue: 0,0:22:18.19,0:22:19.63,Default,,0,0,0,,Làm được rồi, Aniki!
Dialogue: 0,0:22:19.63,0:22:20.64,Default,,0,0,0,,Ừ.
Dialogue: 0,0:22:20.64,0:22:22.07,Default,,0,0,0,,Chúc mừng nhé, Danji.
Dialogue: 0,0:22:22.07,0:22:23.16,Default,,0,0,0,,Ư-Ừm...
Dialogue: 0,0:22:23.41,0:22:25.19,Default,,0,0,0,,Th-Tuyệt vời quá!
Dialogue: 0,0:22:25.19,0:22:27.03,Default,,0,0,0,,Thật cảm động!
Dialogue: 0,0:22:27.03,0:22:29.29,Default,,0,0,0,,Cứ thấy rạo rực hết cả lên, và... \Nkhông biết diễn tả thế nào nữa!
Dialogue: 0,0:22:29.29,0:22:30.04,Default,,0,0,0,,Ừ, hiểu mà!
Dialogue: 0,0:22:30.29,0:22:32.92,Default,,0,0,0,,Trận đấu của Aniki luôn khác biệt mà!
Dialogue: 0,0:22:32.92,0:22:34.88,Default,,0,0,0,,Vâng, có thể thấy rõ sự khác biệt đó!
Dialogue: 0,0:22:34.88,0:22:37.27,Default,,0,0,0,,Ngay cả con gái cũng cảm nhận được sự tuyệt vời của Aniki nhỉ.
Dialogue: 0,0:22:37.27,0:22:38.41,Default,,0,0,0,,Biết nói sao đây?
Dialogue: 0,0:22:38.41,0:22:40.80,Default,,0,0,0,,Yu-yu là con trai.
Dialogue: 0,0:22:40.80,0:22:42.72,Default,,0,0,0,,Yu-yu, để giới thiệu nhé.
Dialogue: 0,0:22:42.72,0:22:45.98,Default,,0,0,0,,Tomari ở đây là người khuấy động đám đông \Nbằng cách bình luận các trận đấu.
Dialogue: 0,0:22:45.98,0:22:50.07,Default,,0,0,0,,Yu-yu là con trai. Phụ huynh của em ấy \Nđã nhờ đi tìm.
Dialogue: 0,0:22:50.07,0:22:54.61,Default,,0,0,0,,V-Vị cảnh sát đã giúp chúng ta \Nchiều nay thực ra là Tomari sao!
Dialogue: 0,0:22:54.61,0:22:58.62,Default,,0,0,0,,Hình như bị chị gái \Nbắt mặc đồ con gái để trêu đùa thôi.
Dialogue: 0,0:22:58.62,0:23:02.32,Default,,0,0,0,,X-Xin lỗi! Chỉ là... \Nkhông giỏi từ chối...
Dialogue: 0,0:23:02.57,0:23:04.11,Default,,0,0,0,,Kh-Không thể tin được...
Dialogue: 0,0:23:04.11,0:23:05.86,Default,,0,0,0,,Ngây thơ quá đấy, Megumi.
Dialogue: 0,0:23:05.86,0:23:08.33,Default,,0,0,0,,Trai hay gái thì hai đứa vẫn nên làm bạn mà.
Dialogue: 0,0:23:08.57,0:23:10.75,Default,,0,0,0,,Nói thật là không nhận ra luôn đấy.
Dialogue: 0,0:23:10.75,0:23:12.86,Default,,0,0,0,,Có nghi ngờ chút rồi.
Dialogue: 0,0:23:12.86,0:23:13.83,Default,,0,0,0,,Ư-Ừm...
Dialogue: 0,0:23:14.08,0:23:15.56,Default,,0,0,0,,Không hề cố ý lừa đâu!
Dialogue: 0,0:23:15.56,0:23:18.85,Default,,0,0,0,,Và thực sự nghĩ \Ntrận đấu Cardfight vừa rồi rất tuyệt...
Dialogue: 0,0:23:18.85,0:23:20.09,Default,,0,0,0,,Hiểu rồi.
Dialogue: 0,0:23:20.38,0:23:23.75,Default,,0,0,0,,Còn nhỏ thế mà dám bỏ nhà đi.
Dialogue: 0,0:23:23.75,0:23:25.97,Default,,0,0,0,,Chỉ có đàn ông đích thực mới có gan như thế thôi.
Dialogue: 0,0:23:25.97,0:23:28.52,Default,,0,0,0,,Chà, gu mặn thật đấy.
Dialogue: 0,0:23:28.52,0:23:29.67,Default,,0,0,0,,Đừng có trêu.
Dialogue: 0,0:23:29.67,0:23:32.46,Default,,0,0,0,,Danji, về trận tiếp theo...
Dialogue: 0,0:23:32.46,0:23:34.48,Default,,0,0,0,,Đúng rồi! Tới ngay đây!
Dialogue: 0,0:23:34.48,0:23:36.78,Default,,0,0,0,,Còn những người thách đấu khác đang đợi đấy!
Dialogue: 0,0:23:36.78,0:23:38.95,Default,,0,0,0,,Chỉ nhận đấu với kẻ mạnh thôi.
Dialogue: 0,0:23:38.95,0:23:41.52,Default,,0,0,0,,Đi thôi, Yu-yu. Sẽ đưa về nhà.
Dialogue: 0,0:23:41.52,0:23:43.99,Default,,0,0,0,,Kh-Khoan đã!
Dialogue: 0,0:23:44.48,0:23:48.24,Default,,0,0,0,,Có thể... Có thể quay lại đây nữa không?!
Dialogue: 0,0:23:49.75,0:23:53.24,Default,,0,0,0,,Cứ rảnh rỗi là mọi người sẽ ở đây.
Dialogue: 0,0:23:53.24,0:23:56.50,Default,,0,0,0,,Lúc nào cũng hoan nghênh, \Nnhưng đừng mong có tiệc tùng linh đình gì nhé.
Dialogue: 0,0:23:56.50,0:23:58.92,Default,,0,0,0,,Không còn là khách nữa đâu.
Dialogue: 0,0:24:00.33,0:24:04.08,Default,,0,0,0,,Trông vui vẻ quá nhỉ. Vì Yu-yu dễ thương sao?
Dialogue: 0,0:24:04.08,0:24:06.56,Default,,0,0,0,,Kh-Không phải! Bớt chọc đi, Tomari!
Dialogue: 0,0:24:06.56,0:24:07.84,Default,,0,0,0,,Đỏ mặt làm gì thế?
Dialogue: 0,0:24:07.84,0:24:09.79,Default,,0,0,0,,Có đỏ mặt đâu!
Dialogue: 0,0:24:09.79,0:24:12.98,Default,,0,0,0,,Y...Yu-yu là con trai sao?!
Dialogue: 0,0:26:13.78,0:26:13.86,Default,,0,0,0,,Một mảnh linh hồn
Dialogue: 0,0:26:13.86,0:26:15.57,Default,,0,0,0,,Check Out My Card!\NMột mảnh linh hồn
Dialogue: 0,0:26:15.57,0:26:16.14,Default,,0,0,0,,Một mảnh linh hồn
Dialogue: 0,0:26:16.14,0:26:16.97,Default,,0,0,0,,Danji đây!\NMột mảnh linh hồn
Dialogue: 0,0:26:16.97,0:26:20.78,Default,,0,0,0,,Lần này sẽ giới thiệu \NDiabolos, "Violence" Bruce!\NMột mảnh linh hồn
Dialogue: 0,0:26:20.78,0:26:21.21,Default,,0,0,0,,Lần này sẽ giới thiệu \NDiabolos, "Violence" Bruce!
Dialogue: 0,0:26:21.21,0:26:23.47,Default,,0,0,0,,Sẽ im lặng trong lượt được ride,
Dialogue: 0,0:26:23.47,0:26:27.27,Default,,0,0,0,,nhưng đột nhiên trở nên tối thượng ở lượt tiếp theo!
Dialogue: 0,0:26:28.31,0:26:30.34,Default,,0,0,0,,Giải thích thế chưa đủ à?
Dialogue: 0,0:26:30.34,0:26:32.23,Default,,0,0,0,,Được rồi, hiểu rồi.
Dialogue: 0,0:26:32.23,0:26:36.79,Default,,0,0,0,,Ở lượt thứ hai đó... Bùm! \NSức mạnh và kỹ năng sẽ tăng vọt!
Dialogue: 0,0:26:36.79,0:26:39.51,Default,,0,0,0,,Bruce lao vào kẻ địch \Nnhư một hiệp sĩ trong bộ giáp sáng ngời!
Dialogue: 0,0:26:39.51,0:26:39.91,Default,,0,0,0,,Một mảnh linh hồn
Dialogue: 0,0:26:39.91,0:26:42.76,Default,,0,0,0,,Sao? Thẻ bài tuyệt quá đúng không?!\NMột mảnh linh hồn
Dialogue: 0,0:26:42.97,0:26:43.68,Default,,0,0,0,,Còn tiếp
Dialogue: 0,0:26:43.76,0:26:45.23,Default,,0,0,0,,Tập tiếp theo
Dialogue: 0,0:26:53.73,0:26:58.70,Default,,0,0,0,,Trickstar