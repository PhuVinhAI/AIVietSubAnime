{
  "name": "anime-cli",
  "version": "0.1.0",
  "description": "CLI tự động hoá pipeline dịch phụ đề anime (extract audio/sub, smart track grouping, hardsub queue)",
  "type": "module",
  "bin": {
    "anime-cli": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepare-mode": "tsx src/index.tsx prepare",
    "hardsub-mode": "tsx src/index.tsx hardsub"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "ink": "^7.0.5",
    "ink-gradient": "^4.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
